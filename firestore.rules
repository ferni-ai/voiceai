rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if the authenticated user owns this document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Check if user has admin claim
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    
    // Check if user is a service account (backend)
    function isServiceAccount() {
      return isSignedIn() && request.auth.token.service_account == true;
    }
    
    // Rate limiting check (max 100 writes per hour per user)
    // Note: This is a soft limit - real rate limiting is in auth-middleware.ts
    
    // ============================================================================
    // USER PROFILES (bogle_users collection)
    // This is the PRIMARY user data store - MOST SENSITIVE
    // ============================================================================
    
    match /bogle_users/{userId} {
      // Users can only read/write their OWN profile
      // Admin/service accounts can read any profile for support
      allow read: if isOwner(userId) || isAdmin() || isServiceAccount();
      
      // Users can only write their own profile
      // Service accounts (backend) can write any profile
      allow create: if isOwner(userId) || isServiceAccount();
      allow update: if isOwner(userId) || isServiceAccount();
      
      // Only admins can delete profiles (GDPR requests go through admin)
      allow delete: if isAdmin();
      
      // Subcollections under user profile
      match /summaries/{summaryId} {
        allow read, write: if isOwner(userId) || isServiceAccount();
      }
      
      match /moments/{momentId} {
        allow read, write: if isOwner(userId) || isServiceAccount();
      }
      
      match /goals/{goalId} {
        allow read, write: if isOwner(userId) || isServiceAccount();
      }
      
      // Trust profiles (boundaries, growth, inside jokes, etc.)
      match /trust_profiles/{profileId} {
        allow read, write: if isOwner(userId) || isServiceAccount();
      }
      
      // Utility preferences (timers, tips, timezone patterns, etc.)
      // "Better than human" everyday helpers with cross-session memory
      match /utility_preferences/{prefId} {
        allow read, write: if isOwner(userId) || isServiceAccount();
      }
      
      // Group conversation sessions (Team Roundtables, Conference Calls)
      // Stores session metadata, participants, and transcripts
      match /group_sessions/{sessionId} {
        allow read, write: if isOwner(userId) || isServiceAccount();
      }
      
      // Social graph (people mentioned in conversations)
      // "Better than Human" - relationship network intelligence
      match /social_graph/{docId} {
        allow read, write: if isOwner(userId) || isServiceAccount();
      }
    }
    
    // ============================================================================
    // LEGACY users COLLECTION (for Firebase Auth integration)
    // ============================================================================
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================================================
    // SECURITY EVENTS (audit log - write only)
    // ============================================================================
    
    match /security_events/{eventId} {
      // Only service accounts can write security events
      allow create: if isServiceAccount();
      // Only admins can read security events
      allow read: if isAdmin();
      // No updates or deletes - audit trail must be immutable
      allow update, delete: if false;
    }
    
    // ============================================================================
    // PHONE LOOKUP INDEX (for cross-device identification)
    // Stores hashed phone -> userId mappings
    // ============================================================================
    
    match /phone_index/{hashedPhone} {
      // Only service accounts can read/write (backend manages this)
      allow read, write: if isServiceAccount();
    }
    
    // ============================================================================
    // OPTIMIZATION & ANALYTICS DATA
    // ============================================================================
    
    match /optimization_feedback/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isServiceAccount();
    }
    
    match /optimization_recommendations/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    match /optimization_experiments/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    match /optimization_sessions/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isServiceAccount();
    }
    
    match /optimization_patterns/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    match /optimization_cycles/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    match /optimization_daily_summaries/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    match /optimization_weekly_reports/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    // ============================================================================
    // TOOL USAGE ANALYTICS
    // ============================================================================
    
    match /tool_usage_stats/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    match /tool_usage_calls/{document=**} {
      allow read: if isSignedIn();
      allow write: if isServiceAccount();
    }
    
    // ============================================================================
    // LEARNING SIGNALS
    // ============================================================================

    match /learning_signals/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isServiceAccount();
    }

    // ============================================================================
    // MARKETPLACE - Tools & Agents Registry
    // ============================================================================

    // Tool manifests - public read, publisher/admin write
    match /marketplace_tools/{toolId} {
      // Anyone can read verified tools
      allow read: if resource.data.verification.verified == true || isAdmin() || isServiceAccount();
      // Publishers can only write their own tools
      allow create: if isSignedIn() && request.resource.data.publisher.id == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.publisher.id == request.auth.uid ||
        isAdmin() ||
        isServiceAccount()
      );
      allow delete: if isAdmin();
    }

    // Agent manifests - public read, publisher/admin write
    match /marketplace_agents/{agentId} {
      // Anyone can read verified agents
      allow read: if resource.data.verification.verified == true || isAdmin() || isServiceAccount();
      // Publishers can only write their own agents
      allow create: if isSignedIn() && request.resource.data.publisher.id == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.publisher.id == request.auth.uid ||
        isAdmin() ||
        isServiceAccount()
      );
      allow delete: if isAdmin();
    }

    // ============================================================================
    // MARKETPLACE - User Installations
    // ============================================================================

    match /marketplace_installations/{installationId} {
      // Users can only read their own installations
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Users can install items for themselves
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Users can update their own installations (enable/disable)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Users can uninstall their own items
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Service accounts can manage all installations
      allow read, write: if isServiceAccount();
    }

    // ============================================================================
    // MARKETPLACE - Execution Audit Log
    // ============================================================================

    match /marketplace_executions/{executionId} {
      // Users can read their own executions
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Only service accounts can write (backend records executions)
      allow create: if isServiceAccount();
      // Executions are immutable
      allow update, delete: if false;
      // Publishers can read executions for their tools
      allow read: if isSignedIn() && resource.data.publisherId == request.auth.uid;
    }

    // ============================================================================
    // MARKETPLACE - Usage & Billing
    // ============================================================================

    match /marketplace_usage/{usageId} {
      // Users can read their own usage
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Only service accounts can write usage records
      allow create, update: if isServiceAccount();
      // Usage records are immutable once created
      allow delete: if false;
    }

    // Monthly usage aggregates per user+item
    match /marketplace_usage_monthly/{aggregateId} {
      // Users can read their own aggregates
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Only service accounts can write
      allow write: if isServiceAccount();
    }

    // ============================================================================
    // MARKETPLACE - Revenue Share (Publishers)
    // ============================================================================

    match /marketplace_revenue_shares/{shareId} {
      // Publishers can read their own revenue shares
      allow read: if isSignedIn() && resource.data.publisherId == request.auth.uid;
      // Only service accounts can write (billing system)
      allow write: if isServiceAccount();
      // Admins can read all
      allow read: if isAdmin();
    }

    // ============================================================================
    // MARKETPLACE - Publisher Profiles
    // ============================================================================

    match /marketplace_publishers/{publisherId} {
      // Public read for verified publishers
      allow read: if resource.data.verified == true || isAdmin() || isServiceAccount();
      // Publishers can update their own profile
      allow create: if isSignedIn() && publisherId == request.auth.uid;
      allow update: if isSignedIn() && publisherId == request.auth.uid;
      // Only admins can verify/delete publishers
      allow delete: if isAdmin();
    }

    // ============================================================================
    // DEFAULT DENY - Everything else is blocked
    // ============================================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
