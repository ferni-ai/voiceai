rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Optimization data - admin only or authenticated users with custom claims
    match /optimization_feedback/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /optimization_recommendations/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /optimization_experiments/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /optimization_sessions/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /optimization_patterns/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /optimization_cycles/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /optimization_daily_summaries/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /optimization_weekly_reports/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /tool_usage_stats/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /tool_usage_calls/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Learning signals - allow authenticated writes
    match /learning_signals/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

