# ⚠️  DEPRECATED - Use docker/Dockerfile.ui instead
# ============================================================================
# This file is kept for backwards compatibility.
# New builds should use: docker build -f docker/Dockerfile.ui .
# See docker/README.md for documentation.
# ============================================================================

# UI Server for Ferni Voice AI
# Multi-stage build: Build backend + frontend, then serve with Node.js

# ============================================================================
# Stage 1: Build the backend TypeScript
# ============================================================================
FROM node:20-slim AS backend-builder

WORKDIR /app

# Copy root package files
COPY package*.json ./
COPY tsconfig.json ./

# Install all dependencies (including dev for building)
RUN npm ci

# Copy backend source
COPY src/ ./src/

# Build backend TypeScript
RUN npm run build

# ============================================================================
# Stage 2: Build the frontend-typescript app
# ============================================================================
FROM node:20-slim AS frontend-builder

WORKDIR /app

# Copy design-system dist (needed for @design-system imports)
COPY design-system/dist ./design-system/dist/

# Copy frontend package files
COPY frontend-typescript/package*.json ./frontend-typescript/

WORKDIR /app/frontend-typescript

# Install frontend dependencies
RUN npm ci

# Copy frontend source
COPY frontend-typescript/ ./

# Build the frontend (outputs to dist/)
RUN npm run build

# ============================================================================
# Stage 3: Production server
# ============================================================================
FROM node:20-slim AS production

WORKDIR /app

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Copy root package files (for ui-server.js dependencies)
COPY package*.json ./

# Install production dependencies only
RUN npm ci --omit=dev

# Copy UI server
COPY ui-server.js ./

# Copy built backend from builder stage (needed for engagement-routes.js)
COPY --from=backend-builder /app/dist ./dist/

# Copy JS source files that aren't compiled by tsc (src/api/*.js)
COPY src/api/ ./dist/api/

# Copy persona bundles (JSON manifests needed at runtime)
COPY src/personas/bundles ./src/personas/bundles/

# Create frontend-typescript/dist directory structure
RUN mkdir -p frontend-typescript/dist

# Copy built frontend from frontend-builder stage
COPY --from=frontend-builder /app/frontend-typescript/dist ./frontend-typescript/dist/

# Set environment
ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

# Run UI server
CMD ["node", "ui-server.js"]
