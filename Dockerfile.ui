# UI Server Dockerfile
FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --only=production

# Copy UI server and frontend files
COPY ui-server.js ./
COPY frontend/ ./frontend/

# Set environment variables
ENV NODE_ENV=production
ENV PORT=8080

# Expose port
EXPOSE 8080

# Run the UI server
CMD ["node", "ui-server.js"]

