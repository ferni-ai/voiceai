{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // PRODUCTION BUILD CONFIG
    // Inherit strict settings from base tsconfig - DO NOT RELAX!
    // skipLibCheck handles library .d.ts issues (LiveKit, Google Cloud)
    "skipLibCheck": true,

    // CRITICAL: Stop build on type errors
    // If this causes build failures, FIX THE CODE - don't disable this
    "noEmitOnError": true,

    // Remove comments in production for smaller bundle
    "removeComments": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/tests/**/*",
    "src/services/trust-systems/__tests__/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**/*"
  ]
}
