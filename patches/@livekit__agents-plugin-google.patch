diff --git a/dist/beta/realtime/realtime_api.cjs b/dist/beta/realtime/realtime_api.cjs
index 7f0dfd55f958ef1a3437a1f404b0e54863326503..3d631e71cceae1de81c5d60b8ccc2faab8a44508 100644
--- a/dist/beta/realtime/realtime_api.cjs
+++ b/dist/beta/realtime/realtime_api.cjs
@@ -754,6 +754,37 @@ class RealtimeSession extends import_agents.llm.RealtimeSession {
     if (opts.contextWindowCompression !== void 0) {
       config.contextWindowCompression = opts.contextWindowCompression;
     }
+    // PATCHED: Add toolConfig support for function calling mode
+    if (opts.toolChoice !== void 0) {
+      const toolChoice = opts.toolChoice;
+      if (toolChoice === 'required') {
+        config.toolConfig = {
+          functionCallingConfig: {
+            mode: 'ANY'  // Force model to call a function
+          }
+        };
+      } else if (toolChoice === 'none') {
+        config.toolConfig = {
+          functionCallingConfig: {
+            mode: 'NONE'  // Disable function calling
+          }
+        };
+      } else if (typeof toolChoice === 'object' && toolChoice.type === 'function') {
+        config.toolConfig = {
+          functionCallingConfig: {
+            mode: 'ANY',
+            allowedFunctionNames: [toolChoice.function.name]
+          }
+        };
+      } else if (toolChoice === 'auto') {
+        // PATCHED: Explicitly set AUTO mode - without this, tools may not be called
+        config.toolConfig = {
+          functionCallingConfig: {
+            mode: 'AUTO'
+          }
+        };
+      }
+    }
     return config;
   }
   startNewGeneration() {
