{
  "name": "voiceai-gemini-cartesia",
  "version": "1.0.0",
  "description": "LiveKit voice AI agent with Gemini Live STT and Cartesia TTS",
  "type": "module",
  "main": "dist/agent.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/agent.ts dev",
    "dev:jack": "PERSONA_ID=jack-bogle tsx src/agent.ts dev",
    "dev:jack-b": "PERSONA_ID=jack-b tsx src/agent.ts dev",
    "dev:peter": "PERSONA_ID=peter-lynch tsx src/agent.ts dev",
    "start": "node dist/agent.js start",
    "start:jack": "PERSONA_ID=jack-bogle node dist/agent.js start",
    "start:jack-b": "PERSONA_ID=jack-b node dist/agent.js start",
    "start:peter": "PERSONA_ID=peter-lynch node dist/agent.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "npx tsx scripts/test-e2e.ts",
    "test:storage": "npx tsx scripts/test-storage.ts",
    "test:all": "npm test && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "validate:voices": "npx tsx scripts/validate-voice-ids.ts",
    "agents": "npx tsx src/cli/agent-manager.ts",
    "agents:list": "npx tsx src/cli/agent-manager.ts list",
    "agents:create": "npx tsx src/cli/agent-manager.ts create",
    "agents:validate": "npx tsx src/cli/agent-manager.ts validate",
    "persona": "npx tsx src/cli/persona-cli.ts",
    "persona:list": "npx tsx src/cli/persona-cli.ts list",
    "persona:validate": "npx tsx src/cli/persona-cli.ts validate",
    "persona:build": "npx tsx src/cli/persona-cli.ts build",
    "tools:report": "npx tsx src/cli/tools-report.ts",
    "tools:deprecation": "npx tsx src/cli/tools-report.ts deprecation",
    "tools:versions": "npx tsx src/cli/tools-report.ts versions",
    "tools:experiments": "npx tsx src/cli/tools-report.ts experiments",
    "tools:route": "npx tsx src/cli/tools-report.ts route",
    "tools:activate": "npx tsx src/cli/tools-report.ts activate",
    "tools:deactivate": "npx tsx src/cli/tools-report.ts deactivate",
    "tools:benchmark": "npx tsx src/cli/tools-report.ts benchmark",
    "tools:recommendations": "npx tsx src/cli/tools-report.ts recommendations",
    "tools:patterns": "npx tsx src/cli/tools-report.ts patterns",
    "tools:optimizer": "npx tsx src/cli/tools-report.ts optimizer",
    "tools:health": "npx tsx src/cli/tools-report.ts health",
    "tools:alerts": "npx tsx src/cli/tools-report.ts alerts",
    "tools:help": "npx tsx src/cli/tools-report.ts help",
    "generate:personas": "npx tsx scripts/generate-frontend-personas.ts",
    "prebuild:frontend": "npm run generate:personas",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "build:tokens": "node design-system/build.js",
    "design-system": "node design-system/dev-server.js",
    "design-system:dev": "node design-system/dev-server.js",
    "design-system:test": "npx playwright test --config=design-system/playwright.config.ts",
    "design-system:test:update": "npx playwright test --config=design-system/playwright.config.ts --update-snapshots",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "setup": "bash scripts/setup-local.sh",
    "services:up": "docker compose -f docker-compose.local.yml up -d",
    "services:down": "docker compose -f docker-compose.local.yml down",
    "services:logs": "docker compose -f docker-compose.local.yml logs -f",
    "docker:build": "docker build -t voice-agent .",
    "docker:run": "docker run --env-file .env -p 8080:8080 voice-agent",
    "deploy": "bash scripts/deploy-gcp.sh",
    "deploy:gcp": "bash scripts/deploy-gcp.sh",
    "token-server": "node token-server.js",
    "dev:full": "npm run token-server & npm run dev"
  },
  "keywords": [
    "livekit",
    "gemini",
    "cartesia",
    "voice-ai",
    "speech-to-text",
    "text-to-speech"
  ],
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@google/genai": "^1.30.0",
    "@livekit/agents": "^1.0.22",
    "@livekit/agents-plugin-cartesia": "^1.0.22",
    "@livekit/agents-plugin-google": "^1.0.22",
    "@livekit/agents-plugin-openai": "^1.0.22",
    "@livekit/agents-plugin-silero": "^1.0.0",
    "@livekit/noise-cancellation-node": "^0.1.9",
    "dotenv": "^16.4.0",
    "ioredis": "^5.8.2",
    "livekit-client": "^2.16.0",
    "livekit-server-sdk": "^2.14.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.19.25",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.14",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "firebase-admin": "^13.6.0",
    "prettier": "^3.7.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
