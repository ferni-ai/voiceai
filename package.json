{
  "name": "voiceai-gemini-cartesia",
  "version": "1.0.0",
  "description": "LiveKit voice AI agent with Gemini Live STT and Cartesia TTS",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bogle-agent.ts dev",
    "dev:agent": "tsx src/agent.ts dev",
    "start": "node dist/bogle-agent.js start",
    "start:agent": "node dist/agent.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "docker:build": "docker build -t bogle-voice-agent .",
    "docker:run": "docker run --env-file .env -p 8080:8080 bogle-voice-agent",
    "deploy": "./deploy.sh"
  },
  "keywords": [
    "livekit",
    "gemini",
    "cartesia",
    "voice-ai",
    "speech-to-text",
    "text-to-speech"
  ],
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@google/genai": "^1.30.0",
    "@livekit/agents": "^1.0.22",
    "@livekit/agents-plugin-cartesia": "^1.0.22",
    "@livekit/agents-plugin-google": "^1.0.22",
    "@livekit/agents-plugin-openai": "^1.0.22",
    "@livekit/agents-plugin-silero": "^1.0.0",
    "@livekit/noise-cancellation-node": "^0.1.9",
    "dotenv": "^16.4.0",
    "ioredis": "^5.8.2",
    "livekit-client": "^2.16.0",
    "livekit-server-sdk": "^2.14.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.14",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
