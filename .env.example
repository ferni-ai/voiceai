# ============================================================================
# Ferni AI - Environment Configuration
# ============================================================================
# Auto-generated by: npm run env:generate
# Generated: 2025-12-07T14:00:47.331Z
# ============================================================================

# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the app to work.
# Variables marked [OPTIONAL] have defaults or are only needed for specific features.

# ----------------------------------------------------------------------------
# LIVEKIT
# ----------------------------------------------------------------------------

# LiveKit API key
# [REQUIRED]
LIVEKIT_API_KEY=APIxxxxxxx

# LiveKit API secret
# [REQUIRED]
LIVEKIT_API_SECRET=your-secret-key

# LiveKit server WebSocket URL
# [REQUIRED]
LIVEKIT_URL=wss://your-project.livekit.cloud

# ----------------------------------------------------------------------------
# GOOGLE AI
# ----------------------------------------------------------------------------

# Google AI API key for Gemini
# [REQUIRED]
GOOGLE_API_KEY=AIza...

# ----------------------------------------------------------------------------
# CARTESIA TTS
# ----------------------------------------------------------------------------

# Cartesia API key for text-to-speech
# [REQUIRED for Cartesia provider]
CARTESIA_API_KEY=sk-cart-...

# ----------------------------------------------------------------------------
# BTCW TTS (CosyVoice - Alternative to Cartesia)
# ----------------------------------------------------------------------------

# TTS provider to use: 'cartesia' (default) or 'btcw'
# [OPTIONAL]
# TTS_PROVIDER=cartesia

# BTCW server endpoint (Cloud Run GPU service)
# [REQUIRED if TTS_PROVIDER=btcw]
# BTCW_ENDPOINT=https://btcw-cosyvoice-1031920444452.us-central1.run.app

# BTCW API key for authentication
# [REQUIRED if TTS_PROVIDER=btcw and auth enabled]
# BTCW_API_KEY=your-api-key

# Default BTCW voice (persona name: ferni, peter, alex, maya, jordan, nayan)
# [OPTIONAL]
# BTCW_DEFAULT_VOICE=ferni

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------

# Node environment (development/production)
# [OPTIONAL]
# NODE_ENV=development

# Default persona to use
# [OPTIONAL]
# PERSONA_ID=nayan-patel

# ----------------------------------------------------------------------------
# TESTING / DEVELOPMENT
# ----------------------------------------------------------------------------

# Bypass team member unlock requirements (for testing/demo)
# [OPTIONAL]
# Options:
#   "all" or "true" - Unlock all team members
#   "1"             - Unlock first member (Maya)
#   "2"             - Unlock first two (Maya, Peter)
#   "3"             - Unlock first three (Maya, Peter, Alex)
#   "4"             - Unlock first four (Maya, Peter, Alex, Jordan)
#   "5"             - Unlock all five (Maya, Peter, Alex, Jordan, Nayan)
#   "maya"          - Unlock specific member by name
#   "maya,peter"    - Comma-separated list of members
# BYPASS_TEAM_UNLOCKS=all

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------

# PostgreSQL connection URL
# [OPTIONAL]
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Redis connection URL
# [OPTIONAL]
# REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# GOOGLE CLOUD
# ----------------------------------------------------------------------------

# Path to GCP service account JSON
# [OPTIONAL]
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCP project ID for Firestore
# [OPTIONAL]
# GOOGLE_CLOUD_PROJECT=your-project-id

# ----------------------------------------------------------------------------
# COMMUNICATION
# ----------------------------------------------------------------------------

# SendGrid API key for email
# [OPTIONAL]
# SENDGRID_API_KEY=SG.xxx

# Twilio account SID
# [OPTIONAL]
# TWILIO_ACCOUNT_SID=ACxxx

# Twilio auth token
# [OPTIONAL]
# TWILIO_AUTH_TOKEN=your-auth-token

# Twilio phone number for SMS/calls
# [OPTIONAL]
# TWILIO_PHONE_NUMBER=+1234567890

# ----------------------------------------------------------------------------
# FINANCIAL APIS
# ----------------------------------------------------------------------------

# Alpha Vantage API key for stock data
# [OPTIONAL]
# ALPHA_VANTAGE_API_KEY=demo

# Finnhub API key for market data
# [OPTIONAL]
# FINNHUB_API_KEY=your-finnhub-key

# ----------------------------------------------------------------------------
# SPOTIFY
# ----------------------------------------------------------------------------

# Spotify OAuth client ID
# [OPTIONAL]
# SPOTIFY_CLIENT_ID=your-client-id

# Spotify OAuth client secret
# [OPTIONAL]
# SPOTIFY_CLIENT_SECRET=your-client-secret

# ----------------------------------------------------------------------------
# SMART HOME
# ----------------------------------------------------------------------------

# Ecobee API key for thermostat control
# [OPTIONAL] - Required for Ecobee thermostat integration
# Get one at: https://www.ecobee.com/consumerportal/index.html#/dev
# ECOBEE_API_KEY=your-ecobee-api-key

# Eight Sleep OAuth credentials for smart mattress control
# [OPTIONAL] - Required for Eight Sleep mattress integration
# Register at: https://www.eightsleep.com/partner-program/
# EIGHT_SLEEP_CLIENT_ID=your-client-id
# EIGHT_SLEEP_CLIENT_SECRET=your-client-secret
# EIGHT_SLEEP_REDIRECT_URI=https://your-domain.com/api/eight-sleep/auth/callback

# Oura Ring OAuth credentials for sleep and readiness tracking
# [OPTIONAL] - Required for Oura Ring integration
# Register at: https://cloud.ouraring.com/oauth/applications
# OURA_CLIENT_ID=your-client-id
# OURA_CLIENT_SECRET=your-client-secret
# OURA_REDIRECT_URI=https://your-domain.com/api/oura/auth/callback

# ----------------------------------------------------------------------------
# STRIPE
# ----------------------------------------------------------------------------

# Stripe secret key for payments
# [OPTIONAL]
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret
# [OPTIONAL]
# STRIPE_WEBHOOK_SECRET=whsec_...

# ----------------------------------------------------------------------------
# MONITORING
# ----------------------------------------------------------------------------

# Sentry DSN for error tracking
# [OPTIONAL]
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ----------------------------------------------------------------------------
# NOTIFICATIONS
# ----------------------------------------------------------------------------

# Slack webhook URL for notifications
# [OPTIONAL]
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ----------------------------------------------------------------------------
# DEPLOYMENT
# ----------------------------------------------------------------------------

# GCP project ID for deployment
# [OPTIONAL]
# GCP_PROJECT_ID=johnb-2025

# GCP region for deployment
# [OPTIONAL]
# GCP_REGION=us-central1

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------

# Allowed CORS origins (comma-separated)
# [REQUIRED in production] - Must be set to specific origins, not '*'
# ⚠️ SECURITY WARNING: Never use '*' in production! This allows any website to make API requests.
# Example: https://app.ferni.ai,https://ferni.ai
# ALLOWED_ORIGINS=https://app.ferni.ai,https://ferni.ai

# Hash secret for privacy-preserving security logs
# [RECOMMENDED in production] - Used to hash sensitive data in logs
# Generate with: openssl rand -hex 32
# LOG_HASH_SECRET=your-64-char-hex-secret

# Rate limit Redis URL (for persistent rate limiting)
# [RECOMMENDED in production] - Without this, rate limits reset on server restart
# REDIS_RATE_LIMIT_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# MEDIA DISCOVERY APIS
# ----------------------------------------------------------------------------

# YouTube Data API v3 key for video search/discovery
# [OPTIONAL] - Works without key but with lower quotas
# Get one at: https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=AIza...

# Google Books API key for book discovery
# [OPTIONAL] - Works without key (1,000 req/day) or with key (10,000 req/day)
# Get one at: https://console.cloud.google.com/apis/credentials
# GOOGLE_BOOKS_API_KEY=AIza...

