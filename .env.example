# ----------------------------------------------------------------------------

# Cartesia API key for text-to-speech
# [REQUIRED for Cartesia provider]
CARTESIA_API_KEY=sk-cart-...

# ----------------------------------------------------------------------------
# BTCW TTS (CosyVoice - Alternative to Cartesia)
# ----------------------------------------------------------------------------

# TTS provider to use: 'cartesia' (default) or 'btcw'
# [OPTIONAL]
# TTS_PROVIDER=cartesia

# BTCW server endpoint (Cloud Run GPU service)
# [REQUIRED if TTS_PROVIDER=btcw]
# BTCW_ENDPOINT=https://btcw-cosyvoice-1031920444452.us-central1.run.app

# BTCW API key for authentication
# [REQUIRED if TTS_PROVIDER=btcw and auth enabled]
# BTCW_API_KEY=your-api-key

# Default BTCW voice (persona name: ferni, peter, alex, maya, jordan, nayan)
# [OPTIONAL]
# BTCW_DEFAULT_VOICE=ferni

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------

# Node environment (development/production)
# [OPTIONAL]
# NODE_ENV=development

# Default persona to use
# [OPTIONAL]
# PERSONA_ID=nayan-patel

# ----------------------------------------------------------------------------
# TESTING / DEVELOPMENT
# ----------------------------------------------------------------------------

# Bypass team member unlock requirements (for testing/demo)
# [OPTIONAL]
# Options:
#   "all" or "true" - Unlock all team members
#   "1"             - Unlock first member (Maya)
#   "2"             - Unlock first two (Maya, Peter)
#   "3"             - Unlock first three (Maya, Peter, Alex)
#   "4"             - Unlock first four (Maya, Peter, Alex, Jordan)
#   "5"             - Unlock all five (Maya, Peter, Alex, Jordan, Nayan)
#   "maya"          - Unlock specific member by name
#   "maya,peter"    - Comma-separated list of members
# BYPASS_TEAM_UNLOCKS=all

