# ----------------------------------------------------------------------------
# TOOL CONFIGURATION (Meta-Tool Architecture - Jan 2026)
# ----------------------------------------------------------------------------
# Centralized tool configuration. Use these instead of scattered hardcoded limits.

# Maximum tools to send to LLM per turn
# 0 = unlimited (semantic router filters, recommended with meta-tool)
# 18-50 = typical range for direct tool registration with Gemini
# [OPTIONAL - defaults to 0 (unlimited)]
# TOOL_LIMIT=0

# Enable meta-tool pattern: Register ONE tool (executeTool) instead of 100+
# The LLM makes a binary decision "use tool?" then specifies which via executeTool
# Benefits: simpler LLM decision, no context bloat, no tool limits needed
# [OPTIONAL - defaults to false]
# USE_META_TOOL=false

# Include tool catalog in system prompt (when USE_META_TOOL=true)
# When true, system prompt includes available tool names and descriptions
# [OPTIONAL - defaults to true]
# META_TOOL_CATALOG_IN_PROMPT=true

# ============================================================================
# FTIS V5: ML-Based Tool Routing (Qwen3-1.7B, 98% accuracy)
# ============================================================================

# Enable FTIS V5 ONNX classifier for direct tool routing
# When enabled:
# - Qwen3-1.7B ONNX model classifies user intent into 860 tool labels
# --- ML Tool Classifier (FTIS) ---
# Ferni uses trained Qwen3-1.7B models for fast tool classification.
# Fallback chain: V7 hierarchical → V5/V6 flat → semantic router → LLM
#
# V5/V6 Flat Classifier (860 tools, single-stage)
# - V6 model is auto-selected when models/ferni-router-v6-860/ exists
# - V5 is used as fallback when only models/ferni-router-v5-860/ exists
# - 98% top-1 accuracy, 99.7% top-3 accuracy
# [OPTIONAL - defaults to false]
# USE_FTIS_V5=false
# FTIS_V5_THRESHOLD=85

# V7 Hierarchical Classifier (two-stage: domain → meta-tool)
# - Stage 1: Classifies query → domain (44 classes)
# - Stage 2: Classifies "[domain] query" → meta-tool (112 classes)
# - Requires models/ferni-router-v7-stage1/ and models/ferni-router-v7-stage2/
# - Combined confidence = stage1 * stage2
# [OPTIONAL - defaults to false]
# USE_FTIS_V7=false
# FTIS_V7_THRESHOLD=70

# Override model version detection (skips auto-detection)
# Values: v7, v6, v5
# [OPTIONAL - auto-detects from models/ directory]
# ROUTER_MODEL_VERSION=

# Disable ONNX classifier entirely (forces semantic router fallback)
# [OPTIONAL - defaults to false]
# DISABLE_ONNX_CLASSIFIER=false

# [OPTIONAL]
# USERPROFILE=

# [OPTIONAL]
# VAPID_PRIVATE_KEY=your-vapid-private-key

# [OPTIONAL]
# VAPID_PUBLIC_KEY=your-vapid-public-key

# [OPTIONAL]
# VAPID_SUBJECT=mailto:hello@ferni.ai

# [OPTIONAL]
# VAR_NAME=default

# [OPTIONAL]
# VITEST=

# [OPTIONAL]
# WEBHOOK_BASE_URL=https://api.ferni.ai/webhooks/twilio

# [OPTIONAL]
# WELLNESS_COACH_VOICE_ID=79a125e8-cd45-4c13-8a67-188112f4dd22

# [OPTIONAL]
# YELP_API_KEY=your-yelp-api-key

# ----------------------------------------------------------------------------
# LLM MODELS (Configurable - no hardcoding!)
# ----------------------------------------------------------------------------

# Model for outreach content generation (personalized messages)
# [OPTIONAL - defaults to gemini-2.0-flash-exp]
GEMINI_OUTREACH_MODEL=gemini-2.0-flash-exp

# Model for general Gemini tasks
# [OPTIONAL - defaults to gemini-2.0-flash-exp]
GEMINI_MODEL=gemini-2.0-flash-exp

# ----------------------------------------------------------------------------
# GEMINI NATIVE FUNCTION CALLING (Jan 2026)
# ----------------------------------------------------------------------------
# Configuration for Gemini's native function calling with turn-by-turn optimization.
# These settings control how tools are presented to Gemini and executed.
#
# Architecture Modes:
#   - FTIS V2 (default): External tool routing via transcript classification
#   - Native FC: API-level function declarations, Gemini calls tools directly
#   - JSON Workaround: Gemini outputs {"fn":"tool","args":{...}} in text
#
# Quick Presets:
#   Legacy (default): No env vars needed
#   Native FC:        GEMINI_USE_NATIVE_FC=true GEMINI_NATIVE_PROMPTS=true GEMINI_JSON_FALLBACK=false
#   Optimized:        GEMINI_USE_NATIVE_FC=true GEMINI_TURN_OPTIMIZATION=true GEMINI_INJECTION_STRATEGY=turn-by-turn

# Enable native function calling (API-level tool declarations)
# When true, tools are passed via Gemini's native functionDeclarations API
# When false (default), uses JSON workaround or FTIS external routing
# [OPTIONAL - defaults to false]
# GEMINI_USE_NATIVE_FC=false

# Function calling mode
# AUTO: Gemini decides when to call functions (default)
# ANY: Force function calling - Gemini MUST call a function when tools available
# NONE: Disable native function calling entirely
# [OPTIONAL - defaults to AUTO]
# GEMINI_FC_MODE=AUTO

# Keep JSON workaround as fallback when native FC is enabled
# Provides defense-in-depth: native FC is primary, JSON intercept is backup
# [OPTIONAL - defaults to true]
# GEMINI_JSON_FALLBACK=true

# Enable turn-by-turn tool optimization
# Reduces tools from 1000+ to 8-15 per turn based on semantic intent detection
# Dramatically reduces hallucination and improves response time
# [OPTIONAL - defaults to false]
# GEMINI_TURN_OPTIMIZATION=false

# Tool injection strategy (when turn optimization enabled)
# static: Load all tools at session start, never update
# turn-by-turn: Dynamically inject tools based on each turn's intent
# hybrid: Start with essentials, add domain tools as needed, don't remove
# [OPTIONAL - defaults to static]
# GEMINI_INJECTION_STRATEGY=static

# Maximum tools to send per turn (when turn optimization enabled)
# Lower = less hallucination, faster inference
# Higher = more tool coverage per turn
# [OPTIONAL - defaults to 15]
# GEMINI_MAX_TOOLS_PER_TURN=15

# Minimum semantic score to include a tool (0-1)
# Higher = more selective, only highly relevant tools
# Lower = more inclusive, broader tool availability
# [OPTIONAL - defaults to 0.3]
# GEMINI_SEMANTIC_THRESHOLD=0.3

# Enforce strict schemas (anti-hallucination)
# Adds additionalProperties: false to all tool schemas
# Prevents Gemini from inventing parameters not in the schema
# [OPTIONAL - defaults to true]
# GEMINI_STRICT_SCHEMAS=true

# Validate tool calls against known tools before execution
# Rejects calls to hallucinated tools that don't exist
# [OPTIONAL - defaults to true]
# GEMINI_VALIDATE_TOOLS=true

# Use native prompts (no JSON format instructions)
# When true, system prompts don't include JSON function calling format
# Should be true when GEMINI_USE_NATIVE_FC=true and GEMINI_JSON_FALLBACK=false
# [OPTIONAL - defaults to false]
# GEMINI_NATIVE_PROMPTS=false

# Log tool selection decisions for debugging
# Shows which tools are selected, domains detected, timing
# [OPTIONAL - defaults to false]
# GEMINI_DEBUG_TOOLS=false

# Emit tool metrics for monitoring
# Tracks tool call success/failure rates, latency
# [OPTIONAL - defaults to false]
# GEMINI_TOOL_METRICS=false
