# ============================================================================
# JOHN BOGLE VOICE AI - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values

# ============================================================================
# LIVEKIT CREDENTIALS (Required)
# ============================================================================
# Get these from https://cloud.livekit.io/
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# ============================================================================
# AI MODEL PROVIDERS
# ============================================================================

# Google Gemini (Required for LLM)
# Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# OpenAI (Optional - for embeddings)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Cartesia (Required for TTS)
# Get from https://cartesia.ai/
CARTESIA_API_KEY=your_cartesia_api_key

# ============================================================================
# MEMORY STORE SELECTION
# ============================================================================
# Choose one: memory | firestore | postgres
# Default: memory (development), firestore (if GOOGLE_CLOUD_PROJECT set)
MEMORY_STORE_TYPE=memory

# ============================================================================
# GOOGLE CLOUD FIRESTORE (Production - Recommended)
# ============================================================================
# Your Google Cloud project ID
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Path to service account JSON file (if not using ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Firestore database ID (optional, defaults to "(default)")
# FIRESTORE_DATABASE=(default)

# ============================================================================
# POSTGRESQL (Production - Alternative)
# ============================================================================
# Full connection string
# DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# ============================================================================
# REDIS CACHE (Optional - Session caching)
# ============================================================================
# Full connection URL
# REDIS_URL=redis://localhost:6379

# ============================================================================
# EMBEDDINGS (For Semantic RAG)
# ============================================================================
# Provider: openai | google | vertex | local
# EMBEDDING_PROVIDER=openai

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Environment: development | production
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Server port for token server
PORT=8080

# ============================================================================
# API AUTHENTICATION (for protected endpoints)
# ============================================================================
# Comma-separated list of valid API keys for X-API-Key header
# API_KEYS=key1,key2,key3

# Comma-separated list of admin API keys (elevated privileges)
# ADMIN_API_KEYS=admin_key1,admin_key2

# JWT secret for Bearer token verification (HS256)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=your-256-bit-secret

# Allowed origins for CORS (comma-separated, or * for all)
# In production, restrict to your domains
# ALLOWED_ORIGINS=https://ferni.ai,https://app.ferni.ai

# ============================================================================
# SLACK INTEGRATION (for automated notifications)
# ============================================================================
# Get webhook URL from: https://api.slack.com/apps → Your App → Incoming Webhooks
# Workspace: https://ferniai.slack.com/
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Optional: Separate webhooks for different channels
# SLACK_DEPLOYMENTS_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
# SLACK_ALERTS_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
# SLACK_ROLLOUTS_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# Dashboard URL for notification action buttons
# DASHBOARD_URL=https://ferni.ai/admin
