{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "tsconfig.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  
  "// Remote Cache": "Enable with: npx turbo login && npx turbo link",
  "// Or self-hosted": "Set TURBO_REMOTE_CACHE_URL and TURBO_TOKEN env vars",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "cache": true
    },
    "build:fast": {
      "dependsOn": ["^build:fast"],
      "inputs": ["$TURBO_DEFAULT$", "src/**"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "tsconfig*.json"],
      "outputs": [],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "eslint.config.*"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "vitest.config.*"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "tokens:sync": {
      "inputs": ["design-system/tokens/**"],
      "outputs": [
        "design-system/dist/**",
        "apps/web/src/config/animation-constants.generated.ts",
        "promo/**/design-tokens.css"
      ],
      "cache": true
    }
  }
}

