# syntax=docker/dockerfile:1.4
# ============================================================================
# FERNI VOICE AGENT DOCKERFILE (OPTIMIZED WITH PNPM + ESBUILD + RUST)
# ============================================================================
# Builds the LiveKit voice agent service with aggressive caching.
# Supports all personas via PERSONA_ID environment variable.
#
# OPTIMIZATIONS:
# - pnpm for ~40% faster dependency installs
# - esbuild for ~10-50x faster TypeScript compilation
# - Rust native modules for zero-GC audio processing
# - BuildKit 1.4 syntax enables parallel stage builds
# - Cache mounts persist across builds
# - Optimal layer ordering (rarely-changing layers first)
#
# Build:
#   docker build -f docker/Dockerfile.agent -t ferni-agent .
#
# Run:
#   docker run -e PERSONA_ID=ferni -e LIVEKIT_URL=... ferni-agent
# ============================================================================

ARG NODE_VERSION=20
ARG RUST_VERSION=1.75

# ============================================================================
# Stage 1: Build Rust Native Modules (NAPI-RS)
# ============================================================================
# These modules provide zero-allocation audio processing and SIMD-optimized
# embedding operations, reducing GC pressure by ~192KB/sec in the audio path.
FROM rust:${RUST_VERSION}-slim AS rust-builder

WORKDIR /rust

# Install Node.js for napi-rs
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g @napi-rs/cli \
    && rm -rf /var/lib/apt/lists/*

# Copy Rust source files
COPY apps/rust-perf/Cargo.toml apps/rust-perf/Cargo.lock apps/rust-perf/build.rs ./rust-perf/
COPY apps/rust-perf/src/ ./rust-perf/src/

COPY apps/rust-audio/Cargo.toml apps/rust-audio/build.rs ./rust-audio/
COPY apps/rust-audio/src/ ./rust-audio/src/
COPY apps/rust-audio/benches/ ./rust-audio/benches/

# Build rust-perf with release optimizations
WORKDIR /rust/rust-perf
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/rust/rust-perf/target \
    cargo build --release && \
    napi build --platform --release && \
    ls -la *.node

# Build rust-audio with release optimizations
WORKDIR /rust/rust-audio
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/rust/rust-audio/target \
    cargo build --release && \
    napi build --platform --release && \
    ls -la *.node || echo "rust-audio build optional"

# ============================================================================
# Stage 2: Build TypeScript with pnpm + esbuild
# ============================================================================
# Use Ubuntu 24.04 (Noble) for GLIBC 2.39 (needed for Rust ONNX bindings)
# Rust ONNX bindings require GLIBC 2.38+, Ubuntu 24.04 provides 2.39
FROM ubuntu:24.04 AS builder

WORKDIR /app

# Install Node.js 20.x and git
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Copy package files first (cache layer)
COPY package.json package-lock.json* ./
COPY .npmrc ./

# Copy build configs
COPY tsconfig.json ./
COPY tsconfig.build.json ./

# Install dependencies with npm
RUN --mount=type=cache,target=/root/.npm \
    npm install --legacy-peer-deps

# Copy source files (this layer invalidates on source changes)
COPY src/ ./src/

# Copy build scripts
COPY apps/cli/src/commands/build/bundle-agent.ts ./apps/cli/src/commands/build/
COPY apps/cli/src/commands/build/build-fast.ts ./apps/cli/src/commands/build/

# Build TypeScript + Bundle Agent (2441 modules → 1 file!)
# The bundle eliminates the 30-120s module loading time in child processes
# Using build:fast (esbuild) for faster builds - type errors are caught in CI
RUN npm run build:fast && \
    echo "=== Creating agent bundle (2441 modules → 1 file) ===" && \
    npx tsx apps/cli/src/commands/build/bundle-agent.ts && \
    ls -lh dist/agents/voice-agent-bundle.js

# ============================================================================
# Stage 2: Production
# ============================================================================
# Use Ubuntu 24.04 (Noble) for GLIBC 2.39 (needed for Rust ONNX bindings)
# Rust ONNX bindings require GLIBC 2.38+, Ubuntu 24.04 provides 2.39
FROM ubuntu:24.04 AS production

WORKDIR /app

# Install Node.js 20.x and system dependencies (including ffmpeg for DJ-style audio fade-out)
# DEBIAN_FRONTEND=noninteractive suppresses interactive prompts (e.g. tzdata region picker)
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    ffmpeg \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates \
    && corepack enable && corepack prepare pnpm@latest --activate

# Copy package files for production install
COPY package.json pnpm-lock.yaml* package-lock.json* ./
COPY .npmrc .pnpmrc* ./

# Install production dependencies only (no devDependencies)
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    --mount=type=cache,target=/root/.npm \
    if [ -f pnpm-lock.yaml ]; then \
      pnpm install --frozen-lockfile --prefer-offline --prod; \
    else \
      npm ci --omit=dev --prefer-offline; \
    fi

# Patch LiveKit agents library to increase ALL timeouts
# The library has multiple hardcoded timeouts that are too short for Cloud Run cold starts:
# - initializeTimeout: 30s in worker.js (parent waiting for child init)
# - initializeProcessTimeout: 10s in worker.js  
# - ASSIGNMENT_TIMEOUT: 7.5s in worker.js (child response to job dispatch) <-- NEW
# - ORPHANED_TIMEOUT: 15s in job_proc_lazy_main.js (child ping timeout)
# Use find+sed to patch ALL files across npm and pnpm directory structures
RUN echo "=== Patching LiveKit SDK timeouts ===" && \
    echo "--- Patching worker.js/cjs files ---" && \
    find node_modules -name "worker.js" -o -name "worker.cjs" | xargs -I{} sh -c ' \
      if grep -q "initializeTimeout: 3e4" "{}"; then \
        sed -i "s/initializeTimeout: 3e4/initializeTimeout: 3e5 \/* PATCHED 5min *\//g" "{}"; \
        echo "  Patched initializeTimeout in {}"; \
      fi; \
      if grep -q "initializeProcessTimeout = 10 \* 1e3" "{}"; then \
        sed -i "s/initializeProcessTimeout = 10 \* 1e3/initializeProcessTimeout = 600 \* 1e3 \/* PATCHED 10min *\//g" "{}"; \
        echo "  Patched initializeProcessTimeout in {}"; \
      fi; \
      if grep -q "ASSIGNMENT_TIMEOUT = 7.5 \* 1e3" "{}"; then \
        sed -i "s/ASSIGNMENT_TIMEOUT = 7.5 \* 1e3/ASSIGNMENT_TIMEOUT = 60 \* 1e3 \/* PATCHED 60s *\//g" "{}"; \
        echo "  Patched ASSIGNMENT_TIMEOUT in {}"; \
      fi \
    ' && \
    echo "--- Patching job_proc_lazy_main.js files (ORPHANED_TIMEOUT) ---" && \
    find node_modules -name "job_proc_lazy_main.js" | xargs -I{} sh -c ' \
      if grep -q "ORPHANED_TIMEOUT = 15 \* 1e3" "{}"; then \
        sed -i "s/ORPHANED_TIMEOUT = 15 \* 1e3/ORPHANED_TIMEOUT = 300 \* 1e3 \/* PATCHED 5min *\//g" "{}"; \
        echo "  Patched ORPHANED_TIMEOUT in {}"; \
      fi \
    ' && \
    echo "--- Patching inference_proc_lazy_main.js files (ORPHANED_TIMEOUT) ---" && \
    find node_modules -name "inference_proc_lazy_main.js" | xargs -I{} sh -c ' \
      if grep -q "ORPHANED_TIMEOUT = 15 \* 1e3" "{}"; then \
        sed -i "s/ORPHANED_TIMEOUT = 15 \* 1e3/ORPHANED_TIMEOUT = 300 \* 1e3 \/* PATCHED 5min *\//g" "{}"; \
        echo "  Patched ORPHANED_TIMEOUT in {}"; \
      fi \
    ' && \
    echo "=== Verifying patches ===" && \
    grep -r "PATCHED" node_modules/@livekit/agents/dist/ 2>/dev/null | head -6 || echo "Direct path not found" && \
    find node_modules/.pnpm -name "*.js" -exec grep -l "PATCHED" {} \; 2>/dev/null | head -6 || echo "pnpm verification done"

# Copy built files from builder
COPY --from=builder /app/dist ./dist

# Copy Rust native modules (zero-allocation audio processing, SIMD embeddings)
# These modules are optional - the app gracefully falls back to JS if unavailable
RUN mkdir -p apps/rust-perf apps/rust-audio

# Copy rust-perf: native module (.node) and NAPI-generated loader (index.js, index.d.ts)
COPY --from=rust-builder /rust/rust-perf/*.node ./apps/rust-perf/
COPY --from=rust-builder /rust/rust-perf/index.js /rust/rust-perf/index.d.ts ./apps/rust-perf/
COPY apps/rust-perf/package.json ./apps/rust-perf/

# Copy rust-audio: native module and loader files
# Using RUN with mount to handle missing files gracefully (rust-audio may not be built yet)
RUN --mount=from=rust-builder,source=/rust/rust-audio,target=/tmp/rust-audio \
    (cp /tmp/rust-audio/*.node ./apps/rust-audio/ 2>/dev/null && \
     cp /tmp/rust-audio/index.js /tmp/rust-audio/index.d.ts ./apps/rust-audio/ 2>/dev/null) || \
    echo "rust-audio native module not available (will use JS fallback)"

# Copy rust-audio package.json for module resolution
COPY apps/rust-audio/package.json ./apps/rust-audio/

# =============================================================================
# VERIFY NATIVE MODULES LOADED CORRECTLY
# =============================================================================
# This verification step ensures the Rust native modules are properly built
# and can be loaded. If this fails, the container won't start with broken
# native modules - it will fail fast during build instead.
RUN echo "=== Verifying native Rust modules ===" && \
    node -e " \
      const perfPath = './apps/rust-perf'; \
      const audioPath = './apps/rust-audio'; \
      let perfOk = false, audioOk = false; \
      try { \
        const perf = require(perfPath); \
        const info = perf.getLibraryInfo(); \
        console.log('✅ @ferni/perf loaded:', info.version, '- SIMD:', info.simdAvailable ? 'yes' : 'no'); \
        perfOk = true; \
      } catch (e) { console.error('❌ @ferni/perf failed:', e.message); } \
      try { \
        const audio = require(audioPath); \
        const info = audio.getLibraryInfo(); \
        console.log('✅ @ferni/audio loaded:', info.version, '- Sample rate:', info.defaultSampleRate); \
        audioOk = true; \
      } catch (e) { console.error('⚠️ @ferni/audio not available:', e.message, '(optional)'); } \
      if (!perfOk) { process.exit(1); } \
      console.log('=== Native module verification complete ==='); \
    " && \
    echo "Native modules verified successfully"

# Copy persona bundles (JSON, MD files needed at runtime)
COPY --from=builder /app/src/personas/bundles/ ./dist/personas/bundles/

# Copy task wisdom JSON files (not compiled by esbuild)
COPY --from=builder /app/src/tasks/wisdom/*.json ./dist/tasks/wisdom/

# Copy sound effects for session intro/outro (connect.mp3, disconnect.mp3, etc.)
# These are used by the DJ system for "opening the show" moments
COPY apps/web/public/sounds/ ./sounds/

# Set environment variables
ENV NODE_ENV=production
ENV PERSONA_ID=ferni
# Single-process mode: All jobs run in main process (eliminates child process spawn overhead)
# This gives ~100x faster job startup (instant vs 30-120s with child processes)
ENV USE_SINGLE_PROCESS=true

# =============================================================================
# NATIVE RUST MODULE CONFIGURATION
# =============================================================================
# These enable the Rust NAPI modules for production use:
# - @ferni/perf: SIMD-accelerated cosine similarity, LSH deduplication (10-50x faster)
# - @ferni/audio: Zero-allocation audio processing, FFT analysis (reduces GC pressure)
#
# Both are ENABLED by default (the flags use !== 'false' pattern in feature-flags.ts)
# but we set them explicitly here for clarity and Docker layer caching.
ENV USE_NATIVE_AUDIO=true
ENV USE_NATIVE_EMBEDDINGS=true

# Node.js process optimizations for voice agent stability and fast startup
# - --max-old-space-size=3072: 3GB heap for voice processing
# - --max-semi-space-size=128: Larger young generation for less frequent minor GC
# - --no-warnings: Suppress deprecation warnings in production (saves ~50ms)
# - --dns-result-order=ipv4first: Prefer IPv4 for faster DNS resolution
# - --no-deprecation: Disable deprecation warnings
ENV NODE_OPTIONS="--max-old-space-size=3072 --max-semi-space-size=128 --no-warnings --dns-result-order=ipv4first --no-deprecation"

EXPOSE 8080

# =============================================================================
# HEALTH CHECK
# =============================================================================
# The health check verifies:
# 1. Server is responding (basic liveness)
# 2. Workers are ready to accept calls (readiness - workers signal ready)
#
# Start period: 60s - allows time for workers to initialize
# Interval: 30s - check every 30 seconds
# Timeout: 10s - fail if no response in 10 seconds
# Retries: 3 - mark unhealthy after 3 consecutive failures
HEALTHCHECK --start-period=60s --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8080/health/ready || exit 1

# Run the voice agent
CMD ["node", "dist/agent.js", "dev"]
