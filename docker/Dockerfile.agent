# syntax=docker/dockerfile:1.4
# ============================================================================
# FERNI VOICE AGENT DOCKERFILE (OPTIMIZED WITH PNPM + ESBUILD)
# ============================================================================
# Builds the LiveKit voice agent service with aggressive caching.
# Supports all personas via PERSONA_ID environment variable.
#
# OPTIMIZATIONS:
# - pnpm for ~40% faster dependency installs
# - esbuild for ~10-50x faster TypeScript compilation
# - BuildKit 1.4 syntax enables parallel stage builds
# - Cache mounts persist across builds
# - Optimal layer ordering (rarely-changing layers first)
#
# Build:
#   docker build -f docker/Dockerfile.agent -t ferni-agent .
#
# Run:
#   docker run -e PERSONA_ID=ferni -e LIVEKIT_URL=... ferni-agent
# ============================================================================

ARG NODE_VERSION=20

# LiveKit agents SDK version - update this when upgrading @livekit/agents packages
# Check latest: https://www.npmjs.com/package/@livekit/agents
ARG LIVEKIT_AGENTS_VERSION=1.0.31

# ============================================================================
# Stage 0: Build Rust native modules (SIMD-accelerated audio processing)
# ============================================================================
FROM rust:1.92-slim AS rust-builder

WORKDIR /rust

# Install build dependencies for napi-rs and Rust crates
# - pkg-config + libssl-dev: Required for openssl-sys crate
# - libclang-dev: Required for bindgen (used by rust-audio FFI bindings)
# - cmake + git: Required for whisper-rs-sys (builds whisper.cpp via cmake)
# Note: Metal/Objective-C deps not needed - candle-core metal feature is macOS-only
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    pkg-config \
    libssl-dev \
    libclang-dev \
    cmake \
    && rm -rf /var/lib/apt/lists/* \
    && rustup component add rustfmt \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g @napi-rs/cli

# Copy rust-audio source (include Cargo.lock for version pinning)
COPY apps/rust-audio/Cargo.toml apps/rust-audio/Cargo.lock ./rust-audio/
COPY apps/rust-audio/package.json ./rust-audio/
COPY apps/rust-audio/src ./rust-audio/src
COPY apps/rust-audio/build.rs ./rust-audio/
COPY apps/rust-audio/benches ./rust-audio/benches

# Build rust-audio native module for Linux x64
# Cache mounts persist Cargo registry + build artifacts across builds (~5-10 min savings)
WORKDIR /rust/rust-audio
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/rust/rust-audio/target \
    cargo build --release && \
    napi build --platform --release && \
    ls -la *.node && \
    echo "=== rust-audio native module built ==="

# Copy rust-perf source (if it exists)
WORKDIR /rust
COPY apps/rust-perf/Cargo.toml apps/rust-perf/Cargo.lock* ./rust-perf/
COPY apps/rust-perf/package.json ./rust-perf/
COPY apps/rust-perf/src ./rust-perf/src
COPY apps/rust-perf/build.rs ./rust-perf/

# Build rust-perf native module for Linux x64
# Note: rust-perf has pre-existing compilation issues (full_omni_pipeline.rs)
# so we allow this to fail gracefully - the voice agent works without it
WORKDIR /rust/rust-perf
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/rust/rust-perf/target \
    (cargo build --release && \
    napi build --platform --release && \
    ls -la *.node && \
    echo "=== rust-perf native module built ===") || \
    (echo "⚠️ rust-perf build failed (non-fatal) - creating placeholder" && \
     touch /rust/rust-perf/rust-perf.placeholder)

# ============================================================================
# Stage 1: Build TypeScript with pnpm + esbuild
# ============================================================================
# Use Ubuntu 24.04 (Noble) for GLIBC 2.39 (needed for Rust ONNX bindings)
# Rust ONNX bindings require GLIBC 2.38+, Ubuntu 24.04 provides 2.39
FROM ubuntu:24.04 AS builder

# Re-declare ARG after FROM to make it available in this stage
ARG LIVEKIT_AGENTS_VERSION

WORKDIR /app

# Install Node.js 20.x, git, and enable pnpm
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable && corepack prepare pnpm@latest --activate

# Copy package files first (cache layer)
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml* ./
COPY .npmrc .pnpmrc* ./

# Copy workspace packages that are referenced (apps/cli needs to be available)
COPY apps/cli/package.json ./apps/cli/
COPY apps/web/package.json ./apps/web/
COPY apps/async/package.json ./apps/async/
COPY apps/intelligence-worker/package.json ./apps/intelligence-worker/
COPY packages/shared-types/package.json ./packages/shared-types/

# Create stub package.json for packages not in build context (rust packages, design-system)
RUN mkdir -p apps/rust-audio apps/rust-perf design-system && \
    echo '{"name":"@ferni/audio","version":"0.1.0"}' > apps/rust-audio/package.json && \
    echo '{"name":"@ferni/perf","version":"0.1.0"}' > apps/rust-perf/package.json && \
    echo '{"name":"@ferni/design-system","version":"1.0.0"}' > design-system/package.json

# Replace local file: dependencies with npm registry versions for Docker builds
# The local agents-js is not available in Docker context
# Version is controlled by LIVEKIT_AGENTS_VERSION build arg (defined at top of file)
RUN echo "Using @livekit/agents version: ^${LIVEKIT_AGENTS_VERSION}" && \
    sed -i "s|\"file:../agents-js/agents\"|\"^${LIVEKIT_AGENTS_VERSION}\"|g" package.json && \
    sed -i "s|\"file:../agents-js/plugins/cartesia\"|\"^${LIVEKIT_AGENTS_VERSION}\"|g" package.json && \
    sed -i "s|\"file:../agents-js/plugins/deepgram\"|\"^${LIVEKIT_AGENTS_VERSION}\"|g" package.json && \
    sed -i "s|\"file:../agents-js/plugins/google\"|\"^${LIVEKIT_AGENTS_VERSION}\"|g" package.json && \
    sed -i "s|\"file:../agents-js/plugins/openai\"|\"^${LIVEKIT_AGENTS_VERSION}\"|g" package.json && \
    sed -i "s|\"file:../agents-js/plugins/silero\"|\"^${LIVEKIT_AGENTS_VERSION}\"|g" package.json && \
    cat package.json | grep -A5 '"@livekit/agents"' | head -10

# Copy build configs
COPY tsconfig.json ./
COPY tsconfig.build.json ./

# Install dependencies with pnpm (no frozen lockfile since we modified package.json)
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --prefer-offline --no-frozen-lockfile

# Copy source files (this layer invalidates on source changes)
COPY src/ ./src/

# Copy build scripts and CLI source
COPY apps/cli/src/commands/build/bundle-agent.ts ./apps/cli/src/commands/build/
COPY apps/cli/src/commands/build/build-fast.ts ./apps/cli/src/commands/build/
COPY apps/cli/src/commands/build/build-cli-binary.ts ./apps/cli/src/commands/build/
COPY apps/cli/src/ ./apps/cli/src/

# Copy tool manifest/embeddings build scripts
COPY scripts/build-tool-manifest.ts ./scripts/
COPY scripts/build-tool-embeddings.ts ./scripts/
COPY scripts/generate-tool-tiers.js ./scripts/

# Build TypeScript + Bundle Agent + CLI + Tool Artifacts
# - Agent bundle: 2441 modules → 1 file (eliminates 30-120s module loading)
# - Tool manifest: 655 tools pre-indexed (100x faster than dynamic imports)
# - Tool embeddings: 653 pre-computed vectors (30x faster semantic matching)
# - CLI bundle: Packaged for in-container ops
# IMPORTANT: Clean dist folder to avoid stale build artifacts from Kaniko cache
RUN rm -rf dist && pnpm run build:fast && \
    echo "=== Copying JSON config files ===" && \
    mkdir -p dist/agents/shared/sanitizer/config && \
    cp src/agents/shared/sanitizer/config/tool-patterns.json dist/agents/shared/sanitizer/config/ && \
    echo "=== Building tool manifest + embeddings (100x faster startup!) ===" && \
    pnpm exec tsx scripts/build-tool-manifest.ts && \
    pnpm exec tsx scripts/build-tool-embeddings.ts && \
    ls -lh dist/tool-manifest.json dist/tool-embeddings.json && \
    echo "=== Creating agent bundle (2441 modules → 1 file) ===" && \
    pnpm exec tsx apps/cli/src/commands/build/bundle-agent.ts && \
    ls -lh dist/agents/voice-agent-bundle.js && \
    echo "=== Building Ferni CLI for container ===" && \
    (pnpm exec tsx apps/cli/src/commands/build/build-cli-binary.ts --container --release && \
    ls -lh dist/ferni-bundle/) || \
    (echo "⚠️ CLI bundle failed (non-fatal) - creating placeholder" && \
     mkdir -p dist/ferni-bundle && echo '#!/bin/sh\necho "ferni CLI not available in this build"' > dist/ferni-bundle/ferni.js && \
     cp dist/ferni-bundle/ferni.js dist/ferni-bundle/ferni)

# ============================================================================
# Stage 1b: Prepare production node_modules (reuses warm pnpm store)
# ============================================================================
# By running the prod install HERE (same stage as full install), the pnpm store
# is already warm with all resolved packages. This makes prod install near-instant
# (~5s) instead of re-downloading everything from scratch in production (~120s).
# Also applies LiveKit patches and cleanup here to keep the production stage thin.
COPY patches/ ./patches/
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    echo "=== Preparing production node_modules ===" && \
    mkdir -p /prod-deps && \
    cp package.json pnpm-workspace.yaml .npmrc /prod-deps/ && \
    cp pnpm-lock.yaml /prod-deps/ 2>/dev/null || true && \
    cp -r patches /prod-deps/ 2>/dev/null || true && \
    for dir in apps/rust-audio apps/rust-perf design-system apps/cli apps/web apps/async apps/intelligence-worker packages/shared-types; do \
      mkdir -p /prod-deps/$dir && cp $dir/package.json /prod-deps/$dir/ 2>/dev/null || true; \
    done && \
    cd /prod-deps && \
    pnpm install --prefer-offline --prod --no-frozen-lockfile && \
    pnpm store prune && \
    echo "=== Cleaning up node_modules ===" && \
    find node_modules \( -name "*.md" -o -name "*.map" -o -name "CHANGELOG*" \
      -o -name "LICENSE*" -o -name ".npmignore" \) -delete 2>/dev/null || true && \
    find node_modules -name "*.ts" ! -name "*.d.ts" -delete 2>/dev/null || true && \
    find node_modules -type d \( -name "test" -o -name "tests" -o -name "__tests__" \
      -o -name "docs" \) -exec rm -rf {} + 2>/dev/null || true && \
    echo "=== Patching LiveKit SDK timeouts ===" && \
    find node_modules -name "worker.js" -o -name "worker.cjs" | xargs -I{} sh -c ' \
      grep -q "initializeTimeout: 3e4" "{}" && \
        sed -i "s/initializeTimeout: 3e4/initializeTimeout: 3e5 \/* PATCHED 5min *\//g" "{}"; \
      grep -q "initializeProcessTimeout = 10 \* 1e3" "{}" && \
        sed -i "s/initializeProcessTimeout = 10 \* 1e3/initializeProcessTimeout = 600 \* 1e3 \/* PATCHED 10min *\//g" "{}"; \
      grep -q "ASSIGNMENT_TIMEOUT = 7.5 \* 1e3" "{}" && \
        sed -i "s/ASSIGNMENT_TIMEOUT = 7.5 \* 1e3/ASSIGNMENT_TIMEOUT = 60 \* 1e3 \/* PATCHED 60s *\//g" "{}"; \
      true \
    ' && \
    find node_modules \( -name "job_proc_lazy_main.js" -o -name "inference_proc_lazy_main.js" \) | xargs -I{} sh -c ' \
      grep -q "ORPHANED_TIMEOUT = 15 \* 1e3" "{}" && \
        sed -i "s/ORPHANED_TIMEOUT = 15 \* 1e3/ORPHANED_TIMEOUT = 300 \* 1e3 \/* PATCHED 5min *\//g" "{}"; \
      true \
    ' && \
    echo "=== Production node_modules ready ===" && \
    grep -r "PATCHED" node_modules/@livekit/agents/dist/ 2>/dev/null | head -4 || echo "Patch verification done"

# ============================================================================
# Stage 2: Production
# ============================================================================
# Use Ubuntu 24.04 (Noble) for GLIBC 2.39 (needed for Rust ONNX bindings)
# Rust ONNX bindings require GLIBC 2.38+, Ubuntu 24.04 provides 2.39
FROM ubuntu:24.04 AS production

WORKDIR /app

# Install Node.js 20.x and system dependencies (including ffmpeg for DJ-style audio fade-out)
# DEBIAN_FRONTEND=noninteractive suppresses interactive prompts (e.g. tzdata region picker)
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    ffmpeg \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates

# Copy pre-built production node_modules from builder (already cleaned + patched)
# This replaces the full pnpm install + cleanup + LiveKit patching that previously
# ran in the production stage. The builder's pnpm store was warm, so the prod install
# there was near-instant. This COPY is a single layer transfer — no network downloads.
COPY --from=builder /prod-deps/node_modules ./node_modules

# Copy built files from builder
# Includes: dist/tool-manifest.json, dist/tool-embeddings.json (100x faster startup!)
COPY --from=builder /app/dist ./dist

# Copy Rust native modules (SIMD-accelerated audio processing)
# These provide zero-allocation real-time audio analysis
COPY --from=rust-builder /rust/rust-audio/*.node ./apps/rust-audio/
COPY apps/rust-audio/package.json apps/rust-audio/index.d.ts apps/rust-audio/index.js ./apps/rust-audio/
# rust-perf may not have built (pre-existing code issues) - copy .node if available
COPY apps/rust-perf/package.json apps/rust-perf/index.d.ts apps/rust-perf/index.js ./apps/rust-perf/
COPY --from=rust-builder /rust/rust-perf/rust-perf.* ./apps/rust-perf/

# Copy persona bundles (JSON, MD files needed at runtime)
COPY --from=builder /app/src/personas/bundles/ ./dist/personas/bundles/

# Copy task wisdom JSON files (not compiled by esbuild)
COPY --from=builder /app/src/tasks/wisdom/*.json ./dist/tasks/wisdom/

# Copy tool description JSON files (not compiled by esbuild)
COPY --from=builder /app/src/tools/config/*.json ./dist/tools/config/

# Copy sound effects for session intro/outro (connect.mp3, disconnect.mp3, etc.)
# These are used by the DJ system for "opening the show" moments
COPY apps/web/public/sounds/ ./sounds/

# Install Ferni CLI for in-container ops
# The bundle was built in the builder stage and copied with dist/
# Create symlink so `ferni` command is available globally
RUN ln -sf /app/dist/ferni-bundle/ferni /usr/local/bin/ferni && \
    chmod +x /app/dist/ferni-bundle/ferni /app/dist/ferni-bundle/ferni.js && \
    echo "Ferni CLI installed:" && ferni --version || echo "(version check skipped)"

# Set environment variables
ENV NODE_ENV=production
ENV PERSONA_ID=ferni
# Single-process mode: All jobs run in main process (eliminates child process spawn overhead)
# This gives ~100x faster job startup (instant vs 30-120s with child processes)
ENV USE_SINGLE_PROCESS=true

# Node.js process optimizations for voice agent stability and fast startup
# - --max-old-space-size=3072: 3GB heap for voice processing
# - --max-semi-space-size=128: Larger young generation for less frequent minor GC
# - --no-warnings: Suppress deprecation warnings in production (saves ~50ms)
# - --dns-result-order=ipv4first: Prefer IPv4 for faster DNS resolution
# - --no-deprecation: Disable deprecation warnings
ENV NODE_OPTIONS="--max-old-space-size=3072 --max-semi-space-size=128 --no-warnings --dns-result-order=ipv4first --no-deprecation"

EXPOSE 8080

# Run the voice agent
CMD ["node", "dist/agent.js", "dev"]
