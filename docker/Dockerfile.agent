# syntax=docker/dockerfile:1.4
# ============================================================================
# FERNI VOICE AGENT DOCKERFILE (OPTIMIZED WITH PNPM + ESBUILD)
# ============================================================================
# Builds the LiveKit voice agent service with aggressive caching.
# Supports all personas via PERSONA_ID environment variable.
#
# OPTIMIZATIONS:
# - pnpm for ~40% faster dependency installs
# - esbuild for ~10-50x faster TypeScript compilation
# - BuildKit 1.4 syntax enables parallel stage builds
# - Cache mounts persist across builds
# - Optimal layer ordering (rarely-changing layers first)
#
# Build:
#   docker build -f docker/Dockerfile.agent -t ferni-agent .
#
# Run:
#   docker run -e PERSONA_ID=ferni -e LIVEKIT_URL=... ferni-agent
# ============================================================================

ARG NODE_VERSION=20

# ============================================================================
# Stage 1: Build TypeScript with pnpm + esbuild
# ============================================================================
FROM node:${NODE_VERSION}-slim AS builder

WORKDIR /app

# Install git
RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

# Copy package files first (cache layer)
COPY package.json package-lock.json* ./
COPY .npmrc ./

# Copy build configs
COPY tsconfig.json ./
COPY tsconfig.build.json ./

# Install dependencies with npm
RUN --mount=type=cache,target=/root/.npm \
    npm install --legacy-peer-deps

# Copy source files (this layer invalidates on source changes)
COPY src/ ./src/

# Build TypeScript
# Build TypeScript
RUN npm run build

# ============================================================================
# Stage 2: Production
# ============================================================================
FROM node:${NODE_VERSION}-slim AS production

WORKDIR /app

# Install system dependencies (including ffmpeg for DJ-style audio fade-out)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates \
    && corepack enable && corepack prepare pnpm@latest --activate

# Copy package files for production install
COPY package.json pnpm-lock.yaml* package-lock.json* ./
COPY .npmrc .pnpmrc* ./

# Install production dependencies only (no devDependencies)
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    --mount=type=cache,target=/root/.npm \
    if [ -f pnpm-lock.yaml ]; then \
      pnpm install --frozen-lockfile --prefer-offline --prod; \
    else \
      npm ci --omit=dev --prefer-offline; \
    fi

# Patch LiveKit agents library to increase initialization timeout
# The library has hardcoded 10s/30s timeouts that are too short for Cloud Run cold starts
# NOTE: Must patch BOTH worker.js AND worker.cjs as pnpm/npm may use either
RUN node -e " \
  const fs = require('fs'); \
  const path = require('path'); \
  const glob = require('path'); \
  const patchFile = (filePath) => { \
    if (!fs.existsSync(filePath)) return false; \
    let content = fs.readFileSync(filePath, 'utf8'); \
    let patched = false; \
    const patches = [ \
      ['initializeTimeout: 3e4', 'initializeTimeout: 3e5 /* PATCHED 5min */'], \
      ['initializeProcessTimeout = 10 * 1e3', 'initializeProcessTimeout = 300 * 1e3 /* PATCHED 5min */'], \
      ['initializeProcessTimeout=10*1e3', 'initializeProcessTimeout=300*1e3/* PATCHED */'], \
    ]; \
    for (const [search, replace] of patches) { \
      if (content.includes(search)) { \
        content = content.replace(new RegExp(search.replace(/[.*+?^\${}()|[\\]\\\\]/g, '\\\\$&'), 'g'), replace); \
        patched = true; \
        console.log('Patched: ' + search + ' in ' + filePath); \
      } \
    } \
    if (patched) fs.writeFileSync(filePath, content); \
    return patched; \
  }; \
  const agentsDir = 'node_modules/@livekit/agents/dist'; \
  const pnpmDir = 'node_modules/.pnpm/@livekit+agents@*/node_modules/@livekit/agents/dist'; \
  let totalPatched = 0; \
  for (const dir of [agentsDir]) { \
    for (const file of ['worker.js', 'worker.cjs', 'worker.mjs']) { \
      const filePath = path.join(__dirname, dir, file); \
      if (patchFile(filePath)) totalPatched++; \
    } \
  } \
  const pnpmGlob = path.join(__dirname, 'node_modules/.pnpm'); \
  if (fs.existsSync(pnpmGlob)) { \
    const pnpmDirs = fs.readdirSync(pnpmGlob).filter(d => d.startsWith('@livekit+agents@')); \
    for (const pdir of pnpmDirs) { \
      for (const file of ['worker.js', 'worker.cjs', 'worker.mjs']) { \
        const filePath = path.join(pnpmGlob, pdir, 'node_modules/@livekit/agents/dist', file); \
        if (patchFile(filePath)) totalPatched++; \
      } \
    } \
  } \
  console.log('[patch-livekit-timeout] Total files patched: ' + totalPatched); \
"

# Copy built files from builder
COPY --from=builder /app/dist ./dist

# Copy persona bundles (JSON, MD files needed at runtime)
COPY --from=builder /app/src/personas/bundles/ ./dist/personas/bundles/

# Set environment variables
ENV NODE_ENV=production
ENV PERSONA_ID=ferni

# Node.js process optimizations for voice agent stability
ENV NODE_OPTIONS="--max-old-space-size=3072 --max-semi-space-size=128"

EXPOSE 8080

# Run the voice agent
CMD ["node", "dist/agent.js", "dev"]
