# syntax=docker/dockerfile:1.4
# ============================================================================
# FERNI VOICE AGENT DOCKERFILE (OPTIMIZED WITH PNPM + ESBUILD)
# ============================================================================
# Builds the LiveKit voice agent service with aggressive caching.
# Supports all personas via PERSONA_ID environment variable.
#
# OPTIMIZATIONS:
# - pnpm for ~40% faster dependency installs
# - esbuild for ~10-50x faster TypeScript compilation
# - BuildKit 1.4 syntax enables parallel stage builds
# - Cache mounts persist across builds
# - Optimal layer ordering (rarely-changing layers first)
#
# Build:
#   docker build -f docker/Dockerfile.agent -t ferni-agent .
#
# Run:
#   docker run -e PERSONA_ID=ferni -e LIVEKIT_URL=... ferni-agent
# ============================================================================

ARG NODE_VERSION=20

# ============================================================================
# Stage 0: Build Rust native modules (SIMD-accelerated audio processing)
# ============================================================================
FROM rust:1.83-slim AS rust-builder

WORKDIR /rust

# Install build dependencies for napi-rs
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g @napi-rs/cli

# Copy rust-audio source (include Cargo.lock for version pinning)
COPY apps/rust-audio/Cargo.toml apps/rust-audio/Cargo.lock ./rust-audio/
COPY apps/rust-audio/src ./rust-audio/src
COPY apps/rust-audio/build.rs ./rust-audio/
COPY apps/rust-audio/benches ./rust-audio/benches

# Build rust-audio native module for Linux x64
WORKDIR /rust/rust-audio
RUN cargo build --release && \
    napi build --platform --release && \
    ls -la *.node && \
    echo "=== rust-audio native module built ==="

# Copy rust-perf source (if it exists)
WORKDIR /rust
COPY apps/rust-perf/Cargo.toml apps/rust-perf/Cargo.lock* ./rust-perf/
COPY apps/rust-perf/src ./rust-perf/src
COPY apps/rust-perf/build.rs ./rust-perf/

# Build rust-perf native module for Linux x64
WORKDIR /rust/rust-perf
RUN cargo build --release && \
    napi build --platform --release && \
    ls -la *.node && \
    echo "=== rust-perf native module built ==="

# ============================================================================
# Stage 1: Build TypeScript with pnpm + esbuild
# ============================================================================
FROM node:${NODE_VERSION}-slim AS builder

WORKDIR /app

# Install git
RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

# Copy package files first (cache layer)
COPY package.json package-lock.json* ./
COPY .npmrc ./

# Copy build configs
COPY tsconfig.json ./
COPY tsconfig.build.json ./

# Install dependencies with npm
RUN --mount=type=cache,target=/root/.npm \
    npm install --legacy-peer-deps

# Copy source files (this layer invalidates on source changes)
COPY src/ ./src/

# Copy build scripts and CLI source
COPY apps/cli/src/commands/build/bundle-agent.ts ./apps/cli/src/commands/build/
COPY apps/cli/src/commands/build/build-fast.ts ./apps/cli/src/commands/build/
COPY apps/cli/src/commands/build/build-cli-binary.ts ./apps/cli/src/commands/build/
COPY apps/cli/src/ ./apps/cli/src/

# Build TypeScript + Bundle Agent + CLI
# - Agent bundle: 2441 modules → 1 file (eliminates 30-120s module loading)
# - CLI bundle: Packaged for in-container ops
RUN npm run build:fast && \
    echo "=== Creating agent bundle (2441 modules → 1 file) ===" && \
    npx tsx apps/cli/src/commands/build/bundle-agent.ts && \
    ls -lh dist/agents/voice-agent-bundle.js && \
    echo "=== Building Ferni CLI for container ===" && \
    npx tsx apps/cli/src/commands/build/build-cli-binary.ts --container --release && \
    ls -lh dist/ferni-bundle/

# ============================================================================
# Stage 2: Production
# ============================================================================
FROM node:${NODE_VERSION}-slim AS production

WORKDIR /app

# Install system dependencies (including ffmpeg for DJ-style audio fade-out)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates \
    && corepack enable && corepack prepare pnpm@latest --activate

# Copy package files for production install
COPY package.json pnpm-lock.yaml* package-lock.json* ./
COPY .npmrc .pnpmrc* ./

# Copy patches directory (required for pnpm patched packages)
COPY patches/ ./patches/

# Install production dependencies only (no devDependencies)
# Use pnpm prune to remove dev deps and clean up
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    --mount=type=cache,target=/root/.npm \
    if [ -f pnpm-lock.yaml ]; then \
      pnpm install --frozen-lockfile --prefer-offline --prod && \
      pnpm store prune; \
    else \
      npm ci --omit=dev --prefer-offline && \
      npm cache clean --force; \
    fi && \
    # Remove unnecessary files from node_modules to reduce image size
    find node_modules -name "*.md" -delete 2>/dev/null || true && \
    find node_modules -name "*.map" -delete 2>/dev/null || true && \
    find node_modules -name "*.ts" ! -name "*.d.ts" -delete 2>/dev/null || true && \
    find node_modules -name "CHANGELOG*" -delete 2>/dev/null || true && \
    find node_modules -name "LICENSE*" -delete 2>/dev/null || true && \
    find node_modules -name ".npmignore" -delete 2>/dev/null || true && \
    find node_modules -type d -name "test" -exec rm -rf {} + 2>/dev/null || true && \
    find node_modules -type d -name "tests" -exec rm -rf {} + 2>/dev/null || true && \
    find node_modules -type d -name "__tests__" -exec rm -rf {} + 2>/dev/null || true && \
    find node_modules -type d -name "docs" -exec rm -rf {} + 2>/dev/null || true

# Patch LiveKit agents library to increase ALL timeouts
# The library has multiple hardcoded timeouts that are too short for Cloud Run cold starts:
# - initializeTimeout: 30s in worker.js (parent waiting for child init)
# - initializeProcessTimeout: 10s in worker.js  
# - ASSIGNMENT_TIMEOUT: 7.5s in worker.js (child response to job dispatch) <-- NEW
# - ORPHANED_TIMEOUT: 15s in job_proc_lazy_main.js (child ping timeout)
# Use find+sed to patch ALL files across npm and pnpm directory structures
RUN echo "=== Patching LiveKit SDK timeouts ===" && \
    echo "--- Patching worker.js/cjs files ---" && \
    find node_modules -name "worker.js" -o -name "worker.cjs" | xargs -I{} sh -c ' \
      if grep -q "initializeTimeout: 3e4" "{}"; then \
        sed -i "s/initializeTimeout: 3e4/initializeTimeout: 3e5 \/* PATCHED 5min *\//g" "{}"; \
        echo "  Patched initializeTimeout in {}"; \
      fi; \
      if grep -q "initializeProcessTimeout = 10 \* 1e3" "{}"; then \
        sed -i "s/initializeProcessTimeout = 10 \* 1e3/initializeProcessTimeout = 600 \* 1e3 \/* PATCHED 10min *\//g" "{}"; \
        echo "  Patched initializeProcessTimeout in {}"; \
      fi; \
      if grep -q "ASSIGNMENT_TIMEOUT = 7.5 \* 1e3" "{}"; then \
        sed -i "s/ASSIGNMENT_TIMEOUT = 7.5 \* 1e3/ASSIGNMENT_TIMEOUT = 60 \* 1e3 \/* PATCHED 60s *\//g" "{}"; \
        echo "  Patched ASSIGNMENT_TIMEOUT in {}"; \
      fi \
    ' && \
    echo "--- Patching job_proc_lazy_main.js files (ORPHANED_TIMEOUT) ---" && \
    find node_modules -name "job_proc_lazy_main.js" | xargs -I{} sh -c ' \
      if grep -q "ORPHANED_TIMEOUT = 15 \* 1e3" "{}"; then \
        sed -i "s/ORPHANED_TIMEOUT = 15 \* 1e3/ORPHANED_TIMEOUT = 300 \* 1e3 \/* PATCHED 5min *\//g" "{}"; \
        echo "  Patched ORPHANED_TIMEOUT in {}"; \
      fi \
    ' && \
    echo "--- Patching inference_proc_lazy_main.js files (ORPHANED_TIMEOUT) ---" && \
    find node_modules -name "inference_proc_lazy_main.js" | xargs -I{} sh -c ' \
      if grep -q "ORPHANED_TIMEOUT = 15 \* 1e3" "{}"; then \
        sed -i "s/ORPHANED_TIMEOUT = 15 \* 1e3/ORPHANED_TIMEOUT = 300 \* 1e3 \/* PATCHED 5min *\//g" "{}"; \
        echo "  Patched ORPHANED_TIMEOUT in {}"; \
      fi \
    ' && \
    echo "=== Verifying patches ===" && \
    grep -r "PATCHED" node_modules/@livekit/agents/dist/ 2>/dev/null | head -6 || echo "Direct path not found" && \
    find node_modules/.pnpm -name "*.js" -exec grep -l "PATCHED" {} \; 2>/dev/null | head -6 || echo "pnpm verification done"

# Copy built files from builder
COPY --from=builder /app/dist ./dist

# Copy Rust native modules (SIMD-accelerated audio processing)
# These provide zero-allocation real-time audio analysis
COPY --from=rust-builder /rust/rust-audio/*.node ./apps/rust-audio/
COPY apps/rust-audio/package.json apps/rust-audio/index.d.ts apps/rust-audio/index.js ./apps/rust-audio/
COPY --from=rust-builder /rust/rust-perf/*.node ./apps/rust-perf/
COPY apps/rust-perf/package.json apps/rust-perf/index.d.ts apps/rust-perf/index.js ./apps/rust-perf/

# Copy persona bundles (JSON, MD files needed at runtime)
COPY --from=builder /app/src/personas/bundles/ ./dist/personas/bundles/

# Copy task wisdom JSON files (not compiled by esbuild)
COPY --from=builder /app/src/tasks/wisdom/*.json ./dist/tasks/wisdom/

# Copy tool description JSON files (not compiled by esbuild)
COPY --from=builder /app/src/tools/config/*.json ./dist/tools/config/

# Copy sound effects for session intro/outro (connect.mp3, disconnect.mp3, etc.)
# These are used by the DJ system for "opening the show" moments
COPY apps/web/public/sounds/ ./sounds/

# Install Ferni CLI for in-container ops
# The bundle was built in the builder stage and copied with dist/
# Create symlink so `ferni` command is available globally
RUN ln -sf /app/dist/ferni-bundle/ferni /usr/local/bin/ferni && \
    chmod +x /app/dist/ferni-bundle/ferni /app/dist/ferni-bundle/ferni.js && \
    echo "Ferni CLI installed:" && ferni --version || echo "(version check skipped)"

# Set environment variables
ENV NODE_ENV=production
ENV PERSONA_ID=ferni
# Single-process mode: All jobs run in main process (eliminates child process spawn overhead)
# This gives ~100x faster job startup (instant vs 30-120s with child processes)
ENV USE_SINGLE_PROCESS=true

# Node.js process optimizations for voice agent stability and fast startup
# - --max-old-space-size=3072: 3GB heap for voice processing
# - --max-semi-space-size=128: Larger young generation for less frequent minor GC
# - --no-warnings: Suppress deprecation warnings in production (saves ~50ms)
# - --dns-result-order=ipv4first: Prefer IPv4 for faster DNS resolution
# - --no-deprecation: Disable deprecation warnings
ENV NODE_OPTIONS="--max-old-space-size=3072 --max-semi-space-size=128 --no-warnings --dns-result-order=ipv4first --no-deprecation"

EXPOSE 8080

# Run the voice agent
CMD ["node", "dist/agent.js", "dev"]
