# ============================================================================
# FERNI VOICE AGENT DOCKERFILE
# ============================================================================
# Builds the LiveKit voice agent service.
# Supports all personas via PERSONA_ID environment variable.
#
# Build:
#   docker build -f docker/Dockerfile.agent -t ferni-agent .
#
# Run:
#   docker run -e PERSONA_ID=ferni -e LIVEKIT_URL=... ferni-agent
# ============================================================================

ARG NODE_VERSION=20

# ============================================================================
# Stage 1: Build TypeScript
# ============================================================================
FROM node:${NODE_VERSION}-slim AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev for building)
RUN npm ci

# Copy source files
COPY tsconfig.json ./
COPY tsconfig.build.json ./
COPY src/ ./src/

# Build TypeScript
RUN npm run build

# ============================================================================
# Stage 2: Production
# ============================================================================
FROM node:${NODE_VERSION}-slim AS production

WORKDIR /app

# Install system dependencies (including ffmpeg for DJ-style audio fade-out)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates

# Copy package files and install production dependencies
COPY package*.json ./
RUN npm ci --only=production

# Patch LiveKit agents library to increase initialization timeout
# The library has hardcoded 10s/30s timeouts that are too short for Cloud Run cold starts
RUN node -e " \
  const fs = require('fs'); \
  const path = require('path'); \
  const workerPath = path.join(__dirname, 'node_modules/@livekit/agents/dist/worker.js'); \
  if (!fs.existsSync(workerPath)) { console.log('worker.js not found, skipping patch'); process.exit(0); } \
  let content = fs.readFileSync(workerPath, 'utf8'); \
  const p1 = 'initializeTimeout: 3e4'; \
  const p1r = 'initializeTimeout: 3e5 /* PATCHED 5min */'; \
  const p2 = 'initializeProcessTimeout = 10 * 1e3'; \
  const p2r = 'initializeProcessTimeout = 300 * 1e3 /* PATCHED 5min */'; \
  if (content.includes(p1)) { content = content.replace(p1, p1r); console.log('Patched InferenceProcExecutor timeout'); } \
  if (content.includes(p2)) { content = content.replace(p2, p2r); console.log('Patched initializeProcessTimeout'); } \
  fs.writeFileSync(workerPath, content); \
  console.log('[patch-livekit-timeout] Patch complete'); \
"

# Copy built files from builder
COPY --from=builder /app/dist ./dist

# Copy persona bundles (JSON, MD files needed at runtime)
COPY --from=builder /app/src/personas/bundles/ ./dist/personas/bundles/

# Set environment variables
ENV NODE_ENV=production
ENV PERSONA_ID=ferni

# Node.js process optimizations for voice agent stability
# - max-old-space-size: Set heap limit to 3072MB (75% of 4GB container limit)
#   This gives headroom before OOM and allows GC to work effectively
# - max-semi-space-size: Increase young generation for voice processing (128MB)
# - expose-gc: Allow manual GC triggering if needed
ENV NODE_OPTIONS="--max-old-space-size=3072 --max-semi-space-size=128"

EXPOSE 8080

# Run the voice agent
CMD ["node", "dist/agent.js", "start"]

