# ============================================================================
# FERNI UI SERVER DOCKERFILE
# ============================================================================
# Multi-stage build for the main UI server.
# Includes: backend API, frontend app, engagement routes, etc.
#
# Build:
#   docker build -f docker/Dockerfile.ui -t ferni-ui .
#
# Run:
#   docker run -p 8080:8080 -e LIVEKIT_URL=... ferni-ui
# ============================================================================

ARG NODE_VERSION=20

# ============================================================================
# Stage 1: Build Backend TypeScript
# ============================================================================
FROM node:${NODE_VERSION}-slim AS backend-builder

# Install git for GitHub dependencies (ferni-speaker)
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
COPY tsconfig.json ./
COPY tsconfig.build.json ./

# CI=true skips husky install in prepare script
RUN CI=true npm ci

COPY src/ ./src/

RUN npm run build

# ============================================================================
# Stage 2: Build Frontend
# ============================================================================
FROM node:${NODE_VERSION}-slim AS frontend-builder

WORKDIR /app

# Copy design-system dist (needed for @design-system imports)
COPY design-system/dist ./design-system/dist/

# Copy frontend package files
COPY frontend-typescript/package*.json ./frontend-typescript/

WORKDIR /app/frontend-typescript

# CI=true skips husky install in prepare script
RUN CI=true npm ci

COPY frontend-typescript/ ./

RUN npm run build

# ============================================================================
# Stage 3: Build ferni-speaker native module
# ============================================================================
# Requires GITHUB_PAT build arg to clone private repo
ARG GITHUB_PAT=""

FROM rust:1.75-slim AS speaker-builder

ARG GITHUB_PAT

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    pkg-config \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js for NAPI build
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs

# Clone and build ferni-speaker (using PAT for auth)
# Falls back to DSP if clone fails (PAT may not have access)
RUN (if [ -n "$GITHUB_PAT" ]; then \
      echo "Cloning ferni-speaker with PAT..." && \
      git clone --depth 1 https://${GITHUB_PAT}@github.com/sethdford/ferni-speaker.git; \
    else \
      echo "No GITHUB_PAT, trying public clone..." && \
      git clone --depth 1 https://github.com/sethdford/ferni-speaker.git; \
    fi && \
    cd ferni-speaker && \
    rm -f Cargo.lock && \
    npm install --ignore-scripts && \
    npm run build) || (echo "ferni-speaker build failed, using DSP fallback" && mkdir -p ferni-speaker/models && touch ferni-speaker/placeholder)

# Export a basic model
RUN if [ -d "ferni-speaker/scripts" ]; then \
      cd ferni-speaker && \
      pip3 install torch onnx --break-system-packages 2>/dev/null && \
      python3 scripts/export-ecapa-tdnn.py 2>/dev/null || \
      python3 scripts/export-wespeaker.py 2>/dev/null || \
      echo "Model export skipped"; \
    fi

# ============================================================================
# Stage 4: Production Server
# ============================================================================
FROM node:${NODE_VERSION}-slim AS production

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Copy package files and install production dependencies
COPY package*.json ./
RUN npm ci --omit=dev

# Copy UI server
COPY ui-server.js ./

# Copy built backend (compiled TypeScript)
COPY --from=backend-builder /app/dist ./dist/

# NOTE: Do NOT copy src/api/ here - the .ts files would overwrite compiled .js files
# All API routes are already in dist/ from the backend-builder stage

# Copy persona bundles
COPY src/personas/bundles ./src/personas/bundles/

# Create frontend directory and copy built frontend
RUN mkdir -p frontend-typescript/dist
COPY --from=frontend-builder /app/frontend-typescript/dist ./frontend-typescript/dist/

# Copy ferni-speaker native module (if build succeeded)
# Using RUN with conditional copy since COPY doesn't support || true
RUN mkdir -p node_modules/ferni-speaker/models
COPY --from=speaker-builder /app/ferni-speaker/ /tmp/ferni-speaker/
RUN cp /tmp/ferni-speaker/*.node node_modules/ferni-speaker/ 2>/dev/null || echo "No .node files"
RUN cp /tmp/ferni-speaker/index.js node_modules/ferni-speaker/ 2>/dev/null || echo "No index.js"
RUN cp /tmp/ferni-speaker/index.d.ts node_modules/ferni-speaker/ 2>/dev/null || echo "No index.d.ts"
RUN cp -r /tmp/ferni-speaker/models/* node_modules/ferni-speaker/models/ 2>/dev/null || echo "No models"
RUN rm -rf /tmp/ferni-speaker

# Environment
ENV NODE_ENV=production
ENV PORT=8080
ENV SPEAKER_MODEL_PATH=/app/node_modules/ferni-speaker/models/ecapa_tdnn.onnx

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

CMD ["node", "ui-server.js"]

