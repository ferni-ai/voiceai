# syntax=docker/dockerfile:1.4
# ============================================================================
# FERNI UI SERVER DOCKERFILE (OPTIMIZED WITH PNPM)
# ============================================================================
# Multi-stage build for the main UI server.
# Includes: backend API, frontend app, engagement routes, etc.
#
# OPTIMIZATIONS:
# - pnpm for ~40% faster dependency installs
# - BuildKit 1.4 syntax enables parallel stage builds
# - Uses pre-built ferni-speaker image (avoids Rust build on every deploy)
# - Cache mounts for pnpm store
#
# Build:
#   docker build -f docker/Dockerfile.ui -t ferni-ui .
#
# Run:
#   docker run -p 8080:8080 -e LIVEKIT_URL=... ferni-ui
# ============================================================================

ARG NODE_VERSION=20
ARG PROJECT_ID=johnb-2025

# ============================================================================
# Stage 1: Build Backend TypeScript (with pnpm + esbuild)
# ============================================================================
FROM node:${NODE_VERSION}-slim AS backend-builder

# Install git and enable pnpm
RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy package files and configs
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml* ./
COPY .npmrc ./
COPY tsconfig.json ./
COPY tsconfig.build.json ./

# Copy patches directory (required by pnpm-lock.yaml)
COPY patches/ ./patches/

# Copy workspace package files
COPY apps/cli/package.json ./apps/cli/
COPY apps/web/package.json ./apps/web/
COPY apps/async/package.json ./apps/async/
COPY apps/intelligence-worker/package.json ./apps/intelligence-worker/
COPY packages/shared-types/package.json ./packages/shared-types/

# Create stub package.json for packages not in build context (rust packages, design-system)
RUN mkdir -p apps/rust-audio apps/rust-perf design-system && \
    echo '{"name":"@ferni/audio","version":"0.1.0"}' > apps/rust-audio/package.json && \
    echo '{"name":"@ferni/perf","version":"0.1.0"}' > apps/rust-perf/package.json && \
    echo '{"name":"@ferni/design-system","version":"1.0.0"}' > design-system/package.json

# Replace local file: dependencies with npm registry versions for Docker builds
RUN sed -i 's|"file:../agents-js/agents"|"^1.0.31"|g' package.json && \
    sed -i 's|"file:../agents-js/plugins/cartesia"|"^1.0.31"|g' package.json && \
    sed -i 's|"file:../agents-js/plugins/deepgram"|"^1.0.31"|g' package.json && \
    sed -i 's|"file:../agents-js/plugins/google"|"^1.0.31"|g' package.json && \
    sed -i 's|"file:../agents-js/plugins/openai"|"^1.0.31"|g' package.json && \
    sed -i 's|"file:../agents-js/plugins/silero"|"^1.0.31"|g' package.json

# Install dependencies with pnpm (no frozen lockfile since we modified package.json)
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --prefer-offline --no-frozen-lockfile

# Copy build script (now in apps/cli/) and source
COPY apps/cli/src/commands/build/build-fast.ts ./apps/cli/src/commands/build/
COPY src/ ./src/

# Build with esbuild (falls back to tsc)
# Note: build-fast.ts is now at apps/cli/src/commands/build/build-fast.ts
RUN npx tsx apps/cli/src/commands/build/build-fast.ts || pnpm build

# ============================================================================
# Stage 2: Build Frontend (runs in parallel with backend)
# Note: apps/web uses npm (not pnpm) with package-lock.json
# ============================================================================
FROM node:${NODE_VERSION}-slim AS frontend-builder

# Build arg for admin API key (passed from Cloud Build)
ARG VITE_ADMIN_API_KEY=""

WORKDIR /app

# Copy design-system dist (needed for @design-system imports)
COPY design-system/dist ./design-system/dist/

# Copy essential brand assets (logos, favicons) from design-system/assets/
# Note: These are included via gcloudignore exceptions
COPY design-system/assets/logos ./design-system/assets/logos/
COPY design-system/assets/favicons ./design-system/assets/favicons/

# Copy frontend package files (npm-based)
COPY apps/web/package.json apps/web/package-lock.json ./apps/web/

WORKDIR /app/apps/web

# Install with npm (frontend uses npm, not pnpm)
RUN --mount=type=cache,target=/root/.npm \
    npm ci --prefer-offline

COPY apps/web/ ./

# Create placeholder for symlinked brand directory (symlink points outside context)
# The symlink apps/web/public/design-system/brand -> ../../../../design-system/docs/brand
# won't work in Docker, so we create an empty directory
# Use rm -rf to handle both file and directory cases, avoiding cache conflicts
# Note: Using explicit date in echo to bust Kaniko cache layer
RUN rm -rf public/design-system/brand 2>/dev/null ; mkdir -p public/design-system/brand && echo "cache-bust-2026-01-03-v3" > /dev/null

# Set env var for Vite build (bakes into the bundle)
ENV VITE_ADMIN_API_KEY=${VITE_ADMIN_API_KEY}

RUN npm run build

# ============================================================================
# Stage 3: Pull pre-built ferni-speaker (instead of building Rust)
# ============================================================================
ARG PROJECT_ID
FROM gcr.io/${PROJECT_ID}/ferni-speaker:latest AS speaker-prebuilt

# ============================================================================
# Stage 4: Production Server
# ============================================================================
FROM node:${NODE_VERSION}-slim AS production

WORKDIR /app

# Install system dependencies and pnpm
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable && corepack prepare pnpm@latest --activate

# Copy package files from builder stage (has file: deps replaced with npm versions)
COPY --from=backend-builder /app/package.json ./
COPY --from=backend-builder /app/pnpm-lock.yaml* ./
COPY .npmrc ./
COPY pnpm-workspace.yaml ./

# Copy patches directory (required by pnpm-lock.yaml)
COPY patches/ ./patches/

# Copy workspace package stubs from builder
COPY --from=backend-builder /app/apps/rust-audio/package.json ./apps/rust-audio/
COPY --from=backend-builder /app/apps/rust-perf/package.json ./apps/rust-perf/
COPY --from=backend-builder /app/design-system/package.json ./design-system/
COPY --from=backend-builder /app/apps/cli/package.json ./apps/cli/
COPY --from=backend-builder /app/apps/web/package.json ./apps/web/
COPY --from=backend-builder /app/apps/async/package.json ./apps/async/
COPY --from=backend-builder /app/apps/intelligence-worker/package.json ./apps/intelligence-worker/
COPY --from=backend-builder /app/packages/shared-types/package.json ./packages/shared-types/

RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --prefer-offline --prod --no-frozen-lockfile && \
    # Remove unnecessary files from node_modules to reduce image size (~30% reduction)
    find node_modules -name "*.md" -delete 2>/dev/null || true && \
    find node_modules -name "*.map" -delete 2>/dev/null || true && \
    find node_modules -name "*.ts" ! -name "*.d.ts" -delete 2>/dev/null || true && \
    find node_modules -name "CHANGELOG*" -delete 2>/dev/null || true && \
    find node_modules -type d -name "test" -exec rm -rf {} + 2>/dev/null || true && \
    find node_modules -type d -name "tests" -exec rm -rf {} + 2>/dev/null || true && \
    find node_modules -type d -name "__tests__" -exec rm -rf {} + 2>/dev/null || true

# UI server is compiled from TypeScript (src/servers/api/index.ts → dist/servers/api/index.js)

# Copy built backend (compiled TypeScript)
COPY --from=backend-builder /app/dist ./dist/

# Copy persona bundles
COPY src/personas/bundles ./src/personas/bundles/

# Copy marketplace agents registry (for /api/marketplace/registry endpoint)
COPY apps/marketplace-agents/registry.json ./apps/marketplace-agents/registry.json

# Create frontend directory and copy built frontend
RUN mkdir -p apps/web/dist
COPY --from=frontend-builder /app/apps/web/dist ./apps/web/dist/

# Copy pre-built ferni-speaker (from the pre-built image)
RUN mkdir -p node_modules/ferni-speaker/models
COPY --from=speaker-prebuilt /speaker/ ./node_modules/ferni-speaker/

# Verify what we have
RUN echo "=== Final ferni-speaker contents ===" && ls -la node_modules/ferni-speaker/

# Environment
ENV NODE_ENV=production
ENV PORT=8080
ENV SPEAKER_MODEL_PATH=/app/node_modules/ferni-speaker/models/ecapa_tdnn.onnx

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

CMD ["node", "dist/servers/api/index.js"]
