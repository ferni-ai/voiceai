{
  "name": "ferni-speaker",
  "version": "0.1.0",
  "description": "High-performance speaker embedding extraction using ECAPA-TDNN in Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/sethdford/ferni-speaker.git"
  },
  "license": "MIT",
  "keywords": [
    "speaker",
    "embedding",
    "voice",
    "recognition",
    "verification",
    "ecapa-tdnn",
    "rust",
    "napi"
  ],
  "napi": {
    "name": "speaker",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node test/test.js",
    "postinstall": "node scripts/download-models.js",
    "universal": "napi universal",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "scripts/",
    "models/.gitkeep"
  ],
  "publishConfig": {
    "access": "public"
  }
}

