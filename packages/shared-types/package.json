{
  "name": "@ferni/shared-types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for Ferni services",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./intelligence": {
      "types": "./dist/intelligence.d.ts",
      "import": "./dist/intelligence.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

