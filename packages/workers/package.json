{
  "name": "@ferni/workers",
  "version": "0.1.0",
  "description": "Async worker platform for Ferni - outreach, scheduled jobs, background processing",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:fast": "npx esbuild src/*.ts src/**/*.ts --outdir=dist --format=esm --platform=node --target=node20",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@google-cloud/pubsub": "^4.10.0",
    "@google-cloud/tasks": "^6.2.1",
    "express": "5.2.1",
    "firebase-admin": "^13.6.0",
    "pino": "10.1.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "^20.19.25",
    "esbuild": "^0.27.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
