            <pre><code class="language-typescript">import { createPersonaBundle } from '@ferni/sdk';
import { habitCoachingTool } from '@ferni/tools/habit-coaching';
import { moodTrackingTool } from '@ferni/tools/mood-tracking';

export const myCoach = createPersonaBundle({
  id: 'my-coach',

  // Register tools this agent can use
  tools: [
    habitCoachingTool,
    moodTrackingTool
  ],

  // Tool usage preferences
  toolPreferences: {
    habitCoaching: {
      frequency: 'daily',
      style: 'encouraging'
    }
  }
});</code></pre>
