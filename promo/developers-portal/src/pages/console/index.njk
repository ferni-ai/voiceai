      <p style="color: var(--text-muted); font-size: var(--text-sm); margin-top: var(--space-8);">
        Don't have an account? <a href="#" style="color: var(--accent-text);">Sign up for free</a>
      </p>
    </div>
  </div>
</section>

<!-- Dashboard Preview (what authenticated users would see) -->
<section class="section" style="background: var(--bg-secondary); padding-top: var(--space-16);">
