/* ═══════════════════════════════════════════════════════════════════════════
   GARDEN PAGE - Complete Redesign
   Inspiring visual storytelling with the garden metaphor
   ═══════════════════════════════════════════════════════════════════════════ */

/* ===== HERO ===== */
.garden-hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
  padding: 120px var(--space-6) 80px;
}

.garden-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.garden-hero__gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(74, 103, 65, 0.08) 0%,
    transparent 40%,
    transparent 60%,
    rgba(74, 103, 65, 0.05) 100%
  );
}

/* Floating seed particles */
.garden-hero__seeds {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.garden-hero__seed {
  position: absolute;
  width: 8px;
  height: 12px;
  background: var(--color-ferni);
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  opacity: 0.15;
  animation: seedFloat 20s ease-in-out infinite;
}

.garden-hero__seed--1 { left: 10%; top: 20%; animation-delay: 0s; }
.garden-hero__seed--2 { left: 85%; top: 30%; animation-delay: -4s; }
.garden-hero__seed--3 { left: 25%; top: 70%; animation-delay: -8s; }
.garden-hero__seed--4 { left: 70%; top: 60%; animation-delay: -12s; }
.garden-hero__seed--5 { left: 50%; top: 15%; animation-delay: -16s; }

@keyframes seedFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.15; }
  25% { transform: translateY(-30px) rotate(10deg); opacity: 0.25; }
  50% { transform: translateY(-10px) rotate(-5deg); opacity: 0.2; }
  75% { transform: translateY(-40px) rotate(15deg); opacity: 0.15; }
}

.garden-hero__content {
  position: relative;
  z-index: 1;
  max-width: 800px;
}

.garden-hero__eyebrow {
  font-family: var(--font-display);
  font-size: 0.8rem;
  font-weight: var(--font-weight-bold);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--color-ferni);
  margin-bottom: var(--space-6);
  opacity: 0;
  animation: fadeUp 1s ease-out 0.2s forwards;
}

.garden-hero__headline {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 8vw, 5rem);
  font-weight: var(--font-weight-bold);
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--color-text-primary);
  margin-bottom: var(--space-8);
  opacity: 0;
  animation: fadeUp 1s ease-out 0.3s forwards;
}

.garden-hero__strike {
  text-decoration: line-through;
  color: var(--color-text-muted);
  opacity: 0.6;
}

.garden-hero__accent {
  color: var(--color-ferni);
}

.garden-hero__subhead {
  font-family: var(--font-body);
  font-size: clamp(1.125rem, 2.5vw, 1.5rem);
  line-height: 1.6;
  color: var(--color-text-secondary);
  opacity: 0;
  animation: fadeUp 1s ease-out 0.4s forwards;
}

.garden-hero__scroll {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  font-size: 0.8rem;
  color: var(--color-text-muted);
  opacity: 0;
  animation: fadeIn 1s ease 1.5s forwards;
}

.garden-hero__scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--color-ferni), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { transform: scaleY(1); opacity: 0.5; }
  50% { transform: scaleY(1.2); opacity: 1; }
}

/* ===== CONTRAST SECTION ===== */
.garden-contrast {
  padding: clamp(80px, 15vh, 140px) var(--space-6);
  background: var(--color-bg-primary);
}

.garden-contrast .container {
  display: grid;
  gap: var(--space-8);
