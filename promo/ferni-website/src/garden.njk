/* ===== METAPHOR SECTION ===== */
.garden-metaphor {
  padding: clamp(80px, 15vh, 140px) var(--space-6);
  background: linear-gradient(180deg, var(--color-bg-elevated) 0%, var(--color-bg-primary) 100%);
