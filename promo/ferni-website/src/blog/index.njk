---
layout: layouts/page.njk
title: Blog
description: Insights on AI coaching, personal growth, and building better habits
permalink: /blog/
---

<section class="blog-hero">
  <div class="container">
    <div class="blog-hero__content">
      <span class="eyebrow">The Ferni Blog</span>
      <h1 class="headline-xl">Thoughts on growth.</h1>
      <p class="body-lg">Insights on AI coaching, personal development, and building a life you love.</p>
    </div>
  </div>
</section>

<section class="blog-posts">
  <div class="container">
    {# Featured Post #}
    {% set featuredPost = collections.posts | reverse | first %}
    {% if featuredPost %}
    <article class="blog-card blog-card--featured reveal">
      {% if featuredPost.data.image %}
      <div class="blog-card__image">
        <img src="/images/blog/{{ featuredPost.data.image }}" alt="{{ featuredPost.data.imageAlt or featuredPost.data.title }}" loading="lazy">
      </div>
      {% endif %}
      <div class="blog-card__content">
        {% if featuredPost.data.category %}
        <span class="blog-card__category">{{ featuredPost.data.category }}</span>
        {% endif %}
        <h2 class="blog-card__title">
          <a href="{{ featuredPost.url }}">{{ featuredPost.data.title }}</a>
        </h2>
        <p class="blog-card__excerpt">{{ featuredPost.data.excerpt }}</p>
        <div class="blog-card__meta">
          <span class="blog-card__author">{{ featuredPost.data.author or 'Ferni Team' }}</span>
          <span class="blog-card__date">{{ featuredPost.date | date("MMMM d, yyyy") }}</span>
        </div>
      </div>
    </article>
    {% endif %}
    
    {# Post Grid #}
    <div class="blog-grid">
      {% for post in collections.posts | reverse %}
      {% if loop.index > 1 %}
      <article class="blog-card reveal reveal-delay-{{ loop.index % 3 }}">
        {% if post.data.image %}
        <div class="blog-card__image">
          <img src="/images/blog/{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy">
        </div>
        {% endif %}
        <div class="blog-card__content">
          {% if post.data.category %}
          <span class="blog-card__category">{{ post.data.category }}</span>
          {% endif %}
          <h3 class="blog-card__title">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h3>
          <p class="blog-card__excerpt">{{ post.data.excerpt }}</p>
          <div class="blog-card__meta">
            <span class="blog-card__date">{{ post.date | date("MMM d, yyyy") }}</span>
            {% if post.data.readTime %}
            <span class="blog-card__read-time">{{ post.data.readTime }} min</span>
            {% endif %}
          </div>
        </div>
      </article>
      {% endif %}
      {% endfor %}
    </div>
    
    {% if collections.posts.length == 0 %}
    <div class="blog-empty">
      <p>No posts yet. Check back soon!</p>
    </div>
    {% endif %}
  </div>
</section>

{# Newsletter CTA #}
<section class="blog-newsletter">
  <div class="container container-narrow">
    <div class="blog-newsletter__card">
      <h3>Stay in the loop</h3>
      <p>Get new articles and Ferni updates delivered to your inbox.</p>
      <form class="blog-newsletter__form" action="https://ferni.us11.list-manage.com/subscribe/post?u=52ffacbad9b81de1f66ebac7c&amp;id=dd755645d6&amp;f_id=00b2c7e3f0" method="POST" target="_blank">
        <input type="email" name="EMAIL" placeholder="your@email.com" required>
        <div aria-hidden="true" style="position: absolute; left: -5000px">
          <input type="text" name="b_52ffacbad9b81de1f66ebac7c_dd755645d6" tabindex="-1" value="">
        </div>
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
    </div>
  </div>
</section>

