<main class="story-page faq-page">

  {# Hero #}
  <section class="story-page__hero" style="min-height: 40vh;">
    <div class="container container--narrow">
      <p class="story-page__eyebrow">FAQ</p>
      <h1 class="story-page__headline">Questions.<br>Answers.</h1>
    </div>
