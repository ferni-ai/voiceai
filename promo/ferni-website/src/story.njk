</section>

{# ============================================
   FOOTER
   ============================================ #}
<footer class="footer">
  <div class="footer__inner">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <span class="nav__logo-mark">FN</span>
          Ferni
        </a>
        <p class="footer__tagline">
          The AI that actually listens. Six specialists, one conversation, infinite memory.
        </p>
      </div>
      
      <div>
        <h4 class="footer__column-title">Product</h4>
        <ul class="footer__links">
          {% for link in site.navigation.footer.product %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div>
        <h4 class="footer__column-title">Company</h4>
        <ul class="footer__links">
          {% for link in site.navigation.footer.company %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div>
        <h4 class="footer__column-title">Connect</h4>
        <ul class="footer__links">
          {% for link in site.navigation.footer.connect %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    
    <div class="footer__bottom">
      <p>&copy; {{ 2024 }} Ferni. All rights reserved.</p>
      <div class="footer__legal">
        {% for link in site.navigation.footer.legal %}
        <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

{# Nav scroll effect #}
<script>
(function() {
  const nav = document.getElementById('nav');
  let lastScroll = 0;
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll > 50) {
      nav.classList.add('is-scrolled');
    } else {
      nav.classList.remove('is-scrolled');
    }
    
    lastScroll = currentScroll;
  });
})();
</script>

