  {# Page Loader #}
  {% include "partials/home/page-loader.njk" %}
  
  {# Navigation #}
  {% include "partials/home/nav.njk" %}
  
  {# Hero Section with Video Background #}
  {% include "partials/home/hero.njk" %}
  
  {# Stats Section #}
  {% include "partials/home/stats.njk" %}
  
  {# AI Company Section #}
  {% include "partials/home/ai-company.njk" %}
  
  {# Features Section #}
  {% include "partials/home/features.njk" %}
  
  {# Testimonials Section #}
  {% include "partials/home/testimonials.njk" %}
  
  {# Demo Section #}
