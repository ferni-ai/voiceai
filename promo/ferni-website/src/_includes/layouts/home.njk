<!DOCTYPE html>
<html lang="en">
<head>
  {% include "partials/head.njk" %}
  
  {# Homepage-specific styles #}
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/living-avatar.css">
  <link rel="stylesheet" href="/css/cookie-banner.css">
  
  {# Structured data for SEO #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "{{ site.name }}",
    "applicationCategory": "LifestyleApplication",
    "operatingSystem": "Web",
    "description": "{{ description or site.tagline }}",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "127" }
  }
  </script>
</head>
<body>
  {# Living Avatar Intro Overlay #}
  {% include "partials/home/living-avatar-overlay.njk" %}
  
