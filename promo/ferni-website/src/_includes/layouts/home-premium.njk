<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  
  {# Preconnect for fonts #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  {# Fonts - Apple-quality rendering #}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
  
  {# Favicon #}
  <link rel="icon" href="/images/logo.svg" type="image/svg+xml">
  
  {# Styles #}
  <style>
    /* Critical CSS inline for performance */
    :root {
      --font-display: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
      --color-ferni: #4a6741;
      --color-ferni-secondary: #3d5a35;
      --space-1: 0.25rem;
      --space-2: 0.5rem;
      --space-3: 0.75rem;
      --space-4: 1rem;
      --space-6: 1.5rem;
      --space-8: 2rem;
      --space-12: 3rem;
      --space-16: 4rem;
      --space-24: 6rem;
      --space-32: 8rem;
      --ease-ease-out: cubic-bezier(0, 0, 0.2, 1);
    }
    
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    a { text-decoration: none; color: inherit; }
    
    html {
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }
    
    body {
      font-family: var(--font-body);
      background: #FAFAF8;
      color: #1D1D1F;
      line-height: 1.5;
    }
    
    /* Prevent FOUC */
    .hero-premium { opacity: 0; animation: heroReveal 0.5s ease 0.1s forwards; }
    @keyframes heroReveal { to { opacity: 1; } }
  </style>
  
  <link rel="stylesheet" href="/css/sections/hero-premium.css">
  
  {# OG Tags #}
  <meta property="og:title" content="{{ title }} | {{ site.name }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:image" content="{{ site.url }}/images/og-image.jpg">
  <meta property="og:url" content="{{ site.url }}">
  <meta name="twitter:card" content="summary_large_image">
</head>
<body>
  {# Premium Hero #}
  {% include "partials/home/hero-premium.njk" %}
  
  <main id="main-content">
    {{ content | safe }}
  </main>
</body>
</html>

