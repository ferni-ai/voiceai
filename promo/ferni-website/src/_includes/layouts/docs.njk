---
layout: layouts/base.njk
isDocs: true
badge: Developers
---

<div class="container container-narrow">
  <div class="doc-header">
    <h1>{{ title }}</h1>
    {% if description %}
    <p>{{ description }}</p>
    {% endif %}
  </div>

  <div class="doc-content">
    {{ content | safe }}

    {# Previous/Next navigation #}
    {% set allDocs = collections.docs %}
    {% set currentIndex = -1 %}
    {% for doc in allDocs %}
      {% if doc.url == page.url %}
        {% set currentIndex = loop.index0 %}
      {% endif %}
    {% endfor %}
    
    {% if currentIndex >= 0 %}
    <div class="doc-nav-buttons">
      {% if currentIndex > 0 %}
        {% set prevDoc = allDocs[currentIndex - 1] %}
        <a href="{{ prevDoc.url }}" class="doc-nav-btn">
          <span class="doc-nav-label">← Previous</span>
          <span class="doc-nav-title">{{ prevDoc.data.title }}</span>
        </a>
      {% else %}
        <a href="/developers/" class="doc-nav-btn">
          <span class="doc-nav-label">← Previous</span>
          <span class="doc-nav-title">Documentation Home</span>
        </a>
      {% endif %}
      
      {% if currentIndex < allDocs.length - 1 %}
        {% set nextDoc = allDocs[currentIndex + 1] %}
        <a href="{{ nextDoc.url }}" class="doc-nav-btn next">
          <span class="doc-nav-label">Next →</span>
          <span class="doc-nav-title">{{ nextDoc.data.title }}</span>
        </a>
      {% else %}
        <a href="/developers/" class="doc-nav-btn next">
          <span class="doc-nav-label">Next →</span>
          <span class="doc-nav-title">Documentation Home</span>
        </a>
      {% endif %}
    </div>
    {% endif %}
  </div>
</div>

