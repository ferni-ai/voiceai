<!DOCTYPE html>
<html lang="en">
<head>
  {% include "partials/head.njk" %}
  
  {# Page-specific styles #}
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/pages.css">
  {% if pageStyles %}
  {% for style in pageStyles %}
  <link rel="stylesheet" href="/css/{{ style }}">
  {% endfor %}
  {% endif %}
  
  {# Page-specific structured data #}
  {% if structuredData %}
  <script type="application/ld+json">
  {{ structuredData | safe }}
  </script>
  {% endif %}
</head>
<body class="{{ bodyClass or '' }}">
  {# Skip Link #}
  <a href="#main" class="skip-link">Skip to main content</a>
  
  {# Navigation #}
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav-container">
      <div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="{{ site.name }}">{{ site.name }}</a>
        <ul class="nav-links">
          {% for item in site.navigation.main %}
          <li><a href="{{ item.url }}" class="nav-link{% if page.url == item.url %} active{% endif %}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
        <div class="nav-actions">
          <a href="{{ site.appUrl }}?utm_source=ferni_website&utm_medium=web&utm_campaign={{ page.fileSlug or 'page' }}" class="btn btn-primary nav-cta">Get Started</a>
          <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </div>
    
    {# Mobile Menu #}
    <div class="mobile-menu" id="mobileMenu">
      <div class="mobile-menu-inner">
        {% for item in site.navigation.mobile %}
        <a href="{{ item.url }}" class="mobile-link">{{ item.title }}</a>
        {% endfor %}
        <div class="mobile-menu-cta">
          <a href="{{ site.appUrl }}?utm_source=ferni_website&utm_medium=web&utm_campaign={{ page.fileSlug or 'page' }}" class="btn btn-primary">Get Started Free</a>
          <a href="tel:{{ site.phoneRaw }}" class="btn btn-ghost">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call {{ site.phone }}
          </a>
        </div>
      </div>
    </div>
  </nav>
  
  {# Main Content #}
  <main id="main">
    {{ content | safe }}
  </main>
  
  {# Footer #}
  {% include "partials/footer.njk" %}
  
  {# Cookie Banner #}
  {% include "cookie-banner.njk" %}
  
  {# Scripts #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
