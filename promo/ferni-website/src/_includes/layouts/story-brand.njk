<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Ferni</title>
  <meta name="description" content="{{ description or site.tagline }}">
  
  {# ====== PRECONNECT & PRELOAD (Performance) ====== #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://www.googletagmanager.com">
  
  {# Preload critical fonts #}
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&display=swap" as="style">
  
  {# ====== FONTS ====== #}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  
  {# ====== FAVICONS ====== #}
  <link rel="icon" href="/images/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#4a6741">
  
  {# ====== STYLES ====== #}
  <link rel="stylesheet" href="/css/story-brand.css">
  <link rel="stylesheet" href="/css/landing-intelligence.css">
  
  {# ====== OPEN GRAPH ====== #}
  <meta property="og:title" content="{{ title }} | Ferni">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:image" content="https://ferni.ai/images/og-image.jpg">
  <meta property="og:url" content="https://ferni.ai{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Ferni">
  <meta property="og:locale" content="en_US">
  
  {# ====== TWITTER CARD ====== #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@ferniAI">
  <meta name="twitter:creator" content="@ferniAI">
  <meta name="twitter:title" content="{{ title }} | Ferni">
  <meta name="twitter:description" content="{{ description or site.tagline }}">
  <meta name="twitter:image" content="https://ferni.ai/images/og-image.jpg">
  
  {# ====== ADDITIONAL SEO ====== #}
  <link rel="canonical" href="https://ferni.ai{{ page.url }}">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Ferni">
  
  {# ====== JSON-LD STRUCTURED DATA ====== #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://ferni.ai/#organization",
        "name": "Ferni",
        "url": "https://ferni.ai",
        "logo": {
          "@type": "ImageObject",
          "url": "https://ferni.ai/images/ferni-logo.png",
          "width": 512,
          "height": 512
        },
        "description": "{{ site.tagline }}",
        "sameAs": [
          "{{ site.social.twitter }}"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "{{ site.phone }}",
          "contactType": "customer service",
          "availableLanguage": "English"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://ferni.ai/#website",
        "url": "https://ferni.ai",
        "name": "Ferni",
        "publisher": {
          "@id": "https://ferni.ai/#organization"
        }
      },
      {
        "@type": "SoftwareApplication",
        "@id": "https://ferni.ai/#product",
        "name": "Ferni AI Life Coach",
        "applicationCategory": "HealthApplication",
        "operatingSystem": "Web, iOS, Android",
        "offers": [
          {
            "@type": "Offer",
            "name": "Free",
            "price": "0",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "name": "Friend",
            "price": "9.99",
            "priceCurrency": "USD",
            "billingIncrement": "P1M"
          },
          {
            "@type": "Offer",
            "name": "Partner",
            "price": "19.99",
            "priceCurrency": "USD",
            "billingIncrement": "P1M"
          }
        ],
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "ratingCount": "1247",
          "bestRating": "5"
        },
        "description": "Six AI specialists who actually listen, remember everything, and help you grow. Available 24/7 via voice, text, or app."
      },
      {
        "@type": "FAQPage",
        "@id": "https://ferni.ai/#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is Ferni a replacement for therapy?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Ferni is a life coaching companion, not a licensed therapist. We're great for day-to-day support, goal-setting, habit building, and talking through decisions."
            }
          },
          {
            "@type": "Question",
            "name": "How does the phone call feature work?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Just call {{ site.phone }} from any phone—no app needed. Your conversation is linked to your phone number, so Ferni remembers you."
            }
          },
          {
            "@type": "Question",
            "name": "What does infinite memory mean?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Unlike other AI, Ferni remembers every conversation you've had. This creates continuity—like talking to a friend who actually knows your story."
            }
          },
          {
            "@type": "Question",
            "name": "Is my data private and secure?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. Your conversations are encrypted and never sold or shared. You can export or delete your data anytime."
            }
          }
        ]
      }
    ]
  }
  </script>
  
  {# ====== ANALYTICS ====== #}
  {% if site.analytics.gaId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.gaId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analytics.gaId }}', {
      page_title: '{{ title }}',
      page_path: '{{ page.url }}'
    });
  </script>
  {% endif %}
</head>
<body>
  {{ content | safe }}
  
  {# ====== COOKIE CONSENT BANNER ====== #}
  <div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Cookie consent">
    <div class="cookie-banner__content">
      <p>We use cookies to improve your experience. <a href="/cookies/">Learn more</a></p>
      <div class="cookie-banner__actions">
        <button class="btn btn--ghost btn--sm" onclick="handleCookies(false)">Decline</button>
        <button class="btn btn--primary btn--sm" onclick="handleCookies(true)">Accept</button>
      </div>
    </div>
  </div>
  
  {# ====== ANIMATION SYSTEM ====== #}
  <script src="/js/landing-animations.js"></script>

  {# ====== FERNI CHARACTER & POLISH ====== #}
  <script src="/js/ferni-character.js"></script>
  
  {# ====== FERNI AWAKENING SEQUENCE (Cinematic Intro) ====== #}
  <script src="/js/ferni-awakens.js"></script>
  
  {# ====== FERNI EQ SYSTEM (Superhuman Emotional Intelligence) ====== #}
  <script src="/js/better-than-human.js"></script>
  {# ferni-sentience.js removed - was creating floating "soft nudge" boxes #}
  <script src="/js/ferni-sounds.js"></script>
  
  {# ====== DEMO WIDGET DISABLED - user complained about floating box #}
  {# <script src="/js/demo-widget.js"></script> #}
  
  {# ====== A/B TESTING & EXPERIMENTS ====== #}
  <script src="/js/experiments.js"></script>
  <script src="/js/experiment-variants.js"></script>
  <script src="/js/conversion-tracking.js"></script>
  
  {# ====== LANDING INTELLIGENCE (Gemini-powered optimization) ====== #}
  <script src="/js/behavior-tracker.js"></script>
  {# chat-widget.js removed - using demo-widget.js instead #}
  <script src="/js/landing-intelligence.js"></script>
  <script src="/js/superpowers-demo.js"></script>
  
  <script>
  (function() {
    'use strict';
    
    // ========== SCROLL REVEAL ==========
    const revealElements = document.querySelectorAll('.reveal, .reveal-stagger');
    
    // Immediately show elements in viewport
    const showIfVisible = (el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        el.classList.add('is-visible');
      }
    };
    
    // Show initially visible elements immediately
    revealElements.forEach(showIfVisible);
    
    // Observer for scroll reveal
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { 
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    revealElements.forEach(el => revealObserver.observe(el));
    
    // ========== NAV SCROLL EFFECT ==========
    const nav = document.getElementById('nav');
    const scrollIndicator = document.querySelector('.scroll-indicator');
    
    if (nav) {
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY > 50;
        nav.classList.toggle('is-scrolled', scrolled);
        if (scrollIndicator) {
          scrollIndicator.style.opacity = scrolled ? '0' : '1';
        }
      }, { passive: true });
    }
    
    // ========== MOBILE MENU ==========
    const mobileToggle = document.getElementById('mobileMenuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileClose = document.querySelector('.mobile-menu__close');
    
    if (mobileToggle && mobileMenu) {
      mobileToggle.addEventListener('click', () => {
        mobileMenu.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      });
      
      if (mobileClose) {
        mobileClose.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      }
      
      // Close on link click
      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      });
    }
    
    // ========== MOBILE CTA VISIBILITY ==========
    const mobileCta = document.getElementById('mobileCta');
    const hero = document.querySelector('.hero');
    const footer = document.querySelector('.footer');
    
    if (mobileCta && hero) {
      const ctaObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.target === hero) {
            mobileCta.classList.toggle('is-visible', !entry.isIntersecting);
          }
          if (entry.target === footer && entry.isIntersecting) {
            mobileCta.classList.remove('is-visible');
          }
        });
      }, { threshold: 0 });
      
      ctaObserver.observe(hero);
      if (footer) ctaObserver.observe(footer);
    }
    
    // ========== SMOOTH SCROLL ==========
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href === '#') return;
        
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
          
          // Update active nav link
          document.querySelectorAll('.nav__link').forEach(link => {
            link.classList.toggle('is-active', link.getAttribute('href') === href);
          });
        }
      });
    });
    
    // ========== FAQ ACCORDION ==========
    document.querySelectorAll('.faq-item').forEach(item => {
      const summary = item.querySelector('summary');
      if (summary) {
        summary.addEventListener('click', () => {
          // Close others
          document.querySelectorAll('.faq-item[open]').forEach(openItem => {
            if (openItem !== item) openItem.removeAttribute('open');
          });
        });
      }
    });
    
    // ========== COOKIE CONSENT ==========
    window.handleCookies = function(accepted) {
      localStorage.setItem('ferni_cookies', accepted ? 'accepted' : 'declined');
      document.getElementById('cookieBanner').classList.add('is-hidden');
      
      if (accepted && typeof gtag === 'function') {
        gtag('consent', 'update', {
          'analytics_storage': 'granted'
        });
      }
    };
    
    // Show banner if not decided
    const cookieChoice = localStorage.getItem('ferni_cookies');
    if (!cookieChoice) {
      setTimeout(() => {
        document.getElementById('cookieBanner').classList.add('is-visible');
      }, 2000);
    }
    
    // ========== ANALYTICS EVENTS ==========
    function trackEvent(category, action, label) {
      if (typeof gtag === 'function') {
        gtag('event', action, {
          'event_category': category,
          'event_label': label
        });
      }
    }
    
    // Track CTA clicks
    document.querySelectorAll('.btn--primary').forEach(btn => {
      btn.addEventListener('click', () => {
        trackEvent('CTA', 'click', btn.textContent.trim());
      });
    });
    
    // Track phone clicks
    document.querySelectorAll('a[href^="tel:"]').forEach(link => {
      link.addEventListener('click', () => {
        trackEvent('Contact', 'phone_click', 'Call Ferni');
      });
    });
    
    // ========== INLINE TRY FERNI DEMO ==========
    const tryFerniBtn = document.getElementById('tryFerniBtn');
    const tryFerniDemo = document.getElementById('tryFerniDemo');
    
    if (tryFerniBtn && tryFerniDemo) {
      tryFerniBtn.addEventListener('click', () => {
        // Track the demo click
        trackEvent('Demo', 'inline_try_click', 'Hero');
        
        // Create inline demo panel if it doesn't exist
        let demoPanel = document.getElementById('heroDemoPanel');
        if (!demoPanel) {
          demoPanel = document.createElement('div');
          demoPanel.id = 'heroDemoPanel';
          demoPanel.className = 'hero__demo-panel';
          demoPanel.innerHTML = `
            <div class="hero__demo-avatar" id="demoAvatar">FE</div>
            <p class="hero__demo-status" id="demoStatus">Click below to start talking</p>
            <div class="hero__demo-action">
              <button class="btn btn--primary" id="demoStartBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                  <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                </svg>
                Start Talking
              </button>
              <button class="btn btn--secondary" id="demoCloseBtn">Maybe Later</button>
            </div>
            <p style="margin-top: var(--space-4); font-size: 13px; color: var(--color-text-muted); text-align: center;">
              Or <a href="tel:+14844813081" style="color: var(--color-ferni-green); text-decoration: underline;">call (484) 481-3081</a> directly
            </p>
          `;
          tryFerniDemo.appendChild(demoPanel);
          
          // Handle close
          document.getElementById('demoCloseBtn').addEventListener('click', () => {
            demoPanel.classList.remove('is-open');
            tryFerniBtn.style.display = '';
          });
          
          // Handle start - redirect to app with demo mode
          document.getElementById('demoStartBtn').addEventListener('click', async () => {
            const avatar = document.getElementById('demoAvatar');
            const status = document.getElementById('demoStatus');
            const startBtn = document.getElementById('demoStartBtn');
            
            avatar.classList.add('listening');
            status.textContent = 'Connecting to Ferni...';
            startBtn.disabled = true;
            startBtn.innerHTML = '<span class="loading-dots">...</span> Connecting';
            
            trackEvent('Demo', 'start_click', 'Hero');
            
            // Small delay for effect, then redirect to app
            setTimeout(() => {
              window.location.href = 'https://app.ferni.ai?demo=true&source=landing';
            }, 800);
          });
        }
        
        // Show panel, hide button
        demoPanel.classList.add('is-open');
        tryFerniBtn.style.display = 'none';
      });
    }
    
    // ========== CURSOR-AWARE AVATAR ==========
    // Make Ferni's orb subtly "look at" the cursor
    const heroOrb = document.querySelector('.hero-ferni__orb');
    if (heroOrb && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.addEventListener('mousemove', (e) => {
        const rect = heroOrb.getBoundingClientRect();
        const orbCenterX = rect.left + rect.width / 2;
        const orbCenterY = rect.top + rect.height / 2;
        
        // Calculate offset (subtle - max 3px)
        const deltaX = (e.clientX - orbCenterX) / window.innerWidth * 3;
        const deltaY = (e.clientY - orbCenterY) / window.innerHeight * 3;
        
        heroOrb.style.transform = `translate(${deltaX}px, ${deltaY}px)`;
      }, { passive: true });
    }
    
  })();
  </script>
</body>
</html>
