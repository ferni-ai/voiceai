---
layout: layouts/base.njk
---

{% include "partials/home/nav.njk" %}

<article class="blog-post">
  <header class="blog-post__header">
    <div class="container container-narrow">
      <a href="/blog/" class="blog-post__back">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to Blog
      </a>
      
      {% if category %}
      <span class="blog-post__category">{{ category }}</span>
      {% endif %}
      
      <h1 class="blog-post__title">{{ title }}</h1>
      
      <div class="blog-post__meta">
        {% if author %}
        <div class="blog-post__author">
          <div class="blog-post__author-avatar" style="background: {{ authorColor or 'var(--color-ferni)' }}">
            {{ authorInitials or 'FN' }}
          </div>
          <div class="blog-post__author-info">
            <span class="blog-post__author-name">{{ author }}</span>
            <span class="blog-post__date">{{ date | date("MMMM d, yyyy") }}</span>
          </div>
        </div>
        {% endif %}
        
        {% if readTime %}
        <span class="blog-post__read-time">{{ readTime }} min read</span>
        {% endif %}
      </div>
    </div>
  </header>
  
  {% if image %}
  <div class="blog-post__hero">
    <div class="container">
      <img src="/images/blog/{{ image }}" alt="{{ imageAlt or title }}" class="blog-post__hero-image" loading="lazy">
    </div>
  </div>
  {% endif %}
  
  <div class="blog-post__content">
    <div class="container container-narrow">
      {{ content | safe }}
    </div>
  </div>
  
  <footer class="blog-post__footer">
    <div class="container container-narrow">
      <div class="blog-post__share">
        <span class="blog-post__share-label">Share this article</span>
        <div class="blog-post__share-buttons">
          <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url }}" 
             target="_blank" rel="noopener" class="blog-post__share-btn" aria-label="Share on Twitter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url }}" 
             target="_blank" rel="noopener" class="blog-post__share-btn" aria-label="Share on LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="blog-post__cta">
        <h3>Ready to try Ferni?</h3>
        <p>Start a conversation with your AI life coach today. It's free.</p>
        <a href="{{ site.appUrl }}?utm_source=blog&utm_medium=web&utm_campaign={{ page.fileSlug }}" class="btn btn-primary">Start Free</a>
      </div>
    </div>
  </footer>
</article>

{% include "partials/home/footer.njk" %}
{% include "cookie-banner.njk" %}

<script src="/js/main.js"></script>

