<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  
  {# Preconnect #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  {# Fonts #}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  
  {# Favicon #}
  <link rel="icon" href="/images/logo.svg" type="image/svg+xml">
  
  {# Styles #}
  <link rel="stylesheet" href="/css/story-premium.css">
  
  {# OG Tags #}
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}">
  <meta property="og:image" content="{{ site.url }}/images/og-image.jpg">
  <meta name="twitter:card" content="summary_large_image">
  
  {# Theme Color #}
  <meta name="theme-color" content="#4A7C59">
</head>
<body>
  {{ content | safe }}
</body>
</html>

