<section class="team" id="team">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Meet Your Team</p>
      <h2 class="headline-lg">Six specialists.<br>One conversation.</h2>
    </div>

    <div class="team-carousel">
      <div class="team-track">
        {% for member in site.team %}
        <div class="team-card reveal{% if loop.index > 1 %} reveal-delay-{{ (loop.index - 1) % 3 }}{% endif %}" style="--team-color: {{ member.color }}">
          <div class="team-avatar"><span>{{ member.initials }}</span></div>
          <h3 class="team-name">{{ member.name }}</h3>
          <p class="team-role">{{ member.role }}</p>
          <p class="team-bio">{{ member.bio }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
