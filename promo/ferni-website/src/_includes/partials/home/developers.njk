<section class="developers" id="developers">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">For Developers</span>
      <h2 class="headline-lg">Build on Ferni.</h2>
      <p class="section-description">
        Create your own conversational AI personas. Access our marketplace. Join the future of voice-first experiences.
      </p>
    </div>

    <div class="developers-grid">
      <div class="developer-card developer-card--featured reveal">
        <div class="developer-card__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3 class="developer-card__title">Persona Marketplace</h3>
        <p class="developer-card__description">
          Discover and deploy specialized AI personas built by our community. From industry experts to creative companions.
        </p>
        <span class="developer-card__badge">Coming Soon</span>
      </div>

      <div class="developer-card reveal reveal-delay-1">
        <div class="developer-card__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3 class="developer-card__title">Developer Portal</h3>
        <p class="developer-card__description">
          Full API access, SDKs, and documentation. Build custom personas with our voice-first AI platform.
        </p>
        <a href="#developer-waitlist" class="developer-card__link">Request Early Access →</a>
      </div>

      <div class="developer-card reveal reveal-delay-2">
        <div class="developer-card__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="developer-card__title">Create Your Persona</h3>
        <p class="developer-card__description">
          Design unique AI personalities with custom knowledge, voice, and behavior. Publish to the marketplace or keep private.
        </p>
        <a href="#developer-waitlist" class="developer-card__link">Join Waitlist →</a>
      </div>
    </div>

    <div class="developer-cta reveal" id="developer-waitlist">
      <div class="developer-cta__content">
        <h3 class="developer-cta__title">Early Access Program</h3>
        <p class="developer-cta__description">
          Be among the first to build on the Ferni platform. Get priority API access, direct support from our team, and shape the future of conversational AI.
        </p>
        <form class="developer-cta__form" id="developerForm" action="https://ferni.us11.list-manage.com/subscribe/post?u=52ffacbad9b81de1f66ebac7c&amp;id=dd755645d6&amp;f_id=00b2c7e3f0" method="POST" target="_blank">
          <input type="email" name="EMAIL" placeholder="developer@company.com" class="developer-cta__input" required>
          <input type="hidden" name="SIGNUP_TYPE" value="developer">
          {# Mailchimp bot protection #}
          <div aria-hidden="true" style="position: absolute; left: -5000px">
            <input type="text" name="b_52ffacbad9b81de1f66ebac7c_dd755645d6" tabindex="-1" value="">
          </div>
          <button type="submit" class="developer-cta__button">
            Request Access
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        </form>
        <p class="developer-cta__note" id="developerNote">Limited spots available. We'll review applications weekly.</p>
        <p class="developer-cta__success" id="developerSuccess" style="display: none; color: var(--color-ferni)">Thanks! We'll be in touch soon.</p>
      </div>
    </div>
  </div>
</section>
