<section class="features" id="features">
  <div class="container">
    {# Hero Feature Statement #}
    <div class="feature-hero reveal">
      <h2 class="feature-hero-headline">Just talk.</h2>
      <p class="feature-hero-sub">
        No commands. No keywords. No learning curve.<br>Speak naturally, and Ferni understands.
      </p>
    </div>

    {# Feature Blocks - Apple's single-message sections #}
    <div class="feature-blocks">
      <div class="feature-block reveal">
        <div class="feature-block-content">
          <h3 class="feature-block-headline">
            It remembers<br><span class="gradient-text">everything.</span>
          </h3>
          <p class="feature-block-description">
            Your goals. Your preferences. Your progress. Every conversation makes Ferni smarter—and more helpful.
          </p>
        </div>
        <div class="feature-block-visual">
          <div class="memory-visual">
            <div class="memory-dot"></div>
            <div class="memory-dot"></div>
            <div class="memory-dot"></div>
            <div class="memory-line"></div>
          </div>
        </div>
      </div>

      <div class="feature-block reverse reveal">
        <div class="feature-block-content">
          <h3 class="feature-block-headline">
            Six minds.<br><span class="gradient-text">One conversation.</span>
          </h3>
          <p class="feature-block-description">
            Each AI brings unique expertise. Talk to one, and they seamlessly bring in others when needed. Like having an entire team in your pocket.
          </p>
        </div>
        <div class="feature-block-visual">
          <div class="team-visual">
            <div class="team-orb">
              <div class="mini-waveform">
                <span></span><span></span><span></span><span></span><span></span>
              </div>
            </div>
            <div class="team-dots">
              <span></span><span></span><span></span><span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </div>

      <div class="feature-block reveal">
        <div class="feature-block-content">
          <h3 class="feature-block-headline">
            Feels<br><span class="gradient-text">instant.</span>
          </h3>
          <p class="feature-block-description">
            Real conversations don't have loading spinners. Neither does Ferni. Responses so fast, you'll forget you're talking to AI.
          </p>
        </div>
        <div class="feature-block-visual">
          <div class="speed-visual">
            <div class="speed-pulse"></div>
            <span class="speed-label">&lt; 500ms</span>
          </div>
        </div>
      </div>
    </div>

    {# Trust Badges - Minimal #}
    <div class="trust-row reveal">
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span>Private & Secure</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        <span>Always Available</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
          <path d="M22 4L12 14.01l-3-3"/>
        </svg>
        <span>No Download Required</span>
      </div>
    </div>
  </div>
</section>
