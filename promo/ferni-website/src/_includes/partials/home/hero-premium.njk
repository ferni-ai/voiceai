{# 
  HERO SECTION - Premium Edition
  
  Design: Apple meets Stripe
  - Massive, confident typography
  - Generous whitespace
  - Subtle, purposeful animation
  - Premium feel in every detail
#}

<section class="hero-premium" id="hero">
  <div class="hero-premium__content">
    
    {# Eyebrow - subtle authority #}
    <p class="hero-premium__eyebrow">Your AI Life Coach</p>
    
    {# Headline - MASSIVE, confident #}
    <h1 class="hero-premium__headline">
      {{ site.hero.headline }}
      <span class="hero-premium__headline-accent">{{ site.hero.headlineAccent }}</span>
    </h1>
    
    {# Subhead - clear value prop #}
    <p class="hero-premium__subhead">
      Six AI specialists who actually listen, remember everything, and help you grow. Available 24/7 by voice or text.
    </p>
    
    {# CTA Group #}
    <div class="hero-premium__cta">
      <a href="{{ site.hero.cta.primary.url }}" class="hero-premium__btn-primary">
        Get started free
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
      <a href="tel:{{ site.phoneRaw }}" class="hero-premium__btn-phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {{ site.phone }}
      </a>
    </div>
    
    {# Social Proof - inline for trust #}
    <div class="hero-premium__trust-row">
      <span class="hero-premium__trust-item">
        <strong>10K+</strong> conversations
      </span>
      <span class="hero-premium__trust-divider">•</span>
      <span class="hero-premium__trust-item">
        <strong>&lt;500ms</strong> response
      </span>
      <span class="hero-premium__trust-divider">•</span>
      <span class="hero-premium__trust-item">
        <strong>∞</strong> memory
      </span>
    </div>
    
    {# Interactive Demo #}
    <div class="hero-premium__demo" id="heroPremiumDemo">
      <div class="hero-premium__input-wrapper">
        <input 
          type="text" 
          class="hero-premium__input"
          id="heroPremiumInput"
          placeholder="What's on your mind?"
          autocomplete="off"
        >
        <button class="hero-premium__mic-btn" id="heroPremiumMic" aria-label="Voice input">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
            <line x1="12" x2="12" y1="19" y2="22"/>
          </svg>
        </button>
      </div>
      
      <div class="hero-premium__prompts">
        <button class="hero-premium__prompt" data-prompt="I'm feeling overwhelmed at work">Overwhelmed at work</button>
        <button class="hero-premium__prompt" data-prompt="Help me build better habits">Building habits</button>
        <button class="hero-premium__prompt" data-prompt="I have a big decision to make">Big decision</button>
      </div>
      
      {# Response preview #}
      <div class="hero-premium__response" id="heroPremiumResponse">
        <div class="hero-premium__response-header">
          <div class="hero-premium__response-avatar">FN</div>
          <span class="hero-premium__response-name">Ferni</span>
        </div>
        <div class="hero-premium__response-text" id="heroPremiumResponseText">
          <div class="hero-premium__typing">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      </div>
    </div>
    
  </div>
  
  {# Scroll indicator #}
  <div class="hero-premium__scroll" aria-hidden="true">
    <span class="hero-premium__scroll-text">Scroll</span>
    <div class="hero-premium__scroll-icon"></div>
  </div>
</section>

<script>
(function() {
  'use strict';
  
  const RESPONSES = {
    "I'm feeling overwhelmed at work": 
      "I hear you. Feeling overwhelmed is tough—but you're not alone in this. Let's break it down together. What's the one thing that feels most urgent right now?",
    "Help me build better habits": 
      "Building habits is one of my favorite topics. The secret isn't willpower—it's making the habit so small you can't say no. What's one thing you've been wanting to build?",
    "I have a big decision to make": 
      "Big decisions deserve space to breathe. I'm curious—what's making this one feel so weighty? Sometimes just naming it helps us see it more clearly."
  };
  
  const input = document.getElementById('heroPremiumInput');
  const response = document.getElementById('heroPremiumResponse');
  const responseText = document.getElementById('heroPremiumResponseText');
  const prompts = document.querySelectorAll('.hero-premium__prompt');
  
  function showResponse(message) {
    const text = RESPONSES[message] || "I'm here to help. What would you like to talk about?";
    
    // Show response container
    response.classList.add('is-visible');
    
    // Show typing, then text
    responseText.innerHTML = '<div class="hero-premium__typing"><span></span><span></span><span></span></div>';
    
    setTimeout(() => {
      // Type out response
      responseText.textContent = '';
      let i = 0;
      const typeInterval = setInterval(() => {
        if (i < text.length) {
          responseText.textContent += text[i];
          i++;
        } else {
          clearInterval(typeInterval);
        }
      }, 15);
    }, 1000);
  }
  
  // Handle prompt clicks
  prompts.forEach(btn => {
    btn.addEventListener('click', () => {
      const prompt = btn.dataset.prompt;
      input.value = prompt;
      showResponse(prompt);
      
      // Fade out prompts
      document.querySelector('.hero-premium__prompts').style.opacity = '0';
    });
  });
  
  // Handle Enter key
  input.addEventListener('keypress', (e) => {
    if (e.key === 'Enter' && input.value.trim()) {
      showResponse(input.value.trim());
    }
  });
})();
</script>

