<nav class="nav" id="nav">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        {{ site.name }}
      </a>
      <ul class="nav-links" id="navLinks">
        {% for item in site.navigation.main %}
        <li><a href="{{ item.url }}" class="nav-link">{{ item.title }}</a></li>
        {% endfor %}
      </ul>
      <div class="nav-actions">
        <a
          href="{{ site.appUrl }}?utm_source=ferni_website&utm_medium=web&utm_campaign=homepage"
          class="btn btn-primary nav-cta"
          onclick="trackEvent('CTA', 'click', 'nav-get-started')"
        >{{ 'common.getStarted' | t }}</a>
        <button class="hamburger" id="hamburger" aria-label="{{ 'accessibility.toggleMenu' | t }}" aria-expanded="false">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>
  </div>

  {# Mobile Menu #}
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu-inner">
      {% for item in site.navigation.mobile %}
      <a href="{{ item.url }}" class="mobile-link">{{ item.title }}</a>
      {% endfor %}
      <div class="mobile-menu-cta">
        <a
          href="{{ site.appUrl }}?utm_source=ferni_website&utm_medium=web&utm_campaign=homepage"
          class="btn btn-primary"
          onclick="trackEvent('CTA', 'click', 'mobile-get-started')"
        >{{ 'common.getStartedFree' | t }}</a>
        <a href="tel:{{ site.phoneRaw }}" class="btn btn-ghost">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {{ 'common.callPhone' | t }} {{ site.phone }}
        </a>
      </div>
    </div>
  </div>
</nav>
