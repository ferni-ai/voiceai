<section class="stats">
  <div class="container">
    <div class="stats-grid">
      {% for stat in site.stats %}
      <div class="stat reveal{% if loop.index > 1 %} reveal-delay-{{ loop.index - 1 }}{% endif %}">
        {% if stat.value == "10,000+" %}
        <span class="stat-number" data-count="10000">0</span>
        {% elif stat.value == "<500ms" %}
        <span class="stat-number">&lt;500<span class="stat-unit">ms</span></span>
        {% else %}
        <span class="stat-number">{{ stat.value }}</span>
        {% endif %}
        <span class="stat-label">{{ stat.label }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
