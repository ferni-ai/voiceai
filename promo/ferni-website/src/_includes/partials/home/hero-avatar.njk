{# Hero Avatar - Corner voice orb that appears after intro #}
<div class="hero-avatar-container" id="heroAvatarContainer" aria-label="Talk to Ferni">
  <div class="living-avatar" data-emotion="neutral">
    <div class="avatar-orb-wrapper">
      <div class="avatar-glow-ring" style="--ring-opacity: 0.4"></div>
      <div class="avatar-glow-ring" style="--ring-opacity: 0.25"></div>
      <div class="avatar-glow-ring" style="--ring-opacity: 0.15"></div>
      
      <div class="avatar-orb">
        <div class="avatar-waveform">
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="hero-avatar-tooltip">
    <span>Talk to Ferni</span>
  </div>
</div>
