<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="font-display font-bold text-xl">{{ site.name }}</span>
      {% if badge %}
      <span class="logo-badge">{{ badge }}</span>
      {% endif %}
    </a>
    <nav class="nav">
      {% if isDocs %}
        {# Developer docs navigation #}
        {% for item in site.navigation.developers %}
        <a href="{{ item.url }}" {% if page.url == item.url %}class="active"{% endif %}>
          {{ item.title }}
        </a>
        {% endfor %}
        <a href="/">← {{ site.name }}</a>
      {% else %}
        {# Main site navigation #}
        {% for item in site.navigation.main %}
        <a href="{{ item.url }}" {% if page.url == item.url %}class="active"{% endif %}>
          {{ item.title }}
        </a>
        {% endfor %}
      {% endif %}
    </nav>
  </div>
</header>

