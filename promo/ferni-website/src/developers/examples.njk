    <div class="examples-list">
      <div class="example-card reveal">
        <div class="example-card__header">
          <span class="example-card__tag">Template</span>
          <h3 class="example-card__title">Life Coach (Ferni)</h3>
        </div>
        <p class="example-card__description">A warm, supportive coach who asks clarifying questions and helps users discover their own answers.</p>
        <div class="example-card__code">
          <pre>npm run agents create my-coach --template coach</pre>
        </div>
        <div class="example-card__features">
          <span>Active listening</span>
          <span>Goal tracking</span>
          <span>Celebration triggers</span>
        </div>
      </div>
      
      <div class="example-card reveal reveal-delay-1">
        <div class="example-card__header">
          <span class="example-card__tag">Template</span>
          <h3 class="example-card__title">Sage Mentor (Nayan)</h3>
        </div>
        <p class="example-card__description">A wise, patient mentor focused on long-term thinking and compound growth.</p>
        <div class="example-card__code">
          <pre>npm run agents create my-sage --template sage</pre>
        </div>
        <div class="example-card__features">
          <span>Long-term perspective</span>
          <span>Story-based wisdom</span>
          <span>Calm presence</span>
        </div>
      </div>
      
      <div class="example-card reveal reveal-delay-2">
        <div class="example-card__header">
          <span class="example-card__tag">Template</span>
          <h3 class="example-card__title">Research Assistant (Peter)</h3>
        </div>
        <p class="example-card__description">An analytical agent that finds patterns and turns data into actionable insights.</p>
        <div class="example-card__code">
          <pre>npm run agents create my-researcher --template research</pre>
        </div>
        <div class="example-card__features">
          <span>Data analysis</span>
          <span>Pattern recognition</span>
          <span>Citation support</span>
        </div>
      </div>
      
      <div class="example-card reveal">
        <div class="example-card__header">
          <span class="example-card__tag">Template</span>
          <h3 class="example-card__title">Habits Specialist (Maya)</h3>
        </div>
        <p class="example-card__description">Helps users build habits through small, consistent actions rather than motivation.</p>
        <div class="example-card__code">
          <pre>npm run agents create my-habits --template habits</pre>
        </div>
        <div class="example-card__features">
          <span>Habit stacking</span>
          <span>Streak tracking</span>
          <span>Gentle accountability</span>
        </div>
