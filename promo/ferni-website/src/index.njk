{# COMPARISON #}
<section class="section comparison" id="comparison">
  <div class="container">
    <div class="section__header reveal">
      <p class="section__eyebrow">Why Ferni</p>
      <h2 class="section__title">Beyond human limitations</h2>
      <p class="section__subtitle">Your best friend, therapist, and mentor all have limits. We don't.</p>
    </div>
    
    <div class="comparison-grid reveal-stagger">
      <div class="comparison-card comparison-card--others">
        <h3 class="comparison-card__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
