  <style>
    /* ════════════════════════════════════════════════════
       Better Than Human - Critical Inline Styles
       ════════════════════════════════════════════════════ */
    
    /* Fluid Typography - Display Headlines */
    .text-display-2xl {
      font-size: clamp(3rem, 2rem + 6vw, 7rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
    }
    .text-display-lg {
      font-size: clamp(2.25rem, 1.75rem + 2.5vw, 4rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }
    .text-display-md {
      font-size: clamp(1.875rem, 1.5rem + 1.875vw, 3rem);
      line-height: 1.2;
      letter-spacing: -0.015em;
    }
    
    /* Body text - optimal readability */
    .text-body-xl {
      font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.625rem);
      line-height: 1.6;
    }
    .text-body-lg {
      font-size: clamp(1.125rem, 1rem + 0.625vw, 1.375rem);
      line-height: 1.7;
    }
    
    /* Eyebrow text */
    .text-eyebrow {
      font-size: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    
    /* Animated gradient text */
    .text-gradient {
      background: linear-gradient(135deg, #4a6741 0%, #5a7751 50%, #3d5a35 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .text-gradient-alive {
      background: linear-gradient(135deg, #2d4a32 0%, #3d5a35 25%, #4a6741 50%, #3d5a35 75%, #2d4a32 100%);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradientShift 6s ease infinite;
    }
    @keyframes gradientShift {
      0%, 100% { background-position: 0% center; }
      50% { background-position: 100% center; }
    }
    
    /* Stagger animation delays */
    .stagger-1 { animation-delay: 0.1s; }
    .stagger-2 { animation-delay: 0.2s; }
    .stagger-3 { animation-delay: 0.3s; }
    .stagger-4 { animation-delay: 0.4s; }
    .stagger-5 { animation-delay: 0.5s; }
    .stagger-6 { animation-delay: 0.6s; }
    
    /* Scroll-triggered reveal - cinematic */
    .reveal {
      opacity: 0;
      transform: translateY(40px) scale(0.98);
      filter: blur(4px);
      transition: 
        opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), 
        transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
        filter 0.3s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
    
    /* Magnetic button effect */
    .btn-magnetic {
      transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .btn-magnetic:hover {
      transform: translateY(-2px) scale(1.02);
    }
    .btn-magnetic:active {
      transform: translateY(0) scale(0.98);
      transition-duration: 50ms;
    }
    
    /* ═══════════════════════════════════════════════════════════════
       FERNI COMES ALIVE - Pixar-quality character animation
       Every frame intentional. Every movement meaningful.
       ═══════════════════════════════════════════════════════════════ */
    
    /* The breath of life - organic, human rhythm */
    .ferni-breathe {
      animation: ferniBreath 4s ease-in-out infinite;
    }
    @keyframes ferniBreath {
      0%, 100% { transform: scale(1) translateY(0); }
      50% { transform: scale(1.015) translateY(-3px); }
    }
    
    /* Ferni notices you - the moment of recognition */
    .ferni-notice {
      animation: ferniBreath 4s ease-in-out infinite, ferniNotice 12s ease-in-out infinite;
    }
    @keyframes ferniNotice {
      0%, 85%, 100% { transform: scale(1) translateY(0) rotate(0deg); }
      88% { transform: scale(1.04) translateY(-4px) rotate(-1.5deg); }
      91% { transform: scale(0.99) translateY(1px) rotate(0.5deg); }
      94% { transform: scale(1.01) translateY(-1px) rotate(0deg); }
    }
    
    /* Hover response - Ferni leans in with interest */
    .ferni-avatar {
      cursor: pointer;
      transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .ferni-avatar:hover {
      transform: scale(1.06) translateY(-6px) !important;
      box-shadow: 0 24px 48px rgba(74, 103, 65, 0.25), 0 0 0 1px rgba(74, 103, 65, 0.1);
    }
    .ferni-avatar:hover .ferni-initials {
      transform: scale(1.05);
      transition: transform 0.3s ease;
    }
    
    /* Warm glow - presence indicator */
    .ferni-glow {
      animation: glowPulse 6s ease-in-out infinite;
    }
    @keyframes glowPulse {
      0%, 100% { opacity: 0.5; transform: scale(1); }
      50% { opacity: 0.35; transform: scale(1.1); }
    }
    
    /* Presence dot - subtle heartbeat */
    .ferni-presence {
      animation: presenceHeartbeat 3s ease-in-out infinite;
    }
    @keyframes presenceHeartbeat {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.2); opacity: 0.8; }
    }
    
    /* Ring pulse - awareness */
    .ferni-ring {
      animation: ringPulse 4s ease-in-out infinite;
    }
    @keyframes ringPulse {
      0%, 100% { opacity: 0.12; transform: scale(1); }
      50% { opacity: 0.2; transform: scale(1.02); }
    }
    
    /* Text reveal - cinematic timing */
    .hero-reveal {
      opacity: 0;
      transform: translateY(24px);
      animation: heroReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .hero-reveal-1 { animation-delay: 0.6s; }
    .hero-reveal-2 { animation-delay: 1s; }
    .hero-reveal-3 { animation-delay: 1.4s; }
    @keyframes heroReveal {
      to { opacity: 1; transform: translateY(0); }
    }
    
    /* Scroll hint */
    .scroll-hint {
      opacity: 0;
      animation: scrollFade 0.6s ease forwards 2s, scrollFloat 2.5s ease-in-out infinite 2s;
    }
    @keyframes scrollFade { to { opacity: 0.4; } }
    @keyframes scrollFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }
    
    /* Legacy support */
    .persona-orbit { animation: orbit 45s linear infinite; }
    .persona-counter { animation: counterOrbit 45s linear infinite; }
    @keyframes orbit { to { transform: rotate(360deg); } }
    @keyframes counterOrbit { to { transform: rotate(-360deg); } }
    [data-breathe] { animation: ferniBreath 4s ease-in-out infinite; }
    
    /* Reduced motion respect */
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; filter: none; transition: none; }
      .ferni-breathe, .ferni-notice, .ferni-glow, .ferni-ring, .ferni-presence,
      .persona-orbit, .persona-counter, [data-breathe], .text-gradient-alive,
      .hero-reveal, .scroll-hint { animation: none !important; opacity: 1; transform: none; }
    }
  </style>
</head>

