{# PRODUCT SHOWCASE #}
<section class="showcase" id="product">
  <div class="showcase__inner">
    <div class="showcase__content reveal">
      <p class="showcase__eyebrow">The App</p>
      <h2 class="showcase__title">A conversation that feels human</h2>
      <p class="showcase__description">
        Talk naturally by voice or text. Ferni remembers your story, understands your context, and responds with genuine insight—not generic advice.
      </p>
      <ul class="showcase__features">
        <li class="showcase__feature">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Voice-first—just call and talk
        </li>
        <li class="showcase__feature">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Remembers every conversation
        </li>
        <li class="showcase__feature">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Connects you to the right specialist
        </li>
      </ul>
    </div>
    
    <div class="showcase__phone reveal">
      <div class="showcase__phone-notch"></div>
      <div class="showcase__phone-screen">
        <div class="showcase__app">
          <div class="showcase__app-header">
            <div class="persona-avatar persona-avatar--md persona-avatar--ferni">
              <div class="persona-avatar__ring"></div>
              <div class="persona-avatar__orb">
                <span class="persona-avatar__text">FN</span>
              </div>
            </div>
            <div class="showcase__app-name">Ferni</div>
            <div class="showcase__app-status">● Online</div>
          </div>
          <div class="showcase__app-chat">
            <div class="showcase__app-bubble showcase__app-bubble--user">
              I'm feeling overwhelmed at work lately
            </div>
            <div class="showcase__app-bubble showcase__app-bubble--ai">
              I hear you. Feeling overwhelmed is tough—but you're not alone in this. What feels most urgent right now?
            </div>
            <div class="showcase__app-bubble showcase__app-bubble--user">
              I have too many projects and don't know where to start
            </div>
            <div class="showcase__app-bubble showcase__app-bubble--ai">
              Let's work through this together. Sometimes the path forward becomes clearer when we name what we're facing...
            </div>
          </div>
          <div class="showcase__app-input">
            <span>Type a message...</span>
            <div class="showcase__app-input-mic">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# PROMISE #}
<section class="section promise">
  <div class="container container--narrow">
    <div class="promise__content reveal">
