---
title: Ferni - Story Hero Preview
description: Preview of the cinematic story hero experience
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="robots" content="noindex">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <!-- Styles -->
  <link rel="stylesheet" href="/css/styles.css">
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
</head>

<body class="bg-paper text-ink font-body antialiased overflow-x-hidden">
  
  {# ═══════════════════════════════════════════════════════════════════════════
     THE STORY HERO
     A cinematic, interactive demonstration of Ferni
     ═══════════════════════════════════════════════════════════════════════════ #}
  
  {% include "partials/home/hero-story.njk" %}
  
  
  {# ═══════════════════════════════════════════════════════════════════════════
     CONTINUATION - After the story, the rest of the page
     ═══════════════════════════════════════════════════════════════════════════ #}
  
  <section class="py-32 px-6 bg-paper">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-eyebrow text-ferni mb-4 reveal">Beyond the moment</p>
      <h2 class="font-display text-display-lg text-ink mb-8 reveal">
        Every conversation builds on the last.
      </h2>
      <p class="text-body-lg text-ink-muted mb-12 reveal">
        Unlike your therapist who forgets, unlike your friend who's busy—Ferni remembers 
        everything. Every breakthrough. Every struggle. Every detail that matters to you.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal">
        <a href="https://app.ferni.ai" class="btn-magnetic inline-flex items-center gap-3 px-8 py-4 bg-ferni hover:bg-ferni-dark text-white font-semibold text-lg rounded-full shadow-xl shadow-ferni/25 transition-all duration-300">
          Start Free
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="tel:+14844813081" class="inline-flex items-center gap-2 text-ink-muted hover:text-ferni font-medium transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.05.39.14.76.26 1.12a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.36.12.73.21 1.12.26A2 2 0 0 1 22 16.92z"/></svg>
          Or call (484) 481-3081
        </a>
      </div>
    </div>
  </section>
  
  
  {# ═══════════════════════════════════════════════════════════════════════════
     THREE WAYS TO CONNECT
     ═══════════════════════════════════════════════════════════════════════════ #}
  
  <section class="py-24 px-6 bg-paper-sand">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-eyebrow text-ferni mb-4 reveal">How to connect</p>
        <h2 class="font-display text-display-lg text-ink reveal">Reach Ferni your way</h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        {# Call #}
        <div class="reveal bg-white rounded-3xl p-8 shadow-lg border border-ink/5 hover:shadow-xl hover:border-ferni/20 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-ferni/10 flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.05.39.14.76.26 1.12a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.36.12.73.21 1.12.26A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3 class="font-display text-xl font-bold text-ink mb-2">Call</h3>
          <p class="text-ink-muted mb-4">Dial from any phone. No app needed.</p>
          <a href="tel:+14844813081" class="font-mono text-ferni font-semibold">(484) 481-3081</a>
        </div>
        
        {# Text #}
        <div class="reveal bg-white rounded-3xl p-8 shadow-lg border border-ink/5 hover:shadow-xl hover:border-ferni/20 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-ferni/10 flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="font-display text-xl font-bold text-ink mb-2">Text</h3>
          <p class="text-ink-muted mb-4">Same number, text anytime.</p>
          <a href="sms:+14844813081" class="text-ferni font-semibold">Send a text →</a>
        </div>
        
        {# Web #}
        <div class="reveal bg-white rounded-3xl p-8 shadow-lg border border-ink/5 hover:shadow-xl hover:border-ferni/20 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-ferni/10 flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="font-display text-xl font-bold text-ink mb-2">Web App</h3>
          <p class="text-ink-muted mb-4">Voice, text, or video in browser.</p>
          <a href="https://app.ferni.ai" class="text-ferni font-semibold">Open app →</a>
        </div>
      </div>
    </div>
  </section>
  
  
  {# ═══════════════════════════════════════════════════════════════════════════
     FOOTER
     ═══════════════════════════════════════════════════════════════════════════ #}
  
  <footer class="py-16 px-6 bg-paper-warm border-t border-ink/5">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex items-center gap-4">
        <span class="font-display font-bold text-xl text-ink">Ferni</span>
        <span class="text-ink-muted">|</span>
        <span class="text-sm text-ink-muted">Better than human.</span>
      </div>
      <div class="flex items-center gap-6 text-sm text-ink-muted">
        <a href="/privacy" class="hover:text-ferni transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-ferni transition-colors">Terms</a>
        <span>© 2025 Ferni</span>
      </div>
    </div>
  </footer>
  
  
  {# ═══════════════════════════════════════════════════════════════════════════
     SCRIPTS
     ═══════════════════════════════════════════════════════════════════════════ #}
  
  <script src="/js/better-than-human.js"></script>
  <script src="/js/hero-story.js"></script>
  
  {# Preview badge #}
  <div style="
    position: fixed;
    top: 20px;
    right: 20px;
    padding: 8px 16px;
    background: #4a6741;
    color: white;
    font-size: 12px;
    font-weight: 600;
    border-radius: 100px;
    z-index: 9999;
    box-shadow: 0 4px 12px rgba(74, 103, 65, 0.3);
  ">
    🎬 Story Hero Preview
  </div>
  
</body>
</html>











