# Eleventy Ignore File
# Files and directories to exclude from processing

# Node modules
node_modules/

# Archive and documentation
_archive/

# The src/ directory is legacy Eleventy structure - we use root HTML files now
src/

# Scripts
scripts/

# Templates that shouldn't be processed
templates/

# Prompts and marketing docs
prompts/

# Generated files
_site/

# Config files
*.json
!src/_data/*.json

# Git
.git/
.gitignore

# Editor
.vscode/
.idea/

# OS
.DS_Store

# Markdown files (except specific ones we want)
*.md
images/**/*.md
videos/**/*.md

# Large sequence images (we use video versions instead)
images/sequence/

