---
layout: layouts/base.njk
title: Categories
description: Browse AI personas by category - Health, Life, Career, Creative, and more
---

{% from "partials/icons.njk" import heart, users, briefcase, palette, wallet, book, starFilled, star, arrowRight %}

<section class="hero" style="padding-bottom: var(--space-12);">
  <div class="container">
    <p class="hero-eyebrow">Browse by Category</p>
    <h1>Find Your Perfect Match</h1>
    <p class="hero-subtitle">
      Explore specialized AI coaches across different areas of life
    </p>
  </div>
</section>

<section class="section" style="padding-top: 0;">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: var(--space-6);">
      
      {% for category in personas.categories %}
      <a href="/category/{{ category.id }}/" class="card" style="padding: var(--space-8); text-align: center; text-decoration: none;">
        <div style="width: 80px; height: 80px; background: var(--bg-secondary); border-radius: var(--radius-2xl); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4); color: var(--accent-primary);">
          {% if category.id == 'health' %}{{ heart(32) }}{% endif %}
          {% if category.id == 'life' %}{{ users(32) }}{% endif %}
          {% if category.id == 'career' %}{{ briefcase(32) }}{% endif %}
          {% if category.id == 'creative' %}{{ palette(32) }}{% endif %}
          {% if category.id == 'finance' %}{{ wallet(32) }}{% endif %}
          {% if category.id == 'education' %}{{ book(32) }}{% endif %}
        </div>
        <h3 style="margin-bottom: var(--space-2);">{{ category.name }}</h3>
        <p style="color: var(--text-secondary); font-size: var(--text-sm);">{{ category.description }}</p>
        <div style="margin-top: var(--space-4); font-size: var(--text-sm); color: var(--accent-primary); display: flex; align-items: center; justify-content: center; gap: var(--space-1);">
          {% set count = 0 %}
          {% for persona in personas.personas %}
            {% if persona.category == category.id %}
              {% set count = count + 1 %}
            {% endif %}
          {% endfor %}
          {{ count }} personas {{ arrowRight(16) }}
        </div>
      </a>
      {% endfor %}
      
    </div>
  </div>
</section>

<!-- Popular in Each Category -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header">
      <h2>Popular Picks</h2>
      <p>Top-rated personas across categories</p>
    </div>
    
    <div class="persona-grid">
      {% for persona in personas.personas | slice(0, 4) %}
      <a href="/persona/{{ persona.id }}/" class="persona-card" style="--persona-color: {{ persona.colors.primary }}; --persona-secondary: {{ persona.colors.secondary }};">
        <div class="persona-header">
          <div class="persona-avatar">
            <span class="persona-initial">{{ persona.name | first }}</span>
          </div>
          <div class="persona-name">{{ persona.name }}</div>
          <div class="persona-tagline">{{ persona.tagline }}</div>
        </div>
        <div class="persona-body">
          <p class="persona-description">{{ persona.description }}</p>
          <div class="persona-tags">
            {% for tag in persona.tags | slice(0, 3) %}
            <span class="persona-tag">{{ tag }}</span>
            {% endfor %}
          </div>
          <div class="persona-footer">
            <div class="persona-rating">
              <span class="persona-stars" style="color: var(--warning);">
                {% for i in range(5) %}
                  {% if i < (persona.rating | round) %}{{ starFilled(14) }}{% else %}{{ star(14) }}{% endif %}
                {% endfor %}
              </span>
              <span class="persona-rating-count">{{ persona.rating }}</span>
            </div>
            <span class="persona-price {% if persona.pricing.model == 'free' or persona.pricing.model == 'freemium' %}free{% endif %}">
              {% if persona.pricing.model == 'free' %}
                Free
              {% elif persona.pricing.model == 'freemium' %}
                Free+
              {% else %}
                ${{ persona.pricing.priceInCents / 100 }}/mo
              {% endif %}
            </span>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
