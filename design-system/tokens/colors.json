      "background": {
        "primary": "#08080c",
        "secondary": "#0f0f14",
        "tertiary": "#16161d",
        "elevated": "#1c1c26",
        "glass": "rgba(255, 255, 255, 0.03)",
        "overlay": "rgba(0, 0, 0, 0.7)"
      },
      "text": {
        "primary": "#fafafa",
        "secondary": "#9ca3af",
        "muted": "#52525b",
        "dimmed": "#3f3f46",
        "inverse": "#08080c"
      },
      "border": {
        "subtle": "rgba(255, 255, 255, 0.06)",
        "medium": "rgba(255, 255, 255, 0.1)",
        "strong": "rgba(255, 255, 255, 0.2)"
      },
      "accent": {
        "primary": "#c8a45c",
        "hover": "#d4b56e",
        "pressed": "#b8944c",
        "glow": "rgba(200, 164, 92, 0.24)",
        "subtle": "rgba(200, 164, 92, 0.08)"
