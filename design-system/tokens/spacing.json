      "glow": "0 0 20px var(--color-accent-glow)",
      "inner": "inset 0 2px 4px rgba(0, 0, 0, 0.4)"
    },
    "zen": {
      "xs": "0 1px 2px rgba(0, 0, 0, 0.04)",
      "sm": "0 2px 4px rgba(0, 0, 0, 0.06)",
      "md": "0 4px 8px rgba(0, 0, 0, 0.08), 0 2px 4px rgba(0, 0, 0, 0.04)",
