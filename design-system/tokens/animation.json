    "keyframes": {
      "voiceGlowPulse": {
        "_description": "Rhythmic pulse that syncs with speaking cadence",
        "0%": {
          "boxShadow": "0 0 var(--glow-spread) var(--glow-color)",
          "opacity": "var(--glow-intensity)"
        },
        "50%": {
          "boxShadow": "0 0 calc(var(--glow-spread) * 1.4) var(--glow-color-alt)",
          "opacity": "calc(var(--glow-intensity) * 1.2)"
        },
        "100%": {
          "boxShadow": "0 0 var(--glow-spread) var(--glow-color)",
          "opacity": "var(--glow-intensity)"
        }
      },
      "voiceGlowBreath": {
        "_description": "Gentle breathing glow when listening/idle",
        "0%": {
          "boxShadow": "0 0 var(--glow-spread) var(--glow-color)",
