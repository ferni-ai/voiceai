{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "VoiceAI Animation Design Tokens - Pixar-Inspired, Magical & Human",

  "pixarPrinciples": {
    "_documentation": "The 12 Principles of Animation adapted for UI - making our personas feel alive",
    
    "squashAndStretch": {
      "description": "Objects deform based on speed and mass - gives weight and flexibility",
      "usage": "Apply to thinking dots, buttons on press, avatar reactions",
      "cssExample": "transform: scaleX(1.2) scaleY(0.8)"
    },
    "anticipation": {
      "description": "Preparation before action - wind up before the pitch",
      "usage": "Before jumps, before speaking, before transitions",
      "timing": "15-20% of total animation duration",
      "cssExample": "Start with slight opposite movement or scale-down"
    },
    "staging": {
      "description": "Direct attention to what matters - clear visual hierarchy",
      "usage": "Focus user attention on active persona, dim inactive elements",
      "principle": "One clear idea at a time"
    },
    "straightAheadAndPose": {
      "description": "Key poses define the motion - in-betweens create flow",
      "usage": "Define key states (idle, thinking, speaking, celebrating)",
      "cssKeyframes": "0%, 35%, 45%, 70%, 100% are the key poses"
    },
    "followThroughAndOverlap": {
      "description": "Not everything stops at once - hair, clothes continue moving",
      "usage": "Secondary elements follow primary with slight delay",
      "timing": "Stagger child elements 50-150ms after parent"
    },
    "slowInSlowOut": {
      "description": "Natural acceleration and deceleration - ease-in-out",
      "usage": "Most transitions should ease in and out",
      "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "arcs": {
      "description": "Natural motion follows curved paths, not straight lines",
      "usage": "Floating elements, avatar movements, thought bubbles",
      "cssExample": "Use translateX AND translateY together, or rotate"
    },
    "secondaryAction": {
      "description": "Supporting actions add richness - breathing, subtle glow",
      "usage": "While speaking: avatar breathes, glow pulses, dots bounce",
      "principle": "Never distract from the main action"
    },
    "timing": {
      "description": "Speed conveys weight and emotion - heavy = slow, light = quick",
      "personaMapping": {
        "wise": "slower, more deliberate (1.5-2x duration)",
        "energetic": "faster, snappier (0.7-0.9x duration)",
        "playful": "varied rhythm, bouncy",
        "calm": "smooth, consistent pace"
      }
    },
    "exaggeration": {
      "description": "Push poses further than reality for clarity and appeal",
      "usage": "Celebrations, errors, aha moments",
      "balance": "Subtle for zen aesthetic, more for playful personas"
    },
    "solidDrawing": {
      "description": "Weight, depth, balance - even 2D should feel 3D",
      "usage": "Shadows, depth layers, consistent light source",
      "cssExample": "box-shadow with realistic angles"
    },
    "appeal": {
      "description": "Characters should be likeable and interesting to watch",
      "usage": "Smooth curves, warm colors, gentle movements",
      "principle": "Would you want to spend time with this character?"
    }
  },

