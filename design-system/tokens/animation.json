{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "VoiceAI Animation Design Tokens",

  "easings": {
    "linear": "linear",
    "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
    "easeOut": "cubic-bezier(0, 0, 0.2, 1)",
    "easeInOut": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easeOutExpo": "cubic-bezier(0.16, 1, 0.3, 1)",
    "easeOutBack": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "easeInOutQuint": "cubic-bezier(0.83, 0, 0.17, 1)",
    "spring": "cubic-bezier(0.5, 1.5, 0.5, 1)",
    "springBouncy": "cubic-bezier(0.68, -0.55, 0.265, 1.55)",
    "smooth": "cubic-bezier(0.45, 0, 0.55, 1)"
  },

  "durations": {
    "instant": "0ms",
    "fastest": "50ms",
    "faster": "100ms",
    "fast": "150ms",
    "normal": "200ms",
    "slow": "300ms",
    "slower": "400ms",
    "slowest": "500ms",
    "deliberate": "700ms",
    "dramatic": "1000ms",
    "glacial": "1500ms"
  },

  "transitions": {
    "none": "none",
    "opacity": "opacity 200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "transform": "transform 200ms cubic-bezier(0.16, 1, 0.3, 1)",
    "colors": "color 200ms, background-color 200ms, border-color 200ms",
    "all": "all 200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "allFast": "all 150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "allSlow": "all 300ms cubic-bezier(0.4, 0, 0.2, 1)",
    "bounce": "transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1)",
    "springIn": "transform 500ms cubic-bezier(0.5, 1.5, 0.5, 1)",
    "smooth": "all 200ms cubic-bezier(0.45, 0, 0.55, 1)"
  },

  "keyframes": {
    "fadeIn": {
      "from": { "opacity": "0" },
      "to": { "opacity": "1" }
    },
    "fadeOut": {
      "from": { "opacity": "1" },
      "to": { "opacity": "0" }
    },
    "slideUp": {
      "from": { "transform": "translateY(10px)", "opacity": "0" },
      "to": { "transform": "translateY(0)", "opacity": "1" }
    },
    "slideDown": {
      "from": { "transform": "translateY(-10px)", "opacity": "0" },
      "to": { "transform": "translateY(0)", "opacity": "1" }
    },
    "scaleIn": {
      "from": { "transform": "scale(0.95)", "opacity": "0" },
      "to": { "transform": "scale(1)", "opacity": "1" }
    },
    "pulse": {
      "0%": { "opacity": "1" },
      "50%": { "opacity": "0.5" },
      "100%": { "opacity": "1" }
    },
    "breathe": {
      "0%": { "transform": "scale(1)" },
      "50%": { "transform": "scale(1.05)" },
      "100%": { "transform": "scale(1)" }
    },
    "shimmer": {
      "0%": { "backgroundPosition": "-200% 0" },
      "100%": { "backgroundPosition": "200% 0" }
    },
    "glow": {
      "0%": { "boxShadow": "0 0 5px var(--color-accent-glow)" },
      "50%": { "boxShadow": "0 0 20px var(--color-accent-glow)" },
      "100%": { "boxShadow": "0 0 5px var(--color-accent-glow)" }
    },
    "spin": {
      "from": { "transform": "rotate(0deg)" },
      "to": { "transform": "rotate(360deg)" }
    }
  },

  "animations": {
    "fadeIn": "fadeIn 200ms cubic-bezier(0.4, 0, 0.2, 1) forwards",
    "fadeOut": "fadeOut 200ms cubic-bezier(0.4, 0, 0.2, 1) forwards",
    "slideUp": "slideUp 300ms cubic-bezier(0.16, 1, 0.3, 1) forwards",
    "slideDown": "slideDown 300ms cubic-bezier(0.16, 1, 0.3, 1) forwards",
    "scaleIn": "scaleIn 200ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards",
    "pulse": "pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite",
    "breathe": "breathe 4s ease-in-out infinite",
    "shimmer": "shimmer 2s linear infinite",
    "glow": "glow 2s ease-in-out infinite",
    "spin": "spin 1s linear infinite"
  }
}
