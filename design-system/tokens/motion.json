  "animationLayers": {
    "_comment": "Layered animation system from ferni-alive.html (lines 3232-3255)",
    "breathing": {
      "priority": 1,
      "cycle": 4000,
      "expansion": 0.018,
      "description": "Always-on base layer"
    },
    "blinking": {
      "priority": 2,
      "intervalMin": 3000,
      "intervalMax": 7000,
      "description": "Random natural blinking"
    },
    "gazeDrift": {
      "priority": 3,
      "cycle": 8000,
      "description": "Subtle eye movement"
    },
    "anticipation": {
      "priority": 4,
      "overshoot": true,
      "description": "Slight overshoot on transitions"
    },
    "expression": {
      "priority": 5,
      "duration": 350,
      "description": "Emotional state changes"
    },
    "speaking": {
      "priority": 6,
      "overridesBreathing": true,
      "description": "Active speech animation"
    }
  },

  "secondaryActionOffsets": {
