    "waveformHeights": {
      "idle": { "min": 0.1, "max": 0.2, "description": "Minimal ambient movement" },
      "listening": { "min": 0.15, "max": 0.35, "description": "Responsive to input audio" },
      "speaking": { "min": 0.4, "max": 0.9, "description": "Active speech visualization" },
