{
  "$schema": "./schema.json",
  "meta": {
    "name": "Ferni Motion Tokens",
    "description": "Animation timing, easing, and choreography definitions - Single Source of Truth for all Ferni motion language",
    "version": "2.0.0",
    "source": "Extracted from design-system/playground/ferni-alive.html",
    "pixarPrinciples": [
      "Squash & Stretch - Organic deformation during movement",
      "Anticipation - Wind-up before action",
      "Staging - Clear focus on important elements",
      "Follow Through & Overlapping - Secondary actions trail primary",
      "Slow In & Slow Out - Natural acceleration/deceleration",
      "Arcs - Natural curved motion paths",
      "Secondary Action - Supporting movements reinforce main action",
      "Timing - Personality through speed",
      "Exaggeration - Emphasis through amplification",
      "Appeal - Charismatic, engaging motion"
    ]
  },

  "duration": {
    "_comment": "Timing categories from ferni-alive.html animation system",
    "instant": {
      "value": 40,
      "unit": "ms",
      "description": "Micro-expressions, subliminal (40-80ms)"
    },
    "micro": {
      "value": 80,
      "unit": "ms",
      "description": "Micro-expressions upper bound"
    },
    "quick": {
      "value": 100,
      "unit": "ms",
      "description": "Quick feedback (100-150ms)"
    },
    "fast": {
      "value": 150,
      "unit": "ms",
      "description": "Blink duration from ferni-alive.html"
    },
    "normal": {
      "value": 250,
      "unit": "ms",
      "description": "Standard UI transitions (250-400ms)"
    },
    "slow": {
      "value": 400,
      "unit": "ms",
      "description": "Deliberate, noticeable moves (400-600ms)"
    },
    "moderate": {
      "value": 450,
      "unit": "ms",
      "description": "Speaking pulse from ferni-alive.html"
    },
    "deliberate": {
      "value": 600,
      "unit": "ms",
      "description": "Emphasis, sparkle rotation (600-1000ms)"
    },
    "dramatic": {
      "value": 800,
      "unit": "ms",
      "description": "Eyes group transition from ferni-alive.html"
    },
    "celebration": {
      "value": 1000,
      "unit": "ms",
      "description": "Contemplative transitions (1000ms+)"
    },
    "glacial": {
      "value": 1500,
      "unit": "ms",
      "description": "Ambient, background effects"
    }
  },

  "easing": {
    "_comment": "Exact values from ferni-alive.html CSS variables (lines 18-24)",
    "standard": {
      "value": "cubic-bezier(0.4, 0.0, 0.2, 1)",
      "description": "Material standard deceleration"
    },
    "accelerate": {
      "value": "cubic-bezier(0.4, 0.0, 1, 1)",
      "description": "Elements leaving the screen"
    },
    "decelerate": {
      "value": "cubic-bezier(0.0, 0.0, 0.2, 1)",
      "description": "Elements entering the screen"
    },
    "sharp": {
      "value": "cubic-bezier(0.4, 0.0, 0.6, 1)",
      "description": "Quick, decisive movements"
    },
    "spring": {
      "value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "description": "Expressive bounce with overshoot - FROM ferni-alive.html --ease-spring"
    },
    "springHeavy": {
      "value": "cubic-bezier(0.34, 1.8, 0.64, 1)",
      "description": "Stronger bounce - FROM ferni-alive.html --ease-spring-heavy"
    },
    "springGentle": {
      "value": "cubic-bezier(0.34, 1.2, 0.64, 1)",
      "description": "Subtle spring, less bounce"
    },
    "expoOut": {
      "value": "cubic-bezier(0.16, 1, 0.3, 1)",
      "description": "Dramatic exit deceleration"
    },
    "gentle": {
      "value": "cubic-bezier(0.4, 0, 0.2, 1)",
      "description": "FROM ferni-alive.html --ease-gentle"
    },
    "organic": {
      "value": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
      "description": "FROM ferni-alive.html --ease-organic"
    },
    "anticipate": {
      "value": "cubic-bezier(0.38, -0.4, 0.88, 0.65)",
      "description": "Wind-up before action"
    },
    "bounce": {
      "value": "cubic-bezier(0.68, -0.55, 0.265, 1.55)",
      "description": "FROM ferni-alive.html --ease-bounce"
    },
    "elastic": {
      "value": "cubic-bezier(0.5, 1.8, 0.5, 0.8)",
      "description": "Elastic snap effect"
    }
  },
  
  "stagger": {
    "fast": {
      "value": 30,
      "unit": "ms",
      "description": "Quick cascade, list items"
    },
    "normal": {
      "value": 50,
      "unit": "ms",
      "description": "Standard stagger delay"
    },
    "slow": {
      "value": 80,
      "unit": "ms",
      "description": "Deliberate cascade"
    },
    "dramatic": {
      "value": 120,
      "unit": "ms",
      "description": "Pronounced reveal"
    }
  },
  
  "presets": {
    "buttonPress": {
      "duration": "fast",
      "easing": "spring",
      "scale": { "from": 1, "to": 0.95 }
    },
    "buttonHover": {
      "duration": "fast",
      "easing": "gentle",
      "scale": { "from": 1, "to": 1.02 }
    },
    "cardHover": {
      "duration": "normal",
      "easing": "gentle",
      "translateY": { "from": 0, "to": -4 }
    },
    "modalEnter": {
      "duration": "slow",
      "easing": "spring",
      "scale": { "from": 0.9, "to": 1 },
      "opacity": { "from": 0, "to": 1 }
    },
    "modalExit": {
      "duration": "normal",
      "easing": "accelerate",
      "scale": { "from": 1, "to": 0.95 },
      "opacity": { "from": 1, "to": 0 }
    },
    "slideInRight": {
      "duration": "moderate",
      "easing": "expoOut",
      "translateX": { "from": "100%", "to": 0 }
    },
    "slideOutRight": {
      "duration": "slow",
      "easing": "accelerate",
      "translateX": { "from": 0, "to": "100%" }
    },
    "fadeIn": {
      "duration": "normal",
      "easing": "decelerate",
      "opacity": { "from": 0, "to": 1 }
    },
    "fadeOut": {
      "duration": "fast",
      "easing": "accelerate",
      "opacity": { "from": 1, "to": 0 }
    },
    "toastEnter": {
      "duration": "slow",
      "easing": "spring",
      "translateY": { "from": 16, "to": 0 },
      "opacity": { "from": 0, "to": 1 }
    },
    "toastExit": {
      "duration": "normal",
      "easing": "accelerate",
      "translateY": { "from": 0, "to": -8 },
      "opacity": { "from": 1, "to": 0 }
    },
    "celebration": {
      "duration": "celebration",
      "easing": "spring",
      "scale": { "from": 0.8, "to": 1 }
    },
    "confettiDrop": {
      "duration": "glacial",
      "easing": "decelerate"
    },
    "breathe": {
      "duration": 5000,
      "easing": "gentle",
      "scale": { "from": 1, "to": 1.02 },
      "repeat": "infinite",
      "direction": "alternate"
    },
    "pulse": {
      "duration": "dramatic",
      "easing": "gentle",
      "scale": { "from": 1, "to": 1.15 },
      "opacity": { "from": 1, "to": 0.8 }
    },
    "shake": {
      "duration": "moderate",
      "easing": "elastic",
      "translateX": [0, -10, 10, -5, 5, 0]
    },
    "bounce": {
      "duration": "slow",
      "easing": "bounce",
      "translateY": [0, -20, 0, -10, 0]
    }
  },
  
  "personaModifiers": {
    "ferni": {
      "timingMultiplier": 1.0,
      "easingPreference": "gentle",
      "description": "Balanced, warm pacing"
    },
    "jack": {
      "timingMultiplier": 1.2,
      "easingPreference": "gentle",
      "description": "LEGACY: Slower, more deliberate - brand accent timing"
    },
    "peter": {
      "timingMultiplier": 0.85,
      "easingPreference": "spring",
      "description": "Quick, energetic"
    },
    "alex": {
      "timingMultiplier": 1.0,
      "easingPreference": "standard",
      "description": "Balanced, professional"
    },
    "maya": {
      "timingMultiplier": 0.95,
      "easingPreference": "standard",
      "description": "Efficient, organized"
    },
    "jordan": {
      "timingMultiplier": 0.8,
      "easingPreference": "spring",
      "description": "Fast, celebratory"
    },
    "nayan": {
      "timingMultiplier": 1.1,
      "easingPreference": "gentle",
      "description": "Thoughtful, measured"
    }
  },
  
  "reducedMotion": {
    "description": "Simplified animations for users who prefer reduced motion",
    "replacements": {
      "spring": "standard",
      "bounce": "standard",
      "elastic": "standard",
      "anticipate": "standard"
    },
    "maxDuration": 200,
    "disableStagger": true,
    "disableTransforms": ["scale", "rotate"],
    "allowedTransforms": ["opacity", "translateY"]
  },
  
  "ferniEQ": {
    "description": "Superhuman emotional intelligence - Better than Human",
    
    "microExpressions": {
      "description": "Subliminal emotional flashes (40-150ms) - below conscious perception",
      "recognition": {
        "value": 80,
        "unit": "ms",
        "expression": "curious",
        "intensity": 0.4,
        "probability": 0.7,
        "trigger": "User mentions familiar topic"
      },
      "concernFlash": {
        "value": 60,
        "unit": "ms",
        "expression": "worried",
        "intensity": 0.3,
        "probability": 0.8,
        "trigger": "Before empathy kicks in"
      },
      "delightFlash": {
        "value": 100,
        "unit": "ms",
        "expression": "pleased",
        "intensity": 0.5,
        "probability": 0.9,
        "trigger": "User achieves something"
      },
      "warmthPulse": {
        "value": 120,
        "unit": "ms",
        "expression": "warm",
        "intensity": 0.3,
        "probability": 0.6,
        "trigger": "Connection moments"
      },
      "interestFlash": {
        "value": 70,
        "unit": "ms",
        "expression": "curious",
        "intensity": 0.4,
        "probability": 0.5,
        "trigger": "Unexpected content"
      }
    },
    
    "activeListening": {
      "description": "Real-time feedback during user speech - shows presence",
      "microNod": {
        "duration": 180,
        "translateY": 1.5,
        "rotate": 0.3,
        "easing": "gentle",
        "pauseRange": { "min": 300, "max": 800 },
        "description": "Barely perceptible nod"
      },
      "subtleNod": {
        "duration": 220,
        "translateY": 2.5,
        "rotate": 0.5,
        "easing": "gentle",
        "pauseRange": { "min": 800, "max": 1500 },
        "description": "Visible acknowledgment nod"
      },
      "visibleNod": {
        "duration": 280,
        "translateY": 4,
        "rotate": 0.8,
        "easing": "gentle",
        "pauseRange": { "min": 1200, "max": 2000 },
        "description": "Clear engagement nod"
      },
      "listeningLean": {
        "duration": 400,
        "translateY": -3,
        "easing": "gentle",
        "holdDuration": 1500,
        "description": "Forward lean showing interest"
      },
      "minNodInterval": 2000,
      "nodProbabilityBase": 0.3
    },
    
    "breathSync": {
      "description": "Neural mirroring - sync breathing with user for connection",
      "slowRate": {
        "value": 10,
        "unit": "breaths/min",
        "description": "Calming effect"
      },
      "normalRate": {
        "value": 15,
        "unit": "breaths/min",
        "description": "Natural sync"
      },
      "fastRate": {
        "value": 20,
        "unit": "breaths/min",
        "description": "Energized connection"
      },
      "syncStrength": 0.3,
      "syncInterval": 5000,
      "calmingMultiplier": 0.95,
      "description": "Ferni breathes slightly slower than user for calming effect"
    },
    
    "concernDetection": {
      "description": "Detect distress signals and respond with care",
      "triggers": {
        "voiceStrain": { "weight": 0.3, "description": "Tension in voice" },
        "longPauses": { "weight": 0.2, "description": "Unusual hesitation" },
        "sighing": { "weight": 0.25, "description": "Detected sighs" },
        "breakingVoice": { "weight": 0.5, "description": "Almost crying" },
        "negativeSelfTalk": { "weight": 0.4, "description": "I'm such an idiot" },
        "hopelessnessWords": { "weight": 0.5, "description": "What's the point" },
        "isolationMentions": { "weight": 0.3, "description": "No one understands" }
      },
      "levels": {
        "mild": { "threshold": 0.2, "response": "attentive" },
        "moderate": { "threshold": 0.5, "response": "empathetic", "holdDuration": 3000 },
        "significant": { "threshold": 0.8, "response": "accompanying", "triggerCheckin": true }
      }
    },
    
    "anticipation": {
      "description": "Predict and show emotion before user finishes expressing",
      "patterns": [
        { "partial": "I've been thinking about", "tone": "falling", "emotion": "contemplative" },
        { "partial": "Guess what", "tone": "rising", "emotion": "curious" },
        { "partial": "Remember when", "tone": "any", "emotion": "remembering" },
        { "partial": "I need to tell you", "tone": "any", "emotion": "attentive" },
        { "partial": "Actually", "tone": "any", "emotion": "curious" }
      ]
    }
  },

  "breathCycles": {
