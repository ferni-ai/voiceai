{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "Ferni Sonic Identity Tokens - Complete audio brand system",
  
  "meta": {
    "name": "Ferni Sonic Identity",
    "version": "1.0.0",
    "description": "Audio design tokens defining Ferni's sonic brand - from the core note to persona signatures"
  },

  "philosophy": {
    "_documentation": "Sound is 50% of the experience. Every sound should feel inevitable, warm, supportive, and memorable.",
    "principles": [
      "Feel inevitable - like it couldn't be any other way",
      "Convey warmth - even functional sounds feel human",
      "Support, not distract - audio serves the experience",
      "Create memory - sounds become associated with feelings"
    ],
    "aesthetic": {
      "references": [
        "Ólafur Arnalds - Warm piano, gentle electronics, breathing space",
        "Max Richter - Emotional depth, cinematic restraint",
        "Nils Frahm - Organic imperfection, felt piano hammers",
        "Apple - Functional clarity, satisfying feedback",
        "Studio Ghibli - Whimsy without excess, natural sounds"
      ],
      "notFerni": [
        "Clinical beeps and boops",
        "Aggressive notification sounds",
        "Generic UI sounds",
        "Synthesized without humanity",
        "Loud or startling",
        "Emotionally manipulative"
      ]
    }
  },

  "coreElements": {
    "_documentation": "The foundational sonic building blocks of Ferni's identity",
    
    "ferniNote": {
      "description": "The foundational sound of Ferni's identity",
      "note": "C4",
      "frequency": 261.63,
      "name": "Middle C - Universal, grounding",
      "timbre": "Warm piano with soft felt, slight reverb",
      "character": "Like a breath, not a strike",
      "duration": 800,
      "decayType": "natural",
      "usage": "Basis for all Ferni-specific sounds"
    },
    "warmthPad": {
      "description": "Ambient undertone for presence",
      "chord": "Cmaj7",
      "notes": ["C4", "E4", "G4", "B4"],
      "frequencies": [261.63, 329.63, 392.00, 493.88],
      "timbre": "Soft synth pad with warmth filter",
      "character": "Barely noticeable, subconscious comfort",
      "volume": -24,
      "usage": "Subtle background during active connection"
    },
    "theBreath": {
      "description": "Organic rhythm element",
      "sound": "Soft inhale/exhale texture",
      "character": "Not literal breath, but the feeling",
      "duration": 1200,
      "cycle": { "inhale": 500, "hold": 200, "exhale": 500 },
      "usage": "Transitions, thinking moments"
    }
  },

