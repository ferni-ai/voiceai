  "technicalSpecs": {
    "_documentation": "Technical specifications for audio assets",
    
    "format": {
      "primary": "mp3",
      "fallback": "ogg",
      "lossless": "wav"
    },
    "quality": {
      "bitrate": "192kbps",
      "sampleRate": 44100,
      "channels": "stereo"
    },
