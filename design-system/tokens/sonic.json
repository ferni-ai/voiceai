      "target": -14,
      "unit": "LUFS",
      "truePeak": -1,
      "note": "Matches streaming platform standards"
    },
    "loopPoints": {
      "note": "For loopable sounds, ensure seamless loop points",
      "crossfade": 50,
      "unit": "ms"
    }
  },

  "accessibility": {
    "_documentation": "Audio accessibility considerations",
    
    "principles": [
      "Never make audio the only feedback channel",
      "Always pair with visual feedback",
      "Provide option to disable all sounds",
      "Respect system mute/volume settings",
      "Avoid sudden loud sounds"
    ],
    "screenReaderConsiderations": [
      "Audio cues should not conflict with screen reader output",
      "Important state changes should have text alternatives",
      "Background audio should be pausable"
    ]
  }
