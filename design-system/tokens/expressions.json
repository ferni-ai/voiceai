      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "transform": "rotate(2deg) translateY(-2px)" },
        "50%": { "transform": "rotate(-1deg) translateY(-3px)" }
      }
    },
    "sillyWobble": {
      "duration": "0.6s",
      "easing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "transform": "rotate(-4deg) scaleX(1.03) translateY(-3px)" },
        "50%": { "transform": "rotate(3deg) scaleX(1.03) translateY(-4px)" }
      }
    },
    "winkPop": {
      "duration": "0.3s",
      "easing": "var(--ease-spring)",
      "keyframes": {
        "0%": { "scaleY": 0.9 },
        "30%": { "scaleY": 0.1 },
        "100%": { "scaleY": 0.15 }
      }
    },
    "cheeringBounce": {
      "duration": "0.5s",
      "easing": "var(--ease-spring)",
      "keyframes": {
        "0%": { "transform": "translateY(0) scale(1)" },
        "50%": { "transform": "translateY(-8px) scale(1.06)" },
        "100%": { "transform": "translateY(-5px) scale(1.04)" }
      }
    },
    "drowsyBlink": {
      "duration": "3s",
      "easing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 90%, 100%": { "scaleY": 0.45 },
        "45%, 55%": { "scaleY": 0.2 }
      }
    },
    "yawnCycle": {
      "duration": "2s",
      "easing": "ease-in-out",
      "keyframes": {
        "0%": { "scaleY": 0.9, "bottomCutoff": 0.12 },
        "30%": { "scaleY": 0.25, "bottomCutoff": 0.35 },
        "70%": { "scaleY": 0.25, "bottomCutoff": 0.35 },
        "100%": { "scaleY": 0.4, "bottomCutoff": 0.25 }
      }
    },
    "nervousLook": {
      "duration": "2s",
      "easing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "translateX": 0 },
        "25%": { "translateX": 2 },
        "75%": { "translateX": -2 }
      }
    },
    "anxiousDart": {
      "duration": "1.5s",
      "easing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "translateX": -2, "translateY": -1 },
        "33%": { "translateX": 2, "translateY": 0 },
        "66%": { "translateX": -1, "translateY": -2 }
      }
    },
    "eyerollArc": {
      "duration": "0.8s",
      "easing": "ease-in-out",
      "keyframes": {
        "0%": { "translateX": 0, "translateY": 0 },
        "30%": { "translateX": 0, "translateY": -4 },
        "60%": { "translateX": 2, "translateY": -3 },
        "100%": { "translateX": 0, "translateY": 0 }
      }
    },
    "passionatePulse": {
      "duration": "1s",
      "easing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "transform": "translateY(-4px) scale(1.03)" },
        "50%": { "transform": "translateY(-5px) scale(1.04)" }
      }
    },
    "calmBreathe": {
      "duration": "4s",
      "easing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "transform": "scale(1)" },
        "50%": { "transform": "scale(1.01)" }
      }
    }
  },

