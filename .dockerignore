# ============================================================================
# Docker Ignore File
# ============================================================================
# Mirrors .gcloudignore for local Docker builds
# ============================================================================

# Note: evalops is now production-ready and included in the build

# Large directories
apps/
ferni-speaker-build/
promo/
functions/
# Design system - only keep dist/
design-system/.storybook/
design-system/assets/
design-system/choreography/
design-system/node_modules/
design-system/preview/
design-system/stories/
design-system/tests/
design-system/tokens/
design-system/*.js
design-system/*.ts
design-system/*.json
design-system/*.md

# Node modules (rebuilt in Docker)
node_modules/
*/node_modules/
**/node_modules/

# Build outputs (at root level only, preserve design-system/dist)
/dist/
frontend-typescript/dist/
coverage/

# Git
.git/
.gitignore

# Secrets
.env
.env.*
*.pem
*.key

# IDE
.vscode/
.idea/
.cursor/

# Docs & tests
*.md
docs/
e2e/
__tests__/

# Misc
.DS_Store
*.log
data/
# Allow needed scripts
# scripts/ - not ignoring anymore, need build-fast.ts and patch-livekit-timeout.js
marketplace-agents/
ferni-speaker/
