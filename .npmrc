# npm and pnpm configuration
#
# This file configures both npm and pnpm for optimal performance.
# pnpm-specific settings are prefixed with shamefully- or use pnpm: namespace

# ============================================================================
# SHARED SETTINGS (npm & pnpm)
# ============================================================================

# Save exact versions (no ^ or ~)
save-exact=true

# Registry
registry=https://registry.npmjs.org/

# Engine strict mode - fail if Node version doesn't match
engine-strict=true

# Fetch retries
fetch-retries=3

# Fetch timeout (30 seconds)
fetch-timeout=30000
