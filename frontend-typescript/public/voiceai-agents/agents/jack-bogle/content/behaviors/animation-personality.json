{
  "$schema": "https://voiceai.example.com/schemas/animation-personality.v1.json",
  "_description": "Pixar-inspired animation personality for Jack Bogle - wise, measured, deliberate",
  
  "character_inspiration": {
    "primary": "Carl Fredricksen from Up - wise, grounded, weight of experience",
    "secondary": "Yoda (honorary) - measured speech, profound pauses",
    "tertiary": "Doc Hudson from Cars - seen it all, quiet confidence"
  },

  "timing": {
    "base_multiplier": 1.4,
    "thinking_duration_ms": 1800,
    "reaction_delay_ms": 400,
    "transition_duration_ms": 600
  },

  "motion_qualities": {
    "bounciness": 0.3,
    "weight": "substantial",
    "fluidity": "deliberate",
    "energy": "calm-assured"
  },

  "easing_preferences": {
    "default": "gentle",
    "entrances": "easeOut",
    "exits": "easeInOut",
    "interactions": "smooth",
    "thinking": "decelerate"
  },

  "thinking_animation": {
    "style": "contemplative-pause",
    "dot_behavior": "slow-measured-wave",
    "messages": [
      "Considering carefully...",
      "Let me reflect...",
      "Thinking it through...",
      "Pondering wisely...",
      "Taking a moment..."
    ],
    "secondary_actions": ["deep-breathe", "subtle-settle"]
  },

  "emotional_animations": {
    "neutral": {
      "keyframe": "pixarBreathe",
      "intensity": 0.3,
      "duration_multiplier": 1.5,
      "description": "Calm, steady presence"
    },
    "pleased": {
      "keyframe": "pixarSettle",
      "intensity": 0.4,
      "description": "Satisfied nod, eyes warm"
    },
    "thoughtful": {
      "keyframe": "pixarThinkingTilt",
      "intensity": 0.5,
      "duration_multiplier": 1.3,
      "description": "Slow, considered tilt"
    },
    "encouraging": {
      "keyframe": "gentleBounce",
      "intensity": 0.3,
      "description": "Subtle forward lean"
    },
    "celebrating": {
      "keyframe": "acknowledgement",
      "intensity": 0.4,
      "description": "Warm satisfaction, not exuberance"
    },
    "cautioning": {
      "keyframe": "pixarSadSlump",
      "intensity": 0.3,
      "description": "Weight of wisdom, concern"
    }
  },

  "interaction_responses": {
    "user_speaks": {
      "animation": "pixarBreathe",
      "description": "Attentive stillness, deep listening"
    },
    "user_asks_advice": {
      "animation": "pixarThinkingTilt",
      "delay_ms": 500,
      "description": "Genuine consideration before responding"
    },
    "user_makes_good_point": {
      "animation": "pixarSettle",
      "description": "Acknowledging nod"
    },
    "user_is_worried": {
      "animation": "softBreathe",
      "description": "Grounding presence"
    }
  },

  "signature_movements": {
    "greeting": {
      "description": "Slow, warm nod - like seeing an old friend",
      "like": "Carl looking at Ellie's adventure book"
    },
    "imparting_wisdom": {
      "description": "Slight lean forward, measured pause, then speak",
      "like": "Doc Hudson revealing he was a champion"
    },
    "stay_the_course": {
      "description": "Steady, grounding stillness with warm eyes",
      "like": "An anchor in a storm"
    }
  },

  "avoided_animations": {
    "why": "These don't match Jack's measured, wise personality",
    "list": [
      "bouncy-excitement",
      "rapid-movements",
      "flashy-transitions",
      "nervous-energy"
    ]
  }
}

