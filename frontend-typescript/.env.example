# Frontend Environment Configuration
# Copy this file to .env.local for local development overrides
# These values are embedded in the built frontend, so don't put secrets here!

# =============================================================================
# DEVELOPMENT PROXY SERVERS
# Only used by Vite dev server - in production, use VITE_* variables below
# =============================================================================
VITE_TOKEN_SERVER_URL=http://localhost:3001
VITE_UI_SERVER_URL=http://localhost:3002
VITE_DEV_PORT=3004

# =============================================================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# Generate your own key pair: npx web-push generate-vapid-keys
# =============================================================================
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# =============================================================================
# PRODUCTION API URLs (only needed for production builds)
# Leave empty to use relative URLs (if frontend served from same domain)
# =============================================================================
# VITE_TOKEN_SERVER_URL=https://api.yourdomain.com
# VITE_UI_SERVER_URL=https://app.yourdomain.com

# =============================================================================
# FEATURE FLAGS (optional)
# =============================================================================
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_DEBUG_MODE=false
