{
  "hosting": [
    {
      "target": "ferni-prod",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/token",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/spotify/**",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/plaid/**",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/health",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(woff|woff2|ttf|otf|eot)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(mp3|wav|ogg)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        }
      ]
    },
    {
      "target": "johnb-app",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/token",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/spotify/**",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/plaid/**",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/health",
          "run": {
            "serviceId": "bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(woff|woff2|ttf|otf|eot)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(mp3|wav|ogg)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        }
      ]
    }
  ]
}
