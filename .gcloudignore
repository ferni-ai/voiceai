# ============================================================================

# Cloud Build Ignore File - OPTIMIZED

# ============================================================================

# Only upload what Dockerfile.ui actually needs (~250MB instead of ~3GB)

#

# What we need:

# - package*.json, tsconfig*.json

# - src/ (backend code)

# - ui-server.js

# - frontend-typescript/ (frontend code)

# - design-system/dist/ (built tokens only)

# - docker/ (Dockerfiles)

# - cloudbuild\*.yaml

# ============================================================================

# ===================

# WORK IN PROGRESS (not ready for production)

# ===================

# EvalOps is WIP - has TypeScript errors, exclude until ready

# Note: evalops is now production-ready and included in the build

# ===================

# LARGE DIRECTORIES - EXCLUDE THESE FIRST

# ===================

# Apps - Electron, iOS, Android builds (1.4GB+)
# Exclude large subdirs but keep apps/cli/ for build scripts
apps/android/
apps/android-native/
apps/electron/
apps/ios/
apps/ios-native/
apps/macos-menubar/
apps/marketing/
# Keep apps/marketplace-agents/registry.json for Dockerfile.ui
apps/marketplace-agents/agents/
apps/shared/
# apps/web - keep for UI server build (frontend code)
# Only exclude large generated/cache directories
apps/web/dist/
apps/web/node_modules/
apps/web/test-results/
# Keep: apps/web/src/, apps/web/public/, apps/web/scripts/, apps/web/tests/
apps/website/
# NOTE: apps/cli/ is intentionally NOT excluded (needed for Dockerfile.agent build)

# Ferni-speaker build directory (1.2GB) - rebuilt inside Docker

ferni-speaker-build/

# Promo/marketing site (639MB)

promo/

# Firebase functions (106MB) - separate deployment

functions/

# Design system (105MB total) - only keep dist/ (196KB)

# Explicitly exclude each subdir except dist

design-system/.storybook/
design-system/assets/
design-system/choreography/
design-system/node_modules/
design-system/preview/
design-system/stories/
design-system/tests/**
design-system/tokens/
design-system/playground/
design-system/site/
design-system/dashboard/
# Brand - only keep logos and favicons (exclude 27MB of social media exports)
# Note: logos/ and favicons/ must be INCLUDED for Dockerfile.ui COPY commands
design-system/brand/exports/
design-system/brand/icons/
design-system/brand/social/
# Keep *.md files - Dockerfile.ui copies them

# Exclude root files

# Only exclude root-level files (not in dist/)
design-system/*.js
design-system/*.ts
design-system/*.json
design-system/*.md

# Test files (5.2MB) - not needed in production
src/tests/

# ===================

# NODE MODULES (always rebuilt)

# ===================

node_modules/
\*/node_modules/
\*\*/node_modules/

# ===================

# BUILD OUTPUTS (rebuilt in Docker)

# ===================

# Use /dist to only match root dist (saves 300MB!), preserve design-system/dist

/dist
frontend-typescript/dist/
coverage/
.nyc_output/

# Root level test directory
tests/

# Deploy logs
.deploy-logs/

# Audit reports
.audit-reports/

# ===================

# GIT & VCS

# ===================

.git/
.gitignore
.gitattributes

# ===================

# SECRETS & ENV

# ===================

.env
.env._
!.env.example
.livekit-secrets.env
.plaid-tokens.json
.spotify-tokens.json
.spotify-device.json
_.pem
\*.key

# ===================

# IDE & EDITOR

# ===================

.vscode/
.idea/
_.swp
_.swo
.cursor/

# ===================

# OS FILES

# ===================

.DS_Store
Thumbs.db

# ===================

# LOGS & TEMP

# ===================

_.log
npm-debug.log_
.deploy-logs/
tmp/
temp/

# ===================

# DOCUMENTATION (not needed in build)

# ===================

\*.md
# BUT include persona bundle markdown files (system prompts, bios, etc.)
!src/personas/bundles/**/*.md
docs/
# Note: /brand/ exclusion removed for design-system/brand access via symlink
# /brand/
reference/

# ===================

# TESTING

# ===================

e2e/
**tests**/
*.test.ts
*.spec.ts
jest.config.*
playwright.config.*
playwright-report/
test-reports/
test-results/
.debug-captures/
coverage/
.nyc_output/

# Apps build artifacts
apps/web/.firebase/
apps/web/*.html
!apps/web/index.html

# ===================

# MARKETPLACE (keep registry.json for builds)

# ===================

# Exclude agents subdir but keep registry.json
# marketplace-agents/ - removed to allow registry.json

# ===================

# NATIVE MODULES (rebuilt in Docker)

# ===================

ferni-speaker/
\*.node

# ===================

# MISC

# ===================

# Note: data/ exclusion removed - apps/web/src/data/ needs to be included
# scripts/ - now allowing for build-fast.ts
# !scripts/patch-livekit-timeout.js
*.tgz
*.tar.gz

# Large unused directories
# Use /brand/ to only match root level, not design-system/brand/
/brand/
vendor/
infra/
infrastructure/
KMS/

# iOS/Android build caches
**/.build/
**/build/intermediates/
