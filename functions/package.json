{
  "name": "ferni-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for Ferni collective learning",
  "main": "dist/evolution-scheduler.js",
  "scripts": {
    "build": "tsc",
    "deploy": "gcloud functions deploy evolutionScheduler --gen2 --runtime=nodejs20 --trigger-topic=evolution-trigger --entry-point=evolutionScheduler --timeout=540s --memory=1GB --region=us-central1",
    "deploy-http": "gcloud functions deploy evolutionSchedulerHttp --gen2 --runtime=nodejs20 --trigger-http --entry-point=evolutionSchedulerHttp --timeout=540s --memory=1GB --region=us-central1 --allow-unauthenticated",
    "setup-scheduler": "gcloud scheduler jobs create pubsub daily-evolution --schedule=\"0 3 * * *\" --topic=evolution-trigger --message-body=\"{}\" --time-zone=\"America/New_York\" --location=us-central1"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.1.0",
    "@google-cloud/pubsub": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  }
}

