      { "word": "명상", "weight": 0.9 },
      { "word": "운동", "weight": 0.9 },
      { "word": "헬스장", "weight": 0.8 }
    ],
    "antiKeywords": ["만들어", "추가", "새로운", "추천", "도와줘", "뭐"]
