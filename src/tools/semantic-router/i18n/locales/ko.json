{
  "$schema": "./locale.schema.json",
  "$locale": "ko",
  "$name": "한국어",

  "weather_current": {
    "phrases": [
      "날씨 어때",
      "날씨가 어때요",
      "오늘 날씨",
      "지금 날씨",
      "밖에 어때",
      "비 와",
      "추워",
      "더워",
      "맑아",
      "우산 필요해",
      "자켓 필요해"
    ],
    "patterns": [
      "^(?:오늘|지금)?\\s*날씨(?:가)?\\s*(?:어때|어떻게|알려줘)",
      "^날씨\\s*(?:가)?(.+)",
      "^(?:비|눈)(?:가)?\\s*(?:와|오|내려)",
      "^우산(?:이)?\\s*(?:필요|있어야)"
    ],
    "keywords": [
      { "word": "날씨", "weight": 1.0 },
      { "word": "기온", "weight": 0.9 },
      { "word": "비", "weight": 0.8 },
      { "word": "맑음", "weight": 0.7 },
      { "word": "흐림", "weight": 0.7 },
      { "word": "추워", "weight": 0.6 },
      { "word": "더워", "weight": 0.6 },
      { "word": "우산", "weight": 0.8 },
      { "word": "예보", "weight": 0.7 }
    ],
    "antiKeywords": ["이메일", "캘린더", "회의", "음악", "재생"]
  },

  "weather_forecast": {
    "phrases": ["일기 예보", "이번 주 날씨", "내일 날씨", "주말 날씨", "예보 알려줘"],
    "patterns": [
      "^(?:이번\\s*주|다음\\s*주|내일)\\s*날씨(?:예보)?",
      "^(?:일기)?\\s*예보(?:를)?\\s*(?:알려줘|보여줘)",
      "^(?:비|눈)(?:가)?\\s*(?:올까|내릴까)"
    ],
    "keywords": [
      { "word": "예보", "weight": 1.0 },
      { "word": "주", "weight": 0.7 },
      { "word": "내일", "weight": 0.8 }
    ],
    "antiKeywords": ["지금", "현재"]
  },

