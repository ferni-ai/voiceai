      { "word": "기억해", "weight": 0.9 },
      { "word": "떠올려", "weight": 1.0 },
      { "word": "알아", "weight": 0.6 },
      { "word": "말했어", "weight": 0.8 }
    ],
    "antiKeywords": ["저장", "메모", "잊지마", "기억해둬"]
