      "^(?:도와줘)?\\s*(?:진정|릴랙스)(?:시켜|하고\\s*싶어)",
      "^(?:그라운딩|호흡|릴랙스)(?:운동|연습)"
    ],
    "keywords": [
      { "word": "불안", "weight": 1.0 },
      { "word": "스트레스", "weight": 0.9 },
      { "word": "패닉", "weight": 1.0 },
      { "word": "진정", "weight": 0.8 },
