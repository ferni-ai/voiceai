      "회의 있어",
      "미팅 있어",
      "다음 일정"
    ],
    "patterns": [
      "^(?:내)?\\s*(?:캘린더|스케줄|일정)(?:을)?\\s*(?:보여줘|확인|알려줘)",
      "^(?:오늘|내일|이번\\s*주)\\s*(?:일정|회의|미팅)(?:이)?",
      "^(?:한가해|바빠|시간\\s*있어)(?:요)?"
