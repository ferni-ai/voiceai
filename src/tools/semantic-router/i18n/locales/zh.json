  "weather_current": {
    "phrases": ["天气怎么样", "现在天气", "外面怎么样", "下雨吗", "冷不冷", "热不热", "需要带伞吗"],
    "patterns": ["^(?:今天|现在)?天气(?:怎么样)?", "^(?:下雨|下雪|冷|热)(?:吗)?", "^需要(?:带)?(?:伞|外套)(?:吗)?"],
    "keywords": [
      { "word": "天气", "weight": 1.0 },
      { "word": "温度", "weight": 0.9 },
      { "word": "下雨", "weight": 0.8 },
      { "word": "伞", "weight": 0.8 }
    ],
    "antiKeywords": ["邮件", "日历", "会议", "音乐"]
  },

  "weather_forecast": {
    "phrases": ["天气预报", "明天天气", "这周天气", "周末天气"],
    "patterns": ["^(?:明天|这周|周末)?天气预报", "^(?:会)?(?:下雨|下雪)(?:吗)?"],
    "keywords": [{ "word": "预报", "weight": 1.0 }, { "word": "明天", "weight": 0.8 }],
