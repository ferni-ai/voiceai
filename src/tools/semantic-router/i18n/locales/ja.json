{
  "$schema": "./locale.schema.json",
  "$locale": "ja",
  "$name": "日本語",

  "weather_current": {
    "phrases": [
      "天気はどう",
      "天気を教えて",
      "今の天気は",
      "外の様子は",
      "雨が降ってる",
      "寒い",
      "暑い",
      "晴れてる",
      "傘が必要",
      "上着が必要"
    ],
    "patterns": [
      "^(?:今日の|今の)?天気(?:は|を)?(?:どう|教えて)",
      "^天気\\s*(?:は)?(.+)",
      "^(?:雨|雪)(?:が|は)?(?:降って|降り)",
      "^傘(?:は|が)?(?:必要|いる)"
    ],
    "keywords": [
      { "word": "天気", "weight": 1.0 },
      { "word": "気温", "weight": 0.9 },
      { "word": "雨", "weight": 0.8 },
      { "word": "晴れ", "weight": 0.7 },
      { "word": "曇り", "weight": 0.7 },
      { "word": "寒い", "weight": 0.6 },
      { "word": "暑い", "weight": 0.6 },
      { "word": "傘", "weight": 0.8 },
      { "word": "予報", "weight": 0.7 }
    ],
    "antiKeywords": ["メール", "カレンダー", "会議", "音楽", "再生"]
  },

  "weather_forecast": {
    "phrases": ["天気予報", "今週の天気", "明日の天気", "週末の天気", "予報を教えて"],
    "patterns": [
      "^(?:今週|来週|明日)の天気(?:予報)?",
      "^天気予報(?:を)?(?:教えて|見せて)",
      "^(?:雨|雪)(?:は)?(?:降る|降り)(?:そう)?"
    ],
    "keywords": [
      { "word": "予報", "weight": 1.0 },
      { "word": "週", "weight": 0.7 },
      { "word": "明日", "weight": 0.8 }
    ],
    "antiKeywords": ["今", "現在"]
  },

