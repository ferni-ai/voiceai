      "^(?:これを)?覚えて(?:おいて)?(.+)?",
      "^忘れないで(.+)?",
      "^(?:保存|メモ|記録)して(.+)?",
      "^ノート(?:を)?(?:取って|して)(.+)?"
    ],
    "keywords": [
      { "word": "覚えて", "weight": 1.0 },
      { "word": "忘れないで", "weight": 0.9 },
      { "word": "保存", "weight": 0.7 },
      { "word": "メモ", "weight": 0.7 }
    ],
    "antiKeywords": ["何", "いつ", "誰", "教えて", "思い出して"]
  },

  "memory_recall": {
    "phrases": ["何を言った", "覚えてる", "について教えて", "思い出して", "私の", "誰が", "いつ"],
    "patterns": [
      "^(?:何|いつ|誰)(?:を|が)?(?:言った|話した)",
      "^覚えて(?:い)?(?:る|ます)(?:か)?(?:何|いつ|誰)?",
      "^(?:私の)(.+)(?:は|を)?(?:何|教えて)?",
      "^思い出して(.+)?"
    ],
    "keywords": [
      { "word": "覚えてる", "weight": 0.9 },
      { "word": "思い出して", "weight": 1.0 },
      { "word": "知ってる", "weight": 0.6 },
      { "word": "言った", "weight": 0.8 }
    ],
    "antiKeywords": ["保存", "メモ", "忘れないで", "覚えて"]
  },

