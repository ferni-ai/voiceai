    ],
    "patterns": [
      "^(?:私の)?(?:カレンダー|スケジュール|予定)(?:を)?(?:見せて|確認|教えて)",
      "^(?:今日|明日|今週)の(?:予定|会議|ミーティング)(?:は)?",
      "^(?:暇|空いて|忙しい)(?:です)?(?:か)?"
