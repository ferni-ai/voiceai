{
  "$schema": "./locale.schema.json",
  "$locale": "zh-Hant",
  "$name": "繁體中文",

  "weather_current": {
    "phrases": [
      "天氣怎麼樣",
      "現在天氣",
      "今天天氣",
      "外面怎麼樣",
      "下雨嗎",
      "冷嗎",
      "熱嗎",
      "晴天嗎",
      "需要帶傘嗎",
      "需要穿外套嗎"
    ],
    "patterns": [
      "^(?:今天|現在)?(?:的)?天氣(?:怎麼樣|如何)?",
      "^天氣\\s*(?:在)?(.+)",
      "^(?:下雨|下雪|冷|熱|晴天|陰天)(?:嗎)?",
      "^(?:需要|要)?(?:帶)?(?:雨傘|外套|大衣)(?:嗎)?"
    ],
    "keywords": [
      { "word": "天氣", "weight": 1.0 },
      { "word": "氣溫", "weight": 0.9 },
      { "word": "雨", "weight": 0.8 },
      { "word": "下雨", "weight": 0.8 },
      { "word": "晴天", "weight": 0.7 },
      { "word": "陰天", "weight": 0.7 },
      { "word": "冷", "weight": 0.6 },
      { "word": "熱", "weight": 0.6 },
      { "word": "雨傘", "weight": 0.8 },
      { "word": "預報", "weight": 0.7 }
    ],
    "antiKeywords": ["郵件", "日曆", "會議", "音樂", "播放"]
  },

  "weather_forecast": {
    "phrases": ["天氣預報", "這週天氣", "明天天氣", "週末天氣", "告訴我預報"],
    "patterns": [
      "^(?:這週|下週|明天)(?:的)?天氣(?:預報)?",
      "^天氣預報(?:是)?(?:什麼)?",
      "^(?:會)?(?:下雨|下雪)(?:嗎)?"
    ],
    "keywords": [
      { "word": "預報", "weight": 1.0 },
      { "word": "週", "weight": 0.7 },
      { "word": "明天", "weight": 0.8 }
    ],
    "antiKeywords": ["現在", "目前"]
  },

  "calendar_list_events": {
    "phrases": [
      "看看日曆",
      "查看日曆",
      "我的日程",
      "今天有什麼",
      "有會議嗎",
      "有約會嗎",
      "接下來有什麼"
    ],
    "patterns": [
      "^(?:查看|看看)?(?:我的)?(?:日曆|日程)(?:表)?",
      "^(?:今天|明天|這週)?(?:有)?(?:什麼)?(?:會議|活動|約會)",
      "^(?:我)?(?:有空|忙|有時間)(?:嗎)?"
    ],
    "keywords": [
      { "word": "日曆", "weight": 1.0 },
      { "word": "日程", "weight": 0.9 },
      { "word": "會議", "weight": 0.8 },
      { "word": "約會", "weight": 0.8 },
      { "word": "安排", "weight": 0.8 }
    ],
    "antiKeywords": ["創建", "添加", "安排", "取消", "刪除"]
  },

  "calendar_create_event": {
    "phrases": ["安排會議", "創建活動", "添加到日曆", "設置會議", "預約時間", "加到日曆"],
    "patterns": [
      "^(?:安排|創建|添加|設置|預約)(?:一個)?(?:會議|活動|約會)",
      "^(?:加|添加)(?:到)?(?:我的)?日曆"
    ],
    "keywords": [
      { "word": "安排", "weight": 1.0 },
      { "word": "創建", "weight": 0.9 },
      { "word": "添加", "weight": 0.8 },
      { "word": "預約", "weight": 0.9 }
    ],
    "antiKeywords": ["查看", "什麼", "取消", "刪除"]
  },

  "habit_track": {
    "phrases": [
      "完成了",
      "做完了",
      "做了",
      "記錄習慣",
      "追蹤習慣",
      "冥想了",
      "鍛鍊了",
      "去健身房了",
      "寫日記了"
    ],
    "patterns": [
      "^(?:.*?)(?:完成|做完|做了|結束了)",
      "^(?:記錄|追蹤)(?:我的)?習慣(?:完成)?",
      "^(?:冥想|鍛鍊|健身房|日記)(?:了|完成)?"
    ],
    "keywords": [
      { "word": "完成", "weight": 0.8 },
      { "word": "做完", "weight": 0.9 },
      { "word": "做了", "weight": 0.8 },
      { "word": "冥想", "weight": 0.9 },
      { "word": "鍛鍊", "weight": 0.9 },
      { "word": "健身房", "weight": 0.8 }
    ],
    "antiKeywords": ["創建", "添加", "新的", "建議", "幫助", "什麼"]
  },

  "memory_save": {
    "phrases": ["記住這個", "記住", "別忘了", "保存這個", "記下來", "記錄", "做個筆記"],
    "patterns": [
      "^(?:請)?記住(?:這個)?(.+)?",
      "^(?:別|不要)忘(?:了|記)(.+)?",
      "^(?:保存|記下|記錄)(?:這個)?(.+)?",
      "^(?:做個|寫個)筆記(.+)?"
    ],
    "keywords": [
      { "word": "記住", "weight": 1.0 },
      { "word": "忘記", "weight": 0.9 },
      { "word": "保存", "weight": 0.7 },
      { "word": "記錄", "weight": 0.7 }
    ],
    "antiKeywords": ["什麼", "什麼時候", "誰", "告訴我", "想起"]
  },

  "memory_recall": {
    "phrases": ["我說過什麼", "你記得嗎", "你知道什麼", "想起來", "我的", "誰是", "什麼時候"],
    "patterns": [
      "^(?:我)?(?:說過|講過|提到過)(?:什麼)?",
      "^(?:你)?記得(?:嗎)?(?:什麼|什麼時候|誰)?",
      "^(?:我的)(.+)(?:是)?(?:什麼)?",
      "^想起(?:來)?(.+)?"
    ],
    "keywords": [
      { "word": "記得", "weight": 0.9 },
      { "word": "想起", "weight": 1.0 },
      { "word": "知道", "weight": 0.6 },
      { "word": "說過", "weight": 0.8 }
    ],
    "antiKeywords": ["保存", "記錄", "別忘了", "記住"]
  },

  "grounding_exercise": {
    "phrases": [
      "我很焦慮",
      "我很緊張",
      "感覺壓力大",
      "需要冷靜",
      "幫我放鬆",
      "接地練習",
      "呼吸練習",
      "我在恐慌",
      "讓我冷靜"
    ],
    "patterns": [
      "^(?:我)?(?:很|感到)?(?:焦慮|緊張|壓力大|恐慌)",
      "^(?:我)?需要(?:冷靜|放鬆|接地)",
      "^(?:幫|幫我)?(?:冷靜|放鬆)(?:下來)?",
      "^(?:做個)?(?:接地|呼吸|放鬆)(?:練習)?"
    ],
    "keywords": [
      { "word": "焦慮", "weight": 1.0 },
      { "word": "緊張", "weight": 0.9 },
      { "word": "恐慌", "weight": 1.0 },
      { "word": "冷靜", "weight": 0.8 },
      { "word": "放鬆", "weight": 0.7 },
      { "word": "呼吸", "weight": 0.8 },
      { "word": "接地", "weight": 1.0 }
    ],
    "antiKeywords": []
  },

  "spotify_play": {
    "phrases": ["播放音樂", "放點音樂", "放歌", "開始播放", "放點什麼", "來點音樂"],
    "patterns": ["^(?:播放|放)(?:一些|點)?(.+)", "^(?:我想)?(?:聽|聽聽)(.+)", "^(?:給我)?放(.+)"],
    "keywords": [
      { "word": "播放", "weight": 1.0 },
      { "word": "音樂", "weight": 0.8 },
      { "word": "歌", "weight": 0.7 },
      { "word": "爵士", "weight": 0.8 },
      { "word": "搖滾", "weight": 0.7 },
      { "word": "古典", "weight": 0.7 }
    ],
    "antiKeywords": ["停止", "暫停", "下一首", "跳過"]
  },

  "info_time": {
    "phrases": ["現在幾點", "幾點了", "現在時間", "告訴我時間"],
    "patterns": ["^(?:現在)?幾點(?:了)?", "^(?:告訴我)?(?:現在)?(?:的)?時間"],
    "keywords": [
      { "word": "時間", "weight": 1.0 },
      { "word": "幾點", "weight": 0.8 }
    ],
    "antiKeywords": ["天氣", "日曆", "會議"]
  },

  "handoff": {
    "phrases": ["轉接到", "讓我和...說話", "能和...說話嗎", "幫我接通", "我想和...說話", "切換到"],
    "patterns": [
      "^(?:轉接|接通)(?:到|給)(.+)",
      "^(?:讓我|我想)(?:和|跟)(.+)(?:說話|聊天)",
      "^切換(?:到)(.+)"
    ],
    "keywords": [
      { "word": "轉接", "weight": 1.0 },
      { "word": "說話", "weight": 0.7 },
      { "word": "瑪雅", "weight": 0.9 },
      { "word": "彼得", "weight": 0.9 },
      { "word": "亞歷克斯", "weight": 0.9 },
      { "word": "喬丹", "weight": 0.9 },
      { "word": "納揚", "weight": 0.9 }
    ],
    "antiKeywords": []
  }
}
