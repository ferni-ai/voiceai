{
  "$schema": "./locale.schema.json",
  "$locale": "zh-Hans",
  "$name": "简体中文",

  "weather_current": {
    "phrases": [
      "天气怎么样",
      "现在天气",
      "今天天气",
      "外面怎么样",
      "下雨吗",
      "冷吗",
      "热吗",
      "晴天吗",
      "需要带伞吗",
      "需要穿外套吗"
    ],
    "patterns": [
      "^(?:今天|现在)?(?:的)?天气(?:怎么样|如何)?",
      "^天气\\s*(?:在)?(.+)",
      "^(?:下雨|下雪|冷|热|晴天|阴天)(?:吗)?",
      "^(?:需要|要)?(?:带)?(?:雨伞|外套|大衣)(?:吗)?"
    ],
    "keywords": [
      { "word": "天气", "weight": 1.0 },
      { "word": "气温", "weight": 0.9 },
      { "word": "雨", "weight": 0.8 },
      { "word": "下雨", "weight": 0.8 },
      { "word": "晴天", "weight": 0.7 },
      { "word": "阴天", "weight": 0.7 },
      { "word": "冷", "weight": 0.6 },
      { "word": "热", "weight": 0.6 },
      { "word": "雨伞", "weight": 0.8 },
      { "word": "预报", "weight": 0.7 }
    ],
    "antiKeywords": ["邮件", "日历", "会议", "音乐", "播放"]
  },

  "weather_forecast": {
    "phrases": [
      "天气预报",
      "这周天气",
      "明天天气",
      "周末天气",
      "告诉我预报"
    ],
    "patterns": [
      "^(?:这周|下周|明天)(?:的)?天气(?:预报)?",
      "^天气预报(?:是)?(?:什么)?",
      "^(?:会)?(?:下雨|下雪)(?:吗)?"
    ],
    "keywords": [
      { "word": "预报", "weight": 1.0 },
      { "word": "周", "weight": 0.7 },
      { "word": "明天", "weight": 0.8 }
    ],
    "antiKeywords": ["现在", "目前"]
  },

