  "weather_current": {
    "phrases": [
      "qué tiempo hace",
      "cómo está el tiempo",
      "cuál es el clima",
      "está lloviendo",
      "hace frío",
      "hace calor",
      "necesito un paraguas",
      "debo llevar abrigo"
    ],
    "patterns": [
      "^(?:qué|cuál\\s+es\\s+el)\\s+(?:tiempo|clima)",
      "^(?:cómo\\s+está|cómo\\s+es)\\s+el\\s+(?:tiempo|clima)",
      "^(?:está|va\\s+a)\\s+(?:lloviendo|llover|nevando|nevar)",
      "^hace\\s+(?:frío|calor|sol|viento)"
    ],
    "keywords": [
      { "word": "tiempo", "weight": 1.0 },
      { "word": "clima", "weight": 1.0 },
      { "word": "lluvia", "weight": 0.8 },
      { "word": "lloviendo", "weight": 0.8 },
      { "word": "sol", "weight": 0.7 },
      { "word": "nublado", "weight": 0.7 },
      { "word": "frío", "weight": 0.6 },
      { "word": "calor", "weight": 0.6 },
