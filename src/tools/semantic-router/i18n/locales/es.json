      "^(?:el\\s+)?tiempo\\s+(?:para\\s+)?(?:esta|la\\s+próxima)\\s+semana",
      "^va\\s+a\\s+(?:llover|nevar)\\s+(?:mañana|esta\\s+semana)"
    ],
    "keywords": [
