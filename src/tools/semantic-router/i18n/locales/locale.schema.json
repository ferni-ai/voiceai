{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ferni.ai/schemas/semantic-router-locale.json",
  "title": "Semantic Router Locale",
  "description": "Schema for semantic router locale files that define tool triggers in different languages",
  "type": "object",
  "required": ["$locale", "$name"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "$locale": {
      "type": "string",
      "description": "BCP 47 language tag (e.g., 'en', 'es', 'zh-Hans')",
      "pattern": "^[a-z]{2,3}(-[A-Z][a-z]{3})?(-[A-Z]{2})?$"
    },
    "$name": {
      "type": "string",
      "description": "Human-readable name of the language in its native script"
    }
  },
  "additionalProperties": {
    "$ref": "#/definitions/toolTrigger"
  },
  "definitions": {
    "toolTrigger": {
      "type": "object",
      "description": "Trigger configuration for a specific tool",
      "required": ["phrases", "patterns", "keywords"],
      "properties": {
        "phrases": {
          "type": "array",
          "description": "Exact phrases that trigger this tool",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "patterns": {
          "type": "array",
          "description": "Regular expression patterns that match tool intents",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "keywords": {
          "type": "array",
          "description": "Weighted keywords for scoring matches",
          "items": {
            "$ref": "#/definitions/keyword"
          },
          "minItems": 1
        },
        "antiKeywords": {
          "type": "array",
          "description": "Keywords that indicate this is NOT the intended tool",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "keyword": {
      "type": "object",
      "description": "A weighted keyword for intent matching",
      "required": ["word", "weight"],
      "properties": {
        "word": {
          "type": "string",
          "description": "The keyword to match",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "description": "Weight for scoring (0.0 to 1.0)",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
