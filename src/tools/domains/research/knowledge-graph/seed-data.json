    {
      "id": "loss_aversion",
      "type": "concept",
      "name": "Loss Aversion",
      "aliases": ["fear of loss", "loss hurts more than gains feel good"],
      "definition": "Psychological tendency where losses feel about 2x as painful as equivalent gains feel good.",
