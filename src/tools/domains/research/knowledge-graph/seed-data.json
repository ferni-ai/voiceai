      "relatedMetrics": ["Total return", "Net return"],
      "ranges": { "low": 0.03, "typical": 0.2, "high": 0.75, "extreme": 1.5 },
      "metadata": {
        "confidence": 1.0,
        "sources": ["John Bogle", "Morningstar"],
        "helpfulnessScore": 0.95
      }
    },
    {
