    {
      "id": "index_funds",
      "type": "concept",
      "name": "Index Funds",
      "aliases": ["passive investing", "index investing", "market-cap weighted funds"],
      "definition": "Funds that track a market index like the S&P 500, offering broad diversification at low cost.",
