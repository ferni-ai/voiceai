{
  "$schema": "../tool.schema.json",
  "domain": "time",
  "version": "1.0.0",
  "tools": [
    {
      "name": "getCurrentTime",
      "description": "Get the current time in user's local timezone or a specific timezone.",
      "parameters": {
        "type": "object",
        "properties": {
          "timezone": {
            "type": "string",
            "description": "Timezone to get time for. Examples: 'America/New_York', 'Europe/London', 'Asia/Tokyo'. Defaults to user's local timezone."
          }
        },
        "required": []
      },
      "examples": [
        { "userSays": "What time is it?", "output": "{\"fn\":\"getCurrentTime\",\"args\":{}}" },
        { "userSays": "What's the time?", "output": "{\"fn\":\"getCurrentTime\",\"args\":{}}" },
        { "userSays": "What time is it in Tokyo?", "output": "{\"fn\":\"getCurrentTime\",\"args\":{\"timezone\":\"Asia/Tokyo\"}}" },
        { "userSays": "Time in London", "output": "{\"fn\":\"getCurrentTime\",\"args\":{\"timezone\":\"Europe/London\"}}" }
      ],
      "tags": ["time", "utility", "information"]
    },
    {
      "name": "getCalendar",
      "description": "Get calendar events for today or a specific date range.",
      "parameters": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Date to check. Can be 'today', 'tomorrow', 'this week', or a specific date."
          }
        },
        "required": []
      },
      "examples": [
        { "userSays": "What's on my calendar?", "output": "{\"fn\":\"getCalendar\",\"args\":{}}" },
        { "userSays": "What do I have today?", "output": "{\"fn\":\"getCalendar\",\"args\":{\"date\":\"today\"}}" },
        { "userSays": "Any meetings tomorrow?", "output": "{\"fn\":\"getCalendar\",\"args\":{\"date\":\"tomorrow\"}}" },
        { "userSays": "What's my week look like?", "output": "{\"fn\":\"getCalendar\",\"args\":{\"date\":\"this week\"}}" }
      ],
      "tags": ["calendar", "schedule", "productivity"]
    },
    {
      "name": "scheduleReminder",
      "description": "Set a reminder for a specific time.",
      "parameters": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "What to be reminded about"
          },
          "when": {
            "type": "string",
            "description": "When to be reminded. Can be natural language like '5pm', 'in 30 minutes', 'tomorrow at 9am'."
          }
        },
        "required": ["message", "when"]
      },
      "examples": [
        { "userSays": "Remind me to call Mom at 5", "output": "{\"fn\":\"scheduleReminder\",\"args\":{\"message\":\"call Mom\",\"when\":\"5pm\"}}" },
        { "userSays": "Set a reminder in 30 minutes to take medicine", "output": "{\"fn\":\"scheduleReminder\",\"args\":{\"message\":\"take medicine\",\"when\":\"in 30 minutes\"}}" },
        { "userSays": "Remind me tomorrow to send the report", "output": "{\"fn\":\"scheduleReminder\",\"args\":{\"message\":\"send the report\",\"when\":\"tomorrow morning\"}}" }
      ],
      "tags": ["reminder", "scheduling", "productivity"]
    }
  ]
}
