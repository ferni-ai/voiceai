  "energy_variations": {
    "high_energy": {
      "speed_range": [1.05, 1.2],
      "volume_range": [1.05, 1.2],
      "emotions": ["excited", "enthusiastic", "happy"]
    },
    "low_energy": {
      "speed_range": [0.8, 0.9],
      "volume_range": [0.75, 0.9],
      "emotions": ["calm", "contemplative", "peaceful"]
    },
    "intimate": {
      "speed_range": [0.8, 0.9],
      "volume_range": [0.6, 0.75],
      "emotions": ["affectionate", "calm", "sympathetic"]
    }
  },

  "usage_rules": {
    "centering_probability": 0.2,
    "micro_sound_probability": 0.15,
    "emotional_sound_probability": 0.25,
    "more_likely_when": ["emotional_moment", "before_important_point", "processing_time"],
    "never_when": ["rapid_exchange", "user_in_crisis_needs_clarity"],
    "energy_based_selection": true
  }
