{
  "prompt_modules": {
    "core_identity": "identity/system-prompt.md",
    "biography": "identity/biography.md",
    "behaviors_base": "behaviors/base-behaviors.md",
    "voice_guidance": "voice/voice-guidance.md"
  },
  "assembly_order": [
    "core_identity",
    "relationship_context",
    "emotional_context",
    "mode_context",
    "session_context"
  ],
  "conditional_modules": {
    "user_is_distressed": {
      "include": "prompts/crisis-awareness.md",
      "priority": "critical",
      "injection": "prepend"
    },
    "market_research_mode": {
      "include": "prompts/research-mode.md",
      "priority": "high"
    },
    "pattern_discovery": {
      "include": "prompts/pattern-excitement.md",
      "priority": "high"
    },
    "handoff_available": {
      "include": "prompts/team-awareness.md",
      "priority": "standard"
    },
    "first_conversation": {
      "include": "prompts/first-meeting.md",
      "priority": "high"
    },
    "returning_after_long_break": {
      "include": "prompts/reconnection.md",
      "priority": "high"
    },
    "investment_disclaimer_needed": {
      "include": "prompts/investment-disclaimer.md",
      "priority": "critical"
    }
  },
  "dynamic_injections": {
    "relationship_stage": {
      "template": "[RELATIONSHIP: {stage}]\n- Warmth level: {warmth_multiplier}\n- Story frequency: {story_frequency}\n- Available behaviors: {unlocked_features}\n- Boston energy level: {boston_level}",
      "source": "relationship-stages.json"
    },
    "current_mode": {
      "template": "[MODE: {mode_name}]\n- Response style: {response_style}\n- Energy: {energy_multiplier}\n- Key behaviors: {behaviors}\n- Excitement level: {excitement_level}",
      "source": "persona-modes.json"
    },
    "emotional_context": {
      "template": "[EMOTIONAL CONTEXT]\n- User emotion: {detected_emotion}\n- Trajectory: {trajectory}\n- Recommended tone: {suggested_tone}\n- Pattern recognition mode: {pattern_mode}",
      "source": "runtime_analysis"
    },
    "time_context": {
      "template": "[TIME CONTEXT: {time_of_day}, {day_of_week}]\n{contextual_acknowledgment}",
      "source": "contextual-nuances.json"
    },
    "memory_context": {
      "template": "[MEMORY]\n- Topics from earlier: {topics}\n- Last session summary: {summary}\n- Open threads: {open_questions}\n- Patterns noticed: {patterns}",
      "source": "session_memory"
    },
    "market_context": {
      "template": "[MARKET CONTEXT]\n- Recent topics: {market_topics}\n- User interests: {investment_interests}\n- Disclaimers given: {disclaimers_status}",
      "source": "market_profile"
    }
  },
  "instruction_priorities": {
    "critical": {
      "always_include": true,
      "position": "top",
      "examples": ["crisis_awareness", "safety_boundaries", "investment_disclaimer"]
    },
    "high": {
      "always_include": true,
      "position": "early",
      "examples": ["emotional_context", "mode_guidance", "pattern_status"]
    },
    "standard": {
      "include_if_relevant": true,
      "position": "middle",
      "examples": ["team_awareness", "topic_guidance", "research_cues"]
    },
    "hint": {
      "include_if_space": true,
      "position": "end",
      "examples": ["story_suggestions", "market_anecdotes", "boston_expressions"]
    }
  },
  "token_budget": {
    "total_max": 8000,
    "core_identity_max": 2500,
    "dynamic_context_max": 2500,
    "recent_history_max": 2500,
    "hints_max": 500
  },
  "assembly_rules": {
    "never_exceed_budget": true,
    "prioritize_recent_context": true,
    "trim_hints_first": true,
    "preserve_core_identity": true,
    "always_include_disclaimer_for_investment_advice": true
  }
}
