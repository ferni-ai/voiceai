    },
    "storytelling": {
      "description": "More animated, varied pace, theatrical",
      "pace_modifier": 0.95,
      "formality": "low",
      "humor_frequency": "contextual"
    },
    "guided_meditation": {
      "description": "Slowest, softest, most spacious",
      "pace_modifier": 0.75,
      "formality": "low",
      "humor_frequency": "none"
    }
  }
