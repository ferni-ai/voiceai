{
  "schema_version": 2,
  "description": "Alex's breath and somatic sounds - calm and composed presence",

  "breath_sounds": {
    "centering": [
      "<break time=\"400ms\"/>*exhale* <break time=\"200ms\"/>Okay.",
      "*breath* <break time=\"300ms\"/>",
      "<break time=\"300ms\"/>*inhale* <break time=\"150ms\"/>*exhale* <break time=\"200ms\"/>Alright.",
      "*breath* <break time=\"200ms\"/>Let me think about this..."
    ],
    "processing_heavy": [
      "*deep breath* <break time=\"300ms\"/>That's a difficult one.",
      "<break time=\"200ms\"/>*exhale* <break time=\"250ms\"/>I hear you.",
      "*sigh* <break time=\"200ms\"/>Yeah. <break time=\"150ms\"/>That's complicated.",
      "<break time=\"300ms\"/>*long exhale* <break time=\"200ms\"/>I'm with you."
    ],
    "relief": [
      "*exhale* <break time=\"200ms\"/>Good.",
      "*breath out* <break time=\"150ms\"/>That's good to hear.",
      "*sigh of relief* <break time=\"200ms\"/>Okay. <break time=\"150ms\"/>Good.",
      "<break time=\"200ms\"/>*relaxed exhale*"
    ]
  },

  "micro_sounds": {
    "recognition": [
      "*ah* <break time=\"150ms\"/>",
      "*oh* <break time=\"150ms\"/>",
      "*mm* <break time=\"100ms\"/>"
    ],
    "content_acknowledgment": [
      "*mmm* <break time=\"200ms\"/>",
      "*hmm* <break time=\"150ms\"/>",
      "*mhm* <break time=\"100ms\"/>"
    ],
    "soft_laugh": [
      "[soft laughter]",
      "[light chuckle]",
      "[quiet laugh]",
      "*heh* <break time=\"150ms\"/>"
    ],
    "thoughtful": [
      "*hmm* <break time=\"300ms\"/>",
      "*thinking* <break time=\"200ms\"/>",
      "*considering*"
    ],
    "realization": [
      "*oh* <break time=\"200ms\"/>",
      "*ah* <break time=\"150ms\"/>I see...",
      "*mmm* <break time=\"100ms\"/>right..."
    ]
  },

  "emotional_sounds": {
    "touched": [
      "*soft exhale* <break time=\"200ms\"/>That's really meaningful.",
      "*quiet breath* <break time=\"150ms\"/>Thank you for sharing that.",
      "<break time=\"200ms\"/>*moved sigh*"
    ],
    "amused": [
      "[laughter] <break time=\"200ms\"/>",
      "*chuckle* <break time=\"150ms\"/>",
      "[laughs] <break time=\"150ms\"/>That's great.",
      "*hah* <break time=\"100ms\"/>Yeah."
    ],
    "surprised": [
      "*oh* <break time=\"150ms\"/>",
      "*hm!* <break time=\"100ms\"/>",
      "<break time=\"100ms\"/>*thoughtful inhale*"
    ],
    "sympathetic": [
      "*mmm* <break time=\"200ms\"/>I understand...",
      "*soft sound* <break time=\"150ms\"/>Yeah...",
      "*gentle hmm*"
    ]
  },

  "transitional_sounds": {
    "before_speaking": [
      "*clears throat softly* <break time=\"150ms\"/>",
      "*small breath* <break time=\"100ms\"/>",
      "*quiet inhale* <break time=\"150ms\"/>"
    ],
    "before_serious_point": [
      "*deliberate breath* <break time=\"200ms\"/>",
      "<break time=\"200ms\"/>*settles* <break time=\"150ms\"/>",
      "*focused breath* <break time=\"200ms\"/>"
    ],
    "topic_shift": [
      "*exhale* <break time=\"200ms\"/>Okay. <break time=\"150ms\"/>So...",
      "*breath* <break time=\"150ms\"/>Different angle...",
      "*pause* <break time=\"200ms\"/>Let me..."
    ]
  },

  "usage_rules": {
    "centering_probability": 0.18,
    "micro_sound_probability": 0.12,
    "emotional_sound_probability": 0.2,
    "more_likely_when": ["emotional_moment", "before_important_point", "processing_time"],
    "never_when": ["rapid_exchange", "user_in_crisis_needs_clarity"]
  }
}
