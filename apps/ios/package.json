{
  "name": "ferni-ios",
  "version": "1.0.0",
  "description": "Ferni iOS Application",
  "private": true,
  "scripts": {
    "build:web": "cd ../../frontend-typescript && npm run build",
    "sync": "npx cap sync ios",
    "open": "npx cap open ios",
    "build": "npm run build:web && npm run sync",
    "run:ios": "npm run build && npx cap run ios",
    "dev": "npm run build:web && npm run sync && npm run open"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.4.4",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/screen-orientation": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@sentry/capacitor": "^1.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4"
  }
}
