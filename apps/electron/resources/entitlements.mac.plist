<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT for better performance -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow unsigned executable memory (required for Electron) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Hardened Runtime exceptions for Electron -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Microphone access for voice AI -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    
    <!-- Camera access (optional, for future video features) -->
    <key>com.apple.security.device.camera</key>
    <true/>
    
    <!-- Network access for LiveKit/WebRTC -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>

