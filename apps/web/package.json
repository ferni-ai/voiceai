{
  "name": "voiceai-frontend",
  "version": "1.0.1",
  "description": "Ferni Frontend - Better than human. Voice-first life coaching experience.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:strict": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx --fix",
    "lint:tokens": "node scripts/validate-design-tokens.js",
    "lint:result-types": "node scripts/lint-result-types.js",
    "lint:i18n": "node scripts/lint-i18n.js",
    "i18n:sync": "node scripts/sync-i18n.js --write",
    "i18n:sync-missing": "node scripts/sync-missing-i18n.js",
    "i18n:check": "node scripts/sync-i18n.js",
    "i18n:extract": "node scripts/extract-i18n-strings.js",
    "i18n:fix:toasts": "node scripts/fix-i18n-toasts.js",
    "i18n:fix:text": "node scripts/fix-i18n-text.js",
    "i18n:fix:aria": "node scripts/fix-i18n-aria.js",
    "i18n:fix:all": "node scripts/fix-i18n-toasts.js && node scripts/fix-i18n-text.js && node scripts/fix-i18n-aria.js && npm run i18n:sync-missing",
    "i18n:coverage": "node scripts/sync-missing-i18n.js",
    "generate:icons": "node scripts/generate-icons.js",
    "lint:brand": "node scripts/check-brand-compliance.js",
    "lint:a11y": "node scripts/check-a11y-colors.js",
    "lint:a11y:strict": "node scripts/check-a11y-colors.js --strict",
    "lint:a11y:fix": "node scripts/check-a11y-colors.js --fix",
    "audit:ui": "node scripts/audit-ui.js",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run lint:tokens && npm run lint:brand && npm run lint:a11y && npm run test -- --run",
    "quality:full": "npm run quality && npm run audit:ui",
    "bundle:check": "node scripts/bundle-size-check.js",
    "build:check": "npm run build && npm run bundle:check",
    "quality:check": "node scripts/quality-check.js",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.4",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/local-notifications": "^7.0.3",
    "@capacitor/push-notifications": "^7.0.3",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/slim": "^3.9.1",
    "firebase": "^10.14.1",
    "gsap": "^3.13.0",
    "livekit-client": "^2.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.2",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jsdom": "^23.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-bundle-visualizer": "1.2.1",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/ui/**/*.ts": [
      "node scripts/validate-design-tokens.js",
      "node scripts/check-a11y-colors.js --strict",
      "node scripts/lint-i18n.js --staged"
    ],
    "src/services/**/*.ts": [
      "node scripts/lint-i18n.js --staged"
    ],
    "src/**/*.{ts,tsx,css}": [
      "node scripts/check-brand-compliance.js"
    ],
    "public/**/*.{css,html}": [
      "node scripts/check-brand-compliance.js"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
