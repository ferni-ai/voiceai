{
  "name": "voiceai-frontend",
  "version": "1.0.1",
  "description": "Ferni Frontend - Better than human. Voice-first life coaching experience.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:strict": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx --fix",
    "lint:tokens": "node scripts/validate-design-tokens.js",
    "generate:icons": "node scripts/generate-icons.js",
    "lint:brand": "node scripts/check-brand-compliance.js",
    "lint:a11y": "node scripts/check-a11y-colors.js",
    "lint:a11y:strict": "node scripts/check-a11y-colors.js --strict",
    "lint:a11y:fix": "node scripts/check-a11y-colors.js --fix",
    "audit:ui": "node scripts/audit-ui.js",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run lint:tokens && npm run lint:brand && npm run lint:a11y && npm run test -- --run",
    "quality:full": "npm run quality && npm run audit:ui",
    "bundle:check": "node scripts/bundle-size-check.js",
    "build:check": "npm run build && npm run bundle:check",
    "quality:check": "node scripts/quality-check.js",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.4",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/local-notifications": "^7.0.3",
    "@capacitor/push-notifications": "^7.0.3",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/slim": "^3.9.1",
    "firebase": "^10.14.1",
    "gsap": "^3.13.0",
    "livekit-client": "^2.16.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jsdom": "^23.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-bundle-visualizer": "1.2.1",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/ui/**/*.ts": [
      "node scripts/validate-design-tokens.js",
      "node scripts/check-a11y-colors.js --strict"
    ],
    "src/**/*.{ts,tsx,css}": [
      "node scripts/check-brand-compliance.js"
    ],
    "public/**/*.{css,html}": [
      "node scripts/check-brand-compliance.js"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
