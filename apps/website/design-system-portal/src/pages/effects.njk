  <!-- Loading States -->
  <section class="section" id="loading">
    <h2>Loading States</h2>

    <h3>Shimmer Effect</h3>
    <p>Loading skeleton shimmer makes loading feel alive.</p>

    <div class="shimmer-demo">
      <div class="shimmer-card">
        <div class="shimmer-avatar"></div>
        <div class="shimmer-content">
          <div class="shimmer-line"></div>
          <div class="shimmer-line short"></div>
        </div>
      </div>
    </div>

    <pre><code>.shimmer {
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.08) 50%,
    transparent 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}</code></pre>
  </section>

  <!-- Accessibility -->
  <section class="section" id="accessibility">
    <h2>Accessibility</h2>
    <p>Visual effects must respect user preferences.</p>

    <div class="a11y-grid">
      <div class="a11y-card">
        <h4>Reduced Motion</h4>
        <p>For users with vestibular disorders</p>
        <pre><code>@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}</code></pre>
      </div>

      <div class="a11y-card">
        <h4>Focus Ring</h4>
        <p>High-visibility for keyboard navigation</p>
        <pre><code>:focus-visible {
  outline: 3px solid var(--color-focus-ring);
  outline-offset: 2px;
}</code></pre>
      </div>

      <div class="a11y-card">
        <h4>High Contrast</h4>
        <p>Enhanced contrast for visual impairments</p>
        <pre><code>@media (prefers-contrast: high) {
  .glass {
    border-width: 2px;
  }
}</code></pre>
      </div>
    </div>
  </section>
</article>

<style>
/* Effects Page Styles */
.effects-page {
  max-width: 1200px;
  margin: 0 auto;
}

/* Gradient Grid */
.gradient-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--space-4);
  margin-top: var(--space-6);
}

.gradient-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--border-subtle);
}

.gradient-card.wide {
  grid-column: 1 / -1;
}

.gradient-preview {
  height: 120px;
}

.gradient-preview.aurora {
  background: linear-gradient(135deg, rgba(74, 103, 65, 0.4) 0%, rgba(212, 168, 74, 0.4) 50%, rgba(92, 184, 132, 0.4) 100%);
}

.gradient-preview.warm-glow {
  background: radial-gradient(circle at 50% 50%, rgba(212, 168, 74, 0.5) 0%, transparent 70%), var(--bg-subtle);
}

.gradient-preview.sunbeam {
  background: linear-gradient(180deg, rgba(212, 168, 74, 0.3) 0%, transparent 70%), var(--bg-subtle);
}

.gradient-preview.persona-glow {
  background: radial-gradient(circle at 50% 50%, var(--color-ferni) 0%, transparent 60%);
  opacity: 0.5;
}

.gradient-preview.mesh {
  background:
    radial-gradient(at 40% 20%, rgba(74, 103, 65, 0.3) 0px, transparent 50%),
    radial-gradient(at 80% 0%, rgba(212, 168, 74, 0.3) 0px, transparent 50%),
    radial-gradient(at 0% 50%, rgba(92, 184, 132, 0.2) 0px, transparent 50%),
    var(--bg-subtle);
}

.gradient-info {
  padding: var(--space-4);
}

.gradient-info h4 {
  margin-bottom: var(--space-2);
}

.gradient-info p {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
}

.gradient-info code {
  font-size: var(--text-xs);
  word-break: break-all;
}

/* Texture Grid */
.texture-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--space-4);
  margin-top: var(--space-6);
}

.texture-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--border-subtle);
}

.texture-preview {
  height: 120px;
  position: relative;
}

.texture-preview.paper-grain {
  background: var(--bg-subtle);
}

.texture-preview.paper-grain::after {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.15;
}

.texture-preview.linen {
  background:
    repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(128,128,128,0.1) 2px, rgba(128,128,128,0.1) 4px),
    repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(128,128,128,0.1) 2px, rgba(128,128,128,0.1) 4px),
    var(--bg-subtle);
}

.texture-preview.noise {
  background: var(--bg-subtle);
}

.texture-preview.noise::after {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.2;
}

.texture-info {
  padding: var(--space-4);
}

.texture-info h4 {
  margin-bottom: var(--space-2);
}

.texture-info p {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.texture-opacity {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  font-family: var(--font-mono);
}

/* Glass Thickness Scale */
.thickness-cards {
  display: flex;
  gap: var(--space-4);
  margin-top: var(--space-6);
  overflow-x: auto;
  padding-bottom: var(--space-2);
}

.thickness-card {
  flex: 0 0 160px;
}

.glass-sample {
  height: 100px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
