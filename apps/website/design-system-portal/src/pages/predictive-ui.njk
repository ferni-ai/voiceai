        </div>
        <div class="density balanced">
          <span class="label">Balanced</span>
          <ul>
            <li>Spacing: 1×</li>
            <li>Font: 1×</li>
            <li>Items/view: 5</li>
          </ul>
        </div>
        <div class="density dense">
          <span class="label">Dense</span>
          <ul>
            <li>Spacing: 0.8×</li>
            <li>Font: 0.95×</li>
            <li>Items/view: 8</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="personalization-card">
      <h4>Interaction Speed</h4>
      <div class="speed-options">
        <div class="speed deliberate">
          <span class="label">Deliberate</span>
          <ul>
            <li>Animation: 0.8×</li>
            <li>Hold duration: 1.2×</li>
            <li>Tooltip delay: 400ms</li>
          </ul>
        </div>
        <div class="speed balanced">
          <span class="label">Balanced</span>
          <ul>
            <li>Animation: 1×</li>
            <li>Hold duration: 1×</li>
            <li>Tooltip delay: 300ms</li>
          </ul>
        </div>
        <div class="speed quick">
          <span class="label">Quick</span>
          <ul>
            <li>Animation: 1.3×</li>
            <li>Hold duration: 0.7×</li>
            <li>Tooltip delay: 150ms</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="personalization-card">
      <h4>Visual Complexity</h4>
      <div class="complexity-options">
        <div class="complexity calm">
          <span class="label">Calm</span>
          <ul>
            <li>Particles: none</li>
            <li>Gradients: subtle</li>
            <li>Animations: minimal</li>
          </ul>
        </div>
        <div class="complexity balanced">
          <span class="label">Balanced</span>
          <ul>
            <li>Particles: light</li>
            <li>Gradients: moderate</li>
            <li>Animations: standard</li>
          </ul>
        </div>
        <div class="complexity rich">
          <span class="label">Rich</span>
          <ul>
            <li>Particles: full</li>
            <li>Gradients: vibrant</li>
            <li>Animations: expressive</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.skeleton-demo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-6);
  margin: var(--space-6) 0;
  align-items: center;
}

.skeleton-card {
  padding: var(--space-5);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
}

.skeleton-line {
  height: 16px;
  background: linear-gradient(90deg, var(--color-border-subtle) 0%, var(--color-bg-elevated) 50%, var(--color-border-subtle) 100%);
  background-size: 200% 100%;
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-3);
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-specs ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.skeleton-specs li {
  padding: var(--space-1) 0;
}

.ghost-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.ghost-item {
  text-align: center;
}

.ghost-shape {
  margin: 0 auto var(--space-3);
  background: var(--color-border-subtle);
  animation: pulse 2s ease-in-out infinite;
}

.ghost-shape.text-line {
  width: 80%;
  height: 16px;
  border-radius: var(--radius-sm);
}

.ghost-shape.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
}

.ghost-shape.card {
  width: 100%;
  aspect-ratio: 16/9;
  border-radius: var(--radius-md);
}

.ghost-shape.button {
  width: 120px;
  height: 44px;
  border-radius: var(--radius-full);
}

.ghost-item span {
  display: block;
  margin-bottom: var(--space-1);
  font-weight: 500;
}

.ghost-item code {
  font-size: 0.75rem;
  color: var(--color-text-tertiary);
}

.reveal-demo {
  display: flex;
  gap: var(--space-3);
  margin: var(--space-6) 0;
}

.reveal-item {
  flex: 1;
  padding: var(--space-3);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-md);
  text-align: center;
  animation: revealItem 3s ease-out infinite;
  animation-delay: calc(var(--delay) * 0.15s);
}

@keyframes revealItem {
  0%, 100% { opacity: 0.3; transform: translateY(8px); }
  20%, 80% { opacity: 1; transform: translateY(0); }
}

.reveal-item .priority {
  display: block;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-accent);
}

.reveal-item .element {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
}

.spec-note {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  text-align: center;
}

.anticipation-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.anticipation-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
}

.anticipation-card h4 {
  margin: 0 0 var(--space-2);
  color: var(--color-accent);
}

.anticipation-card > p {
  margin: 0 0 var(--space-3);
  color: var(--color-text-secondary);
}

.anticipation-card ul {
  list-style: none;
  padding: 0;
  margin: 0;
  font-size: 0.9rem;
}

.anticipation-card li {
  padding: var(--space-1) 0;
}

.time-preloads, .context-preloads {
  margin-top: var(--space-3);
}

.time-slot, .context-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-2);
  border-bottom: 1px solid var(--color-border-subtle);
  font-size: 0.85rem;
}

.time-slot .time, .context-row .context {
  font-weight: 500;
}

.time-slot .content, .context-row .loads {
  color: var(--color-text-secondary);
}

.suggestion-types {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.suggestion-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
}

.suggestion-demo {
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-primary);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-4);
}

.suggestion-bubble {
  padding: var(--space-3) var(--space-4);
  background: var(--glass-regular-background);
  backdrop-filter: blur(8px);
  border-radius: 16px;
  font-size: 0.9rem;
  max-width: 200px;
  animation: bubbleIn 2s ease-out infinite;
}

@keyframes bubbleIn {
  0%, 100% { opacity: 0; transform: scale(0.8) translateY(10px); }
  30%, 70% { opacity: 1; transform: scale(1) translateY(0); }
}

.nudge-target {
  width: 60px;
  height: 60px;
  background: var(--color-accent);
  border-radius: var(--radius-md);
  position: relative;
}

.nudge-arrow {
  position: absolute;
  right: -20px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 8px solid transparent;
  border-bottom: 8px solid transparent;
  border-left: 12px solid var(--color-accent);
  animation: nudgePulse 2s ease-in-out infinite;
}

@keyframes nudgePulse {
  0%, 100% { transform: translateY(-50%) translateX(0); }
  25% { transform: translateY(-50%) translateX(4px); }
  75% { transform: translateY(-50%) translateX(-2px); }
}

.spotlight-target {
  width: 60px;
  height: 60px;
  background: var(--color-accent);
  border-radius: var(--radius-md);
  box-shadow: 0 0 20px var(--color-accent);
  animation: spotlightPulse 3s ease-in-out infinite;
}

@keyframes spotlightPulse {
  0%, 100% { box-shadow: 0 0 20px var(--color-accent); }
  50% { box-shadow: 0 0 40px var(--color-accent); }
}

.suggestion-card h4 {
  margin: 0 0 var(--space-3);
}

.suggestion-card ul {
  list-style: none;
  padding: 0;
  margin: 0;
  font-size: 0.9rem;
}

