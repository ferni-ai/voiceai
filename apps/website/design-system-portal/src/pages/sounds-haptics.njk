  <!-- Philosophy Section -->
  <section class="section">
    <h2>Philosophy</h2>
    <div class="philosophy-cards">
      <div class="philosophy-card">
        <div class="philosophy-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18V5l12-2v13"/>
            <circle cx="6" cy="18" r="3"/>
            <circle cx="18" cy="16" r="3"/>
          </svg>
        </div>
        <h3>Sound</h3>
        <p>Every sound should feel like it belongs in nature—warm chimes, soft tones, organic textures. Never harsh, never robotic.</p>
      </div>
      <div class="philosophy-card">
        <div class="philosophy-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/>
            <path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/>
            <path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/>
            <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>
          </svg>
        </div>
        <h3>Haptics</h3>
        <p>Touch feedback that feels like communication—breathing rhythms, heartbeats, gentle acknowledgments. Felt, not noticed.</p>
      </div>
      <div class="philosophy-card">
        <div class="philosophy-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
        </div>
        <h3>Timing</h3>
        <p>Synchronize with user actions. Immediate for confirmations, gentle delays for emotional moments. Never jarring.</p>
      </div>
    </div>
  </section>

