<script>
// Spring animation triggers
function triggerSpring(demoElement, springType) {
  var ball = demoElement.querySelector('.spring-ball');

  // Define spring timings (approximated with CSS transitions)
  var springConfigs = {
    snappy: { duration: 200, easing: 'cubic-bezier(0.34, 1.2, 0.64, 1)' },
    gentle: { duration: 500, easing: 'cubic-bezier(0.34, 1.1, 0.64, 1)' },
    bouncy: { duration: 600, easing: 'cubic-bezier(0.34, 1.8, 0.64, 1)' },
    heavy: { duration: 800, easing: 'cubic-bezier(0.4, 0, 0.2, 1)' },
    ethereal: { duration: 1200, easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)' },
    organic: { duration: 500, easing: 'cubic-bezier(0.34, 1.3, 0.64, 1)' }
  };

  var config = springConfigs[springType];
  ball.style.transition = 'transform ' + config.duration + 'ms ' + config.easing;

  // Animate out
  ball.style.transform = 'scale(1.5)';

  // Animate back
  setTimeout(function() {
    ball.style.transform = 'scale(1)';
  }, config.duration);
}

// Gravity demo
function triggerGravityDemo() {
  var demo = document.getElementById('gravityDemo');
  demo.classList.remove('dropped');

  // Force reflow
  void demo.offsetWidth;

  demo.classList.add('dropped');
}

// Ripple effect
function createRipple(event, container) {
  var rect = container.getBoundingClientRect();
  var x = event.clientX - rect.left;
  var y = event.clientY - rect.top;

  var ripple = document.createElement('div');
  ripple.className = 'ripple';
  ripple.style.left = (x - 50) + 'px';
  ripple.style.top = (y - 50) + 'px';
  ripple.style.width = '100px';
  ripple.style.height = '100px';

  container.appendChild(ripple);

  setTimeout(function() {
    ripple.remove();
  }, 600);
}

// Auto-run demos on load
document.addEventListener('DOMContentLoaded', function() {
  // Trigger initial gravity demo
  setTimeout(triggerGravityDemo, 1000);
});
</script>
