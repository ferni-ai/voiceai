        <div class="gravity-ball" data-type="floating"></div>
        <div class="gravity-floor"></div>
      </div>
      <button class="demo-btn" onclick="triggerGravityDemo()">Drop All</button>
    </div>

    <div class="gravity-grid">
      <div class="gravity-card">
        <h4>Light</h4>
        <p>Gentle settling, soft landings</p>
        <div class="gravity-specs">
          <span>Acceleration: 200</span>
          <span>Bounce: 0.4</span>
        </div>
      </div>
      <div class="gravity-card">
        <h4>Normal</h4>
        <p>Standard physics</p>
        <div class="gravity-specs">
          <span>Acceleration: 980</span>
          <span>Bounce: 0.3</span>
        </div>
      </div>
      <div class="gravity-card">
        <h4>Heavy</h4>
        <p>Dramatic impacts, importance</p>
        <div class="gravity-specs">
          <span>Acceleration: 1500</span>
          <span>Bounce: 0.1</span>
        </div>
      </div>
      <div class="gravity-card">
