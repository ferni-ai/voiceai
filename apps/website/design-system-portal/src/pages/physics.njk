<style>
/* Physics Page Styles */
.physics-page {
  max-width: 1200px;
  margin: 0 auto;
}

/* Spring Grid */
.spring-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--space-4);
  margin-top: var(--space-6);
}

.spring-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--border-subtle);
}

.spring-demo {
  height: 120px;
  background: var(--bg-subtle);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spring-ball {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-full);
  background: var(--color-ferni);
  transform: scale(1);
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.spring-demo[data-animating="true"] .spring-ball {
  transform: scale(1.5);
}

.spring-card[data-spring="snappy"] .spring-ball { background: var(--color-peter); }
.spring-card[data-spring="gentle"] .spring-ball { background: var(--color-ferni); }
.spring-card[data-spring="bouncy"] .spring-ball { background: var(--color-maya); }
.spring-card[data-spring="heavy"] .spring-ball { background: var(--color-alex); }
.spring-card[data-spring="ethereal"] .spring-ball { background: var(--color-jordan); }
.spring-card[data-spring="organic"] .spring-ball { background: var(--color-nayan); }

.replay-btn {
  position: absolute;
  bottom: var(--space-2);
  right: var(--space-2);
  padding: var(--space-1) var(--space-3);
  background: var(--bg-elevated);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  cursor: pointer;
  transition: all 0.2s;
}

.replay-btn:hover {
  background: var(--color-accent);
  color: white;
  border-color: var(--color-accent);
}

.spring-info {
  padding: var(--space-4);
}

.spring-info h4 {
  margin-bottom: var(--space-1);
}

.emotional-context {
  font-size: var(--text-sm);
  color: var(--color-accent);
  font-style: italic;
  margin-bottom: var(--space-3);
}

.spring-params {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
  font-size: var(--text-sm);
}

.spring-params span {
  color: var(--text-secondary);
}

.spring-params strong {
  color: var(--text-primary);
}

.use-case {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  padding: var(--space-2) var(--space-3);
  background: var(--bg-subtle);
  border-radius: var(--radius-md);
  margin: 0;
}

/* Momentum Grid */
.momentum-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: var(--space-4);
  margin-top: var(--space-6);
}

.momentum-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  border: 1px solid var(--border-subtle);
}

.momentum-card h4 {
  margin-bottom: var(--space-3);
}

.card-description {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
}

.momentum-specs {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.spec-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--text-sm);
}

.spec-row span {
  color: var(--text-secondary);
}

.spec-row code {
  background: var(--bg-subtle);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
  font-size: var(--text-xs);
}

/* Gravity Section */
.gravity-demo-container {
  margin: var(--space-6) 0;
  text-align: center;
}

.gravity-demo {
  height: 200px;
  background: var(--bg-subtle);
  border-radius: var(--radius-lg);
  position: relative;
  overflow: hidden;
  margin-bottom: var(--space-4);
  display: flex;
  justify-content: space-around;
  padding: var(--space-4);
}

.gravity-ball {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-full);
  position: absolute;
  top: 20px;
  transition: top 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.gravity-ball[data-type="light"] {
  background: var(--color-jordan);
  left: 15%;
}

.gravity-ball[data-type="normal"] {
  background: var(--color-ferni);
  left: 38%;
}

.gravity-ball[data-type="heavy"] {
  background: var(--color-alex);
  left: 55%;
}

.gravity-ball[data-type="floating"] {
  background: var(--color-maya);
  left: 78%;
}

.gravity-demo.dropped .gravity-ball {
  top: calc(100% - 60px);
}

.gravity-demo.dropped .gravity-ball[data-type="light"] {
  animation: bounceLightGravity 0.8s ease-out;
}

.gravity-demo.dropped .gravity-ball[data-type="normal"] {
  animation: bounceNormalGravity 0.6s ease-out;
}

.gravity-demo.dropped .gravity-ball[data-type="heavy"] {
  animation: bounceHeavyGravity 0.4s ease-out;
}

.gravity-demo.dropped .gravity-ball[data-type="floating"] {
  animation: bounceFloatingGravity 1.5s ease-out;
}

@keyframes bounceLightGravity {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30px); }
}

@keyframes bounceNormalGravity {
  0%, 100% { transform: translateY(0); }
  40% { transform: translateY(-20px); }
}

@keyframes bounceHeavyGravity {
  0%, 100% { transform: translateY(0); }
  30% { transform: translateY(-8px); }
}

@keyframes bounceFloatingGravity {
  0%, 100% { transform: translateY(0); }
  25% { transform: translateY(-40px); }
  50% { transform: translateY(-20px); }
  75% { transform: translateY(-30px); }
}

.gravity-floor {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 20px;
  background: var(--border-subtle);
}

.demo-btn {
  padding: var(--space-2) var(--space-5);
