        Hero headline
      </div>
    </div>
    <div class="type-sample">
      <div class="type-sample-label">text-5xl<br>3rem</div>
      <div class="type-sample-text" style="font-size: var(--text-5xl); font-family: var(--font-display); font-weight: 700; line-height: var(--leading-tight);">
        Page title
      </div>
    </div>
    <div class="type-sample">
      <div class="type-sample-label">text-4xl<br>2.25rem</div>
      <div class="type-sample-text" style="font-size: var(--text-4xl); font-family: var(--font-display); font-weight: 700; line-height: var(--leading-tight);">
        Section heading
      </div>
    </div>
    <div class="type-sample">
      <div class="type-sample-label">text-3xl<br>1.875rem</div>
      <div class="type-sample-text" style="font-size: var(--text-3xl); font-family: var(--font-display); font-weight: 600;">
        Subsection heading
      </div>
    </div>
    <div class="type-sample">
      <div class="type-sample-label">text-2xl<br>1.5rem</div>
      <div class="type-sample-text" style="font-size: var(--text-2xl); font-family: var(--font-display); font-weight: 600;">
        Card title
      </div>
    </div>
    <div class="type-sample">
      <div class="type-sample-label">text-xl<br>1.25rem</div>
      <div class="type-sample-text" style="font-size: var(--text-xl);">
