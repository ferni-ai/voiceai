<h1>Typography</h1>
<p class="lead">
  A thoughtful type system built on three font families: Plus Jakarta Sans for display, Inter for body text, and JetBrains Mono for code.
</p>

<section class="section">
  <h2>Font Families</h2>

  <div class="type-scale">
    <div class="type-sample">
      <div class="type-sample-label">Display</div>
      <div class="type-sample-text" style="font-family: var(--font-display); font-size: var(--text-3xl);">
        Plus Jakarta Sans - The quick brown fox
      </div>
    </div>
    <div class="type-sample">
      <div class="type-sample-label">Body</div>
      <div class="type-sample-text" style="font-family: var(--font-body);">
        Inter - The quick brown fox jumps over the lazy dog. Perfect for longer reading.
      </div>
    </div>
    <div class="type-sample">
      <div class="type-sample-label">Mono</div>
      <div class="type-sample-text" style="font-family: var(--font-mono);">
        JetBrains Mono - const greeting = "Hello, world!";
      </div>
    </div>
  </div>

  <pre><code>--font-display: 'Plus Jakarta Sans', -apple-system, sans-serif;
--font-body: 'Inter', -apple-system, sans-serif;
--font-mono: 'JetBrains Mono', 'Fira Code', monospace;</code></pre>
</section>

<section class="section">
