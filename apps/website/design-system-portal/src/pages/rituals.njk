          <label><input type="checkbox" checked disabled> System</label>
          <label><input type="checkbox" checked disabled> Celebration</label>
          <label><input type="checkbox" checked disabled> Notification</label>
          <label><input type="checkbox" checked disabled> Ambient</label>
        </div>
        <div class="volume-slider">
          <span>Volume</span>
          <div class="slider-track">
            <div class="slider-fill" style="width: 80%"></div>
          </div>
          <span>80%</span>
        </div>
      </div>

      <div class="preference-card">
        <h4>Visual Effects</h4>
        <div class="preference-toggles">
          <label><input type="checkbox" checked disabled> Confetti</label>
          <label><input type="checkbox" checked disabled> Glow Effects</label>
          <label><input type="checkbox" disabled> Reduced Motion</label>
        </div>
      </div>
    </div>
  </section>

  <!-- Usage Example -->
  <section class="section" id="usage">
    <h2>Usage</h2>
    <div class="code-example">
      <pre><code>import { triggerRitual, rituals } from 'design-system/rituals';

// Trigger a ritual by ID
await triggerRitual('small_win');

// Trigger with custom parameters
await triggerRitual('streak', {
  streakCount: 7,
  personalized: true
});

// Check if ritual can fire (respects cooldowns)
if (rituals.canFire('thinking_of_you')) {
  await triggerRitual('thinking_of_you');
}

// Listen for ritual completion
rituals.on('ritual:complete', (ritual) => {
  console.log(`Ritual ${ritual.id} completed`);
});</code></pre>
    </div>
  </section>
</article>

<style>
/* Rituals Page Styles */
.rituals-page {
  max-width: 1200px;
  margin: 0 auto;
}

/* Philosophy Card */
.philosophy-card {
  background: linear-gradient(135deg, var(--bg-elevated), var(--bg-subtle));
  border-radius: var(--radius-xl);
  padding: var(--space-8);
  border: 1px solid var(--border-subtle);
}

.philosophy-card h2 {
  margin-bottom: var(--space-4);
}

.philosophy-card p {
  font-size: var(--text-lg);
  line-height: 1.7;
  color: var(--text-secondary);
  margin-bottom: var(--space-4);
}

.philosophy-card p:last-child {
  margin-bottom: 0;
}

/* Rituals Grid */
.rituals-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: var(--space-4);
  margin-top: var(--space-6);
}

.ritual-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  border: 1px solid var(--border-subtle);
  transition: transform 0.2s, box-shadow 0.2s;
}

.ritual-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.ritual-header {
  display: flex;
  gap: var(--space-4);
  margin-bottom: var(--space-3);
}

.ritual-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.wake-icon { background: linear-gradient(135deg, #FFD93D, #FF9F1C); }
.connection-icon { background: linear-gradient(135deg, var(--color-ferni), var(--color-peter)); }
.listening-icon { background: linear-gradient(135deg, var(--color-peter), var(--color-alex)); }
.persona-icon { background: linear-gradient(135deg, var(--color-maya), var(--color-jordan)); }
.small-win-icon { background: linear-gradient(135deg, #4ADE80, #22C55E); }
.big-win-icon { background: linear-gradient(135deg, #FBBF24, #F59E0B); }
.streak-icon { background: linear-gradient(135deg, #F472B6, #EC4899); }
.team-icon { background: linear-gradient(135deg, var(--color-nayan), var(--color-ferni)); }
.deep-icon { background: linear-gradient(135deg, #818CF8, #6366F1); }
.thinking-icon { background: linear-gradient(135deg, var(--color-maya), var(--color-alex)); }
.goodbye-icon { background: linear-gradient(135deg, var(--color-jordan), var(--color-nayan)); }

.ritual-meta h3 {
  margin: 0 0 var(--space-1);
  font-size: var(--text-lg);
}

.ritual-trigger {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  background: var(--bg-subtle);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
}

.ritual-description {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-4);
}

/* Ritual Steps */
.ritual-steps {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
  padding: var(--space-3);
  background: var(--bg-subtle);
  border-radius: var(--radius-md);
}

.step {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: var(--text-sm);
}

.step-icon {
  width: 20px;
  height: 20px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.step[data-type="glow"] .step-icon { background: linear-gradient(135deg, #FFD93D, #FF9F1C); }
.step[data-type="audio"] .step-icon { background: linear-gradient(135deg, #60A5FA, #3B82F6); }
.step[data-type="haptic"] .step-icon { background: linear-gradient(135deg, #A78BFA, #8B5CF6); }
.step[data-type="visual"] .step-icon { background: linear-gradient(135deg, #4ADE80, #22C55E); }

.step-action {
  flex: 1;
  font-family: var(--font-mono);
  color: var(--text-primary);
}

.step-delay {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

/* Ritual Footer */
.ritual-footer {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  align-items: center;
}

.emotion-badge {
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
}

.emotion-badge.welcoming { background: rgba(74, 222, 128, 0.15); color: #22C55E; }
