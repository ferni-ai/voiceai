  <!-- Step Types Legend -->
  <section class="section" id="step-types">
    <h2>Step Types</h2>
    <p>Each ritual step has a type that determines which system handles it.</p>

    <div class="step-types-grid">
      <div class="step-type-card">
        <div class="step-type-icon glow-type"></div>
        <h4>Glow</h4>
        <p>Avatar glow animations—breathing, pulsing, celebrating, persona color shifts</p>
        <code>type: "glow"</code>
      </div>

      <div class="step-type-card">
        <div class="step-type-icon audio-type"></div>
        <h4>Audio</h4>
        <p>Sound effects from the audio library—startup chimes, celebrations, notifications</p>
        <code>type: "audio"</code>
      </div>

      <div class="step-type-card">
        <div class="step-type-icon haptic-type"></div>
        <h4>Haptic</h4>
        <p>Tactile feedback patterns—taps, bumps, vibration sequences</p>
        <code>type: "haptic"</code>
      </div>

      <div class="step-type-card">
        <div class="step-type-icon visual-type"></div>
        <h4>Visual</h4>
        <p>Screen animations—confetti, particles, celebration effects</p>
        <code>type: "visual"</code>
      </div>
    </div>
  </section>

  <!-- Preferences -->
  <section class="section" id="preferences">
    <h2>User Preferences</h2>
    <p>Users can customize ritual behavior to match their preferences.</p>

    <div class="preferences-grid">
      <div class="preference-card">
        <h4>Haptics</h4>
        <div class="preference-options">
