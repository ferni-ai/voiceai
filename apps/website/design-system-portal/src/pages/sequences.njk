<div class="page-header">
  <h1>Animation Sequences</h1>
  <p class="lead">Choreographed multi-step animation sequences for key brand moments. Pixar-style orchestration that makes every interaction feel alive.</p>
</div>

<section class="section" id="overview">
  <h2>Sequence Orchestration</h2>

  <div class="orchestration-rules">
    <div class="rule-card">
      <h4>Priority Levels</h4>
      <ul>
        <li><strong>Critical:</strong> connection_success, error_recovery</li>
        <li><strong>High:</strong> celebration_big, team_unlock</li>
        <li><strong>Normal:</strong> handoff_transition, celebration_small</li>
        <li><strong>Low:</strong> deep_moment, session_end</li>
      </ul>
    </div>
    <div class="rule-card">
      <h4>Timing Rules</h4>
      <ul>
        <li>Max queue: 3 sequences</li>
        <li>Min gap between: 500ms</li>
        <li>Max concurrent: 1</li>
        <li>No overlapping</li>
      </ul>
    </div>
  </div>
</section>

<section class="section" id="onboarding">
  <h2>Onboarding Reveal</h2>
  <p class="sequence-meta">Trigger: first_app_open · Duration: 4500ms · Non-interruptible</p>

  <div class="sequence-timeline">
    <div class="timeline-step" style="--delay: 0; --duration: 800">
      <div class="step-marker">0ms</div>
      <div class="step-content">
        <h4>Backdrop</h4>
        <p>fadeIn · expoOut</p>
        <span class="description">Warm backdrop fades in</span>
      </div>
    </div>
    <div class="timeline-step" style="--delay: 400; --duration: 1200">
      <div class="step-marker">400ms</div>
      <div class="step-content">
        <h4>Avatar</h4>
        <p>breatheIn · gentle</p>
        <span class="description">Avatar materializes with soft breath</span>
      </div>
    </div>
    <div class="timeline-step" style="--delay: 600; --duration: 1000">
      <div class="step-marker">600ms</div>
      <div class="step-content">
        <h4>Avatar Glow</h4>
        <p>pulseIn · gentle</p>
        <span class="description">Persona glow awakens</span>
      </div>
    </div>
    <div class="timeline-step" style="--delay: 1600; --duration: 1500">
      <div class="step-marker">1600ms</div>
      <div class="step-content">
        <h4>Greeting</h4>
        <p>typewriter · linear</p>
        <span class="description">"Hey. I'm Ferni."</span>
      </div>
    </div>
    <div class="timeline-step" style="--delay: 3500; --duration: 400">
      <div class="step-marker">3500ms</div>
      <div class="step-content">
        <h4>CTA</h4>
        <p>fadeSlideUp · spring</p>
        <span class="description">CTA appears, inviting conversation</span>
      </div>
    </div>
  </div>

  <div class="sequence-extras">
    <span class="extra"><strong>Sound:</strong> system.startup @ 300ms</span>
    <span class="extra"><strong>Haptic:</strong> warmWelcome @ 500ms</span>
  </div>
</section>

