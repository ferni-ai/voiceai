<style>
.orchestration-rules {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.rule-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
}

.rule-card h4 {
  margin: 0 0 var(--space-3);
  color: var(--color-accent);
}

.rule-card ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.rule-card li {
  padding: var(--space-1) 0;
  font-size: 0.9rem;
}

.sequence-meta {
  color: var(--color-text-secondary);
  font-size: 0.9rem;
  margin-bottom: var(--space-4);
}

.sequence-timeline {
  position: relative;
  padding-left: var(--space-8);
  margin: var(--space-6) 0;
}

.sequence-timeline::before {
  content: '';
  position: absolute;
  left: 30px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--color-border-subtle);
}

.timeline-step {
  position: relative;
  padding: var(--space-3) 0;
  padding-left: var(--space-6);
}

.timeline-step::before {
  content: '';
  position: absolute;
  left: -26px;
  top: 50%;
  transform: translateY(-50%);
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--color-accent);
  border: 2px solid var(--color-bg-primary);
}

.timeline-step.featured::before {
  width: 16px;
  height: 16px;
  left: -28px;
  box-shadow: 0 0 0 4px rgba(61, 90, 69, 0.2);
}

.step-marker {
  position: absolute;
  left: -70px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.75rem;
  color: var(--color-text-tertiary);
  font-family: monospace;
}

.step-content h4 {
  margin: 0;
  font-size: 1rem;
}

.step-content p {
  margin: var(--space-1) 0;
  font-size: 0.85rem;
  color: var(--color-accent);
  font-family: monospace;
}

.step-content .description {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
  font-style: italic;
  font-family: var(--font-body);
}

.sequence-extras {
  display: flex;
  gap: var(--space-4);
  padding: var(--space-3);
  background: var(--color-bg-elevated);
  border-radius: var(--radius-md);
  font-size: 0.85rem;
}

.reduced-motion-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.reduced-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
  border-left: 3px solid var(--color-warning);
}

.reduced-card h4 {
  margin: 0 0 var(--space-2);
  font-family: monospace;
}

.reduced-card p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--color-text-secondary);
}

.animation-lib-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.anim-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
  text-align: center;
}

.anim-card h4 {
  margin: 0 0 var(--space-3);
  font-family: monospace;
}

.anim-demo {
  width: 40px;
  height: 40px;
  margin: 0 auto var(--space-3);
  background: var(--color-accent);
  border-radius: var(--radius-md);
}

.anim-card code {
  font-size: 0.75rem;
  color: var(--color-text-secondary);
}

.fade-in { animation: fadeIn 2s ease-in-out infinite; }
.fade-slide-up { animation: fadeSlideUp 2s ease-in-out infinite; }
.breathe-in { animation: breatheIn 2s ease-in-out infinite; }
.joy-bounce { animation: joyBounce 2s ease-in-out infinite; }
.spring { animation: spring 2s ease-in-out infinite; }
.nod { animation: nod 2s ease-in-out infinite; }

@keyframes fadeIn {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

@keyframes fadeSlideUp {
  0%, 100% { opacity: 0; transform: translateY(16px); }
  50% { opacity: 1; transform: translateY(0); }
}

@keyframes breatheIn {
  0%, 100% { opacity: 0; transform: scale(0.9); filter: blur(4px); }
  60% { opacity: 1; transform: scale(1.02); filter: blur(0); }
  80% { opacity: 1; transform: scale(1); filter: blur(0); }
}

@keyframes joyBounce {
  0%, 100% { transform: scale(1) translateY(0); }
  20% { transform: scale(1.15) translateY(-20px); }
  40% { transform: scale(0.95) translateY(0); }
  60% { transform: scale(1.05) translateY(-8px); }
  80% { transform: scale(0.98) translateY(0); }
}

@keyframes spring {
  0%, 100% { transform: scale(0.9); }
  50% { transform: scale(1.05); }
  75% { transform: scale(0.98); }
  90% { transform: scale(1); }
}

@keyframes nod {
  0%, 100% { transform: translateY(0) rotate(0); }
  30% { transform: translateY(-4px) rotate(2deg); }
  60% { transform: translateY(0) rotate(0); }
}
</style>
