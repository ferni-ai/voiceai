<script>
document.addEventListener('DOMContentLoaded', function() {
  // Color copy functionality
  document.querySelectorAll('.color-card').forEach(function(card) {
    card.addEventListener('click', async function() {
      var colorValue = card.dataset.color;
      var copyHint = card.querySelector('.copy-hint');

      try {
        await navigator.clipboard.writeText(colorValue);

        copyHint.textContent = 'Copied!';
        card.classList.add('copied');

        setTimeout(function() {
          copyHint.textContent = 'Click to copy';
          card.classList.remove('copied');
        }, 1500);
      } catch (err) {
        // Fallback for older browsers
        var textarea = document.createElement('textarea');
        textarea.value = colorValue;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);

        copyHint.textContent = 'Copied!';
        card.classList.add('copied');

        setTimeout(function() {
          copyHint.textContent = 'Click to copy';
          card.classList.remove('copied');
        }, 1500);
      }
    });
  });

  // Persona card copy buttons - using safe DOM manipulation
  document.querySelectorAll('.persona-card .copy-btn').forEach(function(btn) {
    btn.addEventListener('click', async function(e) {
      e.stopPropagation();
      var colorValue = btn.dataset.copyText;
      var copyTextSpan = btn.querySelector('.copy-text');

      try {
        await navigator.clipboard.writeText(colorValue);

        // Update button state safely
        btn.classList.add('copied');
        copyTextSpan.textContent = 'Copied!';

        setTimeout(function() {
          btn.classList.remove('copied');
          copyTextSpan.textContent = 'Copy';
        }, 1500);
      } catch (err) {
        console.error('Copy failed:', err);
      }
    });
  });

  // Download kit button (placeholder)
  var downloadBtn = document.getElementById('downloadKit');
  if (downloadBtn) {
    downloadBtn.addEventListener('click', function() {
      // In production, this would trigger a ZIP download
      alert('Complete brand kit download coming soon!\n\nFor now, download individual assets from each section.');
    });
  }

  // Smooth scroll for navigation
  document.querySelectorAll('.kit-nav-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var href = link.getAttribute('href');
      if (href.startsWith('#')) {
        e.preventDefault();
        var target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });

  // Animate team orbs on hover
  var teamOrbs = document.querySelectorAll('.team-orb');
  teamOrbs.forEach(function(orb, index) {
    orb.addEventListener('mouseenter', function() {
      orb.style.animation = 'none';
      orb.style.transform = 'translateY(-12px) scale(1.1)';
    });
    orb.addEventListener('mouseleave', function() {
      orb.style.transform = '';
      orb.style.animation = 'gentleBounce 3s ease-in-out infinite ' + (index * 0.1) + 's';
    });
  });

  // Highlight active nav on scroll
  var sections = document.querySelectorAll('.section[id]');
  var navLinks = document.querySelectorAll('.kit-nav-link');

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var id = entry.target.id;
        navLinks.forEach(function(link) {
          link.classList.remove('active');
          if (link.getAttribute('href') === '#' + id) {
            link.classList.add('active');
          }
        });
      }
    });
  }, { threshold: 0.3, rootMargin: '-80px 0px 0px 0px' });

  sections.forEach(function(section) {
    observer.observe(section);
  });
});
</script>
