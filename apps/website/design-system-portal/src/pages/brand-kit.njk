<style>
/* ================================================
   Brand Kit Page Styles
   ================================================ */

.brand-kit-page {
  max-width: 100%;
}

/* Hero Section */
.kit-hero {
  position: relative;
  text-align: center;
  padding: var(--space-20) var(--space-8) var(--space-16);
  background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
  overflow: hidden;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.kit-hero h1 {
  font-family: var(--font-display);
  font-size: var(--text-5xl);
  font-weight: var(--font-weight-bold);
  letter-spacing: -0.02em;
  margin-bottom: var(--space-4);
}

.hero-lead {
  font-size: var(--text-lg);
  color: var(--text-secondary);
  max-width: 600px;
  margin: 0 auto var(--space-8);
  line-height: var(--leading-relaxed);
}

.download-all-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  background: var(--accent-primary);
  color: white;
  padding: var(--space-4) var(--space-8);
  border-radius: var(--radius-lg);
  border: none;
  cursor: pointer;
  font-weight: var(--font-weight-semibold);
  font-size: var(--text-base);
  font-family: var(--font-body);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 4px 16px rgba(74, 103, 65, 0.25);
}

.download-all-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(74, 103, 65, 0.35);
}

.hero-note {
  font-size: var(--text-sm);
  color: var(--text-muted);
  margin-top: var(--space-3);
}

/* Floating Avatars */
.hero-avatars {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.floating-orb {
  position: absolute;
  animation: floatOrb 6s ease-in-out infinite;
}

.orb-1 {
  top: 15%;
  right: 10%;
  animation-delay: 0s;
}

.orb-2 {
  bottom: 20%;
  left: 8%;
  animation-delay: -2s;
}

.orb-3 {
  top: 30%;
  left: 15%;
  animation-delay: -4s;
}

@keyframes floatOrb {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-15px) rotate(3deg); }
}

/* Quick Jump Navigation */
.kit-nav {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: var(--space-3);
  padding: var(--space-6) var(--space-4);
  background: var(--bg-elevated);
  border-bottom: 1px solid var(--border-subtle);
  position: sticky;
  top: 0;
  z-index: 100;
}

.kit-nav-link {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  text-decoration: none;
  color: var(--text-secondary);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  transition: all 0.2s var(--ease-spring);
}

.kit-nav-link:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

/* Section Styles */
.section {
  padding: var(--space-16) var(--space-8);
  max-width: 1200px;
  margin: 0 auto;
  border-bottom: 1px solid var(--border-subtle);
}

.section-header {
  margin-bottom: var(--space-8);
}

.section-header h2 {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: var(--font-weight-bold);
  margin-bottom: var(--space-2);
}

.section-desc {
  font-size: var(--text-base);
  color: var(--text-secondary);
}

.subsection-title {
  font-size: var(--text-lg);
  font-weight: var(--font-weight-semibold);
  margin: var(--space-10) 0 var(--space-4);
  color: var(--text-secondary);
}

/* Asset Grid */
.asset-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--space-6);
}

.asset-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1px solid var(--border-subtle);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.asset-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-xl);
  border-color: var(--accent-primary);
}

.asset-preview {
  height: 160px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-6);
}

.asset-preview.light-bg {
  background: var(--bg-secondary);
}

.asset-preview.dark-bg {
  background: #1a1612;
}

.asset-preview.gradient-bg {
  background: linear-gradient(135deg, #4a6741 0%, #3d5a35 100%);
}

.asset-preview.social-bg {
  background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
}

.asset-info {
  padding: var(--space-5);
  border-top: 1px solid var(--border-subtle);
}

.asset-name {
  font-weight: var(--font-weight-semibold);
  font-size: var(--text-base);
  margin-bottom: var(--space-1);
}

.asset-meta {
  font-size: var(--text-sm);
  color: var(--text-muted);
  margin-bottom: var(--space-3);
}

.asset-formats {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.asset-formats.centered {
  justify-content: center;
  margin-top: var(--space-4);
}

.format-tag {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.15s;
}

.format-tag:hover {
  background: var(--accent-primary);
  color: white;
}

/* Wordmark Preview */
.wordmark-preview {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.wordmark-text {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: var(--text-3xl);
  color: var(--text-primary);
}

/* Favicon Sizes */
.favicon-sizes {
  display: flex;
  align-items: flex-end;
  gap: var(--space-4);
}

/* Social Preview Mock */
.social-preview-mock {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4);
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

.social-preview-mock span {
  font-family: var(--font-display);
  font-weight: var(--font-weight-bold);
  font-size: var(--text-lg);
}

/* Usage Rules */
.usage-rules {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-6);
  margin-top: var(--space-10);
}

.rule {
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
}

.rule.do {
  border-left: 4px solid var(--success);
}

.rule.dont {
  border-left: 4px solid var(--error);
}

.rule-header {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
}

.rule-header h5 {
  font-size: var(--text-lg);
  font-weight: var(--font-weight-semibold);
}

.rule.do .rule-header { color: var(--success); }
.rule.dont .rule-header { color: var(--error); }

.rule ul {
  list-style: none;
  padding: 0;
}

.rule li {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
  padding-left: var(--space-5);
  position: relative;
}

.rule li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.rule.do li::before { background: var(--success); }
.rule.dont li::before { background: var(--error); }

/* Clear Space Diagram */
.clear-space-diagram {
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
  margin-top: var(--space-10);
}

.clear-space-diagram h4 {
  font-size: var(--text-lg);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--space-6);
}

.diagram-wrapper {
