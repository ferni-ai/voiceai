---
layout: layouts/base.njk
title: Brand Kit
description: Download Ferni brand assets - logos, avatars, colors, typography, and guidelines for press and partners
permalink: /brand-kit/
---

<article class="brand-kit-page">
  <!-- Hero Section with Download -->
  <header class="kit-hero">
    <div class="hero-content">
      <h1>Ferni Brand Kit</h1>
      <p class="hero-lead">Everything you need to represent Ferni correctly. Download logos, colors, typography, and guidelines for press, partners, and developers.</p>
      <button class="download-all-btn" id="downloadKit">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7,10 12,15 17,10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download Complete Kit
      </button>
      <p class="hero-note">Includes all logos, icons, color specs, and guidelines as a ZIP file</p>
    </div>

    <!-- Floating Brand Elements -->
    <div class="hero-avatars">
      <svg class="floating-orb orb-1" viewBox="0 0 60 60" width="60" height="60">
        <circle cx="30" cy="30" r="28" fill="#4a6741" opacity="0.9"/>
        <ellipse cx="22" cy="29" rx="4" ry="6" fill="white"/>
        <ellipse cx="38" cy="29" rx="4" ry="6" fill="white"/>
      </svg>
      <svg class="floating-orb orb-2" viewBox="0 0 40 40" width="40" height="40">
        <circle cx="20" cy="20" r="18" fill="#a67a6a" opacity="0.8"/>
        <ellipse cx="15" cy="19" rx="2.5" ry="4" fill="white"/>
        <ellipse cx="25" cy="19" rx="2.5" ry="4" fill="white"/>
      </svg>
      <svg class="floating-orb orb-3" viewBox="0 0 35 35" width="35" height="35">
        <circle cx="17.5" cy="17.5" r="16" fill="#3a6b73" opacity="0.7"/>
        <ellipse cx="13" cy="17" rx="2" ry="3.5" fill="white"/>
        <ellipse cx="22" cy="17" rx="2" ry="3.5" fill="white"/>
      </svg>
    </div>
  </header>

  <!-- Quick Jump Navigation -->
  <nav class="kit-nav">
    <a href="#logos" class="kit-nav-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
      </svg>
      Logos
    </a>
    <a href="#avatars" class="kit-nav-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="4"/>
        <path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/>
      </svg>
      Avatars
    </a>
    <a href="#colors" class="kit-nav-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="13.5" cy="6.5" r="2.5"/>
        <circle cx="6.5" cy="12" r="2.5"/>
        <circle cx="17.5" cy="12" r="2.5"/>
        <circle cx="12" cy="18.5" r="2.5"/>
      </svg>
      Colors
    </a>
    <a href="#typography" class="kit-nav-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="4 7 4 4 20 4 20 7"/>
        <line x1="9" y1="20" x2="15" y2="20"/>
        <line x1="12" y1="4" x2="12" y2="20"/>
      </svg>
      Typography
    </a>
    <a href="#guidelines" class="kit-nav-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      </svg>
      Guidelines
    </a>
  </nav>

  <!-- Logos Section -->
  <section class="section" id="logos">
    <div class="section-header">
      <div>
        <h2>Logos</h2>
        <p class="section-desc">Primary logo marks for digital and print use. Available in SVG and multiple PNG sizes.</p>
      </div>
    </div>

    <div class="asset-grid">
      <!-- Primary Logo -->
      <div class="asset-card">
        <div class="asset-preview light-bg">
          <svg viewBox="0 0 100 100" width="80" height="80">
            <defs>
              <linearGradient id="orbGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#5a7a51"/>
                <stop offset="100%" stop-color="#3d5a35"/>
              </linearGradient>
            </defs>
            {# LUXO STYLE: Opaque white eyes, no pupils #}
            <circle cx="50" cy="50" r="45" fill="url(#orbGrad1)"/>
            <ellipse cx="36" cy="48" rx="7" ry="10" fill="white"/>
            <ellipse cx="64" cy="48" rx="7" ry="10" fill="white"/>
          </svg>
        </div>
        <div class="asset-info">
          <div class="asset-name">Primary Logo</div>
          <div class="asset-meta">Full color, light backgrounds</div>
          <div class="asset-formats">
            <a href="/assets/logos/ferni-logo.svg" class="format-tag" download>SVG</a>
            <a href="/assets/logos/ferni-logo-512.png" class="format-tag" download>PNG</a>
            <a href="/assets/logos/ferni-logo-1024.png" class="format-tag" download>PNG @2x</a>
          </div>
        </div>
      </div>

      <!-- Dark Background Logo -->
      <div class="asset-card">
        <div class="asset-preview dark-bg">
          <svg viewBox="0 0 100 100" width="80" height="80">
            <defs>
              <linearGradient id="orbGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#6a9a61"/>
                <stop offset="100%" stop-color="#4a7a45"/>
              </linearGradient>
            </defs>
            <circle cx="50" cy="50" r="45" fill="url(#orbGrad2)"/>
            <ellipse cx="36" cy="48" rx="7" ry="10" fill="white"/>
            <ellipse cx="64" cy="48" rx="7" ry="10" fill="white"/>
          </svg>
        </div>
        <div class="asset-info">
          <div class="asset-name">Logo on Dark</div>
          <div class="asset-meta">For dark backgrounds</div>
          <div class="asset-formats">
            <a href="/assets/logos/ferni-logo-dark.svg" class="format-tag" download>SVG</a>
            <a href="/assets/logos/ferni-logo-dark-512.png" class="format-tag" download>PNG</a>
            <a href="/assets/logos/ferni-logo-dark-1024.png" class="format-tag" download>PNG @2x</a>
          </div>
        </div>
      </div>

      <!-- Simple Logo -->
      <div class="asset-card">
        <div class="asset-preview light-bg">
          <svg viewBox="0 0 100 100" width="80" height="80">
            <circle cx="50" cy="50" r="45" fill="#4a6741"/>
            <ellipse cx="36" cy="48" rx="7" ry="10" fill="white"/>
            <ellipse cx="64" cy="48" rx="7" ry="10" fill="white"/>
          </svg>
        </div>
        <div class="asset-info">
          <div class="asset-name">Simple Logo</div>
          <div class="asset-meta">Flat color version</div>
          <div class="asset-formats">
            <a href="/assets/logos/ferni-logo-simple.svg" class="format-tag" download>SVG</a>
            <a href="/assets/logos/ferni-logo-simple-512.png" class="format-tag" download>PNG</a>
          </div>
        </div>
      </div>

      <!-- Monochrome Logo -->
      <div class="asset-card">
        <div class="asset-preview light-bg">
          <svg viewBox="0 0 100 100" width="80" height="80">
            <circle cx="50" cy="50" r="45" fill="var(--text-primary)" opacity="0.85"/>
            <ellipse cx="36" cy="48" rx="7" ry="10" fill="var(--bg-primary)"/>
            <ellipse cx="64" cy="48" rx="7" ry="10" fill="var(--bg-primary)"/>
          </svg>
        </div>
        <div class="asset-info">
          <div class="asset-name">Monochrome</div>
          <div class="asset-meta">Single color applications</div>
          <div class="asset-formats">
            <a href="/assets/logos/ferni-logo-mono.svg" class="format-tag" download>SVG</a>
            <a href="/assets/logos/ferni-logo-mono-512.png" class="format-tag" download>PNG</a>
          </div>
        </div>
      </div>

      <!-- Wordmark -->
      <div class="asset-card">
        <div class="asset-preview light-bg">
          <div class="wordmark-preview">
            <svg viewBox="0 0 50 50" width="40" height="40">
              <circle cx="25" cy="25" r="23" fill="#4a6741"/>
              <ellipse cx="18" cy="24" rx="3.5" ry="5" fill="white"/>
              <ellipse cx="32" cy="24" rx="3.5" ry="5" fill="white"/>
            </svg>
            <span class="wordmark-text">Ferni</span>
          </div>
        </div>
        <div class="asset-info">
          <div class="asset-name">Logo + Wordmark</div>
          <div class="asset-meta">Horizontal lockup</div>
          <div class="asset-formats">
            <a href="/assets/logos/ferni-wordmark.svg" class="format-tag" download>SVG</a>
            <a href="/assets/logos/ferni-wordmark-512.png" class="format-tag" download>PNG</a>
          </div>
        </div>
      </div>

      <!-- App Icon -->
      <div class="asset-card">
        <div class="asset-preview gradient-bg">
          <svg viewBox="0 0 100 100" width="70" height="70">
            <rect width="100" height="100" rx="22" fill="#4a6741"/>
            <ellipse cx="36" cy="48" rx="8" ry="11" fill="white"/>
            <ellipse cx="64" cy="48" rx="8" ry="11" fill="white"/>
          </svg>
        </div>
        <div class="asset-info">
          <div class="asset-name">App Icon</div>
          <div class="asset-meta">iOS & Android app stores</div>
          <div class="asset-formats">
            <a href="/assets/icons/app-icon-1024.svg" class="format-tag" download>SVG</a>
            <a href="/assets/icons/app-icon-ios-1024.png" class="format-tag" download>iOS</a>
            <a href="/assets/icons/app-icon-android-512.png" class="format-tag" download>Android</a>
          </div>
        </div>
      </div>

      <!-- Favicon -->
      <div class="asset-card">
        <div class="asset-preview light-bg">
          <div class="favicon-sizes">
            <svg viewBox="0 0 32 32" width="48" height="48">
              <circle cx="16" cy="16" r="15" fill="#4a6741"/>
              <ellipse cx="11" cy="15" rx="2.5" ry="3.5" fill="white"/>
              <ellipse cx="21" cy="15" rx="2.5" ry="3.5" fill="white"/>
            </svg>
            <svg viewBox="0 0 32 32" width="32" height="32">
              <circle cx="16" cy="16" r="15" fill="#4a6741"/>
              <ellipse cx="11" cy="15" rx="2.5" ry="3.5" fill="white"/>
              <ellipse cx="21" cy="15" rx="2.5" ry="3.5" fill="white"/>
            </svg>
            <svg viewBox="0 0 32 32" width="16" height="16">
              <circle cx="16" cy="16" r="15" fill="#4a6741"/>
              <ellipse cx="11" cy="15" rx="2.5" ry="3.5" fill="white"/>
              <ellipse cx="21" cy="15" rx="2.5" ry="3.5" fill="white"/>
            </svg>
          </div>
        </div>
        <div class="asset-info">
          <div class="asset-name">Favicon</div>
          <div class="asset-meta">Browser & bookmark icons</div>
          <div class="asset-formats">
            <a href="/assets/favicons/favicon.svg" class="format-tag" download>SVG</a>
            <a href="/assets/favicons/favicon-16.png" class="format-tag" download>16px</a>
            <a href="/assets/favicons/favicon-32.png" class="format-tag" download>32px</a>
            <a href="/assets/favicons/favicon-192.png" class="format-tag" download>192px</a>
          </div>
        </div>
      </div>

      <!-- Social Preview -->
      <div class="asset-card">
        <div class="asset-preview social-bg">
          <div class="social-preview-mock">
            <svg viewBox="0 0 100 100" width="40" height="40">
              <circle cx="50" cy="50" r="45" fill="#4a6741"/>
              <ellipse cx="36" cy="48" rx="7" ry="10" fill="white"/>
              <ellipse cx="64" cy="48" rx="7" ry="10" fill="white"/>
            </svg>
            <span>Ferni</span>
          </div>
        </div>
        <div class="asset-info">
          <div class="asset-name">Social Preview</div>
          <div class="asset-meta">Open Graph & Twitter cards</div>
          <div class="asset-formats">
            <a href="/assets/social/og-image.png" class="format-tag" download>OG 1200x630</a>
            <a href="/assets/social/twitter-card.png" class="format-tag" download>Twitter</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Logo Usage Rules -->
    <div class="usage-rules">
      <div class="rule do">
        <div class="rule-header">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <h5>Do</h5>
        </div>
        <ul>
          <li>Maintain clear space equal to the eye width around the logo</li>
          <li>Use on solid backgrounds or simple gradients</li>
          <li>Keep eyes as <strong>opaque white</strong> (Luxo-style, no pupils)</li>
          <li>Use provided color variations for different backgrounds</li>
          <li>Maintain the aspect ratio when scaling</li>
        </ul>
      </div>
      <div class="rule dont">
        <div class="rule-header">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
          <h5>Don't</h5>
        </div>
        <ul>
          <li><strong>Never add pupils</strong> to the eyes (breaks Luxo style)</li>
          <li>Stretch, distort, or rotate the orb</li>
          <li>Place on busy, patterned, or photographic backgrounds</li>
          <li>Add shadows, effects, or 3D treatments</li>
          <li>Change the orb shape from a perfect circle</li>
        </ul>
      </div>
    </div>

    <!-- Clear Space Diagram -->
    <div class="clear-space-diagram">
      <h4>Clear Space Requirements</h4>
      <div class="diagram-wrapper">
        <div class="diagram-visual">
          <div class="clear-zone">
            <svg viewBox="0 0 100 100" width="100" height="100">
              <circle cx="50" cy="50" r="45" fill="#4a6741"/>
              <ellipse cx="36" cy="48" rx="7" ry="10" fill="white"/>
              <ellipse cx="64" cy="48" rx="7" ry="10" fill="white"/>
            </svg>
            <div class="measure-x" title="Eye width = minimum clear space"></div>
            <div class="measure-y" title="Eye width = minimum clear space"></div>
          </div>
        </div>
        <p class="diagram-caption">Minimum clear space around logo = width of one eye (X). This ensures the logo maintains visual breathing room in all contexts.</p>
      </div>
    </div>
  </section>

  <!-- Persona Avatars Section -->
  <section class="section" id="avatars">
    <div class="section-header">
      <div>
        <h2>Persona Avatars</h2>
        <p class="section-desc">The Ferni team — 6 specialized AI companions. Each shares the Luxo-style eye design but with distinct colors.</p>
      </div>
    </div>

    <div class="persona-grid">
      {% set personas = [
        { name: 'Ferni', role: 'Coordinator', color: '#4a6741', rgb: '74, 103, 65', desc: 'Team leader, emotional triage, handoffs' },
        { name: 'Maya', role: 'Habits Coach', color: '#a67a6a', rgb: '166, 122, 106', desc: 'Tiny Habits expert, behavior design' },
        { name: 'Peter', role: 'Money Guide', color: '#3a6b73', rgb: '58, 107, 115', desc: 'Financial wisdom, data analysis' },
        { name: 'Jordan', role: 'Life Planner', color: '#c4856a', rgb: '196, 133, 106', desc: 'Goals, milestones, celebrations' },
        { name: 'Alex', role: 'Chief of Staff', color: '#5a6b8a', rgb: '90, 107, 138', desc: 'Communication, scheduling, productivity' },
        { name: 'Nayan', role: 'Wisdom Elder', color: '#b8956a', rgb: '184, 149, 106', desc: 'Philosophy, perspective, life wisdom' }
      ] %}

      {% for persona in personas %}
      <div class="persona-card" data-color="{{ persona.color }}" style="--persona-accent: {{ persona.color }}">
        <div class="persona-avatar-wrapper">
          <svg viewBox="0 0 100 100" width="80" height="80" class="persona-avatar-svg">
            {# LUXO STYLE: Opaque white eyes, no pupils #}
            <circle cx="50" cy="50" r="45" fill="{{ persona.color }}"/>
            <ellipse class="eye-left" cx="36" cy="48" rx="7" ry="10" fill="white"/>
            <ellipse class="eye-right" cx="64" cy="48" rx="7" ry="10" fill="white"/>
          </svg>
          <div class="persona-glow"></div>
        </div>
        <div class="persona-info">
          <h4 class="persona-name">{{ persona.name }}</h4>
          <span class="persona-role">{{ persona.role }}</span>
          <p class="persona-desc">{{ persona.desc }}</p>
          <div class="persona-color-info">
            <code class="color-hex">{{ persona.color }}</code>
            <code class="color-rgb">RGB {{ persona.rgb }}</code>
          </div>
        </div>
        <div class="persona-actions">
          <a href="/assets/avatars/{{ persona.name | lower }}-avatar.svg" class="format-tag" download>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7,10 12,15 17,10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            SVG
          </a>
          <button class="copy-btn" data-copy-text="{{ persona.color }}" title="Copy color">
            <svg class="copy-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            <svg class="check-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="copy-text">Copy</span>
          </button>
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Team Portrait -->
    <div class="team-portrait">
      <h4>Team Portrait</h4>
      <div class="team-portrait-preview">
        <div class="portrait-row">
          {% for persona in personas %}
          <svg viewBox="0 0 60 60" width="50" height="50" class="team-orb" style="animation-delay: {{ loop.index * 0.1 }}s">
            <circle cx="30" cy="30" r="28" fill="{{ persona.color }}"/>
            <ellipse cx="22" cy="29" rx="4" ry="6" fill="white"/>
            <ellipse cx="38" cy="29" rx="4" ry="6" fill="white"/>
          </svg>
          {% endfor %}
        </div>
      </div>
      <div class="asset-formats centered">
        <a href="/assets/team-portrait.svg" class="format-tag" download>SVG</a>
        <a href="/assets/team-portrait.png" class="format-tag" download>PNG</a>
        <a href="/assets/team-portrait-wide.png" class="format-tag" download>Wide 1200x400</a>
      </div>
    </div>
  </section>

  <!-- Color Palette Section -->
  <section class="section" id="colors">
    <div class="section-header">
      <div>
        <h2>Color Palette</h2>
        <p class="section-desc">Official brand and persona colors. Click any swatch to copy the hex value.</p>
      </div>
    </div>

    <!-- Core Brand Colors -->
    <h3 class="subsection-title">Core Brand Colors</h3>
    <div class="color-grid">
      {% set coreColors = [
        { name: 'Accent (CTA)', hex: '#3D5A45', rgb: '61, 90, 69', usage: 'Buttons, links, primary actions' },
        { name: 'Ferni Green', hex: '#4a6741', rgb: '74, 103, 65', usage: 'Ferni persona, brand primary' },
        { name: 'Natural Ink', hex: '#2C2520', rgb: '44, 37, 32', usage: 'Primary text, high contrast' },
        { name: 'Warm White', hex: '#FAF8F5', rgb: '250, 248, 245', usage: 'Light theme backgrounds' },
        { name: 'Kintsugi Gold', hex: '#c9a227', rgb: '201, 162, 39', usage: 'Premium features, highlights' },
        { name: 'Cedar Night', hex: '#1a1612', rgb: '26, 22, 18', usage: 'Dark theme background' }
      ] %}

      {% for color in coreColors %}
      <div class="color-card" data-color="{{ color.hex }}">
        <span class="copy-hint">Click to copy</span>
        <div class="color-swatch" style="background: {{ color.hex }};"></div>
        <div class="color-info">
          <div class="color-name">{{ color.name }}</div>
          <div class="color-values">
            <code class="color-value hex">{{ color.hex }}</code>
            <span class="color-value rgb">RGB {{ color.rgb }}</span>
          </div>
          <p class="color-usage">{{ color.usage }}</p>
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Persona Colors -->
    <h3 class="subsection-title">Persona Colors</h3>
    <div class="color-grid">
      {% set personaColors = [
        { name: 'Ferni', hex: '#4a6741', rgb: '74, 103, 65' },
        { name: 'Maya', hex: '#a67a6a', rgb: '166, 122, 106' },
        { name: 'Peter', hex: '#3a6b73', rgb: '58, 107, 115' },
        { name: 'Jordan', hex: '#c4856a', rgb: '196, 133, 106' },
        { name: 'Alex', hex: '#5a6b8a', rgb: '90, 107, 138' },
        { name: 'Nayan', hex: '#b8956a', rgb: '184, 149, 106' }
      ] %}

      {% for color in personaColors %}
      <div class="color-card" data-color="{{ color.hex }}">
        <span class="copy-hint">Click to copy</span>
        <div class="color-swatch" style="background: {{ color.hex }};"></div>
        <div class="color-info">
          <div class="color-name">{{ color.name }}</div>
          <div class="color-values">
            <code class="color-value hex">{{ color.hex }}</code>
            <span class="color-value rgb">RGB {{ color.rgb }}</span>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Semantic Colors -->
    <h3 class="subsection-title">Semantic Colors</h3>
    <div class="color-grid">
      {% set semanticColors = [
        { name: 'Success', hex: '#6bc48f', rgb: '107, 196, 143', usage: 'Positive outcomes' },
        { name: 'Error', hex: '#e07575', rgb: '224, 117, 117', usage: 'Errors, destructive' },
        { name: 'Warning', hex: '#e0b860', rgb: '224, 184, 96', usage: 'Caution, attention' },
        { name: 'Info', hex: '#7da6cf', rgb: '125, 166, 207', usage: 'Neutral information' }
      ] %}

      {% for color in semanticColors %}
      <div class="color-card" data-color="{{ color.hex }}">
        <span class="copy-hint">Click to copy</span>
        <div class="color-swatch" style="background: {{ color.hex }};"></div>
