<section class="section" id="speaking">
  <h2>Speaking Animation</h2>
  <p>The bottom lid opens based on voice volume, creating natural lip sync.</p>

  <div class="speaking-demo">
    <div class="speaking-avatar">
      <div class="lid top"></div>
      <div class="eye"></div>
      <div class="lid bottom speaking"></div>
