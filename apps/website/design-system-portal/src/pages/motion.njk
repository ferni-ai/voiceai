<style>
.principles-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
}

.pixar-principle {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 1rem;
}

.pixar-principle h4 {
  color: var(--color-ferni);
  margin: 0 0 0.5rem;
  font-size: 0.9rem;
}

.pixar-principle p {
  margin: 0;
  font-size: 0.8rem;
  color: var(--color-text-secondary);
}

.duration-scale {
  margin-top: 1.5rem;
}

.duration-item {
  display: grid;
  grid-template-columns: 100px 60px 1fr;
  gap: 1rem;
  align-items: center;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--color-border);
  position: relative;
}

.duration-item::before {
  content: '';
  position: absolute;
  left: 0;
  bottom: 0;
  height: 3px;
  width: var(--duration-width, 50%);
  background: var(--color-ferni);
  opacity: 0.3;
}

.duration-item.glacial::before {
  opacity: 0.15;
}

.duration-name {
  font-family: var(--font-mono);
  font-weight: 500;
}

.duration-value {
  font-family: var(--font-mono);
  color: var(--color-ferni);
}

.duration-desc {
  color: var(--color-text-secondary);
  font-size: 0.875rem;
}

.easing-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
}

.easing-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 1rem;
}

.easing-card.featured {
  border-color: var(--color-ferni);
}

