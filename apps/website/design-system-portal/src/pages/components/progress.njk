}

.skeleton-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.skeleton-line {
  height: 12px;
  background: linear-gradient(
    90deg,
    var(--bg-tertiary) 25%,
    var(--bg-secondary) 50%,
    var(--bg-tertiary) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}

.skeleton-line-title {
  width: 60%;
  height: 16px;
}

.skeleton-line-short {
  width: 40%;
}

.skeleton-line-medium {
  width: 80%;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Step Progress */
.step-progress {
  display: flex;
  align-items: flex-start;
  width: 100%;
  max-width: 500px;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}

.step-indicator {
  width: 32px;
  height: 32px;
  border: 2px solid var(--border-medium);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: var(--font-weight-semibold);
  font-size: var(--text-sm);
  color: var(--text-muted);
  background: var(--bg-primary);
  transition: all var(--duration-fast) var(--ease-ease-out);
}

.step.active .step-indicator {
  border-color: var(--accent-primary);
  color: var(--accent-primary);
}

.step.completed .step-indicator {
  background: var(--accent-primary);
  border-color: var(--accent-primary);
  color: white;
}

.step-label {
  font-size: var(--text-xs);
  color: var(--text-muted);
  white-space: nowrap;
}

.step.active .step-label {
  color: var(--accent-primary);
  font-weight: var(--font-weight-medium);
}

.step-connector {
  flex: 1;
  height: 2px;
  background: var(--border-subtle);
  margin: 16px var(--space-2) 0;
  min-width: 40px;
}

.step-connector.completed {
  background: var(--accent-primary);
}

/* Guidelines */
.guidelines-list {
  list-style: none;
  padding: 0;
  margin-top: var(--space-6);
}

.guidelines-list li {
  padding: var(--space-3) 0;
  border-bottom: 1px solid var(--border-subtle);
}

.guidelines-list li:last-child {
  border-bottom: none;
}

.guidelines-list code {
  background: var(--bg-secondary);
  padding: 2px var(--space-2);
  border-radius: var(--radius-sm);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
}

.guidelines-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-6);
  margin-top: var(--space-6);
}

.guideline {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
}

.guideline h4 {
  font-family: var(--font-display);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--space-4);
}

.guideline.do h4 { color: var(--success); }
.guideline.dont h4 { color: var(--error); }

.guideline ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.guideline li {
  padding: var(--space-2) 0;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

/* Reduced Motion */
@media (prefers-reduced-motion: reduce) {
  .spinner,
  .pulse-dot,
  .skeleton-line,
  .skeleton-avatar,
  .progress-indeterminate {
    animation: none;
  }

  .spinner {
    border-top-color: var(--accent-primary);
    opacity: 0.7;
  }

  .pulse-dot {
    opacity: 0.6;
  }
}

/* Interactive Slider */
.progress-slider {
  width: 100%;
  margin-top: var(--space-4);
  height: 8px;
  -webkit-appearance: none;
  appearance: none;
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  cursor: pointer;
}

.progress-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 20px;
  height: 20px;
  background: var(--accent-primary);
  border-radius: 50%;
  cursor: pointer;
  transition: transform var(--duration-fast) var(--ease-ease-out);
}

.progress-slider::-webkit-slider-thumb:hover {
  transform: scale(1.1);
}

.progress-slider::-moz-range-thumb {
  width: 20px;
  height: 20px;
  background: var(--accent-primary);
  border: none;
  border-radius: 50%;
  cursor: pointer;
}

@media (max-width: 768px) {
  .page-header h1 {
    font-size: var(--text-3xl);
  }

  .demo-preview {
    padding: var(--space-6);
  }

  .step-progress {
    flex-wrap: wrap;
    justify-content: center;
  }

  .step-connector {
    display: none;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var slider = document.getElementById('progress-slider');
  var progressFill = document.getElementById('progress-interactive');
  var progressPercent = document.getElementById('progress-percent');
  var progressStatus = document.getElementById('progress-status');

  if (slider && progressFill && progressPercent && progressStatus) {
    slider.addEventListener('input', function() {
      var value = this.value;
      progressFill.style.width = value + '%';
      progressPercent.textContent = value + '%';

      // Update status text based on value
      if (value == 0) {
        progressStatus.textContent = 'Not started';
      } else if (value < 30) {
        progressStatus.textContent = 'Starting...';
      } else if (value < 60) {
        progressStatus.textContent = 'In progress...';
      } else if (value < 90) {
        progressStatus.textContent = 'Almost there...';
      } else if (value < 100) {
        progressStatus.textContent = 'Finishing up...';
      } else {
        progressStatus.textContent = 'Complete!';
      }
    });
  }
});
</script>
