<script>
document.addEventListener('DOMContentLoaded', function() {
  var modalTriggers = {
    'open-basic-modal': 'basic-modal',
    'open-sm-modal': 'sm-modal',
    'open-md-modal': 'md-modal',
    'open-lg-modal': 'lg-modal',
    'open-confirm-modal': 'confirm-modal',
    'open-form-modal': 'form-modal'
  };

  Object.keys(modalTriggers).forEach(function(triggerId) {
    var trigger = document.getElementById(triggerId);
    var modal = document.getElementById(modalTriggers[triggerId]);

    if (trigger && modal) {
      trigger.addEventListener('click', function() {
        modal.style.display = 'flex';
      });
    }
  });

  document.querySelectorAll('.demo-modal').forEach(function(modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal || e.target.classList.contains('modal-close') ||
          e.target.classList.contains('modal-cancel') || e.target.classList.contains('modal-confirm')) {
        modal.style.display = 'none';
      }
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.demo-modal').forEach(function(modal) {
        modal.style.display = 'none';
      });
    }
  });
});
</script>
