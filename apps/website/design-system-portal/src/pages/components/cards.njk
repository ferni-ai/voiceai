  <section class="section">
    <h2>Basic Card</h2>
    <p>The default card provides a subtle elevated surface for content grouping.</p>

    <div class="demo-container">
      <div class="card-demo-grid">
        <div class="card">
          <h3 class="card-title">Card Title</h3>
          <p class="card-text">This is a basic card with some example content. Cards help organize information into digestible chunks.</p>
        </div>
      </div>
    </div>

    <div class="code-block">
      <pre><code>&lt;div class="card"&gt;
  &lt;h3 class="card-title"&gt;Card Title&lt;/h3&gt;
  &lt;p class="card-text"&gt;Card content goes here.&lt;/p&gt;
&lt;/div&gt;</code></pre>
    </div>
  </section>

  <section class="section">
