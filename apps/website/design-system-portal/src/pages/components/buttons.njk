        <div class="control-group">
          <label class="control-label">Size</label>
          <div class="control-options" data-control="size">
            <button class="control-btn" data-value="btn-sm">Small</button>
            <button class="control-btn active" data-value="btn-md">Medium</button>
            <button class="control-btn" data-value="btn-lg">Large</button>
