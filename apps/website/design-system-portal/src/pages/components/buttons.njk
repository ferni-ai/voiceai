<script>
document.addEventListener('DOMContentLoaded', function() {
  var playgroundBtn = document.getElementById('playground-button');
  var outputCode = document.getElementById('playground-output');

  if (!playgroundBtn || !outputCode) return;

  var state = {
    variant: 'btn-primary',
    size: 'btn-md',
    icon: 'none',
    state: 'default'
  };

  function createArrowIcon() {
    var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('width', '16');
    svg.setAttribute('height', '16');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '2');

    var path1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path1.setAttribute('d', 'M5 12h14');
    var path2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path2.setAttribute('d', 'M12 5l7 7-7 7');

    svg.appendChild(path1);
    svg.appendChild(path2);
    return svg;
  }

  function createSpinner() {
    var spinner = document.createElement('span');
    spinner.className = 'btn-spinner';
    return spinner;
  }

  function updateButton() {
    // Clear existing content
    while (playgroundBtn.firstChild) {
      playgroundBtn.removeChild(playgroundBtn.firstChild);
    }

    // Reset button classes and state
    playgroundBtn.className = 'btn';
    playgroundBtn.disabled = false;

    // Apply variant and size
    playgroundBtn.classList.add(state.variant);
    playgroundBtn.classList.add(state.size);

    // Build content based on state
    if (state.state === 'loading') {
      playgroundBtn.classList.add('btn-loading');
      playgroundBtn.appendChild(createSpinner());
      var loadingText = document.createElement('span');
      loadingText.textContent = 'Loading...';
      playgroundBtn.appendChild(loadingText);
    } else {
      var textSpan = document.createElement('span');
      textSpan.textContent = 'Button';

      if (state.icon === 'left') {
        playgroundBtn.classList.add('btn-icon-left');
        playgroundBtn.appendChild(createArrowIcon());
        playgroundBtn.appendChild(textSpan);
      } else if (state.icon === 'right') {
        playgroundBtn.classList.add('btn-icon-right');
        playgroundBtn.appendChild(textSpan);
        playgroundBtn.appendChild(createArrowIcon());
      } else {
        playgroundBtn.appendChild(textSpan);
      }
    }

    if (state.state === 'disabled') {
      playgroundBtn.disabled = true;
    }

    updateCode();
  }

  function updateCode() {
    var classes = ['btn', state.variant, state.size];
    if (state.icon === 'left') classes.push('btn-icon-left');
    if (state.icon === 'right') classes.push('btn-icon-right');
    if (state.state === 'loading') classes.push('btn-loading');

    var classStr = classes.join(' ');
    var disabled = state.state === 'disabled' ? ' disabled' : '';

    var innerContent = 'Button';
    if (state.state === 'loading') {
      innerContent = '<span class="btn-spinner"></span>Loading...';
    } else if (state.icon !== 'none') {
      var iconHtml = '<svg>...</svg>';
      innerContent = state.icon === 'left' ? iconHtml + ' Button' : 'Button ' + iconHtml;
    }

    var code = '<button class="' + classStr + '"' + disabled + '>' + innerContent + '</button>';
    outputCode.textContent = code;
  }

  // Add click handlers to control buttons
  document.querySelectorAll('.control-options').forEach(function(group) {
    var controlType = group.getAttribute('data-control');

    group.querySelectorAll('.control-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        // Update active state
        group.querySelectorAll('.control-btn').forEach(function(b) {
          b.classList.remove('active');
        });
        this.classList.add('active');

        // Update state
        state[controlType] = this.getAttribute('data-value');
        updateButton();
      });
    });
  });
});
</script>
