</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var triggerBtn = document.querySelector('.trigger-toast');
  var container = document.getElementById('toast-container');

  if (triggerBtn && container) {
    triggerBtn.addEventListener('click', function() {
      var types = ['success', 'info', 'warning', 'error'];
      var messages = {
        success: 'Saved!',
        info: 'Just a moment...',
        warning: 'Add a name first',
        error: "Couldn't save that. Try again?"
      };

      var type = types[Math.floor(Math.random() * types.length)];
      var template = document.getElementById('toast-template-' + type);

      if (template) {
        var clone = template.content.cloneNode(true);
        var messageEl = clone.querySelector('.toast-message');
        var toastEl = clone.querySelector('.toast');

        if (messageEl) {
          messageEl.textContent = messages[type];
        }

        if (toastEl) {
          toastEl.style.animation = 'toast-slide-in 0.3s ease-out';
        }

        container.appendChild(clone);

        var addedToast = container.lastElementChild;
        var duration = type === 'error' ? 4000 : 2500;

        setTimeout(function() {
          if (addedToast && addedToast.parentNode) {
            addedToast.style.animation = 'toast-fade-out 0.2s ease-out forwards';
            setTimeout(function() {
              if (addedToast.parentNode) {
                addedToast.remove();
              }
            }, 200);
          }
        }, duration);
      }
    });
  }
});
</script>

<style>
@keyframes toast-slide-in {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes toast-fade-out {
  from { opacity: 1; }
  to { opacity: 0; }
}
</style>
