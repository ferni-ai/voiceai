  <section class="section">
    <h2>Animation</h2>

    <div class="demo-block">
      <h3>Enter & Exit</h3>
      <p class="demo-description">Toasts slide in from the edge and fade out gracefully.</p>
      <div class="demo-area animation-demo">
        <button class="btn btn-primary trigger-toast">Show Toast</button>
        <div class="toast-container" id="toast-container">
          <!-- Toast template for cloning -->
          <template id="toast-template-success">
            <div class="toast toast-success">
              <svg class="toast-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span class="toast-message"></span>
            </div>
          </template>
          <template id="toast-template-info">
            <div class="toast toast-info">
              <svg class="toast-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
              </svg>
              <span class="toast-message"></span>
            </div>
          </template>
          <template id="toast-template-warning">
            <div class="toast toast-warning">
              <svg class="toast-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
              <span class="toast-message"></span>
            </div>
          </template>
          <template id="toast-template-error">
            <div class="toast toast-error">
              <svg class="toast-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9" y1="9" x2="15" y2="15"/>
              </svg>
              <span class="toast-message"></span>
            </div>
          </template>
        </div>
      </div>
      <div class="code-block">
        <pre><code>.toast-enter {
  animation: toast-slide-in var(--duration-normal) var(--ease-spring);
}

.toast-exit {
  animation: toast-fade-out var(--duration-fast) var(--ease-ease-out);
}

@keyframes toast-slide-in {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes toast-fade-out {
  from { opacity: 1; }
  to { opacity: 0; }
}</code></pre>
      </div>
    </div>
  </section>

