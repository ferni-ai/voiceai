  font-size: 0.9rem;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.status-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
  text-align: center;
}

.status-avatar {
  width: 50px;
  height: 50px;
  margin: 0 auto var(--space-3);
  border-radius: 50%;
  background: var(--color-accent);
}

.status-avatar.connecting {
  animation: pulse 1.5s ease-in-out infinite;
}

.status-avatar.connected {
  animation: settle 0.5s ease-out;
}

.status-avatar.disconnected {
  opacity: 0.3;
}

.status-avatar.error {
  animation: shake 0.5s ease-in-out;
