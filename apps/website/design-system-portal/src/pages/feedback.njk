<script>
document.addEventListener('DOMContentLoaded', function() {
  const demoToast = document.getElementById('demoToast');
  const triggers = document.querySelectorAll('.toast-trigger');

  triggers.forEach(function(trigger) {
    trigger.addEventListener('click', function() {
      const type = this.getAttribute('data-type');
      const message = this.getAttribute('data-message');

      demoToast.textContent = message;
      demoToast.className = 'demo-toast ' + type;

      demoToast.style.animation = 'none';
      void demoToast.offsetWidth;
      demoToast.style.animation = 'toastEnter 0.3s ease-out';
    });
  });
});
</script>
