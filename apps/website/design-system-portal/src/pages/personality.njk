          <span class="label">Animation</span>
          <span>Stable, 1.0× timing</span>
        </div>
        <div class="spec-row">
          <span class="label">Haptic</span>
          <span>slowBreath</span>
        </div>
        <div class="spec-row">
          <span class="label">Sonic</span>
          <span>Lower register</span>
        </div>
        <div class="spec-row">
          <span class="label">Voice</span>
          <span>Steady</span>
