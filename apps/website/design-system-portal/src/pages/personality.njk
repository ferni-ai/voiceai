      <div class="trait-specs">
        <div class="spec-row">
          <span class="label">Animation</span>
          <span>Attentive, 0.9× timing</span>
        </div>
        <div class="spec-row">
          <span class="label">Haptic</span>
          <span>heartbeat</span>
        </div>
        <div class="spec-row">
          <span class="label">Sonic</span>
          <span>Clear</span>
        </div>
        <div class="spec-row">
          <span class="label">Voice</span>
