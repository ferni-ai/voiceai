    <div class="trait-card" style="--trait-color: #756A5E">
      <div class="trait-header">
        <h3>Human</h3>
        <span class="color-bias">Natural</span>
      </div>
      <p class="trait-description">Natural, organic, approachable</p>

      <div class="trait-specs">
        <div class="spec-row">
          <span class="label">Animation</span>
          <span>Organic, 1.1× timing</span>
        </div>
        <div class="spec-row">
          <span class="label">Haptic</span>
          <span>warmPulse</span>
        </div>
        <div class="spec-row">
          <span class="label">Sonic</span>
          <span>Breath texture</span>
