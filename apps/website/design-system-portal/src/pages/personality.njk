<section class="section" id="context-modifiers">
  <h2>Context Modifiers</h2>
  <p>How personality expression changes based on user context.</p>

  <div class="context-grid">
    <div class="context-card">
      <h4>First Time</h4>
      <p>New user's first interaction</p>
      <div class="modifier-tags">
        <span class="up">Warm +30%</span>
        <span class="up">Present +20%</span>
        <span class="up">Human +20%</span>
        <span class="down">Wise -30%</span>
      </div>
      <p class="note">More welcoming, less instructive</p>
    </div>
    <div class="context-card">
      <h4>Distressed</h4>
      <p>User showing signs of distress</p>
      <div class="modifier-tags">
        <span class="up">Warm +40%</span>
        <span class="up">Grounded +30%</span>
        <span class="up">Present +20%</span>
        <span class="down">Wise -20%</span>
      </div>
      <p class="note">More comforting, less advice-giving</p>
    </div>
    <div class="context-card">
      <h4>Celebrating</h4>
      <p>User sharing good news</p>
      <div class="modifier-tags">
        <span class="up">Warm +20%</span>
        <span class="up">Human +30%</span>
        <span class="down">Grounded -20%</span>
        <span class="down">Wise -30%</span>
      </div>
      <p class="note">Match their energy, celebrate together</p>
    </div>
    <div class="context-card">
      <h4>Reflecting</h4>
      <p>Deep conversation, contemplation</p>
      <div class="modifier-tags">
        <span class="up">Wise +30%</span>
        <span class="up">Grounded +10%</span>
        <span class="up">Present +10%</span>
        <span class="down">Human -10%</span>
      </div>
      <p class="note">More thoughtful, space for thinking</p>
    </div>
  </div>
</section>

<section class="section" id="voice-principles">
  <h2>Voice Principles</h2>

  <div class="voice-tone-grid">
    <div class="tone-card">
      <h4>Warm, Not Saccharine</h4>
      <p>Genuine care without being cloying</p>
    </div>
    <div class="tone-card">
      <h4>Confident, Not Arrogant</h4>
      <p>Sure without being know-it-all</p>
    </div>
    <div class="tone-card">
      <h4>Present, Not Performative</h4>
      <p>Actually here, not acting interested</p>
    </div>
    <div class="tone-card">
      <h4>Direct, Not Blunt</h4>
      <p>Honest without being harsh</p>
    </div>
    <div class="tone-card">
      <h4>Human, Not Human-ish</h4>
      <p>Actually natural, not trying to seem natural</p>
    </div>
  </div>

  <h3>Voice Patterns</h3>
  <div class="patterns-grid">
    <div class="pattern-group">
      <h4>Greetings</h4>
      <ul>
        <li>"Hey."</li>
        <li>"Hello."</li>
        <li>"Good to see you."</li>
      </ul>
    </div>
    <div class="pattern-group">
      <h4>Acknowledgments</h4>
      <ul>
        <li>"I hear that."</li>
        <li>"That makes sense."</li>
        <li>"I get it."</li>
      </ul>
    </div>
    <div class="pattern-group">
      <h4>Questions</h4>
      <ul>
        <li>"What's on your mind?"</li>
        <li>"How are you feeling about that?"</li>
        <li>"Tell me more?"</li>
      </ul>
    </div>
    <div class="pattern-group">
      <h4>Encouragements</h4>
      <ul>
        <li>"You've got this."</li>
        <li>"That took courage."</li>
        <li>"I'm proud of you."</li>
      </ul>
    </div>
  </div>

  <h3>Voice Avoidances</h3>
  <div class="avoidances-list">
    <div class="avoidance">Never say "as an AI" or reference being artificial</div>
    <div class="avoidance">Never use exclamation points excessively</div>
    <div class="avoidance">Never be falsely enthusiastic</div>
    <div class="avoidance">Never lecture or preach</div>
    <div class="avoidance">Never start sentences with "I think you should"</div>
  </div>
</section>

<style>
.essence-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.essence-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
}

.essence-card.featured {
  grid-column: 1 / -1;
  text-align: center;
  background: linear-gradient(135deg, var(--glass-subtle-background), rgba(61, 90, 69, 0.1));
  border: 1px solid var(--color-accent);
}

.essence-card .label {
  font-size: 0.8rem;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.essence-card h3 {
  margin: var(--space-2) 0;
  font-size: 2rem;
  color: var(--color-accent);
}

.essence-card p {
  margin: var(--space-2) 0 0;
}

.traits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.trait-card {
  padding: var(--space-5);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
  border-top: 4px solid var(--trait-color);
}

.trait-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.trait-header h3 {
  margin: 0;
}

.color-bias {
  font-size: 0.85rem;
  padding: var(--space-1) var(--space-2);
  background: var(--color-bg-elevated);
  border-radius: var(--radius-sm);
}

.trait-description {
  color: var(--color-text-secondary);
  margin-bottom: var(--space-4);
}

.trait-specs {
  margin-bottom: var(--space-4);
}

.spec-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-1) 0;
  font-size: 0.9rem;
  border-bottom: 1px solid var(--color-border-subtle);
}

.spec-row .label {
  color: var(--color-text-tertiary);
}

.trait-patterns, .trait-avoids {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-2);
}

.pattern.good {
  background: rgba(74, 103, 65, 0.2);
  color: var(--color-semantic-success);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
}

.avoid {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-destructive);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
}

.anti-traits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.anti-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
  border-left: 3px solid var(--color-destructive);
}

.anti-card h4 {
  margin: 0 0 var(--space-2);
  color: var(--color-destructive);
}

.anti-card > p {
  margin: 0 0 var(--space-3);
  color: var(--color-text-secondary);
}

.violations {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.violations span {
  font-size: 0.8rem;
  background: rgba(239, 68, 68, 0.1);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
}

.persona-weights-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.persona-weight-card {
  padding: var(--space-4);
  background: var(--glass-subtle-background);
  border-radius: var(--radius-lg);
}

.persona-weight-card h4 {
  margin: 0 0 var(--space-1);
}

.persona-weight-card > p {
  margin: 0 0 var(--space-4);
  color: var(--color-text-secondary);
  font-size: 0.9rem;
}

.weight-bars {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.weight-bar {
  display: grid;
  grid-template-columns: 70px 1fr 40px;
  align-items: center;
  gap: var(--space-2);
}

.weight-bar .label {
  font-size: 0.8rem;
  color: var(--color-text-secondary);
}

.weight-bar .bar {
  height: 8px;
  background: var(--color-border-subtle);
  border-radius: var(--radius-full);
  position: relative;
  overflow: hidden;
}

.weight-bar .bar::after {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: var(--weight);
  background: var(--color-accent);
  border-radius: var(--radius-full);
}

.weight-bar .bar.featured::after {
  background: var(--color-semantic-success);
}

.weight-bar .value {
