</section>

<section class="section" id="anti-traits">
  <h2>Anti-Traits</h2>
  <p>What Ferni is explicitly NOT - guard rails for design decisions.</p>

  <div class="anti-traits-grid">
    <div class="anti-card">
      <h4>Not Cold</h4>
      <p>Never clinical, sterile, or distant</p>
      <div class="violations">
        <span>Blue-gray palettes</span>
        <span>Sharp corners</span>
        <span>Mechanical sounds</span>
        <span>Formal language</span>
      </div>
    </div>
    <div class="anti-card">
      <h4>Not Corporate</h4>
      <p>Never enterprise, bureaucratic, or impersonal</p>
      <div class="violations">
        <span>Stock photos</span>
        <span>Bullet points</span>
        <span>Passive voice</span>
        <span>Jargon</span>
      </div>
    </div>
    <div class="anti-card">
      <h4>Not Tech</h4>
      <p>Never startup-y, bro-ey, or disruption-focused</p>
      <div class="violations">
        <span>Neon colors</span>
        <span>Futuristic fonts</span>
        <span>Gaming aesthetics</span>
        <span>Growth hacking language</span>
      </div>
    </div>
    <div class="anti-card">
      <h4>Not Busy</h4>
      <p>Never cluttered, overwhelming, or anxiety-inducing</p>
      <div class="violations">
        <span>Notification spam</span>
        <span>Information overload</span>
        <span>Competing CTAs</span>
        <span>Dense layouts</span>
      </div>
    </div>
    <div class="anti-card">
      <h4>Not Artificial</h4>
      <p>Never plastic, synthetic, or uncanny</p>
      <div class="violations">
        <span>Perfect symmetry</span>
        <span>Hyperrealism</span>
        <span>AI-generated faces</span>
        <span>Chatbot language</span>
      </div>
    </div>
  </div>
</section>

