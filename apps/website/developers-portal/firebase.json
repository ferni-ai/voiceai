{
  "hosting": {
    "site": "ferni-developers",
    "public": "_site",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/api/v1/**",
        "run": {
          "serviceId": "john-bogle-ui",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/v2/**",
        "run": {
          "serviceId": "john-bogle-ui",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/openapi.yaml",
        "destination": "/api/openapi.yaml"
      },
      {
        "source": "/api{,/**}",
        "destination": "/pages/api/index.html"
      },
      {
        "source": "/getting-started{,/**}",
        "destination": "/pages/getting-started/index.html"
      },
      {
        "source": "/sdk{,/**}",
        "destination": "/pages/sdk/index.html"
      },
      {
        "source": "/examples{,/**}",
        "destination": "/pages/examples/index.html"
      },
      {
        "source": "/console{,/**}",
        "destination": "/pages/console/index.html"
      },
      {
        "source": "/personas",
        "destination": "/pages/personas/index.html"
      },
      {
        "source": "/personas/",
        "destination": "/pages/personas/index.html"
      },
      {
        "source": "/personas/create{,/**}",
        "destination": "/pages/personas/create/index.html"
      },
      {
        "source": "**",
        "destination": "/404.html"
      }
    ]
  }
}
