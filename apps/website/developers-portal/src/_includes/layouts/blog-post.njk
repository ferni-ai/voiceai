<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Ferni Developer Blog</title>
  <meta name="description" content="{{ excerpt or description or site.description }}">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233D5A45' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='4 17 10 11 4 5'/><line x1='12' x2='20' y1='19' y2='19'/></svg>">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ excerpt or description }}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  {% if ogImage %}
  <meta property="og:image" content="{{ site.url }}{{ ogImage }}">
  {% endif %}

  <!-- Article metadata -->
  <meta property="article:published_time" content="{{ date | date('iso') }}">
  <meta property="article:author" content="{{ author }}">
  {% if category %}
  <meta property="article:section" content="{{ category }}">
  {% endif %}

  <!-- Theme -->
  <script>
    (function() {
      const saved = localStorage.getItem('ferni-theme');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved || (systemDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.classList.add('no-transitions');
    })();
  </script>

  <!-- Styles -->
  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/docs.css">
  <link rel="stylesheet" href="/css/blog.css">
</head>
<body>
  {% include "partials/nav.njk" %}

  <article class="blog-post">
    <header class="blog-post-header">
      <div class="container-narrow">
        <a href="/blog/" class="blog-back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to Blog
        </a>

        <div class="blog-post-meta">
          {% if category %}
          <span class="blog-post-category">{{ category }}</span>
          {% endif %}
          <time datetime="{{ date | date('iso') }}">{{ date | date('MMMM d, yyyy') }}</time>
          {% if readTime %}
          <span class="blog-post-read-time">{{ readTime }} min read</span>
          {% endif %}
        </div>

        <h1>{{ title }}</h1>

        {% if excerpt %}
        <p class="blog-post-excerpt">{{ excerpt }}</p>
        {% endif %}

        <div class="blog-post-author">
          <span class="blog-post-author-avatar" style="background: {{ authorColor or 'var(--accent-primary)' }}">
            {{ authorInitials or 'FD' }}
          </span>
          <div class="blog-post-author-info">
            <span class="blog-post-author-name">{{ author or 'Ferni Dev Team' }}</span>
            <span class="blog-post-author-role">{{ authorRole or 'Developer' }}</span>
          </div>
        </div>
      </div>
    </header>

    <div class="blog-post-content">
      <div class="container-narrow prose">
        {{ content | safe }}
      </div>
    </div>

    <footer class="blog-post-footer">
      <div class="container-narrow">
        <!-- Share buttons -->
        <div class="blog-share">
          <span class="blog-share-label">Share this article</span>
          <div class="blog-share-buttons">
            <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener" class="btn btn-ghost" aria-label="Share on Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener" class="btn btn-ghost" aria-label="Share on LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <button onclick="copyToClipboard('{{ site.url }}{{ page.url }}')" class="btn btn-ghost" aria-label="Copy link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Newsletter CTA -->
        <div class="blog-newsletter">
          <h3>Stay in the loop</h3>
          <p>Get the latest updates on voice AI development, API changes, and engineering best practices.</p>
          <form class="blog-newsletter-form">
            <input type="email" placeholder="your@email.com" required>
            <button type="submit" class="btn btn-primary">Subscribe</button>
          </form>
        </div>
      </div>
    </footer>
  </article>

  {% include "partials/footer.njk" %}

  <script>
    window.addEventListener('load', function() {
      requestAnimationFrame(function() {
        document.documentElement.classList.remove('no-transitions');
      });
    });

    function toggleTheme() {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('ferni-theme', next);
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => {
        // Could add a toast notification here
        alert('Link copied!');
      });
    }
  </script>
</body>
</html>
