<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- Fonts: Plus Jakarta Sans (display), Inter (body), JetBrains Mono (code) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233D5A45' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='4 17 10 11 4 5'/><line x1='12' x2='20' y1='19' y2='19'/></svg>">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }} | {{ site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">

  <!-- Theme: Prevent flash of wrong theme -->
  <script>
    (function() {
      // Get saved preference or system preference
      const saved = localStorage.getItem('ferni-theme');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved || (systemDark ? 'dark' : 'light');
      
      // Apply theme immediately to prevent flash
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.classList.add('no-transitions');
    })();
  </script>

  <!-- Styles (v=20260120 cache bust) -->
  <link rel="stylesheet" href="/css/tokens.css?v=20260120">
  <link rel="stylesheet" href="/css/components.css?v=20260120">
  <link rel="stylesheet" href="/css/prism.css?v=20260120">
  {% if extraCss %}
  <link rel="stylesheet" href="/css/{{ extraCss }}.css">
  {% endif %}
</head>
<body>
  <!-- Skip to content link for accessibility -->
  <a href="#main-content" class="skip-to-content">Skip to content</a>

  {% include "partials/nav.njk" %}

  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script>
    // Remove no-transitions class after page load
    window.addEventListener('load', function() {
      // Small delay to ensure CSS is applied
      requestAnimationFrame(function() {
        document.documentElement.classList.remove('no-transitions');
      });
    });

    // Theme toggle function
    function toggleTheme() {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      
      html.setAttribute('data-theme', next);
      localStorage.setItem('ferni-theme', next);
    }

    // Listen for system theme changes
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
      // Only auto-switch if user hasn't manually set a preference
      if (!localStorage.getItem('ferni-theme')) {
        document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
      }
    });
  </script>

  <!-- Code copy functionality -->
  <script src="/js/code-copy.js"></script>
  
  <!-- Search functionality -->
  <script src="/js/search.js"></script>

  {% if extraJs %}
  <script src="/js/{{ extraJs }}.js"></script>
  {% endif %}
</body>
</html>
