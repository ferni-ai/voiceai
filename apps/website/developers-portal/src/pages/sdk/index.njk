    <!-- Core Concepts -->
    <div style="margin-bottom: var(--space-12);">
      <h2 style="margin-bottom: var(--space-4);">Core Concepts</h2>

      <div style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: var(--space-6); margin-bottom: var(--space-4);">
        <h3 style="margin-bottom: var(--space-2);">Cognitive Profiles</h3>
        <p style="color: var(--text-secondary); margin-bottom: var(--space-3);">
          Define how your agent reasons and processes information:
        </p>
        <ul style="color: var(--text-secondary); line-height: 2;">
          <li><strong>narrative</strong> - Story-driven reasoning (good for coaches)</li>
          <li><strong>analytical</strong> - Data-driven pattern recognition (researchers)</li>
          <li><strong>empathetic</strong> - Emotion-first approach (therapists)</li>
          <li><strong>pragmatic</strong> - Action-oriented solutions (assistants)</li>
          <li><strong>systematic</strong> - Process-oriented structure (organizers)</li>
          <li><strong>intuitive</strong> - Wisdom-based contemplation (philosophers)</li>
        </ul>
      </div>

      <div style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: var(--space-6); margin-bottom: var(--space-4);">
        <h3 style="margin-bottom: var(--space-2);">Humanization Presets</h3>
        <p style="color: var(--text-secondary); margin-bottom: var(--space-3);">
          Choose how natural your agent's speech patterns should be:
        </p>
        <ul style="color: var(--text-secondary); line-height: 2;">
          <li><strong>casual</strong> - Friendly, conversational tone</li>
          <li><strong>professional</strong> - Clear, business-appropriate</li>
          <li><strong>therapeutic</strong> - Warm, patient, reflective</li>
        </ul>
      </div>

      <div style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: var(--space-6);">
        <h3 style="margin-bottom: var(--space-2);">Context Builders</h3>
        <p style="color: var(--text-secondary); margin-bottom: var(--space-3);">
          Enrich conversations with intelligent context:
        </p>
        <ul style="color: var(--text-secondary); line-height: 2;">
          <li><strong>Memory</strong> - Remember user preferences and history</li>
          <li><strong>Emotion</strong> - Detect and respond to emotional state</li>
          <li><strong>Time</strong> - Adapt to time of day and special dates</li>
          <li><strong>Topics</strong> - Track conversation themes</li>
          <li><strong>Superhuman Insights</strong> - Surface patterns users don't see</li>
        </ul>
      </div>
    </div>

