<div class="environment-selector">
  <label for="env-select">Environment:</label>
  <select id="env-select" onchange="switchEnvironment(this.value)">
    <option value="sandbox">Sandbox (Test)</option>
    <option value="production">Production (Live)</option>
  </select>
  <span class="env-indicator sandbox" id="env-indicator">
    <svg class="env-dot" width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
      <circle cx="12" cy="12" r="6"/>
    </svg>
    <span class="env-label">Test Mode</span>
  </span>
</div>

<div id="production-warning-container" style="display: none;">
  <div class="production-warning">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
      <line x1="12" y1="9" x2="12" y2="13"/>
      <line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <span><strong>Production Mode:</strong> Requests will use your live API key and count toward billing.</span>
  </div>
</div>

<div id="swagger-ui-container"></div>

<!-- Swagger UI CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui.css">
<script src="https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-bundle.js"></script>
<script src="https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-standalone-preset.js"></script>

<script>
  // Environment configuration
  const environments = {
    sandbox: {
      url: 'https://api.ferni.ai',
      keyPrefix: 'ferni_test_',
      label: 'Test Mode',
      className: 'sandbox'
    },
    production: {
      url: 'https://api.ferni.ai',
      keyPrefix: 'ferni_live_',
      label: 'Production',
      className: 'production'
    }
  };

  let currentEnv = 'sandbox';

  // Initialize Swagger UI
  const ui = SwaggerUIBundle({
    url: '/api/openapi.yaml',
    dom_id: '#swagger-ui-container',
    deepLinking: true,
    presets: [
      SwaggerUIBundle.presets.apis,
      SwaggerUIStandalonePreset
    ],
    plugins: [
      SwaggerUIBundle.plugins.DownloadUrl
    ],
    layout: 'StandaloneLayout',
    persistAuthorization: true,
    displayRequestDuration: true,
    filter: true,
    showExtensions: true,
    showCommonExtensions: true,
    requestInterceptor: function(request) {
      // Add environment-specific headers if needed
      return request;
    },
    onComplete: function() {
      // Apply theme after load
      const wrapper = document.querySelector('.swagger-ui');
      if (wrapper) {
        wrapper.style.background = 'transparent';
      }
    }
  });

  // Switch environment (safe DOM manipulation)
  function switchEnvironment(env) {
    currentEnv = env;
    const config = environments[env];

    // Update indicator using safe DOM methods
    const indicator = document.getElementById('env-indicator');
    indicator.className = 'env-indicator ' + config.className;

    const labelEl = indicator.querySelector('.env-label');
    if (labelEl) {
      labelEl.textContent = config.label;
    }

    // Toggle production warning visibility
    const warningContainer = document.getElementById('production-warning-container');
    if (env === 'production') {
      warningContainer.style.display = 'block';
    } else {
      warningContainer.style.display = 'none';
    }
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', function() {
    switchEnvironment('sandbox');
  });
</script>
