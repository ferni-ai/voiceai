---
layout: layouts/base.njk
title: API Explorer
description: Interactive API documentation powered by Swagger UI
permalink: /api/explorer/
---

<style>
  /* Swagger UI Theme Overrides for Ferni Cedar Night */
  .swagger-ui {
    font-family: var(--font-body);
  }

  .swagger-ui .topbar {
    display: none;
  }

  .swagger-ui .info {
    margin: 24px 0;
  }

  .swagger-ui .info .title {
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .swagger-ui .info .description {
    color: var(--text-secondary);
  }

  .swagger-ui .opblock-tag {
    font-family: var(--font-display);
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-primary);
  }

  .swagger-ui .opblock {
    background: var(--surface-secondary);
    border-radius: 8px;
    border: 1px solid var(--border-primary);
    margin-bottom: 8px;
  }

  .swagger-ui .opblock .opblock-summary {
    border-radius: 8px;
  }

  .swagger-ui .opblock .opblock-summary-method {
    border-radius: 4px;
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .swagger-ui .opblock.opblock-get .opblock-summary-method {
    background: var(--color-cedar-dark);
    color: var(--color-gold);
  }

  .swagger-ui .opblock.opblock-post .opblock-summary-method {
    background: #3D5A45;
    color: white;
  }

  .swagger-ui .opblock.opblock-put .opblock-summary-method {
    background: #B8860B;
    color: white;
  }

  .swagger-ui .opblock.opblock-delete .opblock-summary-method {
    background: #8B0000;
    color: white;
  }

  .swagger-ui .opblock-summary-path {
    font-family: var(--font-mono);
    color: var(--text-primary);
  }

  .swagger-ui .opblock-description-wrapper {
    color: var(--text-secondary);
  }

  .swagger-ui .btn {
    font-family: var(--font-body);
    border-radius: 6px;
  }

  .swagger-ui .btn.execute {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .swagger-ui .btn.authorize {
    background: transparent;
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .swagger-ui .btn.authorize svg {
    fill: var(--color-gold);
  }

  .swagger-ui .model-box {
    background: var(--surface-secondary);
    border-radius: 8px;
  }

  .swagger-ui .model {
    color: var(--text-primary);
  }

  .swagger-ui .model-title {
    color: var(--color-gold);
  }

  .swagger-ui .prop-type {
    color: var(--color-accent);
  }

  .swagger-ui table tbody tr td {
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-primary);
  }

  .swagger-ui .parameter__name {
    color: var(--text-primary);
    font-family: var(--font-mono);
  }

  .swagger-ui .parameter__type {
    color: var(--color-gold);
    font-family: var(--font-mono);
  }

  .swagger-ui .response-col_status {
    font-family: var(--font-mono);
    color: var(--text-primary);
  }

  .swagger-ui .response-col_description {
    color: var(--text-secondary);
  }

  .swagger-ui code,
  .swagger-ui pre {
    font-family: var(--font-mono);
    background: var(--surface-tertiary);
    border-radius: 4px;
  }

  .swagger-ui .highlight-code {
    background: var(--surface-tertiary);
    border-radius: 8px;
  }

  .swagger-ui .scheme-container {
    background: var(--surface-secondary);
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 24px;
  }

  .swagger-ui select {
    background: var(--surface-secondary);
    border: 1px solid var(--border-primary);
    border-radius: 4px;
    color: var(--text-primary);
    padding: 8px 12px;
  }

  .swagger-ui input[type="text"],
  .swagger-ui input[type="password"] {
    background: var(--surface-secondary);
    border: 1px solid var(--border-primary);
    border-radius: 4px;
    color: var(--text-primary);
    padding: 8px 12px;
  }

  .swagger-ui .auth-wrapper {
    background: var(--surface-secondary);
    border-radius: 8px;
    padding: 16px;
  }

  .swagger-ui .dialog-ux .modal-ux {
    background: var(--surface-primary);
    border-radius: 12px;
    border: 1px solid var(--border-primary);
  }

  .swagger-ui .dialog-ux .modal-ux-header {
    border-bottom: 1px solid var(--border-primary);
  }

  .swagger-ui .dialog-ux .modal-ux-header h3 {
    color: var(--text-primary);
    font-family: var(--font-display);
  }

  /* Hero section */
  .api-explorer-hero {
    text-align: center;
    padding: 48px 24px;
    border-bottom: 1px solid var(--border-primary);
    margin-bottom: 24px;
  }

  .api-explorer-hero h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .api-explorer-hero p {
    color: var(--text-secondary);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto 24px;
  }

  .api-explorer-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .api-explorer-actions a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .api-explorer-actions .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .api-explorer-actions .btn-primary:hover {
    background: var(--color-accent-dark);
    transform: translateY(-2px);
  }

  .api-explorer-actions .btn-secondary {
    background: transparent;
    border: 1px solid var(--border-primary);
    color: var(--text-primary);
  }

  .api-explorer-actions .btn-secondary:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* Environment selector */
  .environment-selector {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    padding: 16px;
    background: var(--surface-secondary);
    border-radius: 8px;
  }

  .environment-selector label {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .environment-selector select {
    background: var(--surface-tertiary);
    border: 1px solid var(--border-primary);
    border-radius: 6px;
    color: var(--text-primary);
    padding: 8px 16px;
    font-family: var(--font-mono);
    cursor: pointer;
  }

  .environment-selector .env-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .environment-selector .env-indicator.production {
    background: rgba(139, 0, 0, 0.2);
    color: #ff6b6b;
  }

  .environment-selector .env-indicator.sandbox {
    background: rgba(61, 90, 69, 0.2);
    color: #6bff8b;
  }

  .production-warning {
    background: rgba(139, 0, 0, 0.2);
    border: 1px solid #8B0000;
    border-radius: 8px;
    padding: 12px 16px;
    margin: 16px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: #ff6b6b;
  }

  .production-warning svg {
    flex-shrink: 0;
  }

  /* Swagger container */
  #swagger-ui-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px 48px;
  }
</style>

