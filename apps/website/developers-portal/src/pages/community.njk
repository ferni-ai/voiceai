<style>
  .community-page {
    padding-top: var(--header-height);
  }

  .community-header {
    text-align: center;
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
  }

  .community-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-primary);
    background: var(--accent-subtle);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
  }

  .community-header h1 {
    font-size: var(--text-5xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
  }

  .community-header p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .community-content {
    padding: var(--space-12) 0 var(--space-16);
  }

  .community-channels {
    margin-bottom: var(--space-16);
  }

  .community-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .community-channel {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-normal) var(--ease-gentle);
  }

  .community-channel:hover {
    border-color: var(--border-medium);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .community-channel-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .community-channel-content h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .community-channel-content p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .community-channel-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent-primary);
  }

  .community-channel:hover .community-channel-cta svg {
    transform: translate(2px, -2px);
  }

  .community-channel-cta svg {
    transition: transform var(--duration-fast);
  }

  .community-resources {
    margin-bottom: var(--space-16);
  }

  .community-resources h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
    text-align: center;
  }

  .community-resources-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .community-resource {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-normal) var(--ease-gentle);
  }

  .community-resource:hover {
    background: var(--bg-tertiary);
    transform: translateY(-2px);
  }

  .community-resource svg {
    color: var(--accent-primary);
  }

  .community-resource h4 {
    font-size: var(--text-base);
    font-weight: 600;
    margin: 0;
  }

  .community-resource p {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0;
  }

  .community-support {
    background: var(--bg-secondary);
    border-radius: var(--radius-2xl);
    padding: var(--space-12);
    text-align: center;
  }

  .community-support h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }

  .community-support > p {
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .community-support ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-align: left;
    max-width: 400px;
    margin: 0 auto;
  }

  .community-support li {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .community-support li strong {
    color: var(--text-primary);
  }

  @media (max-width: 1024px) {
    .community-resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .community-header h1 {
      font-size: var(--text-4xl);
    }

    .community-grid {
      grid-template-columns: 1fr;
    }

    .community-resources-grid {
      grid-template-columns: 1fr;
    }

    .community-support {
      padding: var(--space-8);
    }
  }
</style>
