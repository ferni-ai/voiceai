---
layout: layouts/base.njk
title: Analytics Dashboard
description: Monitor your API usage and persona performance
---

<section class="hero" style="padding-bottom: var(--space-12);">
  <div class="container">
    <div class="hero-eyebrow">Developer Console</div>
    <h1>Analytics<br><span class="accent">Dashboard</span></h1>
    <p class="hero-subtitle">
      Track API usage, monitor persona performance, and identify trends.
    </p>
  </div>
</section>

<!-- Authentication Gate -->
<section id="auth-gate" class="section" style="padding-top: var(--space-8); padding-bottom: var(--space-8);">
  <div class="container container-narrow">
    <div style="background: var(--bg-elevated); border: 1px solid var(--border-medium); border-radius: var(--radius-2xl); padding: var(--space-12); text-align: center;">
      <div style="width: 64px; height: 64px; background: var(--accent-subtle); border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-6); color: var(--accent-primary);">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 3v18h18"/>
          <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>
        </svg>
      </div>
      <h2 style="margin-bottom: var(--space-4);">Sign in to View Analytics</h2>
      <p style="color: var(--text-secondary); margin-bottom: var(--space-8); max-width: 400px; margin-left: auto; margin-right: auto;">
        Authenticate to view your usage statistics, performance metrics, and trend analysis.
      </p>
      <div style="display: flex; flex-direction: column; gap: var(--space-4); max-width: 320px; margin: 0 auto;">
        <button id="google-signin-btn" class="btn btn-primary" style="width: 100%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Sign in with Google
        </button>
        <button id="github-signin-btn" class="btn btn-secondary" style="width: 100%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Sign in with GitHub
        </button>
      </div>
    </div>
  </div>
</section>

<!-- Analytics Dashboard (shown after authentication) -->
<section id="dashboard" class="section" style="background: var(--bg-secondary); padding-top: var(--space-16); display: none;">
  <div class="container">
    <!-- Header with Period Selector -->
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-12); flex-wrap: wrap; gap: var(--space-4);">
      <div>
        <h2 style="margin-bottom: var(--space-2);">Usage Overview</h2>
        <p id="user-email" style="color: var(--text-secondary); margin: 0;"></p>
      </div>
      <div style="display: flex; gap: var(--space-4); align-items: center;">
        <select id="period-selector" class="period-select">
          <option value="day">Last 24 Hours</option>
          <option value="week" selected>Last 7 Days</option>
          <option value="month">Last 30 Days</option>
          <option value="year">Last Year</option>
        </select>
        <a href="/console/" class="btn btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to Console
        </a>
      </div>
    </div>

    <!-- Stats Overview Cards -->
    <div class="stats-grid" style="margin-bottom: var(--space-12);">
      <div class="stat-card">
        <div class="stat-header">
          <div class="stat-icon" style="background: var(--accent-subtle); color: var(--accent-primary);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <span id="api-calls-change" class="stat-change positive">+0%</span>
        </div>
        <div class="stat-value" id="api-calls-value">0</div>
        <div class="stat-label">Total API Calls</div>
      </div>

      <div class="stat-card">
        <div class="stat-header">
          <div class="stat-icon" style="background: rgba(52, 199, 89, 0.1); color: #34c759;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <span id="users-change" class="stat-change positive">+0%</span>
        </div>
        <div class="stat-value" id="users-value">0</div>
        <div class="stat-label">Unique Users</div>
      </div>

      <div class="stat-card">
        <div class="stat-header">
          <div class="stat-icon" style="background: rgba(175, 82, 222, 0.1); color: #af52de;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
              <line x1="9" y1="9" x2="9.01" y2="9"/>
              <line x1="15" y1="9" x2="15.01" y2="9"/>
            </svg>
          </div>
          <span id="personas-change" class="stat-change positive">+0%</span>
        </div>
        <div class="stat-value" id="personas-value">0</div>
        <div class="stat-label">Active Personas</div>
      </div>

      <div class="stat-card">
        <div class="stat-header">
          <div class="stat-icon" style="background: rgba(255, 149, 0, 0.1); color: #ff9500;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <span id="response-time-change" class="stat-change positive">+0%</span>
        </div>
        <div class="stat-value" id="response-time-value">0<span class="stat-unit">ms</span></div>
        <div class="stat-label">Avg Response Time</div>
      </div>

      <div class="stat-card">
        <div class="stat-header">
          <div class="stat-icon" style="background: rgba(255, 59, 48, 0.1); color: #ff3b30;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <span id="error-rate-change" class="stat-change positive">+0%</span>
        </div>
        <div class="stat-value" id="error-rate-value">0<span class="stat-unit">%</span></div>
        <div class="stat-label">Error Rate</div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-grid" style="margin-bottom: var(--space-12);">
      <!-- Usage Over Time Chart -->
      <div class="chart-card">
        <h3 style="margin-bottom: var(--space-6);">API Usage Over Time</h3>
        <div class="chart-container">
          <canvas id="usage-chart"></canvas>
        </div>
      </div>

      <!-- Persona Breakdown -->
      <div class="chart-card">
        <h3 style="margin-bottom: var(--space-6);">Persona Usage</h3>
        <div id="persona-breakdown" class="persona-list">
          <div style="color: var(--text-muted); text-align: center; padding: var(--space-8);">Loading...</div>
        </div>
      </div>
    </div>

    <!-- Error Breakdown -->
    <div class="chart-card" style="margin-bottom: var(--space-12);">
      <h3 style="margin-bottom: var(--space-6);">Recent Errors</h3>
      <div id="error-breakdown" class="error-list">
        <div style="color: var(--text-muted); text-align: center; padding: var(--space-8);">Loading...</div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radius-xl); padding: var(--space-8);">
      <h3 style="margin-bottom: var(--space-6);">Quick Actions</h3>
      <div class="grid grid-3" style="gap: var(--space-4);">
        <a href="/console/" class="btn btn-secondary" style="width: 100%;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Manage API Keys
        </a>
        <a href="/personas/" class="btn btn-secondary" style="width: 100%;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
          </svg>
          View Personas
        </a>
        <a href="/api/" class="btn btn-secondary" style="width: 100%;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          API Reference
        </a>
      </div>
    </div>

  </div>
</section>

<!-- Styles -->
<style>
  .period-select {
    background: var(--bg-elevated);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    color: var(--text-primary);
    font-size: var(--text-sm);
    cursor: pointer;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stat-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .stat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stat-change {
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .stat-change.positive {
    background: rgba(52, 199, 89, 0.1);
    color: #34c759;
  }

  .stat-change.negative {
    background: rgba(255, 59, 48, 0.1);
    color: #ff3b30;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }

  .stat-unit {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-left: var(--space-1);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .charts-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-6);
  }

  @media (max-width: 768px) {
    .charts-grid {
      grid-template-columns: 1fr;
    }
  }

  .chart-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .chart-container {
    height: 300px;
    position: relative;
  }

  .persona-list {
    max-height: 300px;
    overflow-y: auto;
  }

  .persona-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .persona-item:last-child {
    border-bottom: none;
  }

  .persona-info {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .persona-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-primary);
    font-weight: 600;
  }

  .persona-name {
    font-weight: 600;
  }

  .persona-stats {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .persona-calls {
    text-align: right;
  }

  .persona-calls-value {
    font-weight: 700;
    font-size: 1.125rem;
  }

  .persona-calls-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .error-list {
    max-height: 300px;
    overflow-y: auto;
  }

  .error-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .error-item:last-child {
    border-bottom: none;
  }

  .error-info {
    flex: 1;
  }

  .error-code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #ff3b30;
    margin-bottom: var(--space-1);
  }

  .error-message {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .error-count {
    text-align: right;
    padding-left: var(--space-4);
  }

  .error-count-value {
    font-weight: 700;
    font-size: 1.125rem;
    color: #ff3b30;
  }

  .error-count-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .no-data {
    text-align: center;
    padding: var(--space-8);
    color: var(--text-muted);
  }

  .no-data svg {
    margin-bottom: var(--space-4);
    opacity: 0.5;
  }
</style>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<!-- Analytics Script -->
<script src="/js/analytics-dashboard.js"></script>
