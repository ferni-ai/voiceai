---
layout: layouts/base.njk
title: OAuth Providers - Developer Console
description: Configure OAuth providers for external service authentication
permalink: /console/oauth/
---

<section class="hero" style="padding-bottom: var(--space-12);">
  <div class="container">
    <div class="hero-eyebrow">Developer Console</div>
    <h1>OAuth <span class="accent">Providers</span></h1>
    <p class="hero-subtitle">
      Connect external services by configuring OAuth providers for your agents.
    </p>
  </div>
</section>

<!-- Authentication Gate -->
<section id="auth-gate" class="section" style="padding-top: var(--space-8); padding-bottom: var(--space-8);">
  <div class="container container-narrow">
    <div style="background: var(--bg-elevated); border: 1px solid var(--border-medium); border-radius: var(--radius-2xl); padding: var(--space-12); text-align: center;">
      <p style="color: var(--text-secondary);">Please sign in to manage your OAuth providers.</p>
      <a href="/console/" class="btn btn-primary" style="margin-top: var(--space-4);">Go to Console</a>
    </div>
  </div>
</section>

<!-- Dashboard (shown after authentication) -->
<section id="dashboard" class="section" style="background: var(--bg-secondary); padding-top: var(--space-16); display: none;">
  <div class="container">
    <!-- Header with back button -->
    <div style="display: flex; align-items: center; gap: var(--space-4); margin-bottom: var(--space-8);">
      <a href="/console/" class="btn btn-ghost" style="padding: var(--space-2);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
      </a>
      <div style="flex: 1;">
        <h2 style="margin: 0;">OAuth Providers</h2>
        <p style="color: var(--text-secondary); margin: 0;">Bring your own OAuth credentials</p>
      </div>
      <button id="create-provider-btn" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add Provider
      </button>
    </div>

    <!-- Info box -->
    <div style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radius-xl); padding: var(--space-4); margin-bottom: var(--space-6);">
      <p style="margin: 0; color: var(--text-secondary); font-size: var(--text-sm);">
        <strong>Bring Your Own Credentials (BYOC):</strong> Register OAuth providers with your own client IDs and secrets.
        When users connect through your agent, tokens are stored securely and used for tool execution.
      </p>
    </div>

    <!-- Providers list -->
    <div id="providers-list">
      <div class="loading-state">Loading your OAuth providers...</div>
    </div>

    <!-- Tokens section -->
    <div style="margin-top: var(--space-12);">
      <h3>Connected Tokens</h3>
      <p style="color: var(--text-secondary); font-size: var(--text-sm); margin-bottom: var(--space-4);">
        Active OAuth tokens connected by users.
      </p>
      <div id="tokens-list">
        <div class="loading-state">Loading tokens...</div>
      </div>
    </div>
  </div>
</section>

<!-- Create/Edit Modal -->
<div id="provider-modal" class="modal-overlay" style="display: none;">
  <div class="modal" style="max-width: 600px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6);">
      <h3 id="modal-title" style="margin: 0;">Add OAuth Provider</h3>
      <button id="close-modal-btn" class="btn btn-ghost" style="padding: var(--space-2);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <form id="provider-form">
      <input type="hidden" id="provider-id" name="id">

      <div class="form-group">
        <label for="provider-name">Provider Name</label>
        <input type="text" id="provider-name" name="name" required placeholder="My Spotify Integration">
      </div>

      <div class="form-group">
        <label for="provider-type">Provider Type</label>
        <select id="provider-type" name="type" required>
          <option value="custom">Custom OAuth 2.0</option>
          <option value="google">Google</option>
          <option value="spotify">Spotify</option>
          <option value="github">GitHub</option>
          <option value="slack">Slack</option>
          <option value="notion">Notion</option>
          <option value="linear">Linear</option>
          <option value="discord">Discord</option>
        </select>
      </div>

      <div id="custom-fields">
        <div class="form-group">
          <label for="provider-auth-url">Authorization URL</label>
          <input type="url" id="provider-auth-url" name="authUrl" placeholder="https://provider.com/oauth/authorize">
        </div>

        <div class="form-group">
          <label for="provider-token-url">Token URL</label>
          <input type="url" id="provider-token-url" name="tokenUrl" placeholder="https://provider.com/oauth/token">
        </div>
      </div>

      <div class="form-group">
        <label for="provider-client-id">Client ID</label>
        <input type="text" id="provider-client-id" name="clientId" required placeholder="your-client-id">
      </div>

      <div class="form-group">
        <label for="provider-client-secret">Client Secret</label>
        <input type="password" id="provider-client-secret" name="clientSecret" placeholder="Leave empty to keep existing">
        <small style="color: var(--text-muted);">Stored encrypted. Leave empty when editing to keep existing secret.</small>
      </div>

      <div class="form-group">
        <label for="provider-scopes">Scopes (space-separated)</label>
        <input type="text" id="provider-scopes" name="scopes" placeholder="read write user:email">
      </div>

      <div class="form-group">
        <label for="provider-redirect-uri">Redirect URI</label>
        <input type="url" id="provider-redirect-uri" name="redirectUri" readonly>
        <small style="color: var(--text-muted);">Add this to your OAuth app's allowed redirect URIs.</small>
      </div>

      <div class="form-group">
        <label style="display: flex; align-items: center; gap: var(--space-2); cursor: pointer;">
          <input type="checkbox" id="provider-enabled" name="enabled" checked>
          <span>Enabled</span>
        </label>
      </div>

      <div style="display: flex; gap: var(--space-3); margin-top: var(--space-8);">
        <button type="submit" class="btn btn-primary" style="flex: 1;">Save Provider</button>
        <button type="button" id="cancel-btn" class="btn btn-secondary">Cancel</button>
      </div>
    </form>
  </div>
</div>

<style>
  .provider-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    margin-bottom: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .provider-icon {
    width: 48px;
    height: 48px;
    background: var(--accent-subtle);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-primary);
    flex-shrink: 0;
    font-size: var(--text-xl);
  }
  .provider-info {
    flex: 1;
    min-width: 0;
  }
  .provider-info h4 {
    margin: 0 0 var(--space-1) 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .provider-info p {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .provider-meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-2);
  }
  .provider-actions {
    display: flex;
    gap: var(--space-2);
  }
  .type-badge {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--bg-code);
    color: var(--text-secondary);
    text-transform: capitalize;
  }
  .status-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
  .status-active {
    background: var(--success);
    color: white;
  }
  .status-disabled {
    background: var(--bg-code);
    color: var(--text-muted);
  }
  .token-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    margin-bottom: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .token-info {
    flex: 1;
  }
  .token-info .token-provider {
    font-weight: 500;
    font-size: var(--text-sm);
  }
  .token-info .token-meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .form-group {
    margin-bottom: var(--space-4);
  }
  .form-group label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 500;
  }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%;
    padding: var(--space-3);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    font-size: var(--text-base);
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-primary);
  }
  .form-group input[readonly] {
    background: var(--bg-code);
    color: var(--text-secondary);
  }
  .form-group small {
    display: block;
    margin-top: var(--space-1);
  }
  .empty-state, .loading-state, .error-state {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-12);
    text-align: center;
    color: var(--text-muted);
  }
  .error-state {
    border-color: var(--error);
    color: var(--error);
  }
</style>

<script src="/js/console-auth.js"></script>
<script src="/js/developer-platform-v2.js"></script>
<script>
  // Provider icons
  const PROVIDER_ICONS = {
    google: '🔍',
    spotify: '🎵',
    github: '🐙',
    slack: '💬',
    notion: '📝',
    linear: '📋',
    discord: '🎮',
    custom: '🔗',
  };

  // Default OAuth URLs
  const PROVIDER_DEFAULTS = {
    google: {
      authUrl: 'https://accounts.google.com/o/oauth2/v2/auth',
      tokenUrl: 'https://oauth2.googleapis.com/token',
      scopes: 'openid profile email',
    },
    spotify: {
      authUrl: 'https://accounts.spotify.com/authorize',
      tokenUrl: 'https://accounts.spotify.com/api/token',
      scopes: 'user-read-email user-read-private',
    },
    github: {
      authUrl: 'https://github.com/login/oauth/authorize',
      tokenUrl: 'https://github.com/login/oauth/access_token',
      scopes: 'read:user user:email',
    },
    slack: {
      authUrl: 'https://slack.com/oauth/v2/authorize',
      tokenUrl: 'https://slack.com/api/oauth.v2.access',
      scopes: 'users:read',
    },
    notion: {
      authUrl: 'https://api.notion.com/v1/oauth/authorize',
      tokenUrl: 'https://api.notion.com/v1/oauth/token',
      scopes: '',
    },
    linear: {
      authUrl: 'https://linear.app/oauth/authorize',
      tokenUrl: 'https://api.linear.app/oauth/token',
      scopes: 'read write',
    },
    discord: {
      authUrl: 'https://discord.com/api/oauth2/authorize',
      tokenUrl: 'https://discord.com/api/oauth2/token',
      scopes: 'identify email',
    },
  };

  // State
  let currentProviders = [];
  let currentTokens = [];

  // Show dashboard when authenticated
  window.addEventListener('load', () => {
    setTimeout(async () => {
      const token = await window.getIdToken?.();
      if (token) {
        document.getElementById('auth-gate').style.display = 'none';
        document.getElementById('dashboard').style.display = 'block';
        // Set redirect URI
        const redirectUri = window.location.origin + '/api/v2/developers/oauth/callback';
        document.getElementById('provider-redirect-uri').value = redirectUri;
        loadProviders();
        loadTokens();
      }
    }, 1000);
  });

  // Load providers
  async function loadProviders() {
    const container = document.getElementById('providers-list');
    showLoading(container);

    try {
      const response = await window.oauthProviders.list();
      currentProviders = response.data || [];
      renderProviders(currentProviders);
    } catch (error) {
      showError(container, 'Failed to load providers: ' + error.message);
    }
  }

  // Load tokens
  async function loadTokens() {
    const container = document.getElementById('tokens-list');
    showLoading(container);

    try {
      const response = await window.oauthProviders.tokens.list();
      currentTokens = response.data || [];
      renderTokens(currentTokens);
    } catch (error) {
      showError(container, 'Failed to load tokens: ' + error.message);
    }
  }

  // Render providers list
  function renderProviders(providers) {
    const container = document.getElementById('providers-list');
    container.textContent = '';

    if (!providers || providers.length === 0) {
      container.appendChild(createEmptyState(
        'No OAuth providers configured yet. Add one to enable external service integrations.',
        'Add Your First Provider',
        openCreateModal
      ));
      return;
    }

    providers.forEach(provider => {
      container.appendChild(createProviderCard(provider));
    });
  }

  // Render tokens list
  function renderTokens(tokens) {
    const container = document.getElementById('tokens-list');
    container.textContent = '';

    if (!tokens || tokens.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'empty-state';
      empty.style.padding = 'var(--space-6)';
      empty.textContent = 'No connected tokens yet.';
      container.appendChild(empty);
      return;
    }

    tokens.forEach(token => {
      container.appendChild(createTokenCard(token));
    });
  }

  // Create provider card
  function createProviderCard(provider) {
    const card = document.createElement('div');
    card.className = 'provider-card';

    // Icon
    const icon = document.createElement('div');
    icon.className = 'provider-icon';
    icon.textContent = PROVIDER_ICONS[provider.type] || PROVIDER_ICONS.custom;
    card.appendChild(icon);

    // Info
    const info = document.createElement('div');
    info.className = 'provider-info';

    const header = document.createElement('h4');
    header.textContent = provider.name;

    const badge = createStatusBadge(provider.enabled ? 'active' : 'disabled');
    header.appendChild(badge);

    const typeBadge = document.createElement('span');
    typeBadge.className = 'type-badge';
    typeBadge.textContent = provider.type;
    header.appendChild(typeBadge);

    info.appendChild(header);

    const desc = document.createElement('p');
    desc.textContent = provider.scopes ? 'Scopes: ' + provider.scopes : 'Custom OAuth provider';
    info.appendChild(desc);

    const meta = document.createElement('div');
    meta.className = 'provider-meta';
    meta.textContent = (provider.tokenCount || 0) + ' connected users • Created: ' + formatTimestamp(provider.createdAt);
    info.appendChild(meta);

    card.appendChild(info);

    // Actions
    const actions = document.createElement('div');
    actions.className = 'provider-actions';

    const editBtn = document.createElement('button');
    editBtn.className = 'btn btn-ghost';
    editBtn.textContent = 'Edit';
    editBtn.addEventListener('click', () => openEditModal(provider));
    actions.appendChild(editBtn);

    const deleteBtn = document.createElement('button');
    deleteBtn.className = 'btn btn-ghost btn-danger';
    deleteBtn.textContent = 'Delete';
    deleteBtn.addEventListener('click', () => deleteProvider(provider.id, provider.name));
    actions.appendChild(deleteBtn);

    card.appendChild(actions);

    return card;
  }

  // Create token card
  function createTokenCard(token) {
    const card = document.createElement('div');
    card.className = 'token-card';

    // Info
    const info = document.createElement('div');
    info.className = 'token-info';

    const providerSpan = document.createElement('div');
    providerSpan.className = 'token-provider';
    providerSpan.textContent = token.providerName || token.providerId;
    info.appendChild(providerSpan);

    const meta = document.createElement('div');
    meta.className = 'token-meta';
    meta.textContent = 'User: ' + (token.userId || 'Unknown') + ' • Expires: ' + formatTimestamp(token.expiresAt);
    info.appendChild(meta);

    card.appendChild(info);

    // Revoke button
    const revokeBtn = document.createElement('button');
    revokeBtn.className = 'btn btn-ghost btn-danger';
    revokeBtn.textContent = 'Revoke';
    revokeBtn.addEventListener('click', () => revokeToken(token.id));
    card.appendChild(revokeBtn);

    return card;
  }

  // Modal functions
  function openCreateModal() {
    document.getElementById('modal-title').textContent = 'Add OAuth Provider';
    document.getElementById('provider-form').reset();
    document.getElementById('provider-id').value = '';
    document.getElementById('provider-type').value = 'custom';
    updateProviderTypeFields();
    document.getElementById('provider-modal').style.display = 'flex';
  }

  function openEditModal(provider) {
    document.getElementById('modal-title').textContent = 'Edit OAuth Provider';
    document.getElementById('provider-id').value = provider.id;
    document.getElementById('provider-name').value = provider.name || '';
    document.getElementById('provider-type').value = provider.type || 'custom';
    document.getElementById('provider-auth-url').value = provider.authUrl || '';
    document.getElementById('provider-token-url').value = provider.tokenUrl || '';
    document.getElementById('provider-client-id').value = provider.clientId || '';
    document.getElementById('provider-client-secret').value = ''; // Don't show secret
    document.getElementById('provider-scopes').value = provider.scopes || '';
    document.getElementById('provider-enabled').checked = provider.enabled !== false;
    updateProviderTypeFields();
    document.getElementById('provider-modal').style.display = 'flex';
  }

  function closeModal() {
    document.getElementById('provider-modal').style.display = 'none';
  }

  function updateProviderTypeFields() {
    const type = document.getElementById('provider-type').value;
    const customFields = document.getElementById('custom-fields');

    if (type === 'custom') {
      customFields.style.display = 'block';
    } else {
      customFields.style.display = 'none';
      // Auto-fill defaults
      const defaults = PROVIDER_DEFAULTS[type];
      if (defaults) {
        document.getElementById('provider-auth-url').value = defaults.authUrl;
        document.getElementById('provider-token-url').value = defaults.tokenUrl;
        if (!document.getElementById('provider-scopes').value) {
          document.getElementById('provider-scopes').value = defaults.scopes;
        }
      }
    }
  }

  // Provider operations
  async function saveProvider(event) {
    event.preventDefault();
    const form = event.target;
    const id = form.id.value;
    const type = form.type.value;

    const data = {
      name: form.name.value,
      type: type,
      clientId: form.clientId.value,
      scopes: form.scopes.value,
      enabled: form.enabled.checked,
    };

    // Get URLs (from form or defaults)
    if (type === 'custom') {
      data.authUrl = form.authUrl.value;
      data.tokenUrl = form.tokenUrl.value;
    } else {
      const defaults = PROVIDER_DEFAULTS[type];
      data.authUrl = defaults?.authUrl || form.authUrl.value;
      data.tokenUrl = defaults?.tokenUrl || form.tokenUrl.value;
    }

    // Only include secret if provided
    if (form.clientSecret.value) {
      data.clientSecret = form.clientSecret.value;
    }

    try {
      if (id) {
        await window.oauthProviders.update(id, data);
        showToast('Provider updated', 'success');
      } else {
        await window.oauthProviders.create(data);
        showToast('Provider created', 'success');
      }
      closeModal();
      loadProviders();
    } catch (error) {
      showToast('Failed to save: ' + error.message, 'error');
    }
  }

  async function deleteProvider(id, name) {
    if (!confirm('Are you sure you want to delete "' + name + '"? This will also revoke all connected tokens.')) {
      return;
    }

    try {
      await window.oauthProviders.delete(id);
      showToast('Provider deleted', 'success');
      loadProviders();
      loadTokens();
    } catch (error) {
      showToast('Failed to delete: ' + error.message, 'error');
    }
  }

  async function revokeToken(id) {
    if (!confirm('Revoke this token? The user will need to re-authenticate.')) {
      return;
    }

    try {
      await window.oauthProviders.tokens.revoke(id);
      showToast('Token revoked', 'success');
      loadTokens();
    } catch (error) {
      showToast('Failed to revoke: ' + error.message, 'error');
    }
  }

  // Event listeners
  document.getElementById('create-provider-btn').addEventListener('click', openCreateModal);
  document.getElementById('close-modal-btn').addEventListener('click', closeModal);
  document.getElementById('cancel-btn').addEventListener('click', closeModal);
  document.getElementById('provider-form').addEventListener('submit', saveProvider);
  document.getElementById('provider-type').addEventListener('change', updateProviderTypeFields);
</script>
