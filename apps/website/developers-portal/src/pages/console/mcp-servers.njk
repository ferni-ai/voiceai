---
layout: layouts/base.njk
title: MCP Servers - Developer Console
description: Register and manage external MCP servers
permalink: /console/mcp-servers/
---

<section class="hero" style="padding-bottom: var(--space-12);">
  <div class="container">
    <div class="hero-eyebrow">Developer Console</div>
    <h1>MCP <span class="accent">Servers</span></h1>
    <p class="hero-subtitle">
      Register external Model Context Protocol servers to extend your agents with custom tools.
    </p>
  </div>
</section>

<!-- Authentication Gate -->
<section id="auth-gate" class="section" style="padding-top: var(--space-8); padding-bottom: var(--space-8);">
  <div class="container container-narrow">
    <div style="background: var(--bg-elevated); border: 1px solid var(--border-medium); border-radius: var(--radius-2xl); padding: var(--space-12); text-align: center;">
      <p style="color: var(--text-secondary);">Please sign in to manage your MCP servers.</p>
      <a href="/console/" class="btn btn-primary" style="margin-top: var(--space-4);">Go to Console</a>
    </div>
  </div>
</section>

<!-- Dashboard (shown after authentication) -->
<section id="dashboard" class="section" style="background: var(--bg-secondary); padding-top: var(--space-16); display: none;">
  <div class="container">
    <!-- Header with back button -->
    <div style="display: flex; align-items: center; gap: var(--space-4); margin-bottom: var(--space-8);">
      <a href="/console/" class="btn btn-ghost" style="padding: var(--space-2);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
      </a>
      <div style="flex: 1;">
        <h2 style="margin: 0;">MCP Servers</h2>
        <p style="color: var(--text-secondary); margin: 0;">Connect external tool providers</p>
      </div>
      <button id="create-server-btn" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add Server
      </button>
    </div>

    <!-- Servers list -->
    <div id="servers-list">
      <div class="loading-state">Loading your MCP servers...</div>
    </div>
  </div>
</section>

<!-- Create/Edit Modal -->
<div id="server-modal" class="modal-overlay" style="display: none;">
  <div class="modal" style="max-width: 600px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6);">
      <h3 id="modal-title" style="margin: 0;">Add MCP Server</h3>
      <button id="close-modal-btn" class="btn btn-ghost" style="padding: var(--space-2);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <form id="server-form">
      <input type="hidden" id="server-id" name="id">

      <div class="form-group">
        <label for="server-name">Server Name</label>
        <input type="text" id="server-name" name="name" required placeholder="My MCP Server">
      </div>

      <div class="form-group">
        <label for="server-description">Description</label>
        <textarea id="server-description" name="description" rows="2" placeholder="What tools does this server provide?"></textarea>
      </div>

      <div class="form-group">
        <label for="server-transport">Transport Type</label>
        <select id="server-transport" name="transport" required>
          <option value="http">HTTP</option>
          <option value="websocket">WebSocket</option>
          <option value="stdio">Stdio (Command)</option>
        </select>
      </div>

      <div id="http-fields">
        <div class="form-group">
          <label for="server-endpoint">Endpoint URL</label>
          <input type="url" id="server-endpoint" name="endpoint" placeholder="https://your-mcp-server.com">
        </div>
      </div>

      <div id="stdio-fields" style="display: none;">
        <div class="form-group">
          <label for="server-command">Command</label>
          <input type="text" id="server-command" name="command" placeholder="npx @my-org/mcp-server">
        </div>
        <div class="form-group">
          <label for="server-args">Arguments (comma-separated)</label>
          <input type="text" id="server-args" name="args" placeholder="--port, 3000">
        </div>
      </div>

      <div class="form-group">
        <label style="display: flex; align-items: center; gap: var(--space-2); cursor: pointer;">
          <input type="checkbox" id="server-enabled" name="enabled" checked>
          <span>Enabled</span>
        </label>
      </div>

      <div style="display: flex; gap: var(--space-3); margin-top: var(--space-8);">
        <button type="submit" class="btn btn-primary" style="flex: 1;">Save Server</button>
        <button type="button" id="cancel-btn" class="btn btn-secondary">Cancel</button>
      </div>
    </form>
  </div>
</div>

<style>
  .server-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    margin-bottom: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .server-icon {
    width: 48px;
    height: 48px;
    background: var(--accent-subtle);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-primary);
    flex-shrink: 0;
  }
  .server-info {
    flex: 1;
    min-width: 0;
  }
  .server-info h4 {
    margin: 0 0 var(--space-1) 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .server-info p {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .server-meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-2);
  }
  .server-actions {
    display: flex;
    gap: var(--space-2);
  }
  .status-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
  .status-active {
    background: var(--success);
    color: white;
  }
  .status-error {
    background: var(--error);
    color: white;
  }
  .status-disabled {
    background: var(--bg-code);
    color: var(--text-muted);
  }
  .form-group {
    margin-bottom: var(--space-4);
  }
  .form-group label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 500;
  }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%;
    padding: var(--space-3);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    font-size: var(--text-base);
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-primary);
  }
  .empty-state, .loading-state, .error-state {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-12);
    text-align: center;
    color: var(--text-muted);
  }
  .error-state {
    border-color: var(--error);
    color: var(--error);
  }
</style>

<script src="/js/console-auth.js"></script>
<script src="/js/developer-platform-v2.js"></script>
<script>
  // State
  let currentServers = [];

  // Show dashboard when authenticated
  window.addEventListener('load', () => {
    // Check for existing auth state
    setTimeout(async () => {
      const token = await window.getIdToken?.();
      if (token) {
        document.getElementById('auth-gate').style.display = 'none';
        document.getElementById('dashboard').style.display = 'block';
        loadServers();
      }
    }, 1000);
  });

  // Load servers
  async function loadServers() {
    const container = document.getElementById('servers-list');
    showLoading(container);

    try {
      const response = await window.mcpServers.list();
      currentServers = response.data || [];
      renderServers(currentServers);
    } catch (error) {
      showError(container, 'Failed to load MCP servers: ' + error.message);
    }
  }

  // Render servers list
  function renderServers(servers) {
    const container = document.getElementById('servers-list');
    container.textContent = '';

    if (!servers || servers.length === 0) {
      container.appendChild(createEmptyState(
        'No MCP servers registered yet. Add one to extend your agents with custom tools.',
        'Add Your First Server',
        openCreateModal
      ));
      return;
    }

    servers.forEach(server => {
      container.appendChild(createServerCard(server));
    });
  }

  // Create server card
  function createServerCard(server) {
    const card = document.createElement('div');
    card.className = 'server-card';

    // Icon
    const icon = document.createElement('div');
    icon.className = 'server-icon';
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('width', '24');
    svg.setAttribute('height', '24');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '2');
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', 'M22 12h-4l-3 9L9 3l-3 9H2');
    svg.appendChild(path);
    icon.appendChild(svg);
    card.appendChild(icon);

    // Info
    const info = document.createElement('div');
    info.className = 'server-info';

    const header = document.createElement('h4');
    header.textContent = server.name;
    const badge = createStatusBadge(server.enabled ? (server.status || 'active') : 'disabled');
    header.appendChild(badge);
    info.appendChild(header);

    if (server.description) {
      const desc = document.createElement('p');
      desc.textContent = server.description;
      info.appendChild(desc);
    }

    const meta = document.createElement('div');
    meta.className = 'server-meta';
    meta.textContent = `${server.transport.toUpperCase()} • ${server.toolCount || 0} tools • Last connected: ${formatTimestamp(server.lastConnected)}`;
    info.appendChild(meta);

    card.appendChild(info);

    // Actions
    const actions = document.createElement('div');
    actions.className = 'server-actions';

    const testBtn = document.createElement('button');
    testBtn.className = 'btn btn-ghost';
    testBtn.textContent = 'Test';
    testBtn.addEventListener('click', () => testServer(server.id));
    actions.appendChild(testBtn);

    const editBtn = document.createElement('button');
    editBtn.className = 'btn btn-ghost';
    editBtn.textContent = 'Edit';
    editBtn.addEventListener('click', () => openEditModal(server));
    actions.appendChild(editBtn);

    const deleteBtn = document.createElement('button');
    deleteBtn.className = 'btn btn-ghost btn-danger';
    deleteBtn.textContent = 'Delete';
    deleteBtn.addEventListener('click', () => deleteServer(server.id, server.name));
    actions.appendChild(deleteBtn);

    card.appendChild(actions);

    return card;
  }

  // Modal functions
  function openCreateModal() {
    document.getElementById('modal-title').textContent = 'Add MCP Server';
    document.getElementById('server-form').reset();
    document.getElementById('server-id').value = '';
    document.getElementById('server-modal').style.display = 'flex';
    updateTransportFields();
  }

  function openEditModal(server) {
    document.getElementById('modal-title').textContent = 'Edit MCP Server';
    document.getElementById('server-id').value = server.id;
    document.getElementById('server-name').value = server.name || '';
    document.getElementById('server-description').value = server.description || '';
    document.getElementById('server-transport').value = server.transport || 'http';
    document.getElementById('server-endpoint').value = server.endpoint || '';
    document.getElementById('server-command').value = server.command || '';
    document.getElementById('server-args').value = (server.args || []).join(', ');
    document.getElementById('server-enabled').checked = server.enabled !== false;
    document.getElementById('server-modal').style.display = 'flex';
    updateTransportFields();
  }

  function closeModal() {
    document.getElementById('server-modal').style.display = 'none';
  }

  function updateTransportFields() {
    const transport = document.getElementById('server-transport').value;
    document.getElementById('http-fields').style.display = transport !== 'stdio' ? 'block' : 'none';
    document.getElementById('stdio-fields').style.display = transport === 'stdio' ? 'block' : 'none';
  }

  // Server operations
  async function saveServer(event) {
    event.preventDefault();
    const form = event.target;
    const id = form.id.value;
    const data = {
      name: form.name.value,
      description: form.description.value,
      transport: form.transport.value,
      enabled: form.enabled.checked,
    };

    if (data.transport === 'stdio') {
      data.command = form.command.value;
      data.args = form.args.value.split(',').map(s => s.trim()).filter(Boolean);
    } else {
      data.endpoint = form.endpoint.value;
    }

    try {
      if (id) {
        await window.mcpServers.update(id, data);
        showToast('Server updated', 'success');
      } else {
        await window.mcpServers.create(data);
        showToast('Server created', 'success');
      }
      closeModal();
      loadServers();
    } catch (error) {
      showToast('Failed to save: ' + error.message, 'error');
    }
  }

  async function testServer(id) {
    try {
      showToast('Testing connection...', 'info');
      const result = await window.mcpServers.test(id);
      if (result.data?.success) {
        showToast('Connection successful! Found ' + (result.data.toolCount || 0) + ' tools.', 'success');
      } else {
        showToast('Connection failed: ' + (result.data?.error || 'Unknown error'), 'error');
      }
      loadServers();
    } catch (error) {
      showToast('Test failed: ' + error.message, 'error');
    }
  }

  async function deleteServer(id, name) {
    if (!confirm('Are you sure you want to delete "' + name + '"? This cannot be undone.')) {
      return;
    }

    try {
      await window.mcpServers.delete(id);
      showToast('Server deleted', 'success');
      loadServers();
    } catch (error) {
      showToast('Failed to delete: ' + error.message, 'error');
    }
  }

  // Event listeners
  document.getElementById('create-server-btn').addEventListener('click', openCreateModal);
  document.getElementById('close-modal-btn').addEventListener('click', closeModal);
  document.getElementById('cancel-btn').addEventListener('click', closeModal);
  document.getElementById('server-form').addEventListener('submit', saveServer);
  document.getElementById('server-transport').addEventListener('change', updateTransportFields);
</script>
