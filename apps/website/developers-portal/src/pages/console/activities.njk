---
layout: layouts/base.njk
title: Activities - Developer Console
description: Track custom activities and view analytics
---

<section class="hero" style="padding-bottom: var(--space-12);">
  <div class="container">
    <div class="hero-eyebrow">Developer Console</div>
    <h1>Activity <span class="accent">Tracking</span></h1>
    <p class="hero-subtitle">
      Track custom activities and metrics from your agent integrations.
    </p>
  </div>
</section>

<!-- Authentication Gate -->
<section id="auth-gate" class="section" style="padding-top: var(--space-8); padding-bottom: var(--space-8);">
  <div class="container container-narrow">
    <div style="background: var(--bg-elevated); border: 1px solid var(--border-medium); border-radius: var(--radius-2xl); padding: var(--space-12); text-align: center;">
      <p style="color: var(--text-secondary);">Please sign in to view your activities.</p>
      <a href="/console/" class="btn btn-primary" style="margin-top: var(--space-4);">Go to Console</a>
    </div>
  </div>
</section>

<!-- Dashboard (shown after authentication) -->
<section id="dashboard" class="section" style="background: var(--bg-secondary); padding-top: var(--space-16); display: none;">
  <div class="container">
    <!-- Header with back button -->
    <div style="display: flex; align-items: center; gap: var(--space-4); margin-bottom: var(--space-8);">
      <a href="/console/" class="btn btn-ghost" style="padding: var(--space-2);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
      </a>
      <div style="flex: 1;">
        <h2 style="margin: 0;">Activities</h2>
        <p style="color: var(--text-secondary); margin: 0;">Track and analyze custom metrics</p>
      </div>
      <button id="create-activity-btn" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Log Activity
      </button>
    </div>

    <!-- Stats cards -->
    <div id="stats-container" class="stats-grid" style="margin-bottom: var(--space-8);">
      <div class="stat-card">
        <div class="stat-label">Total Activities</div>
        <div class="stat-value" id="stat-total">-</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Completed</div>
        <div class="stat-value" id="stat-completed">-</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Failed</div>
        <div class="stat-value" id="stat-failed">-</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Avg Duration</div>
        <div class="stat-value" id="stat-duration">-</div>
      </div>
    </div>

    <!-- Visualizations -->
    <div class="charts-grid" style="margin-bottom: var(--space-8);">
      <div class="chart-card">
        <h4 class="chart-title">Activity Volume (7 days)</h4>
        <div id="volume-sparkline" class="chart-container"></div>
      </div>
      <div class="chart-card">
        <h4 class="chart-title">Status Distribution</h4>
        <div id="status-donut" class="chart-container chart-center"></div>
      </div>
      <div class="chart-card">
        <h4 class="chart-title">Top Activity Types</h4>
        <div id="types-bar" class="chart-container"></div>
      </div>
    </div>

    <!-- Filters -->
    <div class="filters-bar" style="margin-bottom: var(--space-6);">
      <div class="form-group" style="margin-bottom: 0;">
        <label for="filter-type">Activity Type</label>
        <select id="filter-type">
          <option value="">All Types</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <label for="filter-status">Status</label>
        <select id="filter-status">
          <option value="">All Statuses</option>
          <option value="started">Started</option>
          <option value="completed">Completed</option>
          <option value="failed">Failed</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <label for="filter-date">Time Range</label>
        <select id="filter-date">
          <option value="24h">Last 24 hours</option>
          <option value="7d">Last 7 days</option>
          <option value="30d">Last 30 days</option>
          <option value="all">All time</option>
        </select>
      </div>
      <button id="refresh-btn" class="btn btn-ghost" style="align-self: flex-end;">
        Refresh
      </button>
    </div>

    <!-- Activities list -->
    <div id="activities-list">
      <div class="loading-state">Loading activities...</div>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="pagination" style="display: none;">
      <button id="prev-page" class="btn btn-ghost">Previous</button>
      <span id="page-info">Page 1</span>
      <button id="next-page" class="btn btn-ghost">Next</button>
    </div>
  </div>
</section>

<!-- Create Activity Modal -->
<div id="activity-modal" class="modal-overlay" style="display: none;">
  <div class="modal" style="max-width: 600px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6);">
      <h3 id="modal-title" style="margin: 0;">Log Activity</h3>
      <button id="close-modal-btn" class="btn btn-ghost" style="padding: var(--space-2);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <form id="activity-form">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
        <div class="form-group">
          <label for="activity-type">Activity Type</label>
          <input type="text" id="activity-type" name="type" required placeholder="workflow.executed">
        </div>

        <div class="form-group">
          <label for="activity-name">Activity Name</label>
          <input type="text" id="activity-name" name="name" required placeholder="Daily Standup">
        </div>
      </div>

      <div class="form-group">
        <label for="activity-status">Status</label>
        <select id="activity-status" name="status" required>
          <option value="started">Started</option>
          <option value="completed">Completed</option>
          <option value="failed">Failed</option>
        </select>
      </div>

      <div class="form-group">
        <label for="activity-data">Data (JSON)</label>
        <textarea id="activity-data" name="data" rows="4" placeholder='{"key": "value"}'></textarea>
        <small style="color: var(--text-muted);">Optional JSON payload for additional context.</small>
      </div>

      <div class="form-group">
        <label for="activity-duration">Duration (ms)</label>
        <input type="number" id="activity-duration" name="duration" placeholder="1500">
      </div>

      <div style="display: flex; gap: var(--space-3); margin-top: var(--space-8);">
        <button type="submit" class="btn btn-primary" style="flex: 1;">Log Activity</button>
        <button type="button" id="cancel-btn" class="btn btn-secondary">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Activity Detail Modal -->
<div id="detail-modal" class="modal-overlay" style="display: none;">
  <div class="modal" style="max-width: 700px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6);">
      <h3 id="detail-title" style="margin: 0;">Activity Details</h3>
      <button id="close-detail-btn" class="btn btn-ghost" style="padding: var(--space-2);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div id="detail-content">
      <!-- Content populated dynamically -->
    </div>
  </div>
</div>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .charts-grid {
    display: grid;
    grid-template-columns: 1fr 200px 1fr;
    gap: var(--space-4);
  }
  @media (max-width: 900px) {
    .charts-grid {
      grid-template-columns: 1fr;
    }
  }
  .chart-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
  }
  .chart-title {
    margin: 0 0 var(--space-3) 0;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
  }
  .chart-container {
    min-height: 100px;
  }
  .chart-center {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stat-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
  }
  .stat-label {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-2);
  }
  .stat-value {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text-primary);
  }
  .filters-bar {
    display: flex;
    gap: var(--space-4);
    align-items: flex-end;
    flex-wrap: wrap;
  }
  .filters-bar .form-group {
    flex: 1;
    min-width: 150px;
  }
  .activity-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    margin-bottom: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .activity-card:hover {
    border-color: var(--accent-primary);
  }
  .activity-status {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .activity-status.started {
    background: var(--warning);
  }
  .activity-status.completed {
    background: var(--success);
  }
  .activity-status.failed {
    background: var(--error);
  }
  .activity-info {
    flex: 1;
    min-width: 0;
  }
  .activity-info .activity-name {
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .activity-info .activity-meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .activity-type-badge {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--bg-code);
    color: var(--text-secondary);
  }
  .activity-duration {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
  .form-group {
    margin-bottom: var(--space-4);
  }
  .form-group label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 500;
    font-size: var(--text-sm);
  }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%;
    padding: var(--space-3);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    font-size: var(--text-base);
    font-family: inherit;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-primary);
  }
  .form-group small {
    display: block;
    margin-top: var(--space-1);
  }
  .empty-state, .loading-state, .error-state {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-12);
    text-align: center;
    color: var(--text-muted);
  }
  .error-state {
    border-color: var(--error);
    color: var(--error);
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .detail-row {
    display: flex;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .detail-row:last-child {
    border-bottom: none;
  }
  .detail-label {
    width: 120px;
    font-weight: 500;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
  .detail-value {
    flex: 1;
  }
  .detail-value pre {
    margin: 0;
    padding: var(--space-3);
    background: var(--bg-code);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    overflow-x: auto;
  }
</style>

<script src="/js/console-auth.js"></script>
<script src="/js/developer-platform-v2.js"></script>
<script src="/js/activity-charts.js"></script>
<script>
  // State
  let currentActivities = [];
  let activityTypes = new Set();
  let currentPage = 1;
  const pageSize = 20;

  // Show dashboard when authenticated
  window.addEventListener('load', () => {
    setTimeout(async () => {
      const token = await window.getIdToken?.();
      if (token) {
        document.getElementById('auth-gate').style.display = 'none';
        document.getElementById('dashboard').style.display = 'block';
        loadStats();
        loadActivities();
      }
    }, 1000);
  });

  // Load stats
  async function loadStats() {
    try {
      const response = await window.activities.stats();
      const stats = response.data || {};

      document.getElementById('stat-total').textContent = stats.total || 0;
      document.getElementById('stat-completed').textContent = stats.completed || 0;
      document.getElementById('stat-failed').textContent = stats.failed || 0;
      document.getElementById('stat-duration').textContent =
        stats.avgDuration ? Math.round(stats.avgDuration) + 'ms' : '-';

      // Render status donut chart
      renderStatusChart(stats);

      // Render type breakdown chart
      if (stats.byType) {
        renderTypeChart(stats.byType);
      }
    } catch (error) {
      console.error('Failed to load stats:', error);
    }
  }

  // Render status distribution chart
  function renderStatusChart(stats) {
    const data = [
      { label: 'Completed', value: stats.completed || 0, color: 'var(--success)' },
      { label: 'Started', value: stats.started || 0, color: 'var(--warning)' },
      { label: 'Failed', value: stats.failed || 0, color: 'var(--error)' },
    ].filter(d => d.value > 0);

    if (window.createDonutChart) {
      window.createDonutChart('status-donut', data);
    }
  }

  // Render type breakdown chart
  function renderTypeChart(byType) {
    const data = Object.entries(byType).map(([type, count]) => ({
      label: type,
      value: count,
      color: 'var(--accent-primary)',
    }));

    if (window.createBarChart) {
      window.createBarChart('types-bar', data, { maxBars: 5 });
    }
  }

  // Render activity volume sparkline
  function renderVolumeChart(activities) {
    // Group by day (last 7 days)
    const today = new Date();
    const days = [];

    for (let i = 6; i >= 0; i--) {
      const date = new Date(today);
      date.setDate(date.getDate() - i);
      const dateStr = date.toISOString().split('T')[0];
      days.push({
        date: dateStr,
        label: date.toLocaleDateString('en-US', { weekday: 'short' }),
        value: 0,
      });
    }

    // Count activities per day
    activities.forEach(activity => {
      if (!activity.createdAt) return;
      const actDate = new Date(activity.createdAt).toISOString().split('T')[0];
      const day = days.find(d => d.date === actDate);
      if (day) day.value++;
    });

    if (window.createSparkline) {
      window.createSparkline('volume-sparkline', days, {
        width: 400,
        height: 80,
        showPoints: true,
      });
    }
  }

  // Load activities
  async function loadActivities() {
    const container = document.getElementById('activities-list');
    showLoading(container);

    try {
      const params = {
        limit: pageSize,
        offset: (currentPage - 1) * pageSize,
      };

      const type = document.getElementById('filter-type').value;
      const status = document.getElementById('filter-status').value;
      const dateRange = document.getElementById('filter-date').value;

      if (type) params.type = type;
      if (status) params.status = status;

      // Calculate date range
      if (dateRange !== 'all') {
        const now = new Date();
        let startDate;
        if (dateRange === '24h') {
          startDate = new Date(now.getTime() - 24 * 60 * 60 * 1000);
        } else if (dateRange === '7d') {
          startDate = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
        } else if (dateRange === '30d') {
          startDate = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
        }
        if (startDate) {
          params.startDate = startDate.toISOString();
        }
      }

      const response = await window.activities.list(params);
      currentActivities = response.data || [];

      // Collect activity types for filter
      currentActivities.forEach(a => {
        if (a.type) activityTypes.add(a.type);
      });
      populateTypeFilter();

      renderActivities(currentActivities);
      updatePagination(response.total || currentActivities.length);

      // Render volume chart with recent activities
      renderVolumeChart(currentActivities);
    } catch (error) {
      showError(container, 'Failed to load activities: ' + error.message);
    }
  }

  // Populate type filter
  function populateTypeFilter() {
    const select = document.getElementById('filter-type');
    const currentValue = select.value;

    // Keep first option
    while (select.options.length > 1) {
      select.remove(1);
    }

    activityTypes.forEach(type => {
      const opt = document.createElement('option');
      opt.value = type;
      opt.textContent = type;
      select.appendChild(opt);
    });

    select.value = currentValue;
  }

  // Render activities list
  function renderActivities(activities) {
    const container = document.getElementById('activities-list');
    container.textContent = '';

    if (!activities || activities.length === 0) {
      container.appendChild(createEmptyState(
        'No activities logged yet. Use the API or click "Log Activity" to track custom metrics.',
        'Log Your First Activity',
        openCreateModal
      ));
      return;
    }

    activities.forEach(activity => {
      container.appendChild(createActivityCard(activity));
    });
  }

  // Create activity card
  function createActivityCard(activity) {
    const card = document.createElement('div');
    card.className = 'activity-card';
    card.addEventListener('click', () => showDetail(activity));

    // Status indicator
    const status = document.createElement('div');
    status.className = 'activity-status ' + (activity.status || 'started');
    card.appendChild(status);

    // Info
    const info = document.createElement('div');
    info.className = 'activity-info';

    const name = document.createElement('div');
    name.className = 'activity-name';
    name.textContent = activity.name;

    const typeBadge = document.createElement('span');
    typeBadge.className = 'activity-type-badge';
    typeBadge.textContent = activity.type;
    name.appendChild(typeBadge);

    info.appendChild(name);

    const meta = document.createElement('div');
    meta.className = 'activity-meta';
    meta.textContent = formatTimestamp(activity.createdAt);
    if (activity.sessionId) {
      meta.textContent += ' • Session: ' + activity.sessionId.slice(0, 8) + '...';
    }
    info.appendChild(meta);

    card.appendChild(info);

    // Duration
    if (activity.duration) {
      const duration = document.createElement('div');
      duration.className = 'activity-duration';
      duration.textContent = activity.duration + 'ms';
      card.appendChild(duration);
    }

    return card;
  }

  // Update pagination
  function updatePagination(total) {
    const pagination = document.getElementById('pagination');
    const totalPages = Math.ceil(total / pageSize);

    if (totalPages <= 1) {
      pagination.style.display = 'none';
      return;
    }

    pagination.style.display = 'flex';
    document.getElementById('page-info').textContent = 'Page ' + currentPage + ' of ' + totalPages;
    document.getElementById('prev-page').disabled = currentPage <= 1;
    document.getElementById('next-page').disabled = currentPage >= totalPages;
  }

  // Modal functions
  function openCreateModal() {
    document.getElementById('activity-form').reset();
    document.getElementById('activity-modal').style.display = 'flex';
  }

  function closeModal() {
    document.getElementById('activity-modal').style.display = 'none';
  }

  // Show activity detail
  function showDetail(activity) {
    document.getElementById('detail-title').textContent = activity.name;

    const content = document.getElementById('detail-content');
    content.textContent = '';

    const fields = [
      { label: 'ID', value: activity.id },
      { label: 'Type', value: activity.type },
      { label: 'Status', value: activity.status },
      { label: 'Duration', value: activity.duration ? activity.duration + 'ms' : '-' },
      { label: 'Session ID', value: activity.sessionId || '-' },
      { label: 'User ID', value: activity.userId || '-' },
      { label: 'Created', value: formatTimestamp(activity.createdAt) },
      { label: 'Completed', value: activity.completedAt ? formatTimestamp(activity.completedAt) : '-' },
    ];

    fields.forEach(field => {
      const row = document.createElement('div');
      row.className = 'detail-row';

      const label = document.createElement('div');
      label.className = 'detail-label';
      label.textContent = field.label;
      row.appendChild(label);

      const value = document.createElement('div');
      value.className = 'detail-value';
      value.textContent = field.value;
      row.appendChild(value);

      content.appendChild(row);
    });

    // Data field
    if (activity.data && Object.keys(activity.data).length > 0) {
      const row = document.createElement('div');
      row.className = 'detail-row';

      const label = document.createElement('div');
      label.className = 'detail-label';
      label.textContent = 'Data';
      row.appendChild(label);

      const value = document.createElement('div');
      value.className = 'detail-value';

      const pre = document.createElement('pre');
      pre.textContent = JSON.stringify(activity.data, null, 2);
      value.appendChild(pre);

      row.appendChild(value);
      content.appendChild(row);
    }

    document.getElementById('detail-modal').style.display = 'flex';
  }

  function closeDetailModal() {
    document.getElementById('detail-modal').style.display = 'none';
  }

  // Activity operations
  async function saveActivity(event) {
    event.preventDefault();
    const form = event.target;

    const data = {
      type: form.type.value,
      name: form.name.value,
      status: form.status.value,
    };

    if (form.duration.value) {
      data.duration = parseInt(form.duration.value);
    }

    if (form.data.value) {
      try {
        data.data = JSON.parse(form.data.value);
      } catch (e) {
        showToast('Invalid JSON in data field', 'error');
        return;
      }
    }

    try {
      await window.activities.create(data);
      showToast('Activity logged', 'success');
      closeModal();
      loadActivities();
      loadStats();
    } catch (error) {
      showToast('Failed to log: ' + error.message, 'error');
    }
  }

  // Event listeners
  document.getElementById('create-activity-btn').addEventListener('click', openCreateModal);
  document.getElementById('close-modal-btn').addEventListener('click', closeModal);
  document.getElementById('cancel-btn').addEventListener('click', closeModal);
  document.getElementById('activity-form').addEventListener('submit', saveActivity);
  document.getElementById('close-detail-btn').addEventListener('click', closeDetailModal);

  document.getElementById('refresh-btn').addEventListener('click', () => {
    currentPage = 1;
    loadActivities();
    loadStats();
  });

  document.getElementById('filter-type').addEventListener('change', () => {
    currentPage = 1;
    loadActivities();
  });

  document.getElementById('filter-status').addEventListener('change', () => {
    currentPage = 1;
    loadActivities();
  });

  document.getElementById('filter-date').addEventListener('change', () => {
    currentPage = 1;
    loadActivities();
  });

  document.getElementById('prev-page').addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      loadActivities();
    }
  });

  document.getElementById('next-page').addEventListener('click', () => {
    currentPage++;
    loadActivities();
  });
</script>
