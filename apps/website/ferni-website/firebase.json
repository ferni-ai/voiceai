{
  "hosting": [
    {
      "site": "ferni-landing",
      "public": "_site",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "/developers",
          "destination": "https://developers.ferni.ai",
          "type": 301
        },
        {
          "source": "/developers/**",
          "destination": "https://developers.ferni.ai/:splat",
          "type": 301
        },
        {
          "source": "/dev-blog",
          "destination": "https://developers.ferni.ai/blog",
          "type": 301
        },
        {
          "source": "/dev-blog/**",
          "destination": "https://developers.ferni.ai/blog/:splat",
          "type": 301
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=604800"
            }
          ]
        },
        {
          "source": "**/*.dmg",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=604800"
            },
            {
              "key": "Content-Type",
              "value": "application/x-apple-diskimage"
            },
            {
              "key": "Content-Disposition",
              "value": "attachment; filename=\"FerniVoice.dmg\""
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "robots.txt",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        },
        {
          "source": "sitemap.xml",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            },
            {
              "key": "Content-Type",
              "value": "application/xml"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [
        {
          "source": "/token",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/demo-token",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/waitlist",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/waitlist/**",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/landing/**",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/sites/**",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "/sites/**",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "!/api/**",
          "destination": "/404.html"
        }
      ]
    },
