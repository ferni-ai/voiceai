{
  "hosting": [
    {
      "site": "ferni-landing",
      "public": "_site",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=604800"
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "robots.txt",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        },
        {
          "source": "sitemap.xml",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            },
            {
              "key": "Content-Type",
              "value": "application/xml"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [
        {
          "source": "/api/landing/**",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/404.html"
        }
      ]
    },
    {
      "target": "ferni-prod",
      "public": "_site",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=604800"
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "robots.txt",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            }
          ]
        },
        {
          "source": "sitemap.xml",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400"
            },
            {
              "key": "Content-Type",
              "value": "application/xml"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [
        {
          "source": "/api/landing/**",
          "run": {
            "serviceId": "john-bogle-ui",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/404.html"
        }
      ]
    }
  ]
}
