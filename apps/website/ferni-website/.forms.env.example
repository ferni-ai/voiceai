# Ferni Setup Configuration
# Copy this file to .forms.env and fill in your details
# NEVER commit .forms.env to git!

# ============================================
# ACCOUNT CREATION INFO
# ============================================

# Your name (for account profiles)
ADMIN_FIRST_NAME=
ADMIN_LAST_NAME=

# Email for account signups (use one you have access to)
SIGNUP_EMAIL=

# Phone number for verification (with country code)
PHONE_NUMBER=

# ============================================
# SOCIAL MEDIA USERNAMES (desired)
# ============================================

TWITTER_USERNAME=ferniAI
LINKEDIN_COMPANY=ferni
INSTAGRAM_USERNAME=ferni.ai
TIKTOK_USERNAME=ferni.ai
YOUTUBE_HANDLE=ferniAI

# ============================================
# AFTER SIGNUP - PASTE YOUR IDS HERE
# ============================================

# Google Analytics Measurement ID (looks like: G-ABC123XYZ)
GOOGLE_ANALYTICS_ID=

# ============================================
# FORM CONFIGURATION
# Choose your preferred service for each form
# ============================================

# NEWSLETTER FORM - Choose one:
# Option 1: Mailchimp (recommended for newsletters)
MAILCHIMP_FORM_ACTION=
# Get this from: Mailchimp → Audience → Signup forms → Embedded forms
# Looks like: https://xyz.us1.list-manage.com/subscribe/post?u=abc123&id=def456

# Option 2: Formspree
FORMSPREE_NEWSLETTER_ID=
# Get this from: formspree.io/forms → Your form ID (like: xabcdefg)

# Option 3: Google Forms
GOOGLE_FORM_NEWSLETTER_URL=
# Get this from: Google Forms → Send → Link

# DEVELOPER WAITLIST - Choose one:
# Option 1: Formspree (recommended)
FORMSPREE_DEVELOPER_ID=

# Option 2: Google Forms
GOOGLE_FORM_DEVELOPER_URL=

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Which email service are you using?
# Options: google_workspace, zoho, cloudflare, other
EMAIL_SERVICE=

# Forward-to email (for Cloudflare routing)
FORWARD_EMAIL=

# ============================================
# DOMAIN INFO
# ============================================

DOMAIN=ferni.ai
APP_DOMAIN=app.ferni.ai

