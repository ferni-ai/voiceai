  <style>
    /* ════════════════════════════════════════════════════
       Better Than Human - Critical Inline Styles
       ════════════════════════════════════════════════════ */
    
    /* Fluid Typography - Display Headlines */
    .text-display-2xl {
      font-size: clamp(3rem, 2rem + 6vw, 7rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
    }
    .text-display-lg {
      font-size: clamp(2.25rem, 1.75rem + 2.5vw, 4rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }
    .text-display-md {
      font-size: clamp(1.875rem, 1.5rem + 1.875vw, 3rem);
      line-height: 1.2;
      letter-spacing: -0.015em;
    }
    
    /* Body text - optimal readability */
    .text-body-xl {
      font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.625rem);
      line-height: 1.6;
    }
    .text-body-lg {
      font-size: clamp(1.125rem, 1rem + 0.625vw, 1.375rem);
      line-height: 1.7;
    }
    
    /* Eyebrow text */
    .text-eyebrow {
      font-size: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    
    /* Animated gradient text */
    .text-gradient {
      background: linear-gradient(135deg, #4a6741 0%, #5a7751 50%, #3d5a35 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .text-gradient-alive {
      background: linear-gradient(135deg, #2d4a32 0%, #3d5a35 25%, #4a6741 50%, #3d5a35 75%, #2d4a32 100%);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradientShift 6s ease infinite;
    }
    @keyframes gradientShift {
      0%, 100% { background-position: 0% center; }
      50% { background-position: 100% center; }
    }
    
    /* Stagger animation delays */
    .stagger-1 { animation-delay: 0.1s; }
    .stagger-2 { animation-delay: 0.2s; }
    .stagger-3 { animation-delay: 0.3s; }
    .stagger-4 { animation-delay: 0.4s; }
    .stagger-5 { animation-delay: 0.5s; }
    .stagger-6 { animation-delay: 0.6s; }
    
    /* Scroll-triggered reveal - cinematic */
    .reveal {
      opacity: 0;
      transform: translateY(40px) scale(0.98);
      filter: blur(4px);
      transition: 
        opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), 
        transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
        filter 0.3s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
    
    /* Magnetic button effect */
    .btn-magnetic {
      transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .btn-magnetic:hover {
      transform: translateY(-2px) scale(1.02);
    }
    .btn-magnetic:active {
      transform: translateY(0) scale(0.98);
      transition-duration: 50ms;
    }
    
    /* ═══════════════════════════════════════════════════════════════
       FERNI ORBS - Apple-level subtlety
       Animations so subtle they're almost subliminal
       ═══════════════════════════════════════════════════════════════ */
    
    /* Ambient glow - barely perceptible breathing */
    .ferni-ambient {
      animation: ambientPulse 8s ease-in-out infinite;
    }
    @keyframes ambientPulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.7; transform: scale(1.02); }
    }
    
    /* Orb wrapper - extremely subtle float */
    .ferni-orb-wrapper {
      animation: subtleFloat 6s ease-in-out infinite;
    }
    @keyframes subtleFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); }
    }
    
    /* The orb itself */
    .ferni-orb {
      box-shadow: 
        0 25px 50px -12px rgba(61, 90, 53, 0.25),
        0 12px 24px -8px rgba(61, 90, 53, 0.15);
      transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s ease;
    }
    
    /* Hover - refined lift */
    .ferni-orb:hover {
      transform: scale(1.02) translateY(-2px);
      box-shadow: 
        0 30px 60px -12px rgba(61, 90, 53, 0.3),
        0 18px 36px -12px rgba(61, 90, 53, 0.2);
    }
    .ferni-orb:hover ~ .ferni-outer-glow {
      opacity: 1;
    }
    
    /* Presence dot - gentle pulse */
    .ferni-presence-dot {
      animation: presencePulse 3s ease-in-out infinite;
    }
    @keyframes presencePulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }
    
    /* Text reveal - Apple-style fade up */
    .hero-reveal {
      opacity: 0;
      transform: translateY(20px);
      animation: heroReveal 1s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    }
    .hero-reveal-1 { animation-delay: 0.3s; }
    .hero-reveal-2 { animation-delay: 0.5s; }
    .hero-reveal-3 { animation-delay: 0.7s; }
    @keyframes heroReveal {
      to { opacity: 1; transform: translateY(0); }
    }
    
    /* Scroll hint */
    .scroll-hint {
      opacity: 0;
      animation: scrollFade 0.6s ease forwards 2s, scrollFloat 2.5s ease-in-out infinite 2s;
    }
    @keyframes scrollFade { to { opacity: 0.4; } }
    @keyframes scrollFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }
    
    /* Legacy support */
    .persona-orbit { animation: orbit 45s linear infinite; }
    .persona-counter { animation: counterOrbit 45s linear infinite; }
    @keyframes orbit { to { transform: rotate(360deg); } }
    @keyframes counterOrbit { to { transform: rotate(-360deg); } }
    [data-breathe] { animation: ferniBreath 4s ease-in-out infinite; }
    
    /* Reduced motion respect */
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; filter: none; transition: none; }
      .ferni-breathe, .ferni-notice, .ferni-glow, .ferni-ring, .ferni-presence,
      .persona-orbit, .persona-counter, [data-breathe], .text-gradient-alive,
      .hero-reveal, .scroll-hint { animation: none !important; opacity: 1; transform: none; }
    }
  </style>
</head>

