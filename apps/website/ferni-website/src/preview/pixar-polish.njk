  .preview-page {
    font-family: var(--font-body, 'Inter', sans-serif);
    background: var(--color-paper-cream, #F5F1E8);
    min-height: 100vh;
  }
  
  .preview-header {
    background: linear-gradient(180deg, white 0%, var(--color-paper-cream, #F5F1E8) 100%);
    padding: 40px 24px;
    text-align: center;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  
  .preview-header h1 {
    font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
    font-size: 48px;
    font-weight: 800;
    color: var(--color-text-primary, #2C2520);
    margin: 0 0 12px;
  }
  
  .preview-header p {
    color: var(--color-text-secondary, #5C544A);
    font-size: 18px;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .preview-nav {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 24px;
    flex-wrap: wrap;
  }
  
  .preview-nav a {
    padding: 10px 20px;
    background: white;
    border-radius: 24px;
    color: var(--color-ferni, #4a6741);
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: all 0.2s ease;
  }
  
  .preview-nav a:hover {
    background: var(--color-ferni, #4a6741);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(74, 103, 65, 0.2);
  }
  
  .preview-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 24px;
  }
  
  .preview-section h2 {
    font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--color-text-primary, #2C2520);
    margin: 0 0 12px;
  }
  
  .preview-section > p {
    color: var(--color-text-secondary, #5C544A);
    margin-bottom: 32px;
    font-size: 16px;
  }
  
  .preview-card {
    background: white;
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    margin-bottom: 24px;
  }
  
  .preview-card h3 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--color-text-primary, #2C2520);
  }
  
  .preview-card > p {
    color: var(--color-text-secondary, #5C544A);
    margin-bottom: 20px;
  }
  
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  
  .feature-item {
    padding: 20px;
    background: rgba(74, 103, 65, 0.05);
    border-radius: 12px;
  }
  
  .feature-item h4 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .feature-item p {
    font-size: 14px;
    color: var(--color-text-secondary, #5C544A);
    margin: 0;
  }
  
  .demo-area {
    background: var(--color-paper-cream, #F5F1E8);
    border-radius: 16px;
    padding: 40px;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  
  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
  }
  
  .controls button {
    padding: 10px 20px;
    border: 1px solid rgba(74, 103, 65, 0.2);
    background: white;
    border-radius: 8px;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }
  
  .controls button:hover {
    background: var(--color-ferni, #4a6741);
    color: white;
    border-color: var(--color-ferni, #4a6741);
  }
  
  .controls button.active {
    background: var(--color-ferni, #4a6741);
    color: white;
    border-color: var(--color-ferni, #4a6741);
  }
  
  .code-preview {
    background: #2C2520;
    color: #F5F1E8;
    padding: 20px;
    border-radius: 12px;
    font-family: 'Monaco', 'Consolas', monospace;
    font-size: 13px;
    overflow-x: auto;
    margin-top: 20px;
  }
  
  .code-preview code {
    display: block;
    white-space: pre;
  }
  
  /* Live Avatar Preview */
  .avatar-preview {
    width: 200px;
    height: 200px;
    position: relative;
  }
  
  .avatar-preview .hero-ferni {
    transform: scale(1.5);
  }
  
  /* Dividers */
  .preview-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(74, 103, 65, 0.2), transparent);
    margin: 60px 0;
  }
</style>

