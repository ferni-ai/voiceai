<div class="chat-page">
  <section class="chat-hero">
    <div class="chat-hero__container">
      <div class="chat-hero__content">
        <p class="chat-hero__eyebrow">
          <span class="pulse"></span>
          Available Right Now
        </p>
        <h1 class="chat-hero__title">Talk to Ferni before you commit</h1>
        <p class="chat-hero__subtitle">
          Not sure if this is right for you? Ask anything. Ferni will give you honest, thoughtful answers—no sales pitch.
        </p>
        <div class="chat-hero__features">
          <div class="feature-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>No sign-up required to chat</span>
          </div>
          <div class="feature-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>Ask about features, pricing, or anything</span>
          </div>
          <div class="feature-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>Get a feel for how Ferni actually talks</span>
          </div>
        </div>
      </div>

      <div class="chat-widget">
        <div class="chat-widget__header">
          <div class="chat-widget__avatar">FE</div>
          <div class="chat-widget__info">
            <h3>Chat with Ferni</h3>
            <p>AI Life Coach</p>
          </div>
          <div class="chat-widget__status">
            <span class="status-dot"></span>
            Online
          </div>
        </div>

        <div class="quick-prompts" id="quickPrompts">
          <button class="quick-prompt">How does this work?</button>
          <button class="quick-prompt">What can you help with?</button>
          <button class="quick-prompt">Is this really AI?</button>
          <button class="quick-prompt">How much does it cost?</button>
        </div>

        <div class="chat-widget__messages" id="chatMessages">
          <!-- Messages will appear here -->
        </div>

        <div class="chat-widget__input">
          <input type="text" id="chatInput" placeholder="Type a message..." />
          <button id="sendBtn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13"/>
