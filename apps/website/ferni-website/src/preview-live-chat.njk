<style>
  .chat-page {
    min-height: 100vh;
    background: var(--color-bg-primary);
    display: flex;
    flex-direction: column;
  }

  /* Hero with embedded chat */
  .chat-hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px var(--space-6) var(--space-10);
    background: linear-gradient(135deg, var(--color-bg-primary) 0%, var(--color-bg-secondary) 100%);
  }

  .chat-hero__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    max-width: 1200px;
    width: 100%;
    align-items: center;
  }

  @media (max-width: 900px) {
    .chat-hero__container {
      grid-template-columns: 1fr;
    }
  }

  /* Left side - Value prop */
  .chat-hero__content {
    max-width: 500px;
  }

  .chat-hero__eyebrow {
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .chat-hero__eyebrow .pulse {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .chat-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }

  .chat-hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .chat-hero__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-base);
  }

  .feature-item svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Right side - Chat widget */
  .chat-widget {
    background: var(--color-bg-elevated);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-2xl);
    border: 1px solid var(--color-border-subtle);
    overflow: hidden;
    max-width: 450px;
    margin: 0 auto;
    width: 100%;
  }

  .chat-widget__header {
    background: linear-gradient(135deg, var(--color-ferni) 0%, var(--color-ferni-secondary) 100%);
    color: white;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .chat-widget__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--text-lg);
  }

  .chat-widget__info h3 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: 2px;
  }

  .chat-widget__info p {
    font-size: var(--text-sm);
    opacity: 0.8;
  }

  .chat-widget__status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    opacity: 0.9;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { box-shadow: 0 0 0 0 var(--color-success-bg); }
    50% { box-shadow: 0 0 0 4px transparent; }
  }

  /* Chat messages */
  .chat-widget__messages {
    height: 350px;
    overflow-y: auto;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--color-bg-primary);
  }

  .chat-message {
    display: flex;
    gap: var(--space-2);
    animation: messageIn 0.3s ease;
  }

  @keyframes messageIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .chat-message--ferni {
    align-items: flex-start;
  }

  .chat-message--user {
    flex-direction: row-reverse;
  }

  .chat-message__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: 600;
    flex-shrink: 0;
  }

  .chat-message--ferni .chat-message__avatar {
    background: var(--color-ferni);
    color: white;
  }

  .chat-message--user .chat-message__avatar {
    background: var(--color-text-muted);
    color: white;
  }

  .chat-message__bubble {
    max-width: 280px;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .chat-message--ferni .chat-message__bubble {
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-subtle);
    border-bottom-left-radius: var(--radius-sm);
  }

  .chat-message--user .chat-message__bubble {
    background: var(--color-ferni);
    color: white;
    border-bottom-right-radius: var(--radius-sm);
  }

  /* Typing indicator */
  .typing-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2);
  }

  .typing-dot {
    width: 6px;
    height: 6px;
    background: var(--color-text-muted);
    border-radius: 50%;
    animation: typingBounce 1.4s ease-in-out infinite;
  }

  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* Chat input */
  .chat-widget__input {
    display: flex;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border-subtle);
  }

  .chat-widget__input input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border-medium);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .chat-widget__input input:focus {
    border-color: var(--color-accent);
  }

  .chat-widget__input input::placeholder {
    color: var(--color-text-muted);
  }

  .chat-widget__input button {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .chat-widget__input button:hover {
    transform: scale(1.05);
    background: var(--color-accent-hover);
  }

  .chat-widget__input button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  /* Quick prompts */
  .quick-prompts {
    display: flex;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-secondary);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .quick-prompts::-webkit-scrollbar {
    display: none;
  }

  .quick-prompt {
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-medium);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .quick-prompt:hover {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  /* Preview Labels */
  .preview-label {
    position: fixed;
    top: var(--space-4);
    left: var(--space-4);
    background: rgba(255, 193, 7, 0.9);
    color: #333;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .preview-nav {
    position: fixed;
    top: var(--space-4);
    right: var(--space-4);
    display: flex;
    gap: var(--space-2);
    z-index: 1000;
  }

  .preview-nav a {
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-medium);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .preview-nav a:hover {
    background: var(--color-bg-secondary);
    border-color: var(--color-accent);
  }

  .preview-nav a.active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  /* CTA below chat */
  .chat-cta {
    text-align: center;
    padding: var(--space-8) var(--space-6);
    background: var(--color-bg-secondary);
  }

  .chat-cta__text {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .chat-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: white;
    font-weight: 500;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .chat-cta__btn:hover {
    transform: translateY(-2px);
    background: var(--color-accent-hover);
    box-shadow: 0 4px 20px var(--color-accent-glow);
  }
</style>

