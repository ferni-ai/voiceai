<script>
(function() {
  'use strict';

  const messagesContainer = document.getElementById('chatMessages');
  const chatInput = document.getElementById('chatInput');
  const sendBtn = document.getElementById('sendBtn');
  const quickPrompts = document.getElementById('quickPrompts');

  // Ferni's conversational knowledge base
  const RESPONSES = {
    greetings: {
      patterns: ['hello', 'hi', 'hey', 'good morning', 'good evening', 'good afternoon'],
      responses: [
        "Hi there! I'm Ferni. What brings you here today?",
        "Hello! Nice to meet you. I'd love to hear what's on your mind.",
        "Hey! Thanks for saying hi. What are you curious about?"
      ]
    },
    howItWorks: {
      patterns: ['how does this work', 'how do you work', 'what is this', 'explain'],
      responses: [
        "Great question! I'm an AI life coach available 24/7. You talk to me about whatever's on your mind—decisions, stress, habits, goals—and I help you find clarity through conversation. No judgment, no generic advice. Just thoughtful questions and perspectives tailored to you.",
        "Simply put: you talk, I listen deeply, and together we explore what's really going on. I'm trained on thousands of coaching conversations to help you think through challenges in ways that actually stick."
      ]
    },
    capabilities: {
      patterns: ['what can you help', 'what do you do', 'can you help', 'what are you good at'],
      responses: [
        "I can help with a lot! The big ones: making difficult decisions, managing stress and overwhelm, building better habits, navigating relationships, finding clarity on your goals, and just... processing life. I'm also connected to five specialists who help with specific things like communication, research, planning, and routines.",
        "I'm best at the 'stuck' moments. When you know something isn't working but can't figure out what. When you have a decision that keeps you up at night. When you need someone to truly listen without an agenda."
      ]
    },
    aiQuestion: {
      patterns: ['really ai', 'are you ai', 'are you human', 'are you real', 'bot'],
      responses: [
        "I am AI, yes—but probably not the kind you're imagining. I'm designed to have genuine conversations, not just answer questions. I remember context, pick up on nuance, and I'm trained specifically on what makes coaching conversations transformative. I won't pretend to be human, but I'm more present than you might expect.",
        "Fully AI—trained on real coaching methodologies. The difference from other AI is that I'm built for depth, not quick answers. I ask more than I tell. And honestly? Some people find it easier to open up to me than to humans. No judgment, available anytime."
      ]
    },
    pricing: {
      patterns: ['how much', 'cost', 'price', 'pricing', 'free', 'subscription'],
      responses: [
        "We have a free tier that gives you a real taste—not just a demo. You get meaningful conversations with me and limited access to specialists. Premium unlocks unlimited everything, plus advanced features like pattern tracking and deeper memory. It's $19/month, but honestly the free tier is substantial if you want to test it out.",
        "Free to start with real value built in. Premium is $19/month for unlimited access. But I'd recommend just trying the free tier first—you'll know pretty quickly if this is something that clicks for you."
      ]
    },
    emotions: {
      patterns: ['stressed', 'anxious', 'overwhelmed', 'sad', 'tired', 'frustrated', 'scared'],
      responses: [
        "I hear you. That's a lot to carry. What's weighing on you most heavily right now?",
        "Those feelings make sense—they're usually telling us something important. What would feel like relief right now, even just a small bit?",
        "I'm here for this. You don't have to have it figured out. Just tell me what's happening."
      ]
    },
    decisions: {
      patterns: ['decision', 'choose', 'should i', 'can\'t decide', 'not sure'],
      responses: [
        "Decisions are heavy when they matter. What are the options you're weighing?",
        "What does your gut say? Sometimes we know the answer but don't trust it yet.",
        "Let's break this down. What would each choice look like six months from now?"
      ]
    },
    thanks: {
      patterns: ['thanks', 'thank you', 'helpful', 'appreciate'],
      responses: [
        "Of course. That's what I'm here for. Anything else on your mind?",
        "Happy to help. Come back anytime—I'll remember this conversation.",
        "You're welcome. I'm always here when you need to think something through."
      ]
    },
    default: [
      "That's interesting. Tell me more about what that means to you.",
      "I'd like to understand better. What's behind that for you?",
      "Can you say more about that? I want to make sure I really get it.",
      "That's worth exploring. What feels most important about it?"
    ]
  };

  // Add initial greeting
  setTimeout(() => {
    addMessage('ferni', getTimeAwareGreeting());
  }, 800);

  function getTimeAwareGreeting() {
    const hour = new Date().getHours();
    if (hour < 12) {
      return "Good morning! I'm Ferni. This is a preview of how we might chat together. Ask me anything—about how I work, what I can help with, or just tell me what's on your mind.";
    } else if (hour < 17) {
      return "Good afternoon! I'm Ferni. This is a preview of our conversations. Feel free to ask questions about how I work, or just share what's on your mind right now.";
    } else if (hour < 21) {
      return "Good evening! I'm Ferni. Welcome to this preview. Ask me anything—I'd love to show you how we'd actually talk together.";
    } else {
      return "You're up late! I'm Ferni. Can't sleep, or just exploring? Either way, I'm here. Ask me anything or tell me what's on your mind.";
    }
  }

  function findResponse(input) {
    const lower = input.toLowerCase();

    for (const [category, data] of Object.entries(RESPONSES)) {
      if (category === 'default') continue;
      if (data.patterns.some(p => lower.includes(p))) {
        return data.responses[Math.floor(Math.random() * data.responses.length)];
      }
    }

    return RESPONSES.default[Math.floor(Math.random() * RESPONSES.default.length)];
  }

  function addMessage(sender, text) {
    const message = document.createElement('div');
    message.className = `chat-message chat-message--${sender}`;
    message.innerHTML = `
      <div class="chat-message__avatar">${sender === 'ferni' ? 'FE' : 'You'}</div>
      <div class="chat-message__bubble">${text}</div>
    `;
    messagesContainer.appendChild(message);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  function addTypingIndicator() {
    const typing = document.createElement('div');
    typing.className = 'chat-message chat-message--ferni';
    typing.id = 'typingIndicator';
    typing.innerHTML = `
      <div class="chat-message__avatar">FE</div>
      <div class="chat-message__bubble">
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      </div>
    `;
    messagesContainer.appendChild(typing);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  function removeTypingIndicator() {
    const typing = document.getElementById('typingIndicator');
    if (typing) typing.remove();
  }

  function handleSend() {
    const text = chatInput.value.trim();
    if (!text) return;

    addMessage('user', text);
    chatInput.value = '';
    sendBtn.disabled = true;

    addTypingIndicator();

    // Simulate AI thinking
    const delay = 1000 + Math.random() * 1000;
    setTimeout(() => {
      removeTypingIndicator();
      const response = findResponse(text);
      addMessage('ferni', response);
      sendBtn.disabled = false;
    }, delay);
  }

  // Event listeners
  sendBtn.addEventListener('click', handleSend);
  chatInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  });

  // Quick prompts
  quickPrompts.addEventListener('click', (e) => {
    if (e.target.classList.contains('quick-prompt')) {
      chatInput.value = e.target.textContent;
      handleSend();
    }
  });

  console.log('%c💬 Live Chat Preview Loaded', 'color: #4a6741; font-weight: bold;');
})();
</script>
