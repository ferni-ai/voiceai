      <span class="api-card-endpoints">7 endpoints</span>
    </a>

    <a href="/developers/api/workflows/" class="api-card">
      <div class="api-card-icon" style="background: rgba(167, 139, 250, 0.1); color: #a78bfa;">⚡</div>
