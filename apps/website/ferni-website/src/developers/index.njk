---
layout: layouts/dev-portal.njk
title: Ferni Developer Platform | Extend Voice Companions with Heart
description: Give Ferni new abilities through MCP servers, custom tools, and webhooks. Build extensions that feel as warm and human as Ferni itself.
---

<style>
  /* Page-specific overrides */
  .dev-hero h1 {
    color: var(--dev-text);
  }

  .dev-hero-eyebrow {
    color: var(--dev-ferni-light);
  }

  .dev-stat-value {
    font-family: 'JetBrains Mono', monospace;
  }

  /* Alternate stat colors for variety */
  .dev-stats-grid > div:nth-child(1) .dev-stat-value { color: var(--dev-peter-light); }
  .dev-stats-grid > div:nth-child(2) .dev-stat-value { color: var(--dev-accent); }
  .dev-stats-grid > div:nth-child(3) .dev-stat-value { color: var(--dev-ferni-light); }
  .dev-stats-grid > div:nth-child(4) .dev-stat-value { color: var(--dev-jordan-light); }

  .api-card-endpoints {
    font-family: 'JetBrains Mono', monospace;
  }

  .code-preview {
    background: var(--dev-code-bg);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }

  .code-preview-header {
    background: rgba(0,0,0,0.3);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--dev-border);
  }

  .code-preview-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .code-preview-dot.red { background: #ff5f56; }
  .code-preview-dot.yellow { background: #ffbd2e; }
  .code-preview-dot.green { background: #27c93f; }

  .code-preview-title {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--dev-text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .code-preview pre {
    margin: 0;
    padding: 1.5rem;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .code-preview code {
    color: var(--dev-text);
  }

  .code-preview .comment { color: #8b9a8b; }
  .code-preview .string { color: #d4a84a; }
  .code-preview .keyword { color: #c4856a; }
  .code-preview .function { color: #6b8760; }

  /* API Cards */
  .api-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .api-card {
    background: var(--dev-surface);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .api-card:hover {
    border-color: var(--dev-accent);
    transform: translateY(-2px);
  }

  .api-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    background: var(--dev-accent-subtle);
    color: var(--dev-accent);
  }

  .api-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: var(--dev-text);
  }

  .api-card p {
    font-size: 0.95rem;
    color: var(--dev-text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .api-card-endpoints {
    font-size: 0.8rem;
    color: var(--dev-accent);
  }

  /* Resources Grid */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .resource-card {
    background: var(--dev-surface);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .resource-card:hover {
    border-color: var(--dev-accent);
  }

  .resource-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--dev-text);
  }

  .resource-card p {
    font-size: 0.9rem;
    color: var(--dev-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Blog Preview */
  .blog-preview {
    background: var(--dev-surface);
    border-top: 1px solid var(--dev-border);
    padding: 5rem 2rem;
  }

  .blog-preview-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .blog-preview-card {
    background: var(--dev-bg);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .blog-preview-card:hover {
    border-color: var(--dev-accent);
  }

  .blog-preview-card-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--dev-accent);
    margin-bottom: 0.75rem;
  }

  .blog-preview-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--dev-text);
    line-height: 1.3;
  }

  .blog-preview-card p {
    font-size: 0.9rem;
    color: var(--dev-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .dev-stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

