<style>
  :root {
    --dev-bg: #0f172a;
    --dev-surface: #1e293b;
    --dev-border: #334155;
    --dev-accent: #38bdf8;
    --dev-accent-hover: #0ea5e9;
    --dev-success: #4ade80;
    --dev-warning: #fbbf24;
    --dev-text: #e2e8f0;
    --dev-text-muted: #94a3b8;
    --dev-code-bg: #1e1e2e;
  }

  body {
    background: var(--dev-bg);
    color: var(--dev-text);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* Developer Navigation */
  .dev-nav {
    background: var(--dev-surface);
    border-bottom: 1px solid var(--dev-border);
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .dev-nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--dev-text);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .dev-nav-brand svg {
    width: 32px;
    height: 32px;
  }

  .dev-nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .dev-nav-links a {
    color: var(--dev-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .dev-nav-links a:hover,
  .dev-nav-links a.active {
    color: var(--dev-accent);
  }

  /* Hero Section */
  .dev-hero {
    background: linear-gradient(135deg, var(--dev-surface) 0%, var(--dev-bg) 100%);
    padding: 6rem 2rem;
    text-align: center;
    border-bottom: 1px solid var(--dev-border);
  }

  .dev-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(56, 189, 248, 0.1);
    border: 1px solid rgba(56, 189, 248, 0.3);
    color: var(--dev-accent);
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .dev-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    background: linear-gradient(135deg, #fff 0%, var(--dev-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .dev-hero p {
    font-size: 1.25rem;
    color: var(--dev-text-muted);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .dev-hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-dev {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-dev-primary {
    background: var(--dev-accent);
    color: var(--dev-bg);
  }

  .btn-dev-primary:hover {
    background: var(--dev-accent-hover);
    transform: translateY(-1px);
  }

  .btn-dev-secondary {
    background: transparent;
    color: var(--dev-text);
    border: 1px solid var(--dev-border);
  }

  .btn-dev-secondary:hover {
    border-color: var(--dev-accent);
    color: var(--dev-accent);
  }

  /* Stats Bar */
  .dev-stats {
    background: var(--dev-surface);
    border-bottom: 1px solid var(--dev-border);
    padding: 2rem;
  }

  .dev-stats-grid {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .dev-stat-value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--dev-accent);
    font-family: 'JetBrains Mono', monospace;
  }

  .dev-stat-label {
    font-size: 0.85rem;
    color: var(--dev-text-muted);
    margin-top: 0.25rem;
  }

  /* Section Styles */
  .dev-section {
    padding: 5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .dev-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .dev-section-header h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--dev-text);
  }

  .dev-section-header p {
    font-size: 1.1rem;
    color: var(--dev-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  /* API Cards */
  .api-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .api-card {
    background: var(--dev-surface);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .api-card:hover {
    border-color: var(--dev-accent);
    transform: translateY(-2px);
  }

  .api-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    font-size: 1.5rem;
  }

  .api-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: var(--dev-text);
  }

  .api-card p {
    font-size: 0.95rem;
    color: var(--dev-text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .api-card-endpoints {
    font-size: 0.8rem;
    color: var(--dev-accent);
    font-family: 'JetBrains Mono', monospace;
  }

  /* Code Preview */
  .code-preview {
    background: var(--dev-code-bg);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }

  .code-preview-header {
    background: rgba(0,0,0,0.3);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--dev-border);
  }

  .code-preview-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .code-preview-dot.red { background: #ff5f56; }
  .code-preview-dot.yellow { background: #ffbd2e; }
  .code-preview-dot.green { background: #27c93f; }

  .code-preview-title {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--dev-text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .code-preview pre {
    margin: 0;
    padding: 1.5rem;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .code-preview code {
    color: var(--dev-text);
  }

  .code-preview .comment { color: #6a9955; }
  .code-preview .string { color: #ce9178; }
  .code-preview .keyword { color: #569cd6; }
  .code-preview .function { color: #dcdcaa; }

  /* Resources Grid */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .resource-card {
    background: var(--dev-surface);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .resource-card:hover {
    border-color: var(--dev-accent);
  }

  .resource-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--dev-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .resource-card p {
    font-size: 0.9rem;
    color: var(--dev-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Blog Preview */
  .blog-preview {
    background: var(--dev-surface);
    border-top: 1px solid var(--dev-border);
    padding: 5rem 2rem;
  }

  .blog-preview-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .blog-preview-card {
    background: var(--dev-bg);
    border: 1px solid var(--dev-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .blog-preview-card:hover {
    border-color: var(--dev-accent);
  }

  .blog-preview-card-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--dev-accent);
    margin-bottom: 0.75rem;
  }

  .blog-preview-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--dev-text);
    line-height: 1.3;
  }

  .blog-preview-card p {
    font-size: 0.9rem;
    color: var(--dev-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Footer */
  .dev-footer {
    background: var(--dev-surface);
    border-top: 1px solid var(--dev-border);
    padding: 2rem;
    text-align: center;
  }

  .dev-footer p {
    color: var(--dev-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .dev-footer a {
    color: var(--dev-accent);
    text-decoration: none;
  }

  .dev-footer a:hover {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .dev-nav {
      flex-direction: column;
      gap: 1rem;
    }

    .dev-nav-links {
      gap: 1rem;
    }

    .dev-hero {
      padding: 4rem 1.5rem;
    }

    .dev-stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .dev-section {
      padding: 3rem 1.5rem;
    }

    .dev-hero-ctas {
      flex-direction: column;
      align-items: center;
    }

    .btn-dev {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>

