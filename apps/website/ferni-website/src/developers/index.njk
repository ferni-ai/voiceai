<section class="blog-preview">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div class="dev-section-header">
      <h2>From the Blog</h2>
      <p>Technical insights and updates from the team</p>
    </div>

    <div class="blog-preview-grid">
      {% for post in collections.devPosts | slice(0, 3) %}
        <a href="{{ post.url }}" class="blog-preview-card">
          {% if post.data.category %}
            <div class="blog-preview-card-category">{{ post.data.category }}</div>
          {% endif %}
          <h3>{{ post.data.title }}</h3>
          {% if post.data.excerpt %}
            <p>{{ post.data.excerpt | truncate(100) }}</p>
          {% endif %}
        </a>
      {% else %}
        <a href="/developers/blog/" class="blog-preview-card">
          <div class="blog-preview-card-category">Coming Soon</div>
          <h3>Developer Blog</h3>
          <p>Technical insights and API updates from the Ferni team.</p>
        </a>
      {% endfor %}
    </div>

    <div style="text-align: center; margin-top: 2rem;">
      <a href="/developers/blog/" class="btn-dev btn-dev-secondary">
        View All Posts
      </a>
    </div>
  </div>
</section>

