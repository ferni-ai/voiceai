<style>
  :root {
    --dev-bg: #584840;
    --dev-surface: #70605a;
    --dev-surface-elevated: #7d6e67;
    --dev-border: rgba(212, 168, 74, 0.2);
    --dev-accent: #d4a84a;
    --dev-accent-hover: #e5bc6a;
    --dev-text: #faf8f5;
    --dev-text-muted: rgba(250, 248, 245, 0.7);
    --dev-code-bg: #4a3c35;
    --dev-ferni-green: #4a6741;
  }

  body.dev-portal {
    background: var(--dev-bg);
    color: var(--dev-text);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    margin: 0;
    padding: 0;
  }

  .dev-nav {
    background: var(--dev-surface);
    border-bottom: 1px solid var(--dev-border);
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .dev-nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--dev-text);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .dev-nav-brand svg {
    width: 32px;
    height: 32px;
  }

  .dev-nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .dev-nav-links a {
    color: var(--dev-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .dev-nav-links a:hover,
  .dev-nav-links a.active {
    color: var(--dev-accent);
  }

  .api-header {
    background: linear-gradient(135deg, var(--dev-surface) 0%, var(--dev-bg) 100%);
    border-bottom: 1px solid var(--dev-border);
    padding: 4rem 2rem;
    text-align: center;
  }

  .api-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--dev-text);
  }

  .api-header p {
    font-size: 1.1rem;
    color: var(--dev-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .api-content {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .api-section {
    margin-bottom: 3rem;
  }

  .api-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--dev-text);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .api-section-icon {
    width: 24px;
    height: 24px;
    color: var(--dev-accent);
  }

  .api-section > p {
    color: var(--dev-text-muted);
    margin-bottom: 1.5rem;
  }

  .endpoint-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--dev-surface);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--dev-border);
  }

  .endpoint-table th,
  .endpoint-table td {
    padding: 1rem;
    text-align: left;
  }

  .endpoint-table th {
    background: rgba(0,0,0,0.15);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--dev-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .endpoint-table td {
    border-top: 1px solid var(--dev-border);
  }

  .endpoint-table tr:hover td {
    background: rgba(212, 168, 74, 0.05);
  }

  .method {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    display: inline-block;
    min-width: 60px;
    text-align: center;
  }

  .method-get { background: rgba(74, 222, 128, 0.2); color: #4ade80; }
  .method-post { background: rgba(212, 168, 74, 0.25); color: var(--dev-accent); }
  .method-put { background: rgba(251, 191, 36, 0.2); color: #fbbf24; }
  .method-delete { background: rgba(248, 113, 113, 0.2); color: #f87171; }

  .endpoint-path {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--dev-text);
  }

  .endpoint-desc {
    color: var(--dev-text-muted);
    font-size: 0.9rem;
  }

  .base-url {
    background: var(--dev-code-bg);
    border: 1px solid var(--dev-border);
    border-radius: 8px;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .base-url-label {
    font-size: 0.85rem;
    color: var(--dev-text-muted);
    font-weight: 500;
  }

  .base-url-value {
    font-family: 'JetBrains Mono', monospace;
    color: var(--dev-accent);
  }

  .auth-note {
    background: rgba(212, 168, 74, 0.1);
    border: 1px solid rgba(212, 168, 74, 0.3);
    border-radius: 8px;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .auth-note-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--dev-accent);
  }

  .auth-note-content h4 {
    margin: 0 0 0.25rem;
    font-size: 0.95rem;
    color: var(--dev-text);
  }

  .auth-note-content p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--dev-text-muted);
  }

  .auth-note-content code {
    background: rgba(0,0,0,0.3);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }

  .auth-note-content a {
    color: var(--dev-accent);
    text-decoration: none;
  }

  .auth-note-content a:hover {
    text-decoration: underline;
  }

  .dev-footer {
    background: var(--dev-surface);
    border-top: 1px solid var(--dev-border);
    padding: 2rem;
    text-align: center;
  }

  .dev-footer p {
    color: var(--dev-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .dev-footer a {
    color: var(--dev-accent);
    text-decoration: none;
  }

  .dev-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .dev-nav {
      flex-direction: column;
      gap: 1rem;
    }

    .endpoint-table {
      display: block;
      overflow-x: auto;
    }

    .base-url {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>

