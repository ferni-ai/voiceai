      MCP Servers
    </h2>
    <p>Register and manage external Model Context Protocol servers.</p>

    <table class="endpoint-table">
      <thead>
        <tr>
          <th>Method</th>
          <th>Endpoint</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="method method-post">POST</span></td>
          <td class="endpoint-path">/mcp-servers</td>
          <td class="endpoint-desc">Register a new MCP server</td>
        </tr>
        <tr>
          <td><span class="method method-get">GET</span></td>
          <td class="endpoint-path">/mcp-servers</td>
          <td class="endpoint-desc">List all your MCP servers</td>
        </tr>
        <tr>
          <td><span class="method method-get">GET</span></td>
          <td class="endpoint-path">/mcp-servers/:id</td>
          <td class="endpoint-desc">Get server details</td>
        </tr>
        <tr>
          <td><span class="method method-put">PUT</span></td>
          <td class="endpoint-path">/mcp-servers/:id</td>
          <td class="endpoint-desc">Update server configuration</td>
        </tr>
        <tr>
          <td><span class="method method-delete">DELETE</span></td>
          <td class="endpoint-path">/mcp-servers/:id</td>
          <td class="endpoint-desc">Delete a server</td>
        </tr>
        <tr>
          <td><span class="method method-post">POST</span></td>
          <td class="endpoint-path">/mcp-servers/:id/test</td>
          <td class="endpoint-desc">Test server connection</td>
        </tr>
        <tr>
          <td><span class="method method-get">GET</span></td>
          <td class="endpoint-path">/mcp-servers/:id/tools</td>
          <td class="endpoint-desc">List discovered tools</td>
        </tr>
      </tbody>
    </table>
  </section>

