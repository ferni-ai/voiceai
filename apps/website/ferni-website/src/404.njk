---
layout: layouts/story-brand.njk
title: "{{ 'errorPage.title' | t }}"
description: "{{ 'errorPage.subtitle' | t }}"
permalink: /404.html
---

<main id="main-content" class="error-page">
  <section class="section error-hero">
    <div class="container">
      <div class="error-hero__content">

        {# Ferni Avatar - Looking confused/curious #}
        <div class="hero-ferni hero-ferni--confused" aria-hidden="true">
          <div class="hero-ferni__glow"></div>
          <div class="hero-ferni__ring hero-ferni__ring--outer"></div>
          <div class="hero-ferni__ring hero-ferni__ring--inner"></div>
          <div class="hero-ferni__orb">
            <span class="hero-ferni__text">?</span>
          </div>
        </div>

        <h1 class="error-hero__headline">{{ 'errorPage.title' | t }}</h1>
        <p class="error-hero__subhead">{{ 'errorPage.subtitle' | t }}</p>

        <div class="error-hero__cta">
          <a href="{{ '/' | localizeUrl }}" class="btn btn--primary btn--lg">
            {{ 'errorPage.goHome' | t }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="tel:{{ site.phoneRaw }}" class="btn btn--secondary btn--lg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {{ 'errorPage.callFerni' | t }}
          </a>
        </div>

        <div class="error-hero__suggestions">
          <p class="error-hero__suggestions-label">{{ 'errorPage.suggestionsLabel' | t }}</p>
          <div class="error-hero__links">
            <a href="{{ '/#team' | localizeUrl }}" class="error-hero__link">{{ 'errorPage.meetTeam' | t }}</a>
            <a href="{{ '/#founders' | localizeUrl }}" class="error-hero__link">{{ 'errorPage.supportFerni' | t }}</a>
            <a href="{{ '/#faq' | localizeUrl }}" class="error-hero__link">{{ 'errorPage.readFaq' | t }}</a>
            <a href="{{ '/blog/' | localizeUrl }}" class="error-hero__link">{{ 'errorPage.readBlog' | t }}</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</main>

<style>
.error-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-paper-cream);
}

.error-hero {
  text-align: center;
  padding: var(--space-20) 0;
}

.error-hero__content {
  max-width: 600px;
  margin: 0 auto;
}

.error-hero .hero-ferni {
  margin-bottom: var(--space-8);
}

.error-hero .hero-ferni--confused {
  animation: confused-tilt 3s ease-in-out infinite;
}

@keyframes confused-tilt {
  0%, 100% { transform: rotate(-5deg); }
  50% { transform: rotate(5deg); }
}

.error-hero .hero-ferni__text {
  font-size: var(--text-h1);
}

.error-hero__headline {
  font-family: var(--font-display);
  font-size: var(--text-display-sm);
  font-weight: 800;
  color: var(--color-natural-ink);
  margin-bottom: var(--space-4);
  letter-spacing: -0.02em;
}

.error-hero__subhead {
  font-size: var(--text-lg);
  color: var(--color-stone);
  margin-bottom: var(--space-8);
  line-height: 1.6;
}

.error-hero__cta {
  display: flex;
  gap: var(--space-4);
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: var(--space-12);
}

.error-hero__suggestions {
  padding-top: var(--space-8);
  border-top: 1px solid var(--color-sand);
}

.error-hero__suggestions-label {
  font-size: var(--text-sm);
  color: var(--color-stone);
  margin-bottom: var(--space-4);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.error-hero__links {
  display: flex;
  gap: var(--space-6);
  justify-content: center;
  flex-wrap: wrap;
}

.error-hero__link {
  color: var(--color-ferni-green);
  font-weight: 500;
  text-decoration: none;
  transition: color 0.2s ease;
}

.error-hero__link:hover {
  color: var(--color-forest-green);
  text-decoration: underline;
}

@media (max-width: 640px) {
  .error-hero__headline {
    font-size: var(--text-h1);
  }

  .error-hero__cta {
    flex-direction: column;
  }

  .error-hero__links {
    flex-direction: column;
    gap: var(--space-3);
  }
}
</style>
