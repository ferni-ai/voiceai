---
layout: layouts/base.njk
title: Finally, someone who actually listens
description: Six AI specialists. One conversation. Just talk—they'll handle the rest.
extraCss: /css/cinematic-demo.css
---

{# Clean page - no default header #}
{% block header %}{% endblock %}

{% block content %}
<div class="cinematic-page">

<!-- ========================================================================
     HERO - Zen Presence
     "Full viewport height, centered headline, generous space"
     ======================================================================== -->
<section class="hero-zen">
  <div class="hero-zen-bg">
    <img 
      src="/images/generated/hero/hero-zen-garden.jpg" 
      alt="" 
      class="hero-zen-image"
      loading="eager"
    >
    <div class="hero-zen-vignette"></div>
    <div class="hero-zen-fade"></div>
  </div>
  
  <div class="hero-zen-content">
    <div class="hero-overline">
      <span class="hero-overline-dot"></span>
      Your AI life coach
    </div>
    
    <h1 class="hero-headline">
      <span class="hero-headline-line">Finally, someone</span>
      <span class="hero-headline-line">who <span class="hero-accent">actually</span></span>
      <span class="hero-headline-line">listens.</span>
    </h1>
    
    <p class="hero-subheadline">
      Six AI specialists. One seamless conversation.<br>
      Just talk—they'll handle the rest.
    </p>
    
    <div class="hero-ctas">
      <a href="{{ site.appUrl }}" class="btn-primary">
        Start a conversation
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="tel:{{ site.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}" class="btn-ghost">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        Or call {{ site.phone }}
      </a>
    </div>
  </div>
  
  <div class="hero-scroll-hint">
    <span>Scroll</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"></line>
      <polyline points="19 12 12 19 5 12"></polyline>
    </svg>
  </div>
</section>


<!-- ========================================================================
     FEATURES - Breathing Space
     "Every element earns its place"
     ======================================================================== -->
<section class="section-warm">
  <div class="cinematic-container">
    <div class="section-header reveal-on-scroll">
      <span class="section-overline">Why Ferni</span>
      <h2 class="section-headline">Conversations<br>that go somewhere.</h2>
      <p class="section-subheadline">
        Simple, powerful AI coaching that fits your life.
      </p>
    </div>
    
    <div class="cards-grid stagger-children">
      <div class="card-elevated">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4"></path>
            <path d="M12 8h.01"></path>
          </svg>
        </div>
        <h3 class="card-title">Six specialists</h3>
        <p class="card-description">
          From career coaching to habit building, each AI is an expert in their domain.
        </p>
      </div>
      
      <div class="card-elevated">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <h3 class="card-title">Natural conversation</h3>
        <p class="card-description">
          Talk like you would with a friend. No scripts, no menus, just conversation.
        </p>
      </div>
      
      <div class="card-elevated">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </div>
        <h3 class="card-title">Always there</h3>
        <p class="card-description">
          2am thoughts? Early morning motivation? Your team is ready when you are.
        </p>
      </div>
    </div>
  </div>
</section>


<!-- ========================================================================
     TEAM - Persona Warmth
     "Grid of avatar cards, hover with lift"
     ======================================================================== -->
<section class="section-warm alt">
  <div class="cinematic-container">
    <div class="section-header reveal-on-scroll">
      <span class="section-overline">Meet your team</span>
      <h2 class="section-headline">They remember.<br>So you don't have to.</h2>
      <p class="section-subheadline">
        Each specialist knows their craft. Together, they know you.
      </p>
    </div>
    
    <div class="team-grid stagger-children">
      <div class="team-card" style="--persona-color: #4a6741;">
        <div class="team-avatar">
          <img src="/images/generated/avatars/ferni-v1.png" alt="Ferni" loading="lazy">
        </div>
        <h3 class="team-name">Ferni</h3>
        <span class="team-role">Life Coach</span>
        <p class="team-bio">Your main guide for life's big questions.</p>
      </div>
      
      <div class="team-card" style="--persona-color: #9a7b5a;">
        <div class="team-avatar">
          <img src="/images/generated/avatars/jack-v1.png" alt="Jack" loading="lazy">
        </div>
        <h3 class="team-name">Jack</h3>
        <span class="team-role">Investment Sage</span>
        <p class="team-bio">Decades of wisdom on building wealth.</p>
      </div>
      
      <div class="team-card" style="--persona-color: #a67a6a;">
        <div class="team-avatar">
          <img src="/images/generated/avatars/maya-v1.png" alt="Maya" loading="lazy">
        </div>
        <h3 class="team-name">Maya</h3>
        <span class="team-role">Habits & Routines</span>
        <p class="team-bio">Building habits that actually stick.</p>
      </div>
      
      <div class="team-card" style="--persona-color: #5a6b8a;">
        <div class="team-avatar">
          <img src="/images/generated/avatars/alex-v1.png" alt="Alex" loading="lazy">
        </div>
        <h3 class="team-name">Alex</h3>
        <span class="team-role">Communications</span>
        <p class="team-bio">Draft emails, prepare for tough talks.</p>
      </div>
      
      <div class="team-card" style="--persona-color: #3a6b73;">
        <div class="team-avatar">
          <img src="/images/generated/avatars/peter-v1.png" alt="Peter" loading="lazy">
        </div>
        <h3 class="team-name">Peter</h3>
        <span class="team-role">Research</span>
        <p class="team-bio">Deep dives into any topic you need.</p>
      </div>
      
      <div class="team-card" style="--persona-color: #c4856a;">
        <div class="team-avatar">
          <img src="/images/generated/avatars/jordan-v1.png" alt="Jordan" loading="lazy">
        </div>
        <h3 class="team-name">Jordan</h3>
        <span class="team-role">Planning & Events</span>
        <p class="team-bio">Celebrate every milestone with style.</p>
      </div>
    </div>
  </div>
</section>


<!-- ========================================================================
     CTA - Rare Dark Moment
     "Dark background (rare), large headline, clear value"
     ======================================================================== -->
<section class="section-cta-dark">
  <div class="cinematic-container">
    <div class="cta-content">
      <h2 class="cta-headline">Ready to be heard?</h2>
      <p class="cta-subheadline">
        Start a conversation today. It's free, and your team is waiting.
      </p>
      <div class="cta-buttons">
        <a href="{{ site.appUrl }}" class="btn-light">
          Start talking
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a href="tel:{{ site.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}" class="btn-ghost-dark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          Or call {{ site.phone }}
        </a>
      </div>
    </div>
  </div>
</section>

</div>

<script>
// Enable JS-enhanced animations
document.querySelector('.cinematic-page').classList.add('js-loaded');

// Scroll reveal with intersection observer
const reveals = document.querySelectorAll('.reveal-on-scroll, .stagger-children');

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, {
  threshold: 0.15,
  rootMargin: '0px 0px -80px 0px'
});

reveals.forEach(el => observer.observe(el));
</script>

{% endblock %}

{% block head %}
<meta name="theme-color" content="#F5F1E8">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
{% endblock %}
