<style>
  /* Voice-First Hero Styles */
  .voice-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg-primary) 0%, var(--color-bg-secondary) 100%);
    position: relative;
    overflow: hidden;
  }

  .voice-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 30%, var(--color-accent-glow) 0%, transparent 60%);
  }

  .voice-hero__content {
    text-align: center;
    max-width: 600px;
    padding: var(--space-8);
    position: relative;
    z-index: 2;
  }

  /* Ferni Avatar - Large & Central */
  .ferni-avatar-container {
    position: relative;
    margin-bottom: var(--space-8);
  }

  .ferni-avatar {
    width: 180px;
    height: 180px;
    margin: 0 auto;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-ferni) 0%, var(--color-ferni-secondary) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: 0 20px 60px var(--color-ferni-glow);
    cursor: pointer;
    transition: transform var(--duration-slow) var(--ease-ease-out);
  }

  .ferni-avatar:hover {
    transform: scale(1.02);
  }

  .ferni-avatar__initials {
    font-family: var(--font-accent);
    font-size: var(--text-6xl);
    color: white;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  /* Voice Rings Animation */
  .voice-rings {
    position: absolute;
    inset: -30px;
    pointer-events: none;
  }

  .voice-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid var(--color-ferni-glow);
    opacity: 0;
    transform: scale(0.8);
  }

  .voice-rings.active .voice-ring {
    animation: ringPulse 2s ease-out infinite;
  }

  .voice-ring:nth-child(1) { animation-delay: 0s; }
  .voice-ring:nth-child(2) { animation-delay: 0.4s; }
  .voice-ring:nth-child(3) { animation-delay: 0.8s; }

  @keyframes ringPulse {
    0% {
      opacity: 0.6;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(1.8);
    }
  }

  /* Listening Indicator */
  .listening-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    height: var(--space-8);
    margin-top: var(--space-4);
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-ease-out);
  }

  .listening-indicator.active {
    opacity: 1;
  }

  .listening-bar {
    width: 4px;
    height: 20px;
    background: var(--color-ferni);
    border-radius: 2px;
    animation: soundBars 0.5s ease-in-out infinite alternate;
  }

  .listening-bar:nth-child(1) { animation-delay: 0s; height: 12px; }
  .listening-bar:nth-child(2) { animation-delay: 0.1s; height: 20px; }
  .listening-bar:nth-child(3) { animation-delay: 0.2s; height: 16px; }
  .listening-bar:nth-child(4) { animation-delay: 0.3s; height: 24px; }
  .listening-bar:nth-child(5) { animation-delay: 0.4s; height: 14px; }

  @keyframes soundBars {
    from { transform: scaleY(0.3); }
    to { transform: scaleY(1); }
  }

  /* Greeting Text */
  .voice-greeting {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
    min-height: 2.4em;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s ease;
  }

  .voice-greeting.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .voice-subtext {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    opacity: 0;
    transition: opacity 0.6s ease 0.3s;
  }

  .voice-subtext.visible {
    opacity: 1;
  }

  /* Start Button - Uses accent color for CTAs per brand guidelines */
  .voice-start-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    background: var(--color-accent);
    color: white;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-medium);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--duration-slow) var(--ease-ease-out);
    box-shadow: 0 4px 20px var(--color-accent-glow);
  }

  .voice-start-btn:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 30px var(--color-accent-glow);
  }

  .voice-start-btn svg {
    width: 24px;
    height: 24px;
  }

  .voice-start-btn.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* Transcript Display */
  .voice-transcript {
    margin-top: var(--space-8);
    padding: var(--space-6);
    background: var(--color-bg-elevated);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border-subtle);
    min-height: 100px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .voice-transcript.visible {
    opacity: 1;
  }

  .transcript-line {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    padding: var(--space-3);
    border-radius: var(--radius-lg);
    animation: fadeIn 0.4s ease;
  }

  .transcript-line.ferni {
    background: var(--color-accent-subtle);
  }

  .transcript-line.user {
    background: var(--color-bg-secondary);
  }

  .transcript-speaker {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    min-width: 60px;
  }

  .transcript-text {
    font-size: var(--text-base);
    color: var(--color-text-primary);
    line-height: 1.5;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Preview Label */
  .preview-label {
    position: fixed;
    top: var(--space-4);
    left: var(--space-4);
    background: rgba(255, 193, 7, 0.9);
    color: #333;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .preview-nav {
    position: fixed;
    top: var(--space-4);
    right: var(--space-4);
    display: flex;
    gap: var(--space-2);
    z-index: 1000;
  }

  .preview-nav a {
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-medium);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .preview-nav a:hover {
    background: var(--color-bg-secondary);
    border-color: var(--color-accent);
    color: var(--color-text-primary);
  }

  .preview-nav a.active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }
</style>

