<section class="voice-hero">
  <div class="voice-hero__content">
    <div class="ferni-avatar-container">
      <div class="ferni-avatar" id="ferniAvatar">
        <span class="ferni-avatar__initials">FE</span>
      </div>
      <div class="voice-rings" id="voiceRings">
        <div class="voice-ring"></div>
        <div class="voice-ring"></div>
        <div class="voice-ring"></div>
      </div>
    </div>

    <div class="listening-indicator" id="listeningIndicator">
      <div class="listening-bar"></div>
      <div class="listening-bar"></div>
      <div class="listening-bar"></div>
      <div class="listening-bar"></div>
      <div class="listening-bar"></div>
    </div>

    <h1 class="voice-greeting" id="voiceGreeting">Hi, I'm Ferni.</h1>
    <p class="voice-subtext" id="voiceSubtext">I'd love to hear what's on your mind today.</p>

    <button class="voice-start-btn" id="startVoiceBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
        <line x1="12" y1="19" x2="12" y2="22"/>
      </svg>
      Start Talking
    </button>

    <div class="voice-transcript" id="voiceTranscript">
      <!-- Transcript lines will appear here -->
    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  const avatar = document.getElementById('ferniAvatar');
  const voiceRings = document.getElementById('voiceRings');
  const listeningIndicator = document.getElementById('listeningIndicator');
  const greeting = document.getElementById('voiceGreeting');
  const subtext = document.getElementById('voiceSubtext');
  const startBtn = document.getElementById('startVoiceBtn');
  const transcript = document.getElementById('voiceTranscript');

  // Ferni's conversational responses (simulated)
  const ferniResponses = [
    { trigger: 'hello|hi|hey', response: "It's nice to hear from you. How are you feeling right now?" },
    { trigger: 'stressed|anxious|worried', response: "I hear that. Stress can be overwhelming. What's weighing on you the most?" },
    { trigger: 'work|job|career', response: "Work can take so much of our energy. What would make your work life feel more fulfilling?" },
    { trigger: 'relationship|family|friend', response: "Relationships are so important. Tell me more about what's happening with them." },
    { trigger: 'decision|choose|decide', response: "Big decisions can feel paralyzing. What outcomes matter most to you here?" },
    { trigger: 'tired|exhausted|burnt out', response: "Your body is telling you something important. When was the last time you truly rested?" },
    { trigger: 'happy|excited|good', response: "I love hearing that energy in your voice! What's bringing you joy right now?" },
    { trigger: 'help|advice|guidance', response: "I'm here to help you find your own answers. What would help most right now?" },
  ];

  let isListening = false;
  let recognition = null;

  // Time-aware greeting
  function getTimeGreeting() {
    const hour = new Date().getHours();
    if (hour < 12) return "Good morning. I'm Ferni.";
    if (hour < 17) return "Good afternoon. I'm Ferni.";
    if (hour < 21) return "Good evening. I'm Ferni.";
    return "You're up late. I'm Ferni.";
  }

  // Initialize with time-aware greeting
  greeting.textContent = getTimeGreeting();

  // Auto-play greeting animation on load
  setTimeout(() => {
    greeting.classList.add('visible');
    voiceRings.classList.add('active');

    // Speak greeting (using Speech Synthesis for demo)
    if ('speechSynthesis' in window) {
      const utterance = new SpeechSynthesisUtterance(greeting.textContent);
      utterance.rate = 0.9;
      utterance.pitch = 1.0;
      utterance.onend = () => {
        voiceRings.classList.remove('active');
        setTimeout(() => {
          subtext.classList.add('visible');
        }, 300);
      };
      // Wait for voices to load
      setTimeout(() => {
        speechSynthesis.speak(utterance);
      }, 500);
    } else {
      setTimeout(() => {
        voiceRings.classList.remove('active');
        subtext.classList.add('visible');
      }, 2000);
    }
  }, 800);

  // Start voice interaction
  startBtn.addEventListener('click', () => {
    if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
      addTranscriptLine('system', 'Voice recognition is not supported in your browser. Try Chrome for the full experience.');
      return;
    }

    startBtn.classList.add('hidden');
    transcript.classList.add('visible');
    startListening();
  });

  function startListening() {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    recognition = new SpeechRecognition();
    recognition.continuous = true;
    recognition.interimResults = true;

    recognition.onstart = () => {
      isListening = true;
      listeningIndicator.classList.add('active');
      addTranscriptLine('system', 'Listening... speak freely.');
    };

    recognition.onresult = (event) => {
      let finalTranscript = '';
      let interimTranscript = '';

      for (let i = event.resultIndex; i < event.results.length; i++) {
        if (event.results[i].isFinal) {
          finalTranscript += event.results[i][0].transcript;
        } else {
          interimTranscript += event.results[i][0].transcript;
        }
      }

      if (finalTranscript) {
        handleUserSpeech(finalTranscript.trim());
      }
    };

    recognition.onerror = (event) => {
      console.error('Speech recognition error:', event.error);
      if (event.error !== 'no-speech') {
        addTranscriptLine('system', `Voice error: ${event.error}. Click avatar to try again.`);
      }
    };

    recognition.onend = () => {
      isListening = false;
      listeningIndicator.classList.remove('active');
      // Restart if we want continuous conversation
      if (isListening) {
        recognition.start();
      }
    };

    recognition.start();
  }

  function handleUserSpeech(text) {
    addTranscriptLine('user', text);

    // Find matching response
    const response = findResponse(text.toLowerCase());

    // Simulate Ferni thinking
    voiceRings.classList.add('active');

    setTimeout(() => {
      addTranscriptLine('ferni', response);
      speakResponse(response);
    }, 800);
  }

  function findResponse(text) {
    for (const r of ferniResponses) {
      if (new RegExp(r.trigger, 'i').test(text)) {
        return r.response;
      }
    }
    // Default thoughtful response
    const defaults = [
      "That's interesting. Tell me more about what that means to you.",
      "I'm curious - what feels most important about that right now?",
      "I hear you. What would feel like progress on that?",
      "That's worth exploring deeper. What's behind that feeling?",
    ];
    return defaults[Math.floor(Math.random() * defaults.length)];
  }

  function speakResponse(text) {
    if ('speechSynthesis' in window) {
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.rate = 0.9;
      utterance.pitch = 1.0;
      utterance.onend = () => {
        voiceRings.classList.remove('active');
      };
      speechSynthesis.speak(utterance);
    } else {
      setTimeout(() => voiceRings.classList.remove('active'), 2000);
    }
  }

  function addTranscriptLine(speaker, text) {
    const line = document.createElement('div');
    line.className = `transcript-line ${speaker}`;

    const speakerEl = document.createElement('span');
    speakerEl.className = 'transcript-speaker';
    speakerEl.textContent = speaker === 'ferni' ? 'Ferni:' : speaker === 'user' ? 'You:' : '';

    const textEl = document.createElement('span');
    textEl.className = 'transcript-text';
    textEl.textContent = text;

    if (speaker !== 'system') {
      line.appendChild(speakerEl);
    }
    line.appendChild(textEl);
    transcript.appendChild(line);

    // Scroll to bottom
    transcript.scrollTop = transcript.scrollHeight;
  }

  // Click avatar to restart listening
  avatar.addEventListener('click', () => {
    if (!isListening && recognition) {
      startListening();
    }
  });

  console.log('%c🎤 Voice-First Preview Loaded', 'color: #4a6741; font-weight: bold;');
})();
</script>
