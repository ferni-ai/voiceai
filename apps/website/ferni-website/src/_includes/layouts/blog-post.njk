<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Ferni Blog</title>
  <meta name="description" content="{{ description or excerpt or site.tagline }}">

  {# ====== PRECONNECT & PRELOAD ====== #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {# ====== FONTS ====== #}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">

  {# ====== FAVICONS ====== #}
  <link rel="icon" href="/images/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
  <meta name="theme-color" content="#4a6741">

  {# ====== STYLES ====== #}
  <link rel="stylesheet" href="/css/story-brand.css?v=20251231">
  <link rel="stylesheet" href="/css/blog-page.css?v=20251231">
  <link rel="stylesheet" href="/css/sections/footer.css?v=20251231">
  <link rel="stylesheet" href="/css/dark-mode.css?v=20251231">

  {# ====== OPEN GRAPH ====== #}
  <meta property="og:title" content="{{ title }} | Ferni Blog">
  <meta property="og:description" content="{{ description or excerpt or site.tagline }}">
  <meta property="og:image" content="https://ferni.ai{{ ogImage or '/images/og-blog.jpg' }}">
  <meta property="og:url" content="https://ferni.ai{{ page.url }}">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Ferni">

  {# ====== TWITTER CARD ====== #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@ferniAI">
  <meta name="twitter:title" content="{{ title }} | Ferni Blog">
  <meta name="twitter:description" content="{{ description or excerpt }}">
  <meta name="twitter:image" content="https://ferni.ai{{ ogImage or '/images/og-blog.jpg' }}">

  {# ====== CANONICAL ====== #}
  <link rel="canonical" href="https://ferni.ai{{ page.url }}">

  {# ====== ANALYTICS ====== #}
  {% if site.analytics.gaId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.gaId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analytics.gaId }}');
  </script>
  {% endif %}
</head>
<body class="blog-page blog-post-page">
  {# ====== SKIP LINK ====== #}
  <a href="#main-content" class="skip-link">Skip to main content</a>

  {# ====== NAVIGATION ====== #}
  <nav class="nav" id="nav" aria-label="Main navigation">
    <div class="nav__inner">
      <a href="/" class="nav__logo nav__logo--wordmark-only">
        <span class="nav__logo-text">Ferni</span>
      </a>

      <ul class="nav__links">
        <li><a href="/features/" class="nav__link">Features</a></li>
        <li><a href="/team/" class="nav__link">Team</a></li>
        <li><a href="/blog/" class="nav__link is-active">Blog</a></li>
        <li><a href="/about/" class="nav__link">About</a></li>
      </ul>

      <a href="{{ site.appUrl }}" class="nav__cta nav__cta--desktop">
        Get Started
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

      <button class="nav__hamburger" id="mobileMenuToggle" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  {# ====== MOBILE MENU ====== #}
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu__header">
      <span class="nav__logo-text">Ferni</span>
      <button class="mobile-menu__close" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <nav class="mobile-menu__nav">
      <a href="/features/">Features</a>
      <a href="/team/">Meet the Team</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>
    <div class="mobile-menu__cta">
      <a href="{{ site.appUrl }}" class="btn btn--primary btn--lg">
        Get Started Free
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  {# ====== MAIN CONTENT ====== #}
  <main id="main-content">
    <article class="blog-post">
      <header class="blog-post__header">
        <div class="container container-narrow">
          <a href="/blog/" class="blog-post__back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back to Blog
          </a>

          {% if category %}
          <span class="blog-post__category">{{ category }}</span>
          {% endif %}

          <h1 class="blog-post__title">{{ title }}</h1>

          <div class="blog-post__meta">
            {% if author %}
            <div class="blog-post__author">
              <div class="blog-post__author-avatar" style="background: {{ authorColor or 'var(--color-ferni)' }}">
                {% if not authorInitials or authorInitials == 'FE' %}<svg class="ferni-eyes-svg" viewBox="0 0 100 100"><ellipse cx="36" cy="50" rx="10" ry="12" fill="white"/><circle cx="33" cy="45" r="2.5" fill="white" opacity="0.9"/><ellipse cx="64" cy="50" rx="10" ry="12" fill="white"/><circle cx="61" cy="45" r="2.5" fill="white" opacity="0.9"/></svg>{% else %}{{ authorInitials }}{% endif %}
              </div>
              <div class="blog-post__author-info">
                <span class="blog-post__author-name">{{ author }}</span>
                {% if authorRole %}<span class="blog-post__author-role">{{ authorRole }}</span>{% endif %}
                <span class="blog-post__date">{{ date | date("MMMM d, yyyy") }}</span>
              </div>
            </div>
            {% endif %}

            {% if readTime %}
            <span class="blog-post__read-time">{{ readTime }} min read</span>
            {% endif %}
          </div>
        </div>
      </header>

      {% if image %}
      <div class="blog-post__hero">
        <div class="container">
          <img src="/images/blog/{{ image }}" alt="{{ imageAlt or title }}" class="blog-post__hero-image" loading="lazy">
        </div>
      </div>
      {% endif %}

      <div class="blog-post__content">
        <div class="container container-narrow">
          {{ content | safe }}
        </div>
      </div>

      <footer class="blog-post__footer">
        <div class="container container-narrow">
          <div class="blog-post__share">
            <span class="blog-post__share-label">Share this article</span>
            <div class="blog-post__share-buttons">
              <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url }}"
                 target="_blank" rel="noopener" class="blog-post__share-btn" aria-label="Share on Twitter">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url }}"
                 target="_blank" rel="noopener" class="blog-post__share-btn" aria-label="Share on LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="blog-post__cta">
            <h3>Ready to try Ferni?</h3>
            <p>Start a conversation with your AI life coach today. It's free.</p>
            <a href="{{ site.appUrl }}?utm_source=blog&utm_medium=web&utm_campaign={{ page.fileSlug }}" class="btn btn-primary">Start Free</a>
          </div>
        </div>
      </footer>
    </article>
  </main>

  {# ====== FOOTER ====== #}
  {% include "partials/home/footer.njk" %}

  {# ====== SCRIPTS ====== #}
  <script>
  (function() {
    'use strict';

    // Nav scroll effect
    const nav = document.getElementById('nav');
    if (nav) {
      window.addEventListener('scroll', () => {
        nav.classList.toggle('is-scrolled', window.scrollY > 50);
      }, { passive: true });
    }

    // Mobile menu
    const mobileToggle = document.getElementById('mobileMenuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileClose = document.querySelector('.mobile-menu__close');

    if (mobileToggle && mobileMenu) {
      mobileToggle.addEventListener('click', () => {
        mobileMenu.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      });

      if (mobileClose) {
        mobileClose.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      }

      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      });
    }
  })();
  </script>
</body>
</html>
