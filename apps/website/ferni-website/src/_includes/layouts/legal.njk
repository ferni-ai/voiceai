{% extends "layouts/base.njk" %}

{% block head %}
<style>
  .legal-page {
    padding: 140px 24px 100px;
    min-height: 100vh;
  }
  
  .legal-container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .legal-header {
    margin-bottom: var(--space-16, 64px);
  }
  
  .legal-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 56px);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: var(--space-4, 16px);
    letter-spacing: -0.02em;
  }
  
  .legal-updated {
    font-size: var(--text-caption, 13px);
    color: var(--color-text-muted);
  }
  
  .legal-content h2 {
    font-family: var(--font-display);
    font-size: var(--text-h3, 24px);
    font-weight: 700;
    color: var(--color-text);
    margin: var(--space-12, 48px) 0 var(--space-4, 16px);
  }
  
  .legal-content h2:first-child {
    margin-top: 0;
  }
  
  .legal-content p {
    font-size: var(--text-body-md, 16px);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-4, 16px);
  }
  
  .legal-content ul,
  .legal-content ol {
    margin: var(--space-4, 16px) 0 var(--space-6, 24px) var(--space-6, 24px);
    color: var(--color-text-secondary);
  }
  
  .legal-content li {
    font-size: var(--text-body-md, 16px);
    line-height: 1.8;
    margin-bottom: var(--space-2, 8px);
  }
  
  .legal-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  
  .legal-content a:hover {
    color: var(--color-accent-hover);
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2, 8px);
    font-size: var(--text-caption, 14px);
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: var(--space-10, 40px);
    transition: color 0.2s ease;
  }
  
  .back-link:hover {
    color: var(--color-accent);
  }
  
  .back-link svg {
    width: 16px;
    height: 16px;
  }
</style>
{% endblock %}

{% block content %}
<main class="legal-page">
  <div class="legal-container">
    <a href="/" class="back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to Home
    </a>
    
    <header class="legal-header">
      <h1 class="legal-title">{{ title }}</h1>
      {% if lastUpdated %}
      <p class="legal-updated">Last updated: {{ lastUpdated }}</p>
      {% endif %}
    </header>
    
    <div class="legal-content">
      {{ content | safe }}
    </div>
  </div>
</main>
{% endblock %}

