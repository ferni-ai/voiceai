<!DOCTYPE html>
<html lang="{{ locale or 'en' }}" dir="ltr">
<head>
  {% include "partials/head.njk" %}

  <!-- Developer Portal Styles - Cedar Night Theme -->
  <style>
    :root {
      /* Cedar Night Theme - Warm, earthy, grounded */
      --dev-bg: #584840;
      --dev-bg-deep: #4a3a35;
      --dev-bg-darker: #3a2e2a;
      --dev-surface: #70605a;
      --dev-surface-elevated: #7a6a64;
      --dev-border: rgba(250, 246, 240, 0.12);
      --dev-border-strong: rgba(250, 246, 240, 0.20);

      /* Gold accent - warm, not neon */
      --dev-accent: #d4a84a;
      --dev-accent-hover: #e0bc6a;
      --dev-accent-subtle: rgba(212, 168, 74, 0.15);

      /* Warm text colors */
      --dev-text: #faf6f0;
      --dev-text-secondary: #f0ebe4;
      --dev-text-muted: #d8d0c8;

      /* Code blocks */
      --dev-code-bg: #2a2420;
      --dev-code-border: rgba(250, 246, 240, 0.08);

      /* Ferni green for brand touches */
      --dev-ferni: #4a6741;
      --dev-ferni-light: #6b8760;

      /* Persona accent colors for variety */
      --dev-peter: #3a6b73;
      --dev-peter-light: #5a8b93;
      --dev-alex: #5a6b8a;
      --dev-alex-light: #7a8baa;
      --dev-maya: #a67a6a;
      --dev-maya-light: #c69a8a;
      --dev-jordan: #c4856a;
      --dev-jordan-light: #e4a58a;
      --dev-nayan: #b8956a;
      --dev-nayan-light: #d8b58a;
      --dev-moss: #5a7a3d;
      --dev-moss-light: #7a9a5d;
    }

    * {
      box-sizing: border-box;
    }

    body {
      background: var(--dev-bg);
      color: var(--dev-text);
      font-family: 'Plus Jakarta Sans', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      margin: 0;
      padding: 0;
      min-height: 100vh;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a {
      color: var(--dev-accent);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    a:hover {
      color: var(--dev-accent-hover);
    }

    /* Navigation */
    .dev-nav {
      background: var(--dev-bg-deep);
      border-bottom: 1px solid var(--dev-border);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .dev-nav-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--dev-text);
      font-weight: 600;
      font-size: 1.1rem;
    }

    .dev-nav-brand svg {
      width: 32px;
      height: 32px;
    }

    .dev-nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .dev-nav-links a {
      color: var(--dev-text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s;
    }

    .dev-nav-links a:hover,
    .dev-nav-links a.active {
      color: var(--dev-accent);
    }

    /* Hero Section */
    .dev-hero {
      background: linear-gradient(180deg, var(--dev-bg-deep) 0%, var(--dev-bg) 100%);
      padding: 5rem 2rem 4rem;
      text-align: center;
      border-bottom: 1px solid var(--dev-border);
    }

    .dev-hero-eyebrow {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--dev-accent);
      margin-bottom: 1.5rem;
    }

    .dev-hero h1 {
      font-size: clamp(2.25rem, 4.5vw, 3.5rem);
      font-weight: 700;
      line-height: 1.15;
      margin: 0 0 1.25rem;
      color: var(--dev-text);
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }

    .dev-hero p {
      font-size: 1.15rem;
      color: var(--dev-text-muted);
      max-width: 550px;
      margin: 0 auto 2rem;
      line-height: 1.65;
    }

    .dev-hero-ctas {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Buttons */
    .btn-dev {
      padding: 0.875rem 1.75rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: none;
      cursor: pointer;
    }

    .btn-dev-primary {
      background: var(--dev-accent);
      color: var(--dev-bg-deep);
    }

    .btn-dev-primary:hover {
      background: var(--dev-accent-hover);
      transform: translateY(-1px);
      color: var(--dev-bg-deep);
    }

    .btn-dev-secondary {
      background: transparent;
      color: var(--dev-text);
      border: 1px solid var(--dev-border-strong);
    }

    .btn-dev-secondary:hover {
      background: var(--dev-surface);
      border-color: var(--dev-accent);
      color: var(--dev-text);
    }

    /* Stats Section */
    .dev-stats {
      background: var(--dev-surface);
      padding: 2.5rem 2rem;
      border-bottom: 1px solid var(--dev-border);
    }

    .dev-stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 2rem;
      max-width: 800px;
      margin: 0 auto;
      text-align: center;
    }

    .dev-stat-value {
      font-size: 2rem;
      font-weight: 700;
      color: var(--dev-accent);
      font-family: 'JetBrains Mono', monospace;
    }

    .dev-stat-label {
      font-size: 0.85rem;
      color: var(--dev-text-muted);
      margin-top: 0.25rem;
    }

    /* Sections */
    .dev-section {
      padding: 4.5rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .dev-section-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .dev-section-header h2 {
      font-size: 1.875rem;
      font-weight: 700;
      color: var(--dev-text);
      margin: 0 0 0.75rem;
    }

    .dev-section-header p {
      font-size: 1.05rem;
      color: var(--dev-text-muted);
      max-width: 500px;
      margin: 0 auto;
    }

    /* Cards Grid */
    .dev-cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
    }

    .dev-card {
      background: var(--dev-surface);
      border: 1px solid var(--dev-border);
      border-radius: 12px;
      padding: 1.75rem;
      transition: all 0.25s ease;
      text-decoration: none;
      color: inherit;
    }

    .dev-card:hover {
      border-color: var(--dev-accent);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }

    .dev-card-icon {
      width: 44px;
      height: 44px;
      background: var(--dev-accent-subtle);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.25rem;
      color: var(--dev-accent);
    }

    .dev-card h3 {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--dev-text);
      margin: 0 0 0.5rem;
    }

    .dev-card p {
      font-size: 0.9rem;
      color: var(--dev-text-muted);
      line-height: 1.55;
      margin: 0 0 1rem;
    }

    .dev-card-link {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--dev-accent);
    }

    /* Code Preview */
    .dev-code-section {
      background: var(--dev-surface);
      padding: 4.5rem 2rem;
      border-top: 1px solid var(--dev-border);
      border-bottom: 1px solid var(--dev-border);
    }

    .dev-code-container {
      max-width: 800px;
      margin: 0 auto;
    }

    .dev-code-block {
      background: var(--dev-code-bg);
      border: 1px solid var(--dev-code-border);
      border-radius: 12px;
      overflow: hidden;
    }

    .dev-code-header {
      background: rgba(0, 0, 0, 0.2);
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      border-bottom: 1px solid var(--dev-code-border);
    }

    .dev-code-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    .dev-code-dot--red { background: #ff6b6b; }
    .dev-code-dot--yellow { background: #ffd93d; }
    .dev-code-dot--green { background: #6bcb77; }

    .dev-code-title {
      margin-left: auto;
      font-size: 0.75rem;
      color: var(--dev-text-muted);
      font-family: 'JetBrains Mono', monospace;
    }

    .dev-code-block pre {
      margin: 0;
      padding: 1.25rem;
      overflow-x: auto;
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 0.85rem;
      line-height: 1.65;
      color: var(--dev-text-secondary);
    }

    .dev-code-block .comment { color: #8b9a8b; }
    .dev-code-block .string { color: #d4a84a; }
    .dev-code-block .keyword { color: #c4856a; }
    .dev-code-block .function { color: #6b8760; }

    /* Resources */
    .dev-resources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .dev-resource {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem;
      background: var(--dev-surface);
      border: 1px solid var(--dev-border);
      border-radius: 10px;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .dev-resource:hover {
      border-color: var(--dev-accent);
      background: var(--dev-surface-elevated);
    }

    .dev-resource-icon {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      background: var(--dev-accent-subtle);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--dev-accent);
      font-size: 1rem;
    }

    .dev-resource-content h4 {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--dev-text);
      margin: 0 0 0.25rem;
    }

    .dev-resource-content p {
      font-size: 0.8rem;
      color: var(--dev-text-muted);
      margin: 0;
      line-height: 1.45;
    }

    /* Blog Preview */
    .dev-blog-section {
      background: var(--dev-surface);
      padding: 4.5rem 2rem;
      border-top: 1px solid var(--dev-border);
    }

    .dev-blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .dev-blog-card {
      background: var(--dev-bg);
      border: 1px solid var(--dev-border);
      border-radius: 12px;
      padding: 1.5rem;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .dev-blog-card:hover {
      border-color: var(--dev-accent);
    }

    .dev-blog-category {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--dev-accent);
      margin-bottom: 0.6rem;
    }

    .dev-blog-card h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--dev-text);
      margin: 0 0 0.4rem;
      line-height: 1.35;
    }

    .dev-blog-card p {
      font-size: 0.85rem;
      color: var(--dev-text-muted);
      margin: 0;
      line-height: 1.5;
    }

    /* Footer */
    .dev-footer {
      background: var(--dev-bg-deep);
      border-top: 1px solid var(--dev-border);
      padding: 2rem;
      text-align: center;
    }

    .dev-footer p {
      color: var(--dev-text-muted);
      font-size: 0.85rem;
      margin: 0;
    }

    .dev-footer a {
      color: var(--dev-accent);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .dev-nav {
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
      }

      .dev-nav-links {
        gap: 1.25rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .dev-hero {
        padding: 3.5rem 1.5rem 3rem;
      }

      .dev-hero-ctas {
        flex-direction: column;
        align-items: center;
      }

      .btn-dev {
        width: 100%;
        max-width: 260px;
        justify-content: center;
      }

      .dev-section {
        padding: 3rem 1.5rem;
      }

      .dev-stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  {% block head %}{% endblock %}
</head>
<body>
  <main id="main-content" role="main">
    {{ content | safe }}
  </main>

  {% block scripts %}{% endblock %}
</body>
</html>
