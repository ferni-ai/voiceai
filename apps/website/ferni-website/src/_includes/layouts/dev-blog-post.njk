<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Ferni Developer Blog</title>
  <meta name="description" content="{{ description or excerpt or 'Developer tutorials, updates, and guides for the Ferni Developer Platform' }}">

  {# ====== FONTS ====== #}
  {% set includeMonoFont = true %}
  {% include "partials/fonts.njk" %}

  {# ====== FAVICONS ====== #}
  <link rel="icon" href="/images/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
  <meta name="theme-color" content="#584840">

  {# ====== CEDAR NIGHT DEVELOPER BLOG STYLES ====== #}
  <style>
    :root {
      /* Cedar Night Theme - Warm, earthy, grounded */
      --dev-bg: #584840;
      --dev-bg-deep: #4a3a35;
      --dev-bg-darker: #3a2e2a;
      --dev-surface: #70605a;
      --dev-surface-elevated: #7a6a64;
      --dev-border: rgba(250, 246, 240, 0.12);
      --dev-border-strong: rgba(250, 246, 240, 0.20);

      /* Gold accent - warm, not neon */
      --dev-accent: #d4a84a;
      --dev-accent-hover: #e0bc6a;
      --dev-accent-subtle: rgba(212, 168, 74, 0.15);

      /* Warm text colors */
      --dev-text: #faf6f0;
      --dev-text-secondary: #f0ebe4;
      --dev-text-muted: #d8d0c8;

      /* Code blocks - darker for contrast */
      --dev-code-bg: #2a2420;
      --dev-code-border: rgba(250, 246, 240, 0.08);
      --dev-code-header: #3a2e2a;

      /* Syntax highlighting - Cedar Night palette */
      --syntax-keyword: #d4a84a;
      --syntax-string: #c4a070;
      --syntax-function: #8fb573;
      --syntax-comment: #8a7a70;
      --syntax-number: #e0bc6a;
      --syntax-operator: #d8d0c8;
      --syntax-class: #c4856a;
      --syntax-property: #8fb573;
      --syntax-punctuation: #a09080;

      /* Ferni green for brand touches */
      --dev-ferni: #4a6741;
      --dev-ferni-light: #6b8760;

      /* Persona accent colors */
      --dev-peter: #3a6b73;
      --dev-alex: #5a6b8a;
      --dev-maya: #a67a6a;
      --dev-jordan: #c4856a;
      --dev-nayan: #b8956a;
    }

    * {
      box-sizing: border-box;
    }

    body {
      background: var(--dev-bg);
      color: var(--dev-text);
      font-family: 'Plus Jakarta Sans', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      margin: 0;
      padding: 0;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    a {
      color: var(--dev-accent);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    a:hover {
      color: var(--dev-accent-hover);
    }

    /* ====== NAVIGATION ====== */
    .dev-nav {
      background: var(--dev-bg-deep);
      border-bottom: 1px solid var(--dev-border);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .dev-nav-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--dev-text);
      font-weight: 600;
      font-size: 1.1rem;
    }

    .dev-nav-brand svg {
      width: 32px;
      height: 32px;
    }

    .dev-nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .dev-nav-links a {
      color: var(--dev-text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s;
    }

    .dev-nav-links a:hover,
    .dev-nav-links a.active {
      color: var(--dev-accent);
    }

    .dev-nav-cta {
      background: var(--dev-accent);
      color: var(--dev-bg-deep);
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.875rem;
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      transition: all 0.2s;
    }

    .dev-nav-cta:hover {
      background: var(--dev-accent-hover);
      color: var(--dev-bg-deep);
    }

    /* ====== ARTICLE HEADER ====== */
    .article-header {
      background: linear-gradient(180deg, var(--dev-bg-deep) 0%, var(--dev-bg) 100%);
      padding: 3rem 2rem 4rem;
      border-bottom: 1px solid var(--dev-border);
    }

    .article-header-inner {
      max-width: 720px;
      margin: 0 auto;
    }

    .article-back {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--dev-text-muted);
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      transition: color 0.2s;
    }

    .article-back:hover {
      color: var(--dev-accent);
    }

    .article-category {
      display: inline-block;
      background: var(--dev-accent);
      color: var(--dev-bg-deep);
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 1rem;
    }

    .article-title {
      font-size: clamp(2rem, 4vw, 2.75rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--dev-text);
      margin: 0 0 1.5rem;
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .article-author {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .article-author-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.875rem;
      color: var(--dev-bg-deep);
    }

    .article-author-info {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }

    .article-author-name {
      font-weight: 600;
      color: var(--dev-text);
      font-size: 0.95rem;
    }

    .article-author-role {
      color: var(--dev-text-muted);
      font-size: 0.8rem;
    }

    .article-date {
      color: var(--dev-text-muted);
      font-size: 0.875rem;
    }

    .article-read-time {
      color: var(--dev-text-muted);
      font-size: 0.875rem;
      display: flex;
      align-items: center;
      gap: 0.375rem;
    }

    /* ====== ARTICLE CONTENT ====== */
    .article-content {
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 2rem 4rem;
    }

    .article-content h1 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--dev-text);
      margin: 3rem 0 1.25rem;
      line-height: 1.3;
    }

    .article-content h2 {
      font-size: 1.625rem;
      font-weight: 700;
      color: var(--dev-text);
      margin: 2.5rem 0 1rem;
      padding-top: 1rem;
      border-top: 1px solid var(--dev-border);
      line-height: 1.3;
    }

    .article-content h2:first-child {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }

    .article-content h3 {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--dev-text);
      margin: 2rem 0 0.75rem;
      line-height: 1.4;
    }

    .article-content h4 {
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--dev-text-secondary);
      margin: 1.5rem 0 0.5rem;
    }

    .article-content p {
      color: var(--dev-text-secondary);
      line-height: 1.8;
      margin: 0 0 1.25rem;
      font-size: 1.0625rem;
    }

    .article-content strong {
      color: var(--dev-text);
      font-weight: 600;
    }

    .article-content em {
      font-style: italic;
    }

    .article-content ul,
    .article-content ol {
      margin: 0 0 1.5rem;
      padding-left: 1.5rem;
    }

    .article-content li {
      color: var(--dev-text-secondary);
      line-height: 1.7;
      margin-bottom: 0.5rem;
      font-size: 1.0625rem;
    }

    .article-content li::marker {
      color: var(--dev-accent);
    }

    /* ====== CODE BLOCKS - Professional Stripe-like styling ====== */
    .article-content pre {
      position: relative;
      background: var(--dev-code-bg);
      border: 1px solid var(--dev-code-border);
      border-radius: 12px;
      margin: 1.75rem 0;
      padding: 0;
      overflow: hidden;
    }

    .article-content pre code {
      display: block;
      padding: 1.25rem 1.5rem;
      overflow-x: auto;
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, monospace;
      font-size: 0.875rem;
      line-height: 1.7;
      color: var(--dev-text-secondary);
      background: transparent;
      tab-size: 2;
    }

    /* Code block header with language label */
    .article-content pre::before {
      content: attr(data-lang);
      display: block;
      background: var(--dev-code-header);
      padding: 0.5rem 1rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--dev-text-muted);
      border-bottom: 1px solid var(--dev-code-border);
    }

    .article-content pre:not([data-lang])::before {
      display: none;
    }

    .article-content pre:not([data-lang]) code {
      padding-top: 1.25rem;
    }

    /* Inline code */
    .article-content code {
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      background: var(--dev-code-bg);
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      font-size: 0.875em;
      color: var(--dev-accent);
      border: 1px solid var(--dev-code-border);
    }

    /* Syntax highlighting - Cedar Night theme */
    .token.comment,
    .token.prolog,
    .token.doctype,
    .token.cdata {
      color: var(--syntax-comment);
      font-style: italic;
    }

    .token.punctuation {
      color: var(--syntax-punctuation);
    }

    .token.property,
    .token.tag,
    .token.constant,
    .token.symbol,
    .token.deleted {
      color: var(--syntax-property);
    }

    .token.boolean,
    .token.number {
      color: var(--syntax-number);
    }

    .token.selector,
    .token.attr-name,
    .token.string,
    .token.char,
    .token.builtin,
    .token.inserted {
      color: var(--syntax-string);
    }

    .token.operator,
    .token.entity,
    .token.url,
    .language-css .token.string,
    .style .token.string,
    .token.variable {
      color: var(--syntax-operator);
    }

    .token.atrule,
    .token.attr-value,
    .token.keyword {
      color: var(--syntax-keyword);
    }

    .token.function,
    .token.class-name {
      color: var(--syntax-function);
    }

    .token.regex,
    .token.important {
      color: var(--syntax-class);
    }

    .token.important,
    .token.bold {
      font-weight: bold;
    }

    .token.italic {
      font-style: italic;
    }

    /* ====== TABLES - Professional data display ====== */
    .article-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.75rem 0;
      font-size: 0.9rem;
      background: var(--dev-surface);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--dev-border);
    }

    .article-content thead {
      background: var(--dev-bg-deep);
    }

    .article-content th {
      color: var(--dev-text);
      padding: 0.875rem 1rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-bottom: 1px solid var(--dev-border);
    }

    .article-content td {
      padding: 0.875rem 1rem;
      color: var(--dev-text-secondary);
      border-bottom: 1px solid var(--dev-border);
    }

    .article-content tr:last-child td {
      border-bottom: none;
    }

    .article-content tbody tr:hover {
      background: var(--dev-surface-elevated);
    }

    /* ====== BLOCKQUOTES ====== */
    .article-content blockquote {
      background: var(--dev-surface);
      border-left: 4px solid var(--dev-accent);
      border-radius: 0 8px 8px 0;
      padding: 1.25rem 1.5rem;
      margin: 1.75rem 0;
    }

    .article-content blockquote p {
      margin: 0;
      color: var(--dev-text);
      font-size: 1rem;
      line-height: 1.7;
    }

    .article-content blockquote p:last-child {
      margin-bottom: 0;
    }

    /* ====== HORIZONTAL RULES ====== */
    .article-content hr {
      border: none;
      height: 1px;
      background: var(--dev-border);
      margin: 3rem 0;
    }

    /* ====== IMAGES ====== */
    .article-content img {
      max-width: 100%;
      height: auto;
      border-radius: 12px;
      border: 1px solid var(--dev-border);
      margin: 1.5rem 0;
    }

    /* ====== CALLOUT BOXES ====== */
    .callout {
      background: var(--dev-surface);
      border: 1px solid var(--dev-border);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      margin: 1.75rem 0;
    }

    .callout--tip {
      border-left: 4px solid var(--dev-ferni);
    }

    .callout--warning {
      border-left: 4px solid var(--dev-nayan);
    }

    .callout--info {
      border-left: 4px solid var(--dev-alex);
    }

    .callout p {
      margin: 0;
    }

    /* ====== ARTICLE FOOTER ====== */
    .article-footer {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
    }

    .article-share {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.5rem 0;
      border-top: 1px solid var(--dev-border);
    }

    .article-share-label {
      color: var(--dev-text-muted);
      font-size: 0.875rem;
    }

    .article-share-buttons {
      display: flex;
      gap: 0.75rem;
    }

    .article-share-btn {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: var(--dev-surface);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--dev-text-muted);
      transition: all 0.2s;
    }

    .article-share-btn:hover {
      background: var(--dev-surface-elevated);
      color: var(--dev-accent);
    }

    /* ====== CTA BOX ====== */
    .article-cta {
      background: linear-gradient(135deg, var(--dev-surface) 0%, var(--dev-bg-deep) 100%);
      border: 1px solid var(--dev-border);
      border-radius: 16px;
      padding: 2.5rem;
      text-align: center;
      margin-top: 2rem;
    }

    .article-cta h3 {
      color: var(--dev-text);
      font-size: 1.375rem;
      margin: 0 0 0.5rem;
    }

    .article-cta p {
      color: var(--dev-text-muted);
      margin: 0 0 1.5rem;
      font-size: 1rem;
    }

    .article-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--dev-accent);
      color: var(--dev-bg-deep);
      padding: 0.875rem 1.75rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.2s;
    }

    .article-cta-btn:hover {
      background: var(--dev-accent-hover);
      transform: translateY(-1px);
      color: var(--dev-bg-deep);
    }

    /* ====== RELATED POSTS ====== */
    .related-posts {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--dev-border);
    }

    .related-posts h4 {
      color: var(--dev-text-muted);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0 0 1rem;
    }

    .related-posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .related-post {
      background: var(--dev-surface);
      border: 1px solid var(--dev-border);
      border-radius: 12px;
      padding: 1.25rem;
      text-decoration: none;
      transition: all 0.2s;
    }

    .related-post:hover {
      border-color: var(--dev-accent);
      transform: translateY(-2px);
    }

    .related-post-category {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--dev-accent);
      margin-bottom: 0.375rem;
    }

    .related-post-title {
      color: var(--dev-text);
      font-weight: 600;
      font-size: 0.95rem;
      line-height: 1.4;
    }

    /* ====== FOOTER ====== */
    .dev-footer {
      background: var(--dev-bg-deep);
      border-top: 1px solid var(--dev-border);
      padding: 2rem;
      text-align: center;
    }

    .dev-footer p {
      color: var(--dev-text-muted);
      font-size: 0.85rem;
      margin: 0;
    }

    /* ====== RESPONSIVE ====== */
    @media (max-width: 768px) {
      .dev-nav {
        padding: 1rem;
      }

      .dev-nav-links {
        display: none;
      }

      .article-header {
        padding: 2rem 1.5rem 3rem;
      }

      .article-title {
        font-size: 1.75rem;
      }

      .article-content {
        padding: 2rem 1.5rem 3rem;
      }

      .article-content pre code {
        font-size: 0.8rem;
        padding: 1rem;
      }

      .article-footer {
        padding: 0 1.5rem 3rem;
      }

      .article-cta {
        padding: 1.75rem;
      }
    }
  </style>

  {# ====== OPEN GRAPH ====== #}
  <meta property="og:title" content="{{ title }} | Ferni Developer Blog">
  <meta property="og:description" content="{{ description or excerpt }}">
  <meta property="og:image" content="https://ferni.ai{{ ogImage or '/images/og-dev-blog.jpg' }}">
  <meta property="og:url" content="https://ferni.ai{{ page.url }}">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Ferni Developers">

  {# ====== TWITTER CARD ====== #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@ferniAI">
  <meta name="twitter:title" content="{{ title }} | Ferni Developer Blog">
  <meta name="twitter:description" content="{{ description or excerpt }}">
  <meta name="twitter:image" content="https://ferni.ai{{ ogImage or '/images/og-dev-blog.jpg' }}">

  {# ====== CANONICAL ====== #}
  <link rel="canonical" href="https://ferni.ai{{ page.url }}">

  {# ====== SYNTAX HIGHLIGHTING ====== #}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css">
</head>
<body>
  {# ====== NAVIGATION ====== #}
  <nav class="dev-nav">
    <a href="/developers/" class="dev-nav-brand">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="45" fill="var(--dev-ferni)"/>
        <ellipse cx="35" cy="45" rx="8" ry="10" fill="#faf6f0"/>
        <ellipse cx="65" cy="45" rx="8" ry="10" fill="#faf6f0"/>
        <path d="M32 68 Q50 80 68 68" stroke="#faf6f0" stroke-width="4" stroke-linecap="round" fill="none"/>
      </svg>
      Ferni <span style="font-weight: 400; opacity: 0.7;">Developers</span>
    </a>

    <ul class="dev-nav-links">
      <li><a href="/developers/">Docs</a></li>
      <li><a href="/developers/api/">API</a></li>
      <li><a href="/developers/blog/" class="active">Blog</a></li>
      <li><a href="https://github.com/ferni-ai" target="_blank" rel="noopener">GitHub</a></li>
    </ul>

    <a href="{{ site.appUrl }}" class="dev-nav-cta">
      Console
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </nav>

  <main>
    <article>
      {# ====== HEADER ====== #}
      <header class="article-header">
        <div class="article-header-inner">
          <a href="/developers/blog/" class="article-back">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Developer Blog
          </a>

          {% if category %}
          <span class="article-category">{{ category }}</span>
          {% endif %}

          <h1 class="article-title">{{ title }}</h1>

          <div class="article-meta">
            {% if author %}
            <div class="article-author">
              <div class="article-author-avatar" style="background: {{ authorColor or 'var(--dev-accent)' }};">
                {% if authorInitials %}{{ authorInitials }}{% else %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                {% endif %}
              </div>
              <div class="article-author-info">
                <span class="article-author-name">{{ author }}</span>
                {% if authorRole %}<span class="article-author-role">{{ authorRole }}</span>{% endif %}
              </div>
            </div>
            {% endif %}

            <span class="article-date">{{ date | date("MMMM d, yyyy") }}</span>

            {% if readTime %}
            <span class="article-read-time">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
              {{ readTime }} min read
            </span>
            {% endif %}
          </div>
        </div>
      </header>

      {# ====== HERO IMAGE ====== #}
      {% if image %}
      <div style="max-width: 960px; margin: 0 auto; padding: 0 2rem;">
        <img src="/images/dev-blog/{{ image }}" alt="{{ imageAlt or title }}" loading="lazy" style="width: 100%; border-radius: 12px; border: 1px solid var(--dev-border); margin-top: -2rem;">
      </div>
      {% endif %}

      {# ====== CONTENT ====== #}
      <div class="article-content">
        {{ content | safe }}
      </div>

      {# ====== FOOTER ====== #}
      <footer class="article-footer">
        <div class="article-share">
          <span class="article-share-label">Share</span>
          <div class="article-share-buttons">
            <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url }}"
               target="_blank" rel="noopener" class="article-share-btn" aria-label="Share on Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url }}"
               target="_blank" rel="noopener" class="article-share-btn" aria-label="Share on LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="article-cta">
          <h3>Ready to build?</h3>
          <p>Start integrating the Ferni Developer Platform today.</p>
          <a href="/developers/getting-started/" class="article-cta-btn">
            Get Started
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </footer>
    </article>
  </main>

  {# ====== FOOTER ====== #}
  <footer class="dev-footer">
    <p>Ferni Developers. Built with care in San Francisco.</p>
  </footer>

  {# ====== SCRIPTS ====== #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-bash.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-javascript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-typescript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-json.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-go.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-markdown.min.js"></script>
  <script>
  (function() {
    'use strict';

    // Add language labels to code blocks
    document.querySelectorAll('pre code').forEach(function(code) {
      var pre = code.parentElement;
      var classes = code.className.split(' ');
      for (var i = 0; i < classes.length; i++) {
        if (classes[i].startsWith('language-')) {
          var lang = classes[i].replace('language-', '').toUpperCase();
          if (lang === 'JS') lang = 'JavaScript';
          if (lang === 'TS') lang = 'TypeScript';
          if (lang === 'BASH' || lang === 'SH') lang = 'Shell';
          if (lang === 'PY') lang = 'Python';
          pre.setAttribute('data-lang', lang);
          break;
        }
      }
    });

    // Highlight code
    if (typeof Prism !== 'undefined') {
      Prism.highlightAll();
    }
  })();
  </script>
</body>
</html>
