<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Ferni Developer Blog</title>
  <meta name="description" content="{{ description or excerpt or 'Developer tutorials, updates, and guides for the Ferni Developer Platform' }}">

  {# ====== FONTS (Single Source of Truth, with Mono for code) ====== #}
  {% set includeMonoFont = true %}
  {% include "partials/fonts.njk" %}

  {# ====== FAVICONS ====== #}
  <link rel="icon" href="/images/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
  <meta name="theme-color" content="#0f172a">

  {# ====== STYLES ====== #}
  <link rel="stylesheet" href="/css/story-brand.css?v=20260111">
  <link rel="stylesheet" href="/css/blog-page.css?v=20260111">
  <link rel="stylesheet" href="/css/sections/footer.css?v=20260111">
  <link rel="stylesheet" href="/css/dark-mode.css?v=20260111">

  {# ====== DEV BLOG SPECIFIC STYLES ====== #}
  <style>
    :root {
      --dev-bg: #0f172a;
      --dev-surface: #1e293b;
      --dev-border: #334155;
      --dev-accent: #38bdf8;
      --dev-accent-hover: #7dd3fc;
      --dev-success: #4ade80;
      --dev-warning: #fbbf24;
      --dev-error: #f87171;
      --dev-code-bg: #1e1e2e;
      --dev-text: #e2e8f0;
      --dev-text-muted: #94a3b8;
    }

    body.dev-blog {
      background: var(--dev-bg);
      color: var(--dev-text);
    }

    .dev-blog .blog-post__header {
      background: linear-gradient(180deg, var(--dev-surface) 0%, var(--dev-bg) 100%);
      border-bottom: 1px solid var(--dev-border);
    }

    .dev-blog .blog-post__back {
      color: var(--dev-text-muted);
    }

    .dev-blog .blog-post__back:hover {
      color: var(--dev-accent);
    }

    .dev-blog .blog-post__category {
      background: var(--dev-accent);
      color: var(--dev-bg);
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .dev-blog .blog-post__title {
      color: var(--dev-text);
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .dev-blog .blog-post__meta {
      color: var(--dev-text-muted);
    }

    .dev-blog .blog-post__author-avatar {
      background: var(--dev-accent) !important;
    }

    .dev-blog .blog-post__author-name {
      color: var(--dev-text);
    }

    .dev-blog .blog-post__author-role,
    .dev-blog .blog-post__date,
    .dev-blog .blog-post__read-time {
      color: var(--dev-text-muted);
    }

    .dev-blog .blog-post__content {
      background: var(--dev-bg);
    }

    .dev-blog .blog-post__content h2,
    .dev-blog .blog-post__content h3,
    .dev-blog .blog-post__content h4 {
      color: var(--dev-text);
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .dev-blog .blog-post__content p,
    .dev-blog .blog-post__content li {
      color: var(--dev-text-muted);
      line-height: 1.8;
    }

    .dev-blog .blog-post__content a {
      color: var(--dev-accent);
    }

    .dev-blog .blog-post__content a:hover {
      color: var(--dev-accent-hover);
    }

    .dev-blog .blog-post__content strong {
      color: var(--dev-text);
    }

    /* Code blocks - developer-focused styling */
    .dev-blog .blog-post__content pre {
      background: var(--dev-code-bg);
      border: 1px solid var(--dev-border);
      border-radius: 0.75rem;
      padding: 1.25rem;
      overflow-x: auto;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.875rem;
      line-height: 1.6;
      margin: 1.5rem 0;
    }

    .dev-blog .blog-post__content code {
      font-family: 'JetBrains Mono', monospace;
      background: var(--dev-code-bg);
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      font-size: 0.875em;
      color: var(--dev-accent);
    }

    .dev-blog .blog-post__content pre code {
      background: transparent;
      padding: 0;
      color: var(--dev-text);
    }

    /* Tables */
    .dev-blog .blog-post__content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-size: 0.875rem;
    }

    .dev-blog .blog-post__content th {
      background: var(--dev-surface);
      color: var(--dev-text);
      padding: 0.75rem 1rem;
      text-align: left;
      font-weight: 600;
      border-bottom: 1px solid var(--dev-border);
    }

    .dev-blog .blog-post__content td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--dev-border);
      color: var(--dev-text-muted);
    }

    .dev-blog .blog-post__content tr:hover td {
      background: var(--dev-surface);
    }

    /* Blockquotes */
    .dev-blog .blog-post__content blockquote {
      border-left: 4px solid var(--dev-accent);
      background: var(--dev-surface);
      padding: 1rem 1.5rem;
      margin: 1.5rem 0;
      border-radius: 0 0.5rem 0.5rem 0;
    }

    .dev-blog .blog-post__content blockquote p {
      margin: 0;
      color: var(--dev-text);
    }

    /* API badges */
    .api-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem 0.5rem;
      border-radius: 0.25rem;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
    }

    .api-badge--get {
      background: rgba(74, 222, 128, 0.1);
      color: var(--dev-success);
    }

    .api-badge--post {
      background: rgba(56, 189, 248, 0.1);
      color: var(--dev-accent);
    }

    .api-badge--put {
      background: rgba(251, 191, 36, 0.1);
      color: var(--dev-warning);
    }

    .api-badge--delete {
      background: rgba(248, 113, 113, 0.1);
      color: var(--dev-error);
    }

    /* Footer CTA */
    .dev-blog .blog-post__cta {
      background: var(--dev-surface);
      border: 1px solid var(--dev-border);
      border-radius: 1rem;
      padding: 2rem;
      text-align: center;
      margin-top: 3rem;
    }

    .dev-blog .blog-post__cta h3 {
      color: var(--dev-text);
      margin-bottom: 0.5rem;
    }

    .dev-blog .blog-post__cta p {
      color: var(--dev-text-muted);
      margin-bottom: 1.5rem;
    }

    .dev-blog .blog-post__cta .btn-primary {
      background: var(--dev-accent);
      color: var(--dev-bg);
      font-weight: 600;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      text-decoration: none;
      display: inline-block;
      transition: background 0.2s;
    }

    .dev-blog .blog-post__cta .btn-primary:hover {
      background: var(--dev-accent-hover);
    }

    /* Share buttons */
    .dev-blog .blog-post__share-label {
      color: var(--dev-text-muted);
    }

    .dev-blog .blog-post__share-btn {
      color: var(--dev-text-muted);
      transition: color 0.2s;
    }

    .dev-blog .blog-post__share-btn:hover {
      color: var(--dev-accent);
    }

    /* Nav */
    .dev-blog .nav {
      background: var(--dev-bg);
      border-bottom: 1px solid var(--dev-border);
    }

    .dev-blog .nav__link {
      color: var(--dev-text-muted);
    }

    .dev-blog .nav__link:hover,
    .dev-blog .nav__link.is-active {
      color: var(--dev-text);
    }

    .dev-blog .nav__cta {
      background: var(--dev-accent);
      color: var(--dev-bg);
    }

    /* Series navigation */
    .series-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--dev-border);
    }

    .series-nav__link {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      color: var(--dev-text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .series-nav__link:hover {
      color: var(--dev-accent);
    }

    .series-nav__label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .series-nav__title {
      font-weight: 600;
      color: var(--dev-text);
    }
  </style>

  {# ====== OPEN GRAPH ====== #}
  <meta property="og:title" content="{{ title }} | Ferni Developer Blog">
  <meta property="og:description" content="{{ description or excerpt }}">
  <meta property="og:image" content="https://ferni.ai{{ ogImage or '/images/og-dev-blog.jpg' }}">
  <meta property="og:url" content="https://ferni.ai{{ page.url }}">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Ferni Developers">

  {# ====== TWITTER CARD ====== #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@ferniAI">
  <meta name="twitter:title" content="{{ title }} | Ferni Developer Blog">
  <meta name="twitter:description" content="{{ description or excerpt }}">
  <meta name="twitter:image" content="https://ferni.ai{{ ogImage or '/images/og-dev-blog.jpg' }}">

  {# ====== CANONICAL ====== #}
  <link rel="canonical" href="https://ferni.ai{{ page.url }}">

  {# ====== SYNTAX HIGHLIGHTING ====== #}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css">
</head>
<body class="blog-page blog-post-page dev-blog">
  {# ====== SKIP LINK ====== #}
  <a href="#main-content" class="skip-link">Skip to main content</a>

  {# ====== NAVIGATION ====== #}
  <nav class="nav" id="nav" aria-label="Main navigation">
    <div class="nav__inner">
      <a href="/developers/" class="nav__logo nav__logo--wordmark-only">
        <span class="nav__logo-text">Ferni <span style="font-weight: 400; opacity: 0.7;">Developers</span></span>
      </a>

      <ul class="nav__links">
        <li><a href="/developers/" class="nav__link">Docs</a></li>
        <li><a href="/developers/api/" class="nav__link">API</a></li>
        <li><a href="/developers/blog/" class="nav__link is-active">Blog</a></li>
        <li><a href="https://github.com/ferni-ai" class="nav__link" target="_blank" rel="noopener">GitHub</a></li>
      </ul>

      <a href="{{ site.appUrl }}" class="nav__cta nav__cta--desktop">
        Console
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

      <button class="nav__hamburger" id="mobileMenuToggle" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  {# ====== MOBILE MENU ====== #}
  <div class="mobile-menu" id="mobileMenu" style="background: var(--dev-bg);">
    <div class="mobile-menu__header">
      <span class="nav__logo-text" style="color: var(--dev-text);">Ferni Developers</span>
      <button class="mobile-menu__close" aria-label="Close menu" style="color: var(--dev-text);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <nav class="mobile-menu__nav">
      <a href="/developers/" style="color: var(--dev-text-muted);">Documentation</a>
      <a href="/developers/api/" style="color: var(--dev-text-muted);">API Reference</a>
      <a href="/developers/blog/" style="color: var(--dev-accent);">Blog</a>
      <a href="https://github.com/ferni-ai" style="color: var(--dev-text-muted);">GitHub</a>
    </nav>
    <div class="mobile-menu__cta">
      <a href="{{ site.appUrl }}" class="btn btn--primary btn--lg" style="background: var(--dev-accent); color: var(--dev-bg);">
        Open Console
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  {# ====== MAIN CONTENT ====== #}
  <main id="main-content">
    <article class="blog-post">
      <header class="blog-post__header">
        <div class="container container-narrow">
          <a href="/developers/blog/" class="blog-post__back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Developer Blog
          </a>

          {% if category %}
          <span class="blog-post__category">{{ category }}</span>
          {% endif %}

          <h1 class="blog-post__title">{{ title }}</h1>

          <div class="blog-post__meta">
            {% if author %}
            <div class="blog-post__author">
              <div class="blog-post__author-avatar">
                {% if authorInitials %}{{ authorInitials }}{% else %}<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>{% endif %}
              </div>
              <div class="blog-post__author-info">
                <span class="blog-post__author-name">{{ author }}</span>
                {% if authorRole %}<span class="blog-post__author-role">{{ authorRole }}</span>{% endif %}
                <span class="blog-post__date">{{ date | date("MMMM d, yyyy") }}</span>
              </div>
            </div>
            {% endif %}

            {% if readTime %}
            <span class="blog-post__read-time">{{ readTime }} min read</span>
            {% endif %}
          </div>
        </div>
      </header>

      {% if image %}
      <div class="blog-post__hero">
        <div class="container">
          <img src="/images/dev-blog/{{ image }}" alt="{{ imageAlt or title }}" class="blog-post__hero-image" loading="lazy" style="border-radius: 1rem; border: 1px solid var(--dev-border);">
        </div>
      </div>
      {% endif %}

      <div class="blog-post__content">
        <div class="container container-narrow">
          {{ content | safe }}
        </div>
      </div>

      <footer class="blog-post__footer">
        <div class="container container-narrow">
          <div class="blog-post__share">
            <span class="blog-post__share-label">Share this article</span>
            <div class="blog-post__share-buttons">
              <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url }}"
                 target="_blank" rel="noopener" class="blog-post__share-btn" aria-label="Share on Twitter">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url }}"
                 target="_blank" rel="noopener" class="blog-post__share-btn" aria-label="Share on LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="blog-post__cta">
            <h3>Ready to build?</h3>
            <p>Start integrating the Ferni Developer Platform today.</p>
            <a href="/developers/getting-started/" class="btn btn-primary">Get Started</a>
          </div>
        </div>
      </footer>
    </article>
  </main>

  {# ====== FOOTER ====== #}
  {% include "partials/home/footer.njk" %}

  {# ====== SCRIPTS ====== #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-bash.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-javascript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-typescript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-json.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js"></script>
  <script>
  (function() {
    'use strict';

    // Nav scroll effect
    const nav = document.getElementById('nav');
    if (nav) {
      window.addEventListener('scroll', () => {
        nav.classList.toggle('is-scrolled', window.scrollY > 50);
      }, { passive: true });
    }

    // Mobile menu
    const mobileToggle = document.getElementById('mobileMenuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileClose = document.querySelector('.mobile-menu__close');

    if (mobileToggle && mobileMenu) {
      mobileToggle.addEventListener('click', () => {
        mobileMenu.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      });

      if (mobileClose) {
        mobileClose.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      }

      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      });
    }

    // Auto-highlight code blocks
    if (typeof Prism !== 'undefined') {
      Prism.highlightAll();
    }
  })();
  </script>
</body>
</html>
