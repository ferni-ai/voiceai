{# Living Avatar Overlay - Pixar-Inspired First Impression #}
<div class="living-avatar-overlay" id="livingAvatarOverlay" role="dialog" aria-modal="true" aria-label="Meet Ferni, your AI life coach">
  {# Soft backdrop with vignette #}
  <div class="avatar-backdrop"></div>

  {# Ambient floating particles #}
  <div class="avatar-particles">
    <div class="ambient-particle"></div>
    <div class="ambient-particle"></div>
    <div class="ambient-particle"></div>
    <div class="ambient-particle"></div>
    <div class="ambient-particle"></div>
    <div class="ambient-particle"></div>
    <div class="ambient-particle"></div>
    <div class="ambient-particle"></div>
  </div>

  {# Aurora glow background #}
  <div class="avatar-aurora"></div>

  {# Main avatar container #}
  <div class="living-avatar" data-emotion="neutral" role="img" aria-label="Ferni - animated waveform visualization">
    {# The orb with glow rings #}
    <div class="avatar-orb-wrapper">
      <div class="avatar-glow-ring" style="--ring-opacity: 0.5"></div>
      <div class="avatar-glow-ring" style="--ring-opacity: 0.35"></div>
      <div class="avatar-glow-ring" style="--ring-opacity: 0.2"></div>

      <div class="avatar-orb">
        {# Emotion-responsive waveform #}
        <div class="avatar-waveform">
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
          <div class="waveform-bar"></div>
        </div>
      </div>
    </div>

    {# Info text #}
    <div class="avatar-info">
      <h2 class="avatar-greeting" id="avatarGreeting">Hello.</h2>
      <p class="avatar-subtext">Your AI team is ready to listen.<br>No judgment. Just guidance.</p>
    </div>

    {# CTA #}
    <div class="avatar-cta">
      <a href="{{ site.appUrl }}?utm_source=ferni_website&utm_medium=web&utm_campaign=intro" class="btn btn-primary btn-glow" id="introStartBtn">
        <span>Start Talking</span>
        <svg class="btn-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  {# Skip button #}
  <button class="avatar-skip" id="skipIntroBtn" aria-label="Skip introduction">
    Skip intro <span aria-hidden="true">→</span>
  </button>
</div>
