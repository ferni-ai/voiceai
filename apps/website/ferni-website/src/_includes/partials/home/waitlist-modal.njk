{#
  Waitlist Modal - Integrated Gate

  A magical modal that appears when users click any CTA.
  Shows the full landing page behind it, with this modal overlay.

  Features:
  - Frosted glass backdrop blur
  - Breathing Ferni avatar
  - Email signup with confetti celebration
  - Accessible: focus trap, ESC to close, aria labels
#}

<div class="waitlist-modal" id="waitlistModal" role="dialog" aria-modal="true" aria-labelledby="waitlistModalTitle" hidden>
  {# Backdrop - click to close #}
  <div class="waitlist-modal__backdrop" aria-hidden="true"></div>

  {# Modal Content #}
  <div class="waitlist-modal__container">
    {# Close button #}
    <button class="waitlist-modal__close" id="waitlistModalClose" aria-label="Close modal" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    {# ====== SIGNUP FORM STATE ====== #}
    <div class="waitlist-modal__content" id="waitlistModalContent">

      {# Ferni Breathing Avatar #}
      <div class="waitlist-modal__avatar" aria-hidden="true">
        <div class="avatar-glow"></div>
        <div class="avatar-orb">
          <svg class="ferni-eyes-svg avatar-text" viewBox="0 0 100 100"><ellipse cx="36" cy="50" rx="10" ry="12" fill="white"/><circle cx="33" cy="45" r="2.5" fill="white" opacity="0.9"/><ellipse cx="64" cy="50" rx="10" ry="12" fill="white"/><circle cx="61" cy="45" r="2.5" fill="white" opacity="0.9"/></svg>
          <div class="avatar-pulse"></div>
        </div>
      </div>

      {# Headline - warm, personal, like a friend inviting you in #}
      <h2 class="waitlist-modal__headline" id="waitlistModalTitle">
        Good things take time.
      </h2>

      {# Subheadline - emotional, not transactional #}
      <p class="waitlist-modal__subhead">
        We're preparing something meaningful. Be first to experience it.
      </p>

      {# Email Form #}
      <form class="waitlist-modal__form" id="waitlistModalForm" novalidate>
        <div class="waitlist-modal__field">
          <input
            type="email"
            id="waitlistModalEmail"
            name="email"
            required
            autocomplete="email"
            placeholder="Your email"
            aria-label="Email address"
            aria-describedby="modalEmailError"
          >
          <span class="waitlist-modal__error" id="modalEmailError" role="alert" aria-live="polite"></span>
        </div>

        {# Phone field - framed as a personal gift, not a request #}
        <div class="waitlist-modal__field waitlist-modal__field--phone">
          <input
            type="tel"
            id="waitlistModalPhone"
            name="phone"
            autocomplete="tel"
            placeholder="Your phone (optional)"
            aria-label="Phone number (optional)"
            aria-describedby="modalPhoneHint"
          >
          <span class="waitlist-modal__hint" id="modalPhoneHint">I'd love to personally welcome you when you're in.</span>
        </div>

        {# Honeypot field for bot detection - hidden from users #}
        <div class="waitlist-modal__honeypot" aria-hidden="true" tabindex="-1">
          <input type="text" name="website" autocomplete="off" tabindex="-1">
        </div>

        <button type="submit" class="waitlist-modal__submit" id="waitlistModalSubmit">
          <span class="waitlist-modal__submit-text">Save my spot</span>
          <span class="waitlist-modal__submit-loading" aria-hidden="true">
            <svg class="waitlist-modal__spinner" viewBox="0 0 24 24" width="20" height="20">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
            </svg>
          </span>
          <svg class="waitlist-modal__submit-arrow" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </form>

      {# Privacy Note - warm and reassuring #}
      <p class="waitlist-modal__note">
        Just one email when we're ready. No noise.
      </p>
    </div>

    {# ====== SUCCESS STATE ====== #}
    <div class="waitlist-modal__success" id="waitlistModalSuccess" hidden>
      {# Ferni Avatar - shows warmth #}
      <div class="waitlist-modal__avatar waitlist-modal__avatar--success" aria-hidden="true">
        <div class="avatar-glow avatar-glow--success"></div>
        <div class="avatar-orb">
          <svg class="ferni-eyes-svg avatar-text" viewBox="0 0 100 100"><ellipse cx="36" cy="50" rx="10" ry="12" fill="white"/><circle cx="33" cy="45" r="2.5" fill="white" opacity="0.9"/><ellipse cx="64" cy="50" rx="10" ry="12" fill="white"/><circle cx="61" cy="45" r="2.5" fill="white" opacity="0.9"/></svg>
          <div class="avatar-pulse"></div>
        </div>
      </div>

      {# Success Message - personal and warm #}
      <h2 class="waitlist-modal__success-headline">
        I'll be in touch.
      </h2>
      <p class="waitlist-modal__success-message">
        Take care of yourself in the meantime.
      </p>

      {# Explore hint - soft invitation #}
      <p class="waitlist-modal__explore-hint">
        Feel free to look around...
      </p>

      <button class="waitlist-modal__explore-btn" id="waitlistModalExplore" type="button">
        Keep exploring
      </button>
    </div>

    {# Confetti Canvas #}
    <canvas id="modalConfettiCanvas" class="waitlist-modal__confetti" aria-hidden="true"></canvas>
  </div>
</div>
