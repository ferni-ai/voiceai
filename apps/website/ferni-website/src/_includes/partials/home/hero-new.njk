{# 
  HERO SECTION - The Competition Crusher
  
  Features:
  - Living avatar with Pixar-style breathing animation
  - Interactive demo input (type or speak)
  - Prominent phone CTA (voice-first)
  - Stats proof above the fold
  - Scroll indicator
#}

<section class="hero" id="hero" data-theme="zen">
  
  {# Ambient background - subtle floating orbs #}
  <div class="hero-ambient" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  
  <div class="hero-content">
    
    {# The Living Avatar #}
    <div class="hero-avatar reveal" id="heroAvatar">
      <div class="avatar-orb avatar-orb-hero animate-pixar-breathe" data-persona="ferni">
        <div class="avatar-eyes track-cursor" id="avatarEyes">
          <span class="eye"></span>
          <span class="eye"></span>
        </div>
      </div>
      <div class="avatar-status">
        <span class="status-dot"></span>
        <span class="status-text">Ready to listen</span>
      </div>
    </div>
    
    {# The Promise - Bold headline #}
    <h1 class="hero-headline reveal reveal-delay-1">
      {{ site.hero.headline }}<br>
      <span class="hero-accent">{{ site.hero.headlineAccent }}</span>
    </h1>
    
    {# The Hook #}
    <p class="hero-subhead reveal reveal-delay-2">
      {{ site.hero.subhead }}<br>
      {{ site.hero.subheadLine2 }}
    </p>
    
    {# Interactive Demo - The Proof #}
    <div class="hero-demo reveal reveal-delay-3" id="heroDemo">
      <div class="demo-input-wrapper">
        <input 
          type="text" 
          id="heroDemoInput"
          class="demo-input"
          placeholder="What's on your mind?"
          aria-label="Try talking to Ferni"
          autocomplete="off"
        >
        <button class="demo-mic-btn" id="demoMicBtn" aria-label="Speak to Ferni">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
            <line x1="12" x2="12" y1="19" y2="22"/>
          </svg>
        </button>
      </div>
      
      <div class="demo-suggestions" id="demoSuggestions">
        <button class="demo-suggestion" data-prompt="I'm feeling overwhelmed at work">
          "I'm overwhelmed at work"
        </button>
        <button class="demo-suggestion" data-prompt="Help me build better habits">
          "Help me build habits"
        </button>
        <button class="demo-suggestion" data-prompt="I have a big decision to make">
          "Big decision to make"
        </button>
      </div>
      
      {# Response preview - appears after input #}
      <div class="hero-response" id="heroResponse">
        <div class="hero-response-header">
          <div class="avatar-orb avatar-orb-sm animate-pixar-breathe" data-persona="ferni">
            <span class="avatar-initials">FE</span>
          </div>
          <span class="response-name">Ferni</span>
        </div>
        <div class="hero-response-text" id="heroResponseText">
          <div class="typing-indicator">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      </div>
    </div>
    
    {# The Action - CTAs #}
    <div class="hero-actions reveal reveal-delay-4">
      <a 
        href="{{ site.hero.cta.primary.url }}" 
        class="btn btn-primary btn-lg btn-glow"
        onclick="typeof trackEvent === 'function' && trackEvent('CTA', 'click', 'hero-start-free')"
      >
        <span>{{ site.hero.cta.primary.text }}</span>
        <svg class="btn-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
      
      <a href="tel:{{ site.phoneRaw }}" class="btn-phone">
        <svg class="phone-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="phone-number">{{ site.phone }}</span>
        <span class="phone-label">Call anytime</span>
      </a>
    </div>
    
    {# Social Proof - Above the fold #}
    <div class="hero-proof reveal reveal-delay-5">
      {% for stat in site.stats %}
      <div class="proof-stat">
        <span class="proof-number" {% if '+' in stat.value %}data-count="{{ stat.value | replace('+', '') | replace(',', '') }}"{% endif %}>
          {{ stat.value }}
        </span>
        <span class="proof-label">{{ stat.label }}</span>
      </div>
      {% if not loop.last %}
      <div class="proof-divider"></div>
      {% endif %}
      {% endfor %}
    </div>
    
  </div>
  
  {# Scroll indicator #}
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-text">Meet the team</span>
    <div class="scroll-arrow"></div>
  </div>
  
</section>

