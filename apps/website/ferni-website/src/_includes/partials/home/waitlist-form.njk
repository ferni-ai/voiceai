{# Waitlist Email Signup Form - Invitation Only Landing Page #}

<section class="waitlist" id="waitlist">
  {# ====== SIGNUP FORM STATE ====== #}
  <div class="waitlist__content" id="waitlistContent">

    {# Ferni Breathing Avatar #}
    <div class="waitlist__avatar" aria-hidden="true">
      <div class="avatar-glow"></div>
      <div class="avatar-orb">
        <div class="avatar-pulse"></div>
      </div>
    </div>

    {# Headline #}
    <h1 class="waitlist__headline">
      Something special is coming.
    </h1>

    {# Subheadline #}
    <p class="waitlist__subhead">
      Join the waitlist to be first when Ferni opens its doors.
    </p>

    {# Email Form #}
    <form class="waitlist__form" id="waitlistForm" novalidate>
      <div class="waitlist__field">
        <input
          type="email"
          id="waitlistEmail"
          name="email"
          required
          autocomplete="email"
          placeholder="Your email"
          aria-label="Email address"
          aria-describedby="emailError"
        >
        <span class="waitlist__error" id="emailError" role="alert" aria-live="polite"></span>
      </div>

      {# Honeypot field for bot detection - hidden from users #}
      <div class="waitlist__honeypot" aria-hidden="true" tabindex="-1">
        <input type="text" name="website" autocomplete="off" tabindex="-1">
      </div>

      <button type="submit" class="waitlist__submit" id="waitlistSubmit">
        <span class="waitlist__submit-text">Join the waitlist</span>
        <span class="waitlist__submit-loading" aria-hidden="true">
          <svg class="waitlist__spinner" viewBox="0 0 24 24" width="20" height="20">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
          </svg>
        </span>
        <svg class="waitlist__submit-arrow" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </form>

    {# Privacy Note #}
    <p class="waitlist__note">
      We'll only email you when it's time. No spam, ever.
    </p>
  </div>

  {# ====== SUCCESS STATE ====== #}
  <div class="waitlist__success" id="waitlistSuccess" hidden>
    {# Success Icon #}
    <div class="waitlist__success-icon">
      <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="var(--color-success)" stroke-opacity="0.2"/>
        <polyline points="8 12 11 15 16 9" stroke="var(--color-success)"/>
      </svg>
    </div>

    {# Success Message #}
    <h2 class="waitlist__success-headline">
      You're on the list!
    </h2>
    <p class="waitlist__success-message">
      We'll reach out soon. Until then, take care of yourself.
    </p>

    {# Confetti Canvas #}
    <canvas id="confettiCanvas" class="waitlist__confetti" aria-hidden="true"></canvas>
  </div>
</section>
