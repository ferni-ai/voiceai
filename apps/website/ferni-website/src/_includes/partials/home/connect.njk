<section class="how-it-works" id="connect">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Connect Anywhere</p>
      <h2 class="headline-lg">Two ways to talk.</h2>
      <p class="section-subtitle">Same AI team. Same great experience. Your choice.</p>
    </div>

    <div class="connect-options">
      <div class="connect-option reveal">
        <div class="connect-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="5" y="2" width="14" height="20" rx="3"/>
            <line x1="12" y1="18" x2="12" y2="18"/>
          </svg>
        </div>
        <h3 class="connect-title">Web App</h3>
        <p class="connect-description">
          Open app.ferni.ai on any device. No download required—works on desktop, tablet, and mobile.
        </p>
        <a href="{{ site.appUrl }}?utm_source=ferni_website&utm_medium=web&utm_campaign=homepage" class="btn btn-primary">Open App</a>
      </div>

      <div class="connect-divider">
        <span>or</span>
      </div>

      <div class="connect-option reveal reveal-delay-1">
        <div class="connect-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <h3 class="connect-title">Phone Call</h3>
        <p class="connect-description">
          Prefer to call? Dial Ferni directly. Same AI team, same great experience—just pick up your phone.
        </p>
        <a href="tel:{{ site.phoneRaw }}" class="phone-cta">
          <span class="phone-number">{{ site.phone }}</span>
          <span class="phone-action">Tap to call</span>
        </a>
      </div>
    </div>

    <div class="steps-simple">
      <div class="step-simple reveal">
        <span class="step-num">1</span>
        <span class="step-text">Connect via web or phone</span>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-simple reveal reveal-delay-1">
        <span class="step-num">2</span>
        <span class="step-text">Start talking</span>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-simple reveal reveal-delay-2">
        <span class="step-num">3</span>
        <span class="step-text">That's it</span>
      </div>
    </div>
  </div>
</section>
