{# ========== LATEST STORIES ========== #}
<section class="building-stories" id="stories">
  <div class="container">
    <div class="section__header">
      <p class="section__eyebrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
        </svg>
        Build Log
      </p>
      <h2 class="section__title">Stories from the trenches</h2>
      <p class="section__subtitle">The unfiltered truth about building something new. Wins, fails, and everything between.</p>
    </div>
    
    {# Story Cards Grid #}
    <div class="building-stories__grid">
      
      {# Featured Story #}
      {% set featuredStory = collections.buildStories | reverse | first %}
      {% if featuredStory %}
      <article class="story-card story-card--featured reveal">
        <a href="{{ featuredStory.url }}" class="story-card__link">
          <div class="story-card__badge">
            <span class="story-card__badge-icon">✨</span>
            Latest
          </div>
          <div class="story-card__content">
            <div class="story-card__meta">
              {% if featuredStory.data.category %}
              <span class="story-card__category story-card__category--{{ featuredStory.data.category | lower | replace(' ', '-') }}">{{ featuredStory.data.category }}</span>
              {% endif %}
              <span class="story-card__date">{{ featuredStory.date | date("MMM d, yyyy") }}</span>
            </div>
            <h3 class="story-card__title">{{ featuredStory.data.title }}</h3>
            <p class="story-card__excerpt">{{ featuredStory.data.excerpt }}</p>
            <span class="story-card__read-more">
              Read story
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      </article>
      {% endif %}
      
      {# Other Stories #}
      {% for story in collections.buildStories | reverse %}
      {% if loop.index > 1 %}
      <article class="story-card reveal" style="--delay: {{ loop.index * 0.1 }}s">
        <a href="{{ story.url }}" class="story-card__link">
          <div class="story-card__content">
            <div class="story-card__meta">
              {% if story.data.category %}
              <span class="story-card__category story-card__category--{{ story.data.category | lower | replace(' ', '-') }}">{{ story.data.category }}</span>
              {% endif %}
              <span class="story-card__date">{{ story.date | date("MMM d, yyyy") }}</span>
            </div>
            <h3 class="story-card__title">{{ story.data.title }}</h3>
            <p class="story-card__excerpt">{{ story.data.excerpt }}</p>
            <span class="story-card__read-more">
              Read story
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      </article>
      {% endif %}
      {% endfor %}
      
      {# Placeholder if no stories yet #}
      {% if collections.buildStories.length == 0 %}
      <article class="story-card story-card--coming reveal">
        <div class="story-card__content">
          <div class="story-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
              <path d="M12 20h9"/>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <h3 class="story-card__title">Stories coming soon</h3>
          <p class="story-card__excerpt">We're writing about our journey. Check back soon for the first stories from the build.</p>
        </div>
      </article>
      {% endif %}
      
    </div>
  </div>
</section>

