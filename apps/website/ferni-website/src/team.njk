<style>
  /* ============================================
     TEAM PAGE - On Brand, On Message
     Six specialists. One relationship.
     ============================================ */

  :root {
    --ferni: #4a6741;
    --maya: #a67a6a;
    --peter: #3a6b73;
    --jordan: #c4856a;
    --alex: #5a6b8a;
    --nayan: #b8956a;
    --paper-cream: #FAF8F5;
    --natural-ink: #2C2520;
    --forest-green: #3D5A45;
    --warm-amber: #C4A265;
    --text-muted: #5C544A;
    --text-light: #756A5E;
  }

  #main-content {
    background: var(--paper-cream);
  }

  /* ============================================
     HERO - Team Cluster
     ============================================ */
  .team-hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 120px 24px 80px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #f0ebe4 0%, var(--paper-cream) 100%);
  }

  .team-hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(74, 103, 65, 0.1) 0%, transparent 60%);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  /* Avatar cluster */
  .team-cluster {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 40px;
  }

  .cluster-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 4px solid var(--paper-cream);
    box-shadow: 0 4px 12px rgba(44, 37, 32, 0.15);
    margin-left: -16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
    position: relative;
  }

  .cluster-avatar:first-child {
    margin-left: 0;
  }

  .cluster-avatar:hover {
    transform: scale(1.15) translateY(-8px);
    z-index: 10;
    box-shadow: 0 8px 24px rgba(44, 37, 32, 0.25);
  }

  .cluster-avatar svg {
    width: 100%;
    height: 100%;
  }

  .hero-overline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ferni);
    margin-bottom: 20px;
  }

  .hero-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(42px, 8vw, 72px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--natural-ink);
    max-width: 800px;
    margin-bottom: 24px;
  }

  .hero-title .highlight {
    background: linear-gradient(135deg, var(--ferni) 0%, var(--peter) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(18px, 3vw, 22px);
    color: var(--text-muted);
    max-width: 700px;
    line-height: 1.6;
    margin-bottom: 48px;
  }

  .scroll-hint {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--text-light);
    font-size: 12px;
    font-weight: 500;
  }

  .scroll-hint svg {
    width: 24px;
    height: 24px;
  }

  /* Removed hero entrance animations for reliability */

  /* ============================================
     KINTSUGI QUOTE SECTION
     ============================================ */
  .kintsugi-section {
    padding: 100px 24px;
    background: white;
  }

  .quote-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .kintsugi-quote {
    position: relative;
    padding: 0 40px;
  }

  .quote-mark {
    position: absolute;
    top: -20px;
    left: 0;
    font-family: Georgia, serif;
    font-size: 120px;
    line-height: 1;
    color: var(--ferni);
    opacity: 0.1;
  }

  .kintsugi-quote p {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 500;
    line-height: 1.5;
    color: var(--natural-ink);
    font-style: italic;
    margin-bottom: 24px;
    position: relative;
  }

  .quote-attribution {
    font-size: 14px;
    font-weight: 600;
    color: var(--ferni);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ============================================
     WHY A TEAM SECTION
     ============================================ */
  .why-section {
    padding: 100px 24px;
    background: linear-gradient(180deg, var(--paper-cream) 0%, #f0ebe4 100%);
  }

  .why-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  .why-content h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--natural-ink);
    margin-bottom: 24px;
  }

  .why-content p {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .why-content .highlight-text {
    color: var(--natural-ink);
    font-weight: 600;
  }

  .why-points {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .why-point {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .why-point svg {
    width: 24px;
    height: 24px;
    color: var(--ferni);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .why-point span {
    font-size: 16px;
    color: var(--text-muted);
  }

  /* Avatar grid */
  .avatar-grid-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .avatar-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 320px;
  }

  .avatar-cell {
    aspect-ratio: 1;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
  }

  .avatar-cell:hover {
    transform: scale(1.1);
  }

  .avatar-cell svg {
    width: 60px;
    height: 60px;
  }

  .avatar-cell:nth-child(1) { background: rgba(74, 103, 65, 0.1); }
  .avatar-cell:nth-child(2) { background: rgba(166, 122, 106, 0.1); }
  .avatar-cell:nth-child(3) { background: rgba(58, 107, 115, 0.1); }
  .avatar-cell:nth-child(4) { background: rgba(196, 133, 106, 0.1); }
  .avatar-cell:nth-child(5) { background: rgba(90, 107, 138, 0.1); }
  .avatar-cell:nth-child(6) { background: rgba(184, 149, 106, 0.1); }

  /* ============================================
     SPECIALISTS HEADER
     ============================================ */
  .specialists-header {
    padding: 80px 24px 40px;
    background: white;
    text-align: center;
  }

  .specialists-header .section-overline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ferni);
    margin-bottom: 16px;
  }

  .specialists-header h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--natural-ink);
    margin-bottom: 16px;
  }

  .specialists-header p {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ============================================
     PERSONA SECTIONS
     ============================================ */
  .persona-section {
    padding: 80px 24px;
    border-top: 1px solid rgba(44, 37, 32, 0.06);
  }

  .persona-section:nth-child(odd) {
    background: white;
  }

  .persona-section:nth-child(even) {
    background: var(--paper-cream);
  }

  .persona-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .persona-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 60px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .persona-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .persona-avatar-col {
      display: flex;
      justify-content: center;
    }
  }

  /* Avatar Column */
  .persona-avatar-col {
    position: sticky;
    top: 100px;
  }

  @media (max-width: 900px) {
    .persona-avatar-col {
      position: static;
    }
  }

  .persona-avatar-large {
    width: 200px;
    height: 200px;
    margin: 0 auto 20px;
    position: relative;
  }

  .persona-avatar-large::before {
    content: '';
    position: absolute;
    inset: -20px;
    background: radial-gradient(circle, var(--persona-glow, rgba(74, 103, 65, 0.2)) 0%, transparent 70%);
    border-radius: 50%;
    animation: glow 3s ease-in-out infinite;
  }

  @keyframes glow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .persona-avatar-large svg {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
  }

  .color-swatches {
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .color-swatch {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  /* Content Column */
  .persona-content {
    padding-top: 10px;
  }

  .persona-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .persona-role-tag {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--persona-color, var(--ferni));
  }

  .persona-archetype {
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    border-radius: 9999px;
    background: rgba(74, 103, 65, 0.08);
    color: var(--persona-color, var(--ferni));
  }

  .persona-content h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 700;
    color: var(--natural-ink);
    margin-bottom: 4px;
  }

  .persona-tagline {
    font-size: 18px;
    font-style: italic;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  /* Quote */
  .persona-quote {
    background: rgba(74, 103, 65, 0.04);
    border-left: 4px solid var(--persona-color, var(--ferni));
    border-radius: 0 16px 16px 0;
    padding: 24px;
    margin-bottom: 32px;
    position: relative;
  }

  .persona-quote::before {
    content: '"';
    position: absolute;
    top: 8px;
    left: 12px;
    font-family: Georgia, serif;
    font-size: 48px;
    color: var(--persona-color, var(--ferni));
    opacity: 0.15;
    line-height: 1;
  }

  .persona-quote p {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 20px;
    font-weight: 500;
    color: var(--natural-ink);
    line-height: 1.5;
    margin: 0;
    position: relative;
  }

  /* Story */
  .persona-story p {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .persona-story strong {
    color: var(--natural-ink);
    font-weight: 600;
  }

  .persona-story em {
    font-style: italic;
  }

  /* Better Than Human Card */
  .bth-card {
    background: white;
    border: 1px solid rgba(44, 37, 32, 0.08);
    border-radius: 20px;
    padding: 28px;
    margin: 32px 0;
    box-shadow: 0 4px 20px rgba(44, 37, 32, 0.04);
  }

  .bth-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .bth-header svg {
    width: 18px;
    height: 18px;
    color: var(--persona-color, var(--ferni));
  }

  .bth-header span {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--persona-color, var(--ferni));
  }

  .bth-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bth-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .bth-item svg {
    width: 20px;
    height: 20px;
    color: var(--persona-color, var(--ferni));
    flex-shrink: 0;
    margin-top: 2px;
  }

  .bth-item span {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .bth-item strong {
    color: var(--natural-ink);
  }

  /* Tags */
  .persona-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .persona-tag {
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    border-radius: 9999px;
    background: rgba(74, 103, 65, 0.08);
    color: var(--persona-color, var(--ferni));
  }

  /* Partner exclusive badge */
  .partner-badge {
    background: linear-gradient(135deg, rgba(74, 103, 65, 0.15), rgba(74, 103, 65, 0.05));
    border: 1px solid rgba(74, 103, 65, 0.2);
    color: var(--ferni);
  }

  /* ============================================
     CTA SECTION
     ============================================ */
  .cta-section {
    padding: 120px 24px;
    background: linear-gradient(135deg, rgba(74, 103, 65, 0.06) 0%, rgba(58, 107, 115, 0.06) 100%);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(74, 103, 65, 0.12) 0%, transparent 60%);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cta-container {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }

  .cta-overline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ferni);
    margin-bottom: 16px;
  }

  .cta-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    color: var(--natural-ink);
    margin-bottom: 16px;
  }

  .cta-subtitle {
    font-size: 18px;
    color: var(--text-muted);
    margin-bottom: 40px;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 9999px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .btn-primary {
    background: var(--forest-green);
    color: white;
    box-shadow: 0 4px 14px rgba(61, 90, 69, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(61, 90, 69, 0.35);
  }

  .btn-secondary {
    background: white;
    color: var(--natural-ink);
    border: 1.5px solid rgba(44, 37, 32, 0.2);
  }

  .btn-secondary:hover {
    background: rgba(44, 37, 32, 0.03);
    border-color: var(--natural-ink);
  }

  .btn svg {
    width: 18px;
    height: 18px;
  }

  /* ============================================
     SCROLL REVEAL - Content Always Visible
     Override global pixar-animations.css .reveal (opacity:0, blur)
     CRITICAL: Use high specificity to ensure override
     ============================================ */
  #main-content .reveal,
  .team-hero,
  .kintsugi-section,
  .why-section,
  .specialists-header,
  .persona-section,
  .cta-section {
    opacity: 1 !important;
    filter: none !important;
    visibility: visible !important;
  }

  .reveal {
    opacity: 1 !important;
    transform: translateY(20px);
    filter: none !important;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.visible {
    transform: translateY(0);
  }

  /* Fallback: if JS doesn't run, content still visible */
  @media (prefers-reduced-motion: reduce), (scripting: none) {
    .reveal {
      transform: translateY(0) !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation: none !important;
      transition: none !important;
    }
    .reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>

