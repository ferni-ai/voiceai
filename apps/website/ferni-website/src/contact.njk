<main id="main-content">
<div class="contact-page">

  {# Hero Section #}
  <section class="pt-32 pb-20 px-6 bg-gradient-to-b from-paper-sand to-paper">
    <div class="max-w-4xl mx-auto text-center">
      <p class="reveal text-eyebrow uppercase tracking-widest text-ferni mb-4">Get in Touch</p>
      <h1 class="reveal font-display text-display-xl text-ink mb-6">We'd love to<br><span class="text-gradient">hear from you.</span></h1>
      <p class="reveal text-body-xl text-ink-muted max-w-2xl mx-auto">Questions, feedback, or just want to say hi? Reach out anytime.</p>
    </div>
  </section>

  {# Contact Options #}
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        
        {# Call #}
        <div class="reveal group bg-white rounded-3xl p-8 shadow-lg hover:shadow-xl border border-ink/5 hover:border-ferni/20 transition-all duration-500 hover:-translate-y-1 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-ferni/15 to-ferni/5 flex items-center justify-center group-hover:from-ferni/25 group-hover:to-ferni/10 transition-all">
            <svg class="w-8 h-8 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.05.39.14.76.26 1.12a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.36.12.73.21 1.12.26A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3 class="font-display font-bold text-xl text-ink mb-2">Call Us</h3>
          <p class="text-ink-muted mb-4">Talk to Ferni anytime</p>
          <a href="tel:+18885983952" class="font-mono text-ferni font-semibold text-lg hover:underline">(888) 598-3952</a>
        </div>
        
        {# Email #}
        <div class="reveal group bg-white rounded-3xl p-8 shadow-lg hover:shadow-xl border border-ink/5 hover:border-ferni/20 transition-all duration-500 hover:-translate-y-1 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-ferni/15 to-ferni/5 flex items-center justify-center group-hover:from-ferni/25 group-hover:to-ferni/10 transition-all">
            <svg class="w-8 h-8 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3 class="font-display font-bold text-xl text-ink mb-2">Email Us</h3>
          <p class="text-ink-muted mb-4">We'll respond within 24 hours</p>
          <a href="mailto:hello@ferni.ai" class="text-ferni font-semibold hover:underline">hello@ferni.ai</a>
        </div>
        
        {# App #}
        <div class="reveal group bg-white rounded-3xl p-8 shadow-lg hover:shadow-xl border border-ink/5 hover:border-ferni/20 transition-all duration-500 hover:-translate-y-1 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-ferni/15 to-ferni/5 flex items-center justify-center group-hover:from-ferni/25 group-hover:to-ferni/10 transition-all">
            <svg class="w-8 h-8 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="font-display font-bold text-xl text-ink mb-2">Try the App</h3>
          <p class="text-ink-muted mb-4">Start a conversation now</p>
          <a href="https://app.ferni.ai" class="text-ferni font-semibold hover:underline">Open App →</a>
        </div>
        
      </div>
    </div>
  </section>

  {# Contact Form #}
  <section class="py-16 px-6 bg-paper-sand">
    <div class="max-w-2xl mx-auto">
      <div class="reveal bg-white rounded-3xl p-8 lg:p-10 shadow-xl">
        <h2 class="font-display text-display-sm text-ink mb-8 text-center">Send us a message</h2>
        
        <form class="space-y-6" action="https://formspree.io/f/your-form-id" method="POST">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-ink mb-2">Name</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 bg-paper-sand border border-ink/10 rounded-xl focus:outline-none focus:border-ferni focus:ring-2 focus:ring-ferni/20 transition-all">
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-ink mb-2">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 bg-paper-sand border border-ink/10 rounded-xl focus:outline-none focus:border-ferni focus:ring-2 focus:ring-ferni/20 transition-all">
            </div>
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-ink mb-2">Subject</label>
            <select id="subject" name="subject"
              class="w-full px-4 py-3 bg-paper-sand border border-ink/10 rounded-xl focus:outline-none focus:border-ferni focus:ring-2 focus:ring-ferni/20 transition-all">
              <option value="general">General Inquiry</option>
              <option value="support">Support</option>
              <option value="feedback">Feedback</option>
              <option value="partnership">Partnership</option>
              <option value="press">Press</option>
            </select>
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-2">Message</label>
            <textarea id="message" name="message" rows="5" required
              class="w-full px-4 py-3 bg-paper-sand border border-ink/10 rounded-xl focus:outline-none focus:border-ferni focus:ring-2 focus:ring-ferni/20 transition-all resize-none"></textarea>
          </div>
          
          <button type="submit" class="btn-magnetic w-full py-4 bg-ferni hover:bg-ferni-dark text-white font-semibold rounded-xl shadow-lg shadow-ferni/20 hover:shadow-xl hover:shadow-ferni/30 transition-all">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

  {# Quick Help Section #}
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="reveal font-display text-display-sm text-ink mb-8">Need quick help?</h2>
      <div class="reveal grid sm:grid-cols-2 gap-6">
        <a href="/faq/" class="group bg-white rounded-2xl p-6 shadow-md hover:shadow-lg border border-ink/5 hover:border-ferni/20 transition-all text-left">
          <h3 class="font-display font-bold text-lg text-ink mb-2 group-hover:text-ferni transition-colors">FAQ</h3>
          <p class="text-ink-muted text-sm">Find answers to common questions about Ferni.</p>
        </a>
        <a href="/privacy/" class="group bg-white rounded-2xl p-6 shadow-md hover:shadow-lg border border-ink/5 hover:border-ferni/20 transition-all text-left">
          <h3 class="font-display font-bold text-lg text-ink mb-2 group-hover:text-ferni transition-colors">Privacy Policy</h3>
          <p class="text-ink-muted text-sm">Learn how we protect your data and privacy.</p>
        </a>
      </div>
    </div>
  </section>

</div>
</main>

