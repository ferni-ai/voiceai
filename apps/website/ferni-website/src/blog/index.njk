---
layout: layouts/blog.njk
title: Blog
description: Insights on AI coaching, personal growth, and building better habits
permalink: /blog/
---

{# Hero Section #}
<section class="blog-hero">
  <div class="container">
    <p class="blog-hero__eyebrow reveal">The Ferni Blog</p>
    <h1 class="blog-hero__title reveal">Thoughts on growth.</h1>
    <p class="blog-hero__subtitle reveal">Insights on AI coaching, personal development, and building a life you love.</p>
  </div>
</section>

{# Blog Posts #}
<section class="blog-posts">
  <div class="container">

    {# Featured Post #}
    {% set featuredPost = collections.posts | reverse | first %}
    {% if featuredPost %}
    <article class="featured-post reveal">
      <a href="{{ featuredPost.url }}" class="featured-post__link">
        <div class="featured-post__image">
          {% if featuredPost.data.image %}
          <img src="/images/blog/{{ featuredPost.data.image }}" alt="{{ featuredPost.data.imageAlt or featuredPost.data.title }}" loading="lazy">
          {% else %}
          <div class="featured-post__placeholder">
            {% if featuredPost.data.category == "Building in Public" %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
            {% elif featuredPost.data.category == "Product" %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            {% elif featuredPost.data.category == "Announcements" %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            {% elif featuredPost.data.category == "Personal Growth" %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0020 0h-3"/><path d="M12 2a5 5 0 00-5 5v3h10V7a5 5 0 00-5-5z"/></svg>
            {% else %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            {% endif %}
          </div>
          {% endif %}
        </div>
        <div class="featured-post__content">
          <div class="featured-post__meta">
            {% if featuredPost.data.category %}
            <span class="post-category">{{ featuredPost.data.category }}</span>
            {% endif %}
            <span class="post-date">{{ featuredPost.date | date("MMMM d, yyyy") }}</span>
          </div>
          <h2 class="featured-post__title">{{ featuredPost.data.title }}</h2>
          <p class="featured-post__excerpt">{{ featuredPost.data.excerpt }}</p>
          <span class="featured-post__cta">
            Read article
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
    </article>
    {% endif %}
      
    {# Post Grid #}
    <div class="posts-grid">
      {% for post in collections.posts | reverse %}
      {% if loop.index > 1 %}
      <article class="post-card reveal">
        <a href="{{ post.url }}" class="post-card__link">
          <div class="post-card__image">
            {% if post.data.image %}
            <img src="/images/blog/{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy">
            {% else %}
            <div class="post-card__placeholder">
              {% if post.data.category == "Building in Public" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
              {% elif post.data.category == "Product" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
              {% elif post.data.category == "Announcements" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 17H2a3 3 0 006 0h8a3 3 0 006 0z"/><path d="M12 2L12 9"/><path d="M4.5 9.5L12 2l7.5 7.5"/><path d="M4 11h16v6H4z"/></svg>
              {% elif post.data.category == "Personal Growth" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0020 0h-3"/><path d="M12 2a5 5 0 00-5 5v3h10V7a5 5 0 00-5-5z"/></svg>
              {% elif post.data.category == "AI & Technology" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
              {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              {% endif %}
            </div>
            {% endif %}
          </div>
          <div class="post-card__content">
            <div class="post-card__meta">
              {% if post.data.category %}
              <span class="post-category">{{ post.data.category }}</span>
              {% endif %}
              <span class="post-date">{{ post.date | date("MMM d, yyyy") }}</span>
            </div>
            <h3 class="post-card__title">{{ post.data.title }}</h3>
            <p class="post-card__excerpt">{{ post.data.excerpt }}</p>
          </div>
        </a>
      </article>
      {% endif %}
      {% endfor %}
    </div>

    {% if collections.posts.length == 0 %}
    <div class="blog-empty">
      <div class="blog-empty__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      </div>
      <p>No posts yet. Check back soon!</p>
    </div>
    {% endif %}

  </div>
</section>

{# Newsletter CTA #}
<section class="blog-newsletter">
  <div class="container container--narrow">
    <div class="newsletter-card reveal">
      <h3 class="newsletter-card__title">Stay in the loop</h3>
      <p class="newsletter-card__subtitle">Get new articles and Ferni updates delivered to your inbox.</p>
      <form class="newsletter-form" action="https://ferni.us11.list-manage.com/subscribe/post?u=52ffacbad9b81de1f66ebac7c&amp;id=dd755645d6&amp;f_id=00b2c7e3f0" method="POST" target="_blank">
        <input type="email" name="EMAIL" placeholder="your@email.com" required class="newsletter-form__input">
        <div aria-hidden="true" style="position: absolute; left: -5000px">
          <input type="text" name="b_52ffacbad9b81de1f66ebac7c_dd755645d6" tabindex="-1" value="">
        </div>
        <button type="submit" class="newsletter-form__btn">Subscribe</button>
      </form>
    </div>
  </div>
</section>
