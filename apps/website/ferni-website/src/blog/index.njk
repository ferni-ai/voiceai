---
layout: layouts/base.njk
title: Blog - Ferni
description: Insights on AI coaching, personal growth, and building better habits
permalink: /blog/
---

<main class="min-h-screen bg-paper">

  {# Hero Section #}
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-paper-sand to-paper">
    <div class="max-w-4xl mx-auto text-center">
      <p class="reveal text-eyebrow uppercase tracking-widest text-ferni mb-4">The Ferni Blog</p>
      <h1 class="reveal font-display text-display-xl text-ink mb-6">Thoughts on growth.</h1>
      <p class="reveal text-body-xl text-ink-muted max-w-2xl mx-auto">Insights on AI coaching, personal development, and building a life you love.</p>
    </div>
  </section>

  {# Blog Posts #}
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      
      {# Featured Post #}
      {% set featuredPost = collections.posts | reverse | first %}
      {% if featuredPost %}
      <article class="reveal mb-12 bg-white rounded-3xl shadow-xl overflow-hidden hover:shadow-2xl transition-shadow duration-500 group">
        <a href="{{ featuredPost.url }}" class="grid lg:grid-cols-2">
          <div class="aspect-video lg:aspect-auto bg-gradient-to-br from-ferni/20 to-peter/20 relative">
            {% if featuredPost.data.image %}
            <img src="/images/blog/{{ featuredPost.data.image }}" alt="{{ featuredPost.data.imageAlt or featuredPost.data.title }}" class="absolute inset-0 w-full h-full object-cover" loading="lazy">
            {% else %}
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-20 h-20 rounded-2xl bg-ferni/20 flex items-center justify-center">
                <svg class="w-10 h-10 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
            </div>
            {% endif %}
          </div>
          <div class="p-8 lg:p-10 flex flex-col justify-center">
            <div class="flex items-center gap-4 mb-4">
              {% if featuredPost.data.category %}
              <span class="px-3 py-1 bg-ferni/10 text-ferni text-xs font-semibold rounded-full">{{ featuredPost.data.category }}</span>
              {% endif %}
              <span class="text-ink-muted text-sm">{{ featuredPost.date | date("MMMM d, yyyy") }}</span>
            </div>
            <h2 class="font-display text-2xl lg:text-3xl font-bold text-ink mb-4 group-hover:text-ferni transition-colors">{{ featuredPost.data.title }}</h2>
            <p class="text-ink-muted mb-6 line-clamp-3">{{ featuredPost.data.excerpt }}</p>
            <span class="inline-flex items-center gap-2 text-ferni font-semibold">
              Read article
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      </article>
      {% endif %}
      
      {# Post Grid #}
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for post in collections.posts | reverse %}
        {% if loop.index > 1 %}
        <article class="reveal group bg-white rounded-2xl shadow-md hover:shadow-xl border border-ink/5 hover:border-ferni/20 overflow-hidden transition-all duration-500 hover:-translate-y-1">
          <a href="{{ post.url }}" class="block">
            <div class="aspect-video bg-gradient-to-br from-ferni/10 to-peter/10 relative">
              {% if post.data.image %}
              <img src="/images/blog/{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" class="absolute inset-0 w-full h-full object-cover" loading="lazy">
              {% else %}
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-xl bg-white/50 flex items-center justify-center">
                  <svg class="w-6 h-6 text-ferni" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                </div>
              </div>
              {% endif %}
            </div>
            <div class="p-5">
              <div class="flex items-center gap-3 mb-3">
                {% if post.data.category %}
                <span class="px-2 py-0.5 bg-ferni/10 text-ferni text-xs font-medium rounded">{{ post.data.category }}</span>
                {% endif %}
                <span class="text-ink-muted text-xs">{{ post.date | date("MMM d, yyyy") }}</span>
              </div>
              <h3 class="font-display font-bold text-lg text-ink mb-2 group-hover:text-ferni transition-colors line-clamp-2">{{ post.data.title }}</h3>
              <p class="text-ink-muted text-sm line-clamp-2">{{ post.data.excerpt }}</p>
            </div>
          </a>
        </article>
        {% endif %}
        {% endfor %}
      </div>
      
      {% if collections.posts.length == 0 %}
      <div class="text-center py-20">
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-ink/5 flex items-center justify-center">
          <svg class="w-8 h-8 text-ink-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        </div>
        <p class="text-ink-muted text-lg">No posts yet. Check back soon!</p>
      </div>
      {% endif %}
      
    </div>
  </section>

  {# Newsletter CTA #}
  <section class="py-16 px-6 bg-paper-sand">
    <div class="max-w-xl mx-auto">
      <div class="reveal bg-white rounded-3xl p-8 lg:p-10 shadow-xl text-center">
        <h3 class="font-display text-display-sm text-ink mb-3">Stay in the loop</h3>
        <p class="text-ink-muted mb-6">Get new articles and Ferni updates delivered to your inbox.</p>
        <form class="flex flex-col sm:flex-row gap-3" action="https://ferni.us11.list-manage.com/subscribe/post?u=52ffacbad9b81de1f66ebac7c&amp;id=dd755645d6&amp;f_id=00b2c7e3f0" method="POST" target="_blank">
          <input type="email" name="EMAIL" placeholder="your@email.com" required
            class="flex-1 px-4 py-3 bg-paper-sand border border-ink/10 rounded-xl focus:outline-none focus:border-ferni focus:ring-2 focus:ring-ferni/20 transition-all">
          <div aria-hidden="true" style="position: absolute; left: -5000px">
            <input type="text" name="b_52ffacbad9b81de1f66ebac7c_dd755645d6" tabindex="-1" value="">
          </div>
          <button type="submit" class="px-6 py-3 bg-ferni hover:bg-ferni-dark text-white font-semibold rounded-xl shadow-lg shadow-ferni/20 hover:shadow-xl transition-all">
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </section>

</main>

{% include "partials/footer.njk" %}
