# LinkedIn Company Page Publishing Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# LINKEDIN API CREDENTIALS
# =============================================================================

# OAuth 2.0 Access Token
# Get this by:
# 1. Create a LinkedIn App at https://www.linkedin.com/developers/
# 2. Add 'w_organization_social' permission for company page posting
# 3. Generate OAuth token through their OAuth flow or developer portal
LINKEDIN_ACCESS_TOKEN=your-access-token-here

# Company Page Organization ID
# Find this by:
# 1. Go to https://www.linkedin.com/company/ferni-ai/admin/
# 2. The ID is in the URL or can be found via LinkedIn API
# 3. Example: If URL is /company/98765432, then ID is 98765432
LINKEDIN_ORGANIZATION_ID=your-company-page-id

# Optional: Client credentials for OAuth flow
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret
# LINKEDIN_CALLBACK_URL=https://app.ferni.ai/api/marketing/linkedin/callback

# =============================================================================
# USAGE
# =============================================================================
#
# 1. Generate social cards:
#    node scripts/linkedin-card-generator.js --generate-all
#
# 2. Check configuration:
#    node scripts/linkedin-publisher.js --status
#
# 3. Post Daily Wisdom (Week 1, Day 1):
#    node scripts/linkedin-publisher.js --post-wisdom --week=1 --day=1
#
# 4. Preview without posting:
#    node scripts/linkedin-publisher.js --post-wisdom --week=1 --day=1 --dry-run
#
# =============================================================================
# GETTING LINKEDIN API ACCESS
# =============================================================================
#
# 1. Create a LinkedIn Developer App:
#    https://www.linkedin.com/developers/apps/new
#
# 2. Request Products:
#    - Sign in with LinkedIn (basic profile)
#    - Share on LinkedIn (w_member_social)
#    - Marketing Developer Platform (for company pages)
#
# 3. For company page posting, you need:
#    - w_organization_social scope
#    - Admin access to the company page
#    - The app must be verified for production use
#
# 4. OAuth Flow:
#    - Use Authorization Code flow (not Client Credentials)
#    - Token expires in 60 days, refresh before expiry
#
# More info: https://learn.microsoft.com/en-us/linkedin/marketing/
