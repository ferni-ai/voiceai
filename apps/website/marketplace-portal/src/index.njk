<!-- Notify Me Section -->
<section class="section section--notify">
  <div class="container container-narrow">
    <div class="notify-card">
      <div class="notify-icon">{{ sprout(40) }}</div>
      <h2>Want to know when we bloom?</h2>
      <p>Be the first to meet your new coaches. We'll notify you the moment the marketplace opens.</p>
      
      <form class="notify-form" id="notify-form">
        <input type="email" name="email" placeholder="your@email.com" required class="notify-input">
        <button type="submit" class="notify-btn">
          Notify Me
          {{ arrowRight(18) }}
        </button>
      </form>
      <script>
        document.getElementById('notify-form').addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = e.target.email.value;
          const btn = e.target.querySelector('button');
          btn.disabled = true;
          btn.innerHTML = 'Sending...';
          try {
            const res = await fetch('https://app.ferni.ai/api/waitlist', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email, source: 'marketplace' })
            });
            const data = await res.json();
            if (data.success) {
              btn.innerHTML = '✓ You\'re on the list!';
              btn.style.background = 'var(--success)';
            } else {
              throw new Error(data.error);
            }
          } catch (err) {
            btn.innerHTML = 'Try again';
            btn.disabled = false;
            alert('Something went wrong. Please try again.');
          }
        });
      </script>
      
      <p class="notify-note">No spam, just one email when we're ready. Unsubscribe anytime.</p>
    </div>
  </div>
</section>

