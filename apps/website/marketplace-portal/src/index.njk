<script>
// Card click navigation - ensures anchor links work properly
(function initCardNavigation() {
  const cards = document.querySelectorAll('a.preview-card');
  cards.forEach(card => {
    card.addEventListener('click', (e) => {
      // Don't navigate if clicking on the voice button
      if (e.target.closest('.voice-sample-btn')) {
        return;
      }
      // Navigate to the href
      window.location.href = card.href;
    });
  });
})();

// Random blinking for avatars - makes them feel alive
(function initAvatarAnimations() {
  const avatars = document.querySelectorAll('.avatar-orb');

  function triggerBlink(avatar) {
    avatar.classList.add('blinking');
    setTimeout(() => avatar.classList.remove('blinking'), 150);
  }

  function scheduleRandomBlinks() {
    avatars.forEach((avatar, index) => {
      // Stagger initial blinks
      setTimeout(() => {
        triggerBlink(avatar);
        // Schedule recurring blinks at random intervals (2-6 seconds)
        setInterval(() => {
          triggerBlink(avatar);
        }, 2000 + Math.random() * 4000);
      }, index * 500 + Math.random() * 1000);
    });
  }

  // Start after a short delay
  setTimeout(scheduleRandomBlinks, 1000);
})();

// Voice sample playback
(function initVoiceSamples() {
  const buttons = document.querySelectorAll('.voice-sample-btn');
  let currentAudio = null;
  let currentButton = null;

  // Placeholder voice samples - replace with actual URLs when available
  const voiceSamples = {
    eli: null,
    marcus: null,
    kenji: null,
    carmen: null,
    amara: null,
    sasha: null
  };

  buttons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const persona = btn.dataset.persona;
      const sampleUrl = voiceSamples[persona];

      // Stop current audio if playing
      if (currentAudio) {
        currentAudio.pause();
        currentAudio.currentTime = 0;
        if (currentButton) {
          currentButton.classList.remove('playing');
        }
      }

      if (!sampleUrl) {
        // Show coming soon tooltip
        const tooltip = document.createElement('div');
        tooltip.className = 'voice-tooltip';
        tooltip.textContent = 'Voice sample coming soon!';
        tooltip.style.cssText = `
          position: absolute;
          bottom: 100%;
          left: 50%;
          transform: translateX(-50%);
          background: var(--text-primary);
          color: var(--bg-primary);
          padding: 6px 12px;
          border-radius: 6px;
          font-size: 12px;
          white-space: nowrap;
          z-index: 100;
          animation: tooltipFade 2s forwards;
        `;
        btn.parentElement.appendChild(tooltip);
        setTimeout(() => tooltip.remove(), 2000);
        return;
      }

      // Play the audio
      currentAudio = new Audio(sampleUrl);
      currentButton = btn;
      btn.classList.add('playing');

      currentAudio.play();
      currentAudio.onended = () => {
        btn.classList.remove('playing');
        currentAudio = null;
        currentButton = null;
      };
    });
  });

  // Add tooltip animation
  const style = document.createElement('style');
  style.textContent = `
    @keyframes tooltipFade {
      0% { opacity: 0; transform: translateX(-50%) translateY(5px); }
      15% { opacity: 1; transform: translateX(-50%) translateY(0); }
      85% { opacity: 1; transform: translateX(-50%) translateY(0); }
      100% { opacity: 0; transform: translateX(-50%) translateY(-5px); }
    }
  `;
  document.head.appendChild(style);
})();
</script>
