}

.hero-feature-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.hero-feature-text strong {
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.hero-feature-text span {
