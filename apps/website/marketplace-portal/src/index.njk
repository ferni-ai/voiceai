  color: var(--text-muted);
}

/* Hero Arrival */
.hero-arrival {
  display: inline-flex;
  flex-direction: column;
  gap: var(--space-1);
  padding: var(--space-4) var(--space-6);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
}

.arrival-label {
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
}

.arrival-date {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--accent-primary);
}

/* Floating Elements */
.hero-float {
  position: absolute;
  opacity: 0.3;
  animation: float 20s ease-in-out infinite;
  color: var(--accent-primary);
}

.hero-float svg {
  width: 32px;
  height: 32px;
}

.hero-float--1 { top: 10%; left: 5%; animation-delay: 0s; }
.hero-float--2 { top: 60%; right: 8%; animation-delay: -7s; }
.hero-float--3 { bottom: 15%; left: 12%; animation-delay: -14s; }

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20px) rotate(10deg); }
}

/* Section Styles */
.section {
  padding: var(--space-24) var(--space-6);
}

.section--preview {
  background: var(--bg-secondary);
}

.section-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto var(--space-12);
}

.section-eyebrow {
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent-primary);
  margin-bottom: var(--space-3);
}

.section-header h2 {
  font-size: var(--text-3xl);
  margin-bottom: var(--space-4);
}

.section-header p {
  font-size: var(--text-lg);
  color: var(--text-secondary);
}

/* Preview Grid */
.preview-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: var(--space-6);
  max-width: 1100px;
  margin: 0 auto;
}

.preview-card {
  display: flex;
  gap: var(--space-4);
  padding: var(--space-5);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  border: 1px solid var(--border-subtle);
  transition: all var(--duration-slow) var(--ease-out);
  text-decoration: none;
  color: inherit;
  cursor: pointer;
}

.preview-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--persona-color, var(--accent-primary));
}

/* ========================================
   LUXO-STYLE ANIMATED AVATARS
   ======================================== */

.preview-avatar-container {
  position: relative;
  width: 64px;
  height: 64px;
  flex-shrink: 0;
}

.avatar-orb {
  width: 100%;
  height: 100%;
  position: relative;
}

.avatar-orb svg {
  width: 100%;
  height: 100%;
  overflow: visible;
}

/* LUXO STYLE: Eyes are solid white ellipses - NO pupils! */
.avatar-orb .eye-white {
  fill: white;
  transform-origin: center center;
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Presence Ring */
.avatar-orb .presence-ring {
  fill: none;
  stroke: var(--persona-color);
  stroke-width: 1.5;
  opacity: 0.4;
  transition: all 0.4s ease;
  transform-origin: center center;
}

/* Avatar Glow */
.avatar-glow {
  position: absolute;
  inset: -12px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--persona-glow) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
}

.preview-card:hover .avatar-glow {
  opacity: 0.8;
}

/* BREATHING - Makes avatars feel alive */
.avatar-orb.breathing .avatar-body {
  animation: avatarBreathe 4s ease-in-out infinite;
}

.avatar-orb.breathing .presence-ring {
  animation: ringBreathe 4s ease-in-out infinite;
  animation-delay: 0.3s;
}

@keyframes avatarBreathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scaleY(1.02) scaleX(0.995); }
}

@keyframes ringBreathe {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.01); opacity: 0.5; }
}

/* BLINKING - Natural eye blinks */
.avatar-orb.blinking .eye-white {
  animation: eyeBlink 0.15s ease-in-out;
}

@keyframes eyeBlink {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.1); }
}

/* GAZE DRIFT - Subtle idle eye movement */
.avatar-orb.gazing .eyes-group {
  animation: gazeDrift 8s ease-in-out infinite;
}

@keyframes gazeDrift {
  0%, 100% { transform: translate(0, 0); }
  25% { transform: translate(0.5px, -0.3px); }
  50% { transform: translate(-0.3px, 0.3px); }
  75% { transform: translate(0.3px, 0px); }
}

