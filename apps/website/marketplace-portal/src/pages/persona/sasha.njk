            <div class="trait-item">
              <span class="trait-dot" style="background: #E07B53;"></span>
              <span class="trait-name">Warmth</span>
              <span class="trait-value">80%</span>
            </div>
            <div class="trait-item">
              <span class="trait-dot" style="background: #B85C3C;"></span>
              <span class="trait-name">Patience</span>
              <span class="trait-value">70%</span>
            </div>
            <div class="trait-item">
              <span class="trait-dot" style="background: #F08B63;"></span>
              <span class="trait-name">Energy</span>
              <span class="trait-value">95%</span>
            </div>
            <div class="trait-item">
              <span class="trait-dot" style="background: #D06B43;"></span>
              <span class="trait-name">Structure</span>
              <span class="trait-value">40%</span>
            </div>
            <div class="trait-item">
              <span class="trait-dot" style="background: #C85B33;"></span>
              <span class="trait-name">Humor</span>
              <span class="trait-value">85%</span>
            </div>
          </div>
        </div>

        <!-- Tags -->
        <div style="background: var(--bg-elevated); border-radius: var(--radius-2xl); padding: var(--space-6); box-shadow: var(--shadow-card); margin-bottom: var(--space-6);">
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-4);">Tags</h3>
          <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
            <span class="persona-tag">Creativity</span>
            <span class="persona-tag">Art</span>
            <span class="persona-tag">Writing</span>
            <span class="persona-tag">Music</span>
            <span class="persona-tag">Inspiration</span>
            <span class="persona-tag">Brainstorming</span>
          </div>
        </div>

        <!-- Pricing -->
        <div style="background: var(--bg-elevated); border-radius: var(--radius-2xl); padding: var(--space-6); box-shadow: var(--shadow-card); margin-bottom: var(--space-6);">
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-4);">Pricing</h3>
          <div style="display: flex; flex-direction: column; gap: var(--space-3);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span>Free tier</span>
              <span style="font-weight: 600;">30 sessions/mo</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span>Premium</span>
              <span style="font-weight: 600;">$6.99/mo</span>
            </div>
          </div>
        </div>

        <!-- Publisher -->
        <div style="background: var(--bg-elevated); border-radius: var(--radius-2xl); padding: var(--space-6); box-shadow: var(--shadow-card); margin-bottom: var(--space-6);">
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-4);">Publisher</h3>
          <div style="display: flex; align-items: center; gap: var(--space-3);">
            <div style="width: 48px; height: 48px; background: var(--accent-primary); border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700;">F</div>
            <div>
              <div style="font-weight: 600;">Ferni Labs</div>
              <div style="font-size: var(--text-sm); color: var(--success); display: flex; align-items: center; gap: var(--space-1);">
                {{ verified(14) }}
                Verified Publisher
              </div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div style="background: linear-gradient(135deg, #E07B53, #B85C3C); border-radius: var(--radius-2xl); padding: var(--space-6); color: white; text-align: center;">
          <h3 style="margin-bottom: var(--space-2); color: white;">Ready to create?</h3>
          <p style="font-size: var(--text-sm); opacity: 0.9; margin-bottom: var(--space-4);">
            Let's make something amazing
          </p>
          <button class="btn" style="background: white; color: #E07B53; width: 100%;">
            Try Free
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

