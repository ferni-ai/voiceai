{% from "partials/icons.njk" import play, plus, starFilled, star, verified, check %}

<!-- Hero -->
<section class="persona-detail-hero" style="--persona-color: #2C3E50; --persona-secondary: #1A252F;">
  <div class="container">
    <div class="persona-detail-content">
      <div class="persona-detail-avatar">
        {# LUXO STYLE: Opaque white ellipse eyes, NO pupils, NO mouth #}
        <svg viewBox="0 0 100 100" width="100%" height="100%">
          <defs>
            <linearGradient id="kenjiDetailGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color: #2C3E50"/>
              <stop offset="100%" style="stop-color: #1A252F"/>
            </linearGradient>
          </defs>
          <circle cx="50" cy="50" r="45" fill="url(#kenjiDetailGrad)"/>
          <ellipse cx="36" cy="48" rx="7" ry="10" fill="white"/>
          <ellipse cx="64" cy="48" rx="7" ry="10" fill="white"/>
        </svg>
      </div>
      <div class="persona-detail-info">
        <h1>Kenji</h1>
        <p class="persona-detail-tagline">Sleep Guide</p>
        <div class="persona-detail-meta">
          <span style="display: inline-flex; align-items: center; gap: var(--space-1); color: var(--warning);">
            {{ starFilled(16) }}{{ starFilled(16) }}{{ starFilled(16) }}{{ starFilled(16) }}{{ star(16) }}
          </span>
          <span>4.7 (1,205 reviews)</span>
          <span style="opacity: 0.7;">|</span>
          <span>18,400+ users</span>
          <span style="opacity: 0.7;">|</span>
          <span>by Ferni Labs</span>
        </div>
        <div class="persona-detail-actions">
          <button class="btn btn-add-team btn-lg">
            {{ plus(20) }}
            Try Free
          </button>
          <button class="btn btn-preview-voice">
            {{ play(20) }}
            Preview Voice
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Main Content -->
<section class="section">
  <div class="container">
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: var(--space-8); align-items: start;">

      <!-- Left Column -->
      <div>
        <!-- Description -->
        <div style="margin-bottom: var(--space-12);">
          <h2 style="margin-bottom: var(--space-4);">About Kenji</h2>
          <p style="color: var(--text-secondary); font-size: var(--text-lg); line-height: var(--leading-relaxed);">
            Kenji helps you reclaim your nights. Evidence-based sleep coaching, relaxation techniques,
            and bedtime routines to help you wake up refreshed.
          </p>
          <p style="color: var(--text-secondary); line-height: var(--leading-relaxed); margin-top: var(--space-4);">
            Sleep isn't a luxury—it's the foundation of everything. Kenji understands that racing thoughts,
            anxiety, and disrupted sleep patterns aren't solved by just "trying harder." With calming
            guidance rooted in sleep science, Kenji helps you build sustainable habits for restful nights.
          </p>
        </div>

        <!-- What Kenji Helps With -->
        <div style="margin-bottom: var(--space-12);">
          <h2 style="margin-bottom: var(--space-4);">What I Help With</h2>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4);">
            <div style="background: var(--bg-elevated); padding: var(--space-4); border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);">
              <h4 style="margin-bottom: var(--space-2);">Sleep Hygiene</h4>
              <p style="font-size: var(--text-sm); color: var(--text-muted);">
                Building habits and environments that support quality sleep
              </p>
            </div>
            <div style="background: var(--bg-elevated); padding: var(--space-4); border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);">
              <h4 style="margin-bottom: var(--space-2);">Wind-Down Routines</h4>
              <p style="font-size: var(--text-sm); color: var(--text-muted);">
                Personalized evening rituals to signal your body it's time for rest
              </p>
            </div>
            <div style="background: var(--bg-elevated); padding: var(--space-4); border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);">
              <h4 style="margin-bottom: var(--space-2);">Relaxation Techniques</h4>
              <p style="font-size: var(--text-sm); color: var(--text-muted);">
                Guided breathing, body scans, and meditation for falling asleep
              </p>
            </div>
            <div style="background: var(--bg-elevated); padding: var(--space-4); border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);">
              <h4 style="margin-bottom: var(--space-2);">Circadian Rhythm</h4>
              <p style="font-size: var(--text-sm); color: var(--text-muted);">
                Syncing your sleep-wake cycle for natural energy and rest
              </p>
            </div>
          </div>
        </div>

        <!-- Voice Sample -->
