              </div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div style="background: linear-gradient(135deg, #2D5A4A, #1E3D32); border-radius: var(--radius-2xl); padding: var(--space-6); color: white; text-align: center;">
          <h3 style="margin-bottom: var(--space-2); color: white;">Ready to get started?</h3>
          <p style="font-size: var(--text-sm); opacity: 0.9; margin-bottom: var(--space-4);">
            Start your free trial today
          </p>
          <button class="btn" style="background: white; color: #2D5A4A; width: 100%;">
            Add to Team - $14.99/mo
          </button>
        </div>
