#!/usr/bin/env sh

# =============================================================================
# PRE-COMMIT QUALITY GATES
# =============================================================================
# Validates code quality before allowing commits.
# Run `git commit --no-verify` to bypass (use sparingly!)
# =============================================================================

set -e  # Exit on first error

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  FERNI PRE-COMMIT QUALITY GATES                              ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# =============================================================================
# QUICK CHECKS (Must pass)
# =============================================================================
echo "🔍 Running quick quality checks..."
echo ""

# TypeScript type check (fast, catches type errors)
echo "  → TypeScript type check..."
npx tsc --noEmit --pretty

# ESLint (catches code quality issues)
echo "  → ESLint..."
npm run lint --silent 2>/dev/null || npm run lint

# Format check (ensures consistent formatting)
echo "  → Prettier format check..."
npm run format:check --silent 2>/dev/null || true

echo ""
echo "  ✓ Quick checks passed"

# =============================================================================
# DEPLOYMENT SAFETY CHECK (BLOCKS COMMIT)
# =============================================================================
echo ""
echo "🚀 Deployment safety check..."

# Check for unsafe deployment patterns
npx tsx apps/cli/src/commands/quality/check-deploy-safety.ts 2>/dev/null || {
  echo ""
  echo "  ❌ UNSAFE DEPLOYMENT PATTERN DETECTED - COMMIT BLOCKED"
  echo ""
  echo "  Run 'npx tsx apps/cli/src/commands/quality/check-deploy-safety.ts' for details"
  echo "  Use 'ferni deploy' instead of direct gcloud/firebase commands"
  echo ""
  exit 1
}

echo "  ✓ Deployment safety check passed"

# =============================================================================
# CODE QUALITY AUDIT (Informational)
# =============================================================================
echo ""
echo "📊 Running code quality audit..."

# Run quality check but don't block on warnings
npx tsx apps/cli/src/commands/quality/code-quality-check.ts 2>/dev/null || {
  echo ""
  echo "  ⚠ Quality check found issues (non-blocking)"
  echo "  Run 'npm run audit quality' for details"
}

# =============================================================================
# DESIGN SYSTEM VALIDATION (AUTO-REGENERATE)
# =============================================================================
echo ""
echo "🎨 Design system checks..."

# Check for token drift - auto-regenerate if detected
if ! node design-system/check-drift.js 2>/dev/null; then
  echo ""
  echo "  ⚠ Token drift detected - auto-regenerating..."
  npm run tokens:sync --silent

  # Stage the regenerated files
  git add design-system/dist/ 2>/dev/null || true
  git add apps/web/src/config/animation-constants.generated.ts 2>/dev/null || true
  git add apps/web/public/design-system/tokens.css 2>/dev/null || true
  git add apps/website/ferni-website/tailwind.config.generated.js 2>/dev/null || true
  git add apps/website/ferni-website/css/design-tokens.css 2>/dev/null || true
  git add apps/website/ferni-website/src/css/_tokens.css 2>/dev/null || true
  git add apps/website/developers-portal/src/css/tokens.css 2>/dev/null || true
  git add apps/website/design-system-portal/src/css/tokens.css 2>/dev/null || true
  git add brand/ferni-design-tokens.css 2>/dev/null || true

  echo "  ✓ Tokens regenerated and staged"
fi

# Check brand color alignment - BLOCKS commit if critical mismatches
node design-system/check-brand.js || {
  echo ""
  echo "  ❌ BRAND COLOR MISALIGNMENT - COMMIT BLOCKED"
  echo ""
  echo "  Fix: Update design-system/tokens/colors.json to match brand guidelines"
  echo "  Then: npm run tokens:sync && git add -A"
  echo ""
  exit 1
}

echo "  ✓ Design system checks passed"

# =============================================================================
# DESIGN SYSTEM COMPLIANCE (Non-blocking warnings)
# =============================================================================
echo ""
echo "🔍 Design system compliance..."

# Check for hardcoded colors, durations, console.logs in staged files
node design-system/check-design-compliance.js --staged 2>/dev/null || {
  echo ""
  echo "  ⚠ Design compliance issues found (review recommended)"
  echo "  Run 'npm run design:check' for details"
}

echo "  ✓ Design compliance check complete"

# =============================================================================
# BRAND COMPLIANCE CHECK (Non-blocking warnings)
# =============================================================================
echo ""
echo "🌿 Brand compliance check..."

# Run brand check on staged files - warns but doesn't block
npx tsx apps/cli/src/commands/quality/check-brand-compliance.ts --staged 2>/dev/null || {
  echo ""
  echo "  ⚠ Brand check found issues (review recommended)"
  echo "  Run 'npm run brand:check' for details"
}

echo "  ✓ Brand check complete"

# =============================================================================
# FRONTEND VALIDATION
# =============================================================================
echo ""
echo "🎨 Frontend checks..."

# Run lint-staged in frontend if it exists
if [ -d "frontend-typescript" ]; then
  cd frontend-typescript
  npx lint-staged 2>/dev/null || true
  cd ..
fi

echo "  ✓ Frontend checks passed"

# =============================================================================
# SECURITY QUICK SCAN (Non-blocking)
# =============================================================================
echo ""
echo "🔐 Security quick scan..."

# Quick secret scan on staged files only
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json)$' || true)
if [ -n "$STAGED_FILES" ]; then
  # Check for obvious secrets patterns
  SECRETS_FOUND=$(echo "$STAGED_FILES" | xargs grep -l -E "(sk_live_|AKIA[A-Z0-9]{16}|-----BEGIN.*PRIVATE KEY)" 2>/dev/null || true)
  if [ -n "$SECRETS_FOUND" ]; then
    echo ""
    echo "  ⚠ POTENTIAL SECRETS DETECTED in:"
    echo "$SECRETS_FOUND" | sed 's/^/    /'
    echo ""
    echo "  Run 'ferni security secrets' for full scan"
  fi
fi

echo "  ✓ Security scan complete"

# =============================================================================
# DONE
# =============================================================================
echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  ✅ ALL PRE-COMMIT CHECKS PASSED                             ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
echo "┌──────────────────────────────────────────────────────────────┐"
echo "│  💭 HUMAN-NESS CHECK                                         │"
echo "│                                                              │"
echo "│  Before you commit, ask yourself:                            │"
echo "│  → Does this make the AI feel more human?                    │"
echo "│  → Does this serve the relationship?                         │"
echo "│  → Is this authentic, not robotic?                           │"
echo "│                                                              │"
echo "│  We believe in making AI human.                              │"
echo "└──────────────────────────────────────────────────────────────┘"
echo ""
